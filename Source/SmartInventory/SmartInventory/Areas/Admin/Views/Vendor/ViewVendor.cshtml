@model Models.Admin.ViewVendorDetailsList

@using Utility
@using SmartInventory.Settings;
<!DOCTYPE html>
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />
<div id="dvViewVendor" style="white-space: nowrap;">
    <div class="update_panel fullWidth">
        <div class="title">
            <h4>
                View Vendor
            </h4>
        </div>
        @{
            WebGrid grid = new WebGrid(rowsPerPage: Model.viewVendorDetail.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewVendor", ajaxUpdateCallback: "onGridHeaderClick('tblVendorDetail')");
            grid.Bind(Model.VendorDetailList, autoSortAndPage: false, rowCount: Model.viewVendorDetail.totalRecord);
            if (Model.viewVendorDetail.totalRecord > 0)
            {
                grid.PageIndex = Model.viewVendorDetail.currentPage - 1;
            }
        }

        <div class="pad_left">
            @using (Html.BeginForm("ViewVendor", "Vendor", FormMethod.Post, new { autocomplete = "off", @id = "frmViewVendor" }))
            {
                <div class="form-inline filter-sec">
                    <div class="d-flex mr-01">
                        <label class="control-label mr-05">
                            Search By :
                        </label>
                        <div class="col-md-8 wtd_set">
                            @Html.DropDownListFor(m => m.viewVendorDetail.searchBy, new SelectList(Model.lstBindSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), new { @class = "chosen-select form-control", @id = "txtSearchBy" })
                        </div>
                    </div>
                    <div class="d-flex ml-05">
                        <label class="control-label mr-05">
                            Search Text:
                        </label>
                        <div class="col-md-8">
                            @Html.TextBoxFor(m => m.viewVendorDetail.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })

                        </div>
                    </div>

                    <div class="wtd_set" id="dvBtnAction">
                        <div class="col-md-8">
                            <button class="btn btn-primary mr-05" id="btnGetSearchResult" name="btnCommandName" value="GetSearchResult" tabindex="5" onclick="return fnGetSearchResult();" type="submit">Search</button>
                            @if (@grid.TotalRowCount > 0)
                            {
                                <input type="button" id="btnExportVendorDetails" value="Export" class="btn btn-primary  mr-05 clsexport" />
                            }
                            else
                            {
                                <input type="button" id="btnExportVendorDetails" value="Export" disabled="disabled" class="btn btn-primary  mr-05 clsexport" />
                            }
                            <a href="@Url.Action("ViewVendor")" class="btn btn-default" title="Reset">Reset</a>
                        </div>
                    </div>
                </div>

                if (Model.VendorDetailList.Count > 0)
                {
                    <div id="divVendorDetail">
                        <div class="recordCount mb-01"><b>Total Records:<span data="spanTotalRowCount">@grid.TotalRowCount</span></b></div>
                        <div class="table-responsive tble_cls">
                            @grid.GetHtml(tableStyle: "grid",
                    htmlAttributes: new { id = "tblVendorDetail" },
                    mode: WebGridPagerModes.All,
                    columns: grid.Columns(
                         grid.Column("", "Action", format:
                                                @<text>
                                                    <a href="@Url.Action("ViewVendorUpdateMode", "Vendor", new { id = @item.id })" class="auto" title="Edit"> <i class="fa fa-pencil action_icon fa-fw m-r-xs"></i></a>
                                                    <a href="javascript:void(0);" onclick="DeleteVendor(@item.id);" title="Close"> <i class="fa fa-fw fa-trash" style=" font-size: 13px; color: #f50000;"></i></a>

                                                </text>),
     grid.Column("name", "Name", format: @<text>@item.name</text>),
grid.Column("type", "Type", format: @<text>@item.type</text>),
grid.Column("address", "Address", format: @<text>@item.address</text>, canSort: true),

grid.Column("contact", "Contact", format: @<text>@item.contact</text>),
grid.Column("email_id", "Email-Id", format: @<text>@item.email_id</text>),


grid.Column("remarks", "Remarks", format: @<text>@item.remarks</text>),
grid.Column("is_active", "Status", format: @<text>@(item.is_active == true ? "Active" : "InActive")</text>),
grid.Column("created_by_text", "Created By", format: @<text>@item.created_by_text</text>),

grid.Column("created_on", "Created On", format: @<text>@(item.created_on == null ? item.created_on : MiscHelper.FormatDateTime(item.created_on.ToString()))</text>),

grid.Column("modified_by_text", "Modified By", format: @<text>@item.modified_by_text</text>),
grid.Column("modified_on", "Modified On", format: @<text>@(item.modified_on == null ? item.modified_on : MiscHelper.FormatDateTime(item.modified_on.ToString()))</text>)


))

                            @Html.Hidden("dir", grid.SortDirection)
                            @Html.Hidden("col", grid.SortColumn)
                            @Html.HiddenFor(m => m.viewVendorDetail.searchBy)
                            @Html.HiddenFor(m => m.viewVendorDetail.searchText)
                        </div>

                    </div>
                }
                else
                {
                    <div style="text-align: center; margin-top: 30px;">
                        No Records Found.
                    </div>
                }

            }
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        updateNumberstoFormatedNumber();
        addDefaultSortingIcons("tblVendorDetail");
        //download vendordetails as excel format
        $("#btnExportVendorDetails").on("click", function () {
            window.location = appRoot + 'Vendor/ExportVendorDetails';
        });
    });
    function updateNumberstoFormatedNumber() {
        $('span[data]').each(function (index) {
            // Get the value of the data-target attribute for each element
            var targetValue = $(this).data('data');

            // Do whatever you want with the element or its data
            $(this).text(getFormattedNumber($(this).text().trim()));
        });
    }
</script>


@model Models.Admin.ViewLayerGroup
@using Utility
@using SmartInventory.Settings;
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />

<div id="dvViewLayerGroups">
    <div class="update_panel fullWidth">
        <div class="title">
            <h4>View Groups</h4>
        </div>

        @{
            WebGrid grid = new WebGrid(rowsPerPage: Model.objGridAttributes.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewLayerGroups", ajaxUpdateCallback: "onGridHeaderClick('tblLayerGroups')");
            grid.Bind(Model.lstLayerGroups, autoSortAndPage: false, rowCount: Model.objGridAttributes.totalRecord);
            if (Model.objGridAttributes.totalRecord > 0)
            {
                grid.PageIndex = Model.objGridAttributes.currentPage - 1;
            }
        }


        @using (Html.BeginForm("ViewGroups", "LayerSettings", FormMethod.Post, new { autocomplete = "off", @id = "frmViewLayerGroups" }))
        {
            <section class="--pad-15">
                <div class="form-inline filter-sec ">
                    <div class="form-group wtd_set">
                        <label class="control-label col-sm-4">
                            Search By :
                        </label>
                        <div class="col-md-8">
                            @Html.DropDownListFor(m => m.objGridAttributes.searchBy, new SelectList(Model.lstBindSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control" })
                        </div>
                    </div>
                    <div class="form-group wtd_set">
                        <label class="control-label col-sm-4">
                            Search Text:
                        </label>
                        <div class="col-md-8">
                            @Html.TextBoxFor(m => m.objGridAttributes.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })
                        </div>
                    </div>
                    <div class="form-group wtd_set" id="dvBtnAction">
                        <div class="col-md-8">
                            <button class="btn btn-primary mr-05" id="btnGetSearchResult" name="btnCommandName" value="GetSearchResult" tabindex="5" onclick="return fnGetSearchResult();" type="submit">Search</button>
                            @if (@grid.TotalRowCount > 0)
                            {
                                <input type="button" id="btnViewGroupExport" value="Export" class="btn btn-primary  mr-05" onclick="ViewGroupsReport()" />
                            }
                            else
                            {
                                <input type="button" id="btnViewGroupExport" value="Export" disabled="disabled" class="btn btn-primary  mr-05" />
                            }
                            <a href="@Url.Action("ViewGroups")" class="btn btn-default  mr-05" title="Reset">Reset</a>
                            <span>
                                <input type="button" id="btnAddNew" onclick="AddLayerGroups(0);" value="Add New" class="btn btn-primary" />
                            </span>
                        </div>
                    </div>

                </div>

                @if (Model.lstLayerGroups.Count > 0)
                {
                    <div id="divLayerGroupDetail">
                        <div class="recordCount mb-01"><b>Total Records:<span data="spanTotalRowCount">@grid.TotalRowCount</span></b></div>

                        <div class="table-responsive tble_cls">
                            @grid.GetHtml(tableStyle: "grid",
            htmlAttributes: new { id = "tblLayerGroups" },
            mode: WebGridPagerModes.All,
            columns: grid.Columns(

     grid.Column("", "Action", format:
                                    @<text>
                                        <a href="#" onclick="AddLayerGroups(@item.group_id);" class="auto" title="Edit"> <i class="fa fa-pencil action_icon fa-fw m-r-xs"></i></a>
                                        <a href="javascript:void(0);" onclick="DeleteLayerGroups(@item.group_id);" title="Delete"> <i class="fa fa-fw fa-trash" style="font-size: 13px; color: #f50000;"></i></a>
                                    </text>),
grid.Column("group_name", "Group Name", format: @<text>@item.group_name</text>),
grid.Column("group_description", "Group Description", format: @<text>@item.group_description</text>),
grid.Column("status", "Group Status", format: @<text>@(item.status == true ? "Active" : "InActive")</text>),
grid.Column("created_by_text", "Created By", format: @<text>@item.created_by_text</text>),
grid.Column("created_on", "Created On", format: @<text>@(item.created_on == null ? item.created_on : MiscHelper.FormatDateTime(item.created_on.ToString()))</text>),
grid.Column("modified_by_text", "Modified By", format: @<text>@item.modified_by_text</text>),
grid.Column("modified_on", "Modified On", format: @<text> @(item.modified_on == null ? item.modified_on : MiscHelper.FormatDateTime(item.modified_on.ToString())) </text>)


))
                            @Html.Hidden("dir", grid.SortDirection)
                            @Html.Hidden("col", grid.SortColumn)
                            @Html.HiddenFor(m => m.objGridAttributes.searchBy)
                            @Html.HiddenFor(m => m.objGridAttributes.searchText)
                        </div>

                    </div>
                }
                else
                {
                    <div style="text-align: center; margin-top: 30px;">
                        No Records Found.
                    </div>
                }

            </section>


        }

        <script>
            $(document).ready(function () {
                updateNumberstoFormatedNumber();
                addDefaultSortingIcons("tblLayerGroups");
            });

            function ViewGroupsReport() {
                window.location = appRoot + 'LayerSettings/DownloadViewGroupsDetail';
            }

            function updateNumberstoFormatedNumber() {
                $('span[data]').each(function (index) {
                    // Get the value of the data-target attribute for each element
                    var targetValue = $(this).data('data');

                    // Do whatever you want with the element or its data
                    $(this).text(getFormattedNumber($(this).text().trim()));
                });
            }
        </script>
    </div>
</div>

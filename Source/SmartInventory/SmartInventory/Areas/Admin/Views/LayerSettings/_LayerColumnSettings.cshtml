@model Models.Admin.ViewLayerGroupMapping
@using Utility
<style>
    .noMove, .noMove:hover {
        cursor: not-allowed;
       
    }

    .Move {
        cursor: move;
        background-color: white;
    }

    #tblReportColumnsInfo tr:hover:not(.noMove) {
        color: white !important;
        background-color: #154777 !important;
    }

    .field-validation-error {
        bottom: auto;
        right: 49px;
    }
</style>
<div class="col-lg-12" id="dvPageMessage">
    @{Html.RenderPartial("_PageMessage", Model.pageMsg);}
</div>
<div id="dvReportColumnSettings" class="update_panel" style="position:relative;width:80%!important">
    <div class="title">
        <h4><span class="icon16 icomoon-icon-bars"></span><span>Layer Group Mapping</span></h4>
    </div>
    @using (Html.BeginForm("SaveLayerGroupMapping", "LayerSettings", FormMethod.Post, new { autocomplete = "off", @id = "frmReportColumnSettings", enctype = "multipart/form-data", @class = "form-horizontal  pad_left" }))
    {

        if (Model.lstLayerGroupsMapping.Count > 0)
        {
            <div style="width: 99%;height: 26px;">
                <span style="float:right"><b>Total Columns: @Model.lstLayerGroupsMapping.Count</b></span><span style="float:left"><b>Note:</b> Drag drop rows to reorder layers. </span>
            </div>
            <div class="table-responsive tble_cls" style="border: none;">

                <table id="tblLayerColumnsInfo" class="grid">
                    <thead>
                        <tr>
                            <th>Action</th>
                            <th>Layer Name</th>
                            <th>Group Name</th>
                            <th>Group Description</th>
                            <th>Modified By</th>
                            <th>Modified On</th>
                        </tr>
                    </thead>
                    <tbody>

                        @for (int i = 0; i < Model.lstLayerGroups.Count; i++)
                        {
                            var lstGroupData = Model.lstLayerGroupsMapping.Where(m => m.group_name == Model.lstLayerGroups[i].group_name).OrderBy(m=>m.layer_seq).ToList();

                            <tr id='@Model.lstLayerGroups[i].group_name' 
                                class="noMove"
                                style="background-color: gainsboro;"
                                data-group-id='@Model.lstLayerGroups[i].group_id'
                                data-group-name='@Model.lstLayerGroups[i].group_name'
                                data-group-description='@Model.lstLayerGroups[i].group_description'
                                >
                        <td colspan="7">@Model.lstLayerGroups[i].group_name</td>
                            </tr>


                            if (lstGroupData.Count > 0)
                            {
                                for (int j = 0; j < lstGroupData.Count; j++)
                                {
                    <tr class="Move" data-id='@lstGroupData[j].layer_id' data-group-id='@lstGroupData[j].group_id' data-layer_name=' @lstGroupData[j].layer_name'>
                        <td>
                            @Html.Hidden(string.Concat("lstLayerGroupsMapping[", j, "].", "layer_id"), lstGroupData[j].layer_id)
                            @Html.Hidden(string.Concat("lstLayerGroupsMapping[", j, "].", "group_id"), lstGroupData[j].group_id)
                            @Html.Hidden(string.Concat("lstLayerGroupsMapping[", j, "].", "layer_seq"), lstGroupData[j].layer_seq, new { @class = "setSqens" })
                            @Html.Hidden(string.Concat("lstLayerGroupsMapping[", j, "].", "mapping_id"), lstGroupData[j].mapping_id)
                            @Html.Hidden(string.Concat("lstLayerGroupsMapping[", j, "].", "created_by"), lstGroupData[j].created_by)
                            @Html.Hidden(string.Concat("lstLayerGroupsMapping[", j, "].", "created_on"), lstGroupData[j].created_on)
                            @Html.Hidden(string.Concat("lstLayerGroupsMapping[", j, "].", "layer_name"), lstGroupData[j].layer_name)
                            <a href="@Url.Action("AddVendorSpecification", "VendorSepcification", new { id = lstGroupData[j].layer_id })" class="auto" title="Edit"> <i class="fa fa-pencil action_icon fa-fw m-r-xs"></i></a>
                            
                        </td>
                        <td>
                            @lstGroupData[j].layer_name

                        </td>
                        <td>
                            @lstGroupData[j].group_name
                        </td>
                        <td>
                            @lstGroupData[j].group_description
                        </td>
                        <td>
                            @lstGroupData[j].modified_by_text
                        </td>
                        <td>
                            @lstGroupData[j].modified_on
                        </td>
                    </tr>

                                }

                            }
                        else
                        {
                    <tr class="Move" style="height:0px !important; visibility:hidden;" no-sequence="y">
                        <td colspan="7" style="height:0px !important">
                           
                        </td>
                        
                    </tr>
                        }
                        }
                       
                    </tbody>
                </table>
            </div>
            <div class="form-group" id="dvBtnAction">
                <div class="row">
                    <div class="col-md-8"></div>
                    <div class="col-md-4 text-right" style="padding-right:20px;">
                        <input type="submit" class="btn btn-primary" name="btnaction" id="btnSubmit" value="Save" />
                        <a href="@Url.Action("ViewLayerGroupsMapping", "LayerSettings", new { id = 0 })" class="btn btn-default" title="Reset">Reset</a>
                        <input type="button" id="btnExport" value="Export" class="btn btn-primary" />
                    </div>
                </div>
            </div>
        }
        <div class="clearfix"></div>
    }
</div>
<script>
    $("#btnExport").click(function () {
        window.location = appRoot + 'LayerSettings/DownloadViewGroupsMappingDetail';
    });

    $(document).ready(function () {
        $('.chosen-select').chosen({ width: '100%' });
        //checkHeaderCheckbox();
        checkHeaderCheckbox('tdreportrequired', 'chkSelectAll');
        checkHeaderCheckbox('tdkmlrequired', 'chkSelectAllKML');
        $('#chkSelectAll').click(function () {
            {
                $("#tdreportrequired input[type=checkbox].attr").prop("checked", $(this).prop("checked"));
            }
        });
        $('.attr').click(function () {
            {
                checkHeaderCheckbox('tdreportrequired', 'chkSelectAll');
            }
        });
        $('#chkSelectAllKML').click(function () {
            {
                $("#tdkmlrequired input[type=checkbox].kmlattr").prop("checked", $(this).prop("checked"));
            }
        });
        $('.kmlattr').click(function () {
            {
                checkHeaderCheckbox('tdkmlrequired', 'chkSelectAllKML');
            }
        });

        $("#tblLayerColumnsInfo  tbody").sortable({
            items: "tr:not(.noMove)",
            update: function (event, ui) {
                //get current group name and update the same in dropped TR.
                var currentGroup = ui.item.prevAll('tr.noMove').first();
                
                ui.item.attr("data-group-id", currentGroup.attr("data-group-id"));
                ui.item.find("td:eq(2)").text(currentGroup.attr("data-group-name"));
                ui.item.find("td:eq(3)").text(currentGroup.attr("data-group-description"));

                ui.item.find("td:eq(0)").find('input[id$="group_id"]').val(currentGroup.attr("data-group-id"));
               // ui.item.find("td:eq(0)").find('input[id$="layer_seq"]').val(currentGroup.attr("layer_seq"));
               
                //setTimeout(function () {

                    var index = 1;
                    debugger;
                   // $('#tblLayerColumnsInfo  tbody tr[data-group-id=' + currentGroup.attr("data-group-id") + '] input:hidden[name$="layer_seq"]').each(function () {
                    $('#tblLayerColumnsInfo  tbody tr').each(function () {
                    debugger;
                        //var inx = $(this).index();
                       // if ($(this).attr("no-sequence") == undefined && $(this).attr("data-group-name") == undefined ) {
                        if ($(this).attr("no-sequence") == undefined && $(this).attr("data-layer_name") != undefined) {
                            // lstLayerGroupsMapping[0].layer_seq
                            $(this).find("td:eq(0)").find('.setSqens').val(index);
                           // $(this).attr("value", index);
                            index++;
                        }
                    });
                //}, 1000);
                //ui.item.find("td:eq(0)").find('input[id$="layer_seq"]').val(currentGroup.attr("layer_seq"));
                
            }
        });
    });
    function checkHeaderCheckbox(tdid, chkallid) {
        var totalAttr = $("#" + tdid + " input[type=checkbox]").length;
        var totalSelected = $("#" + tdid + " input[type=checkbox]:checked").length;
        $('#' + chkallid).prop("checked", totalAttr == totalSelected ? true : false);
    }
    function ReportLayerChange() {
        var _layername = $('#lstLayers option:selected').text();
        var _layerId = $('#lstLayers option:selected').val();
        if (_layerId != undefined && _layerId != 0) {
            window.open(appRoot + '/AdvancedSettings/ReportColumnSettings/' + _layerId, "_self");
        }
        else {
            window.open(appRoot + '/AdvancedSettings/ReportColumnSettings', "_self");
        }
    }
</script>

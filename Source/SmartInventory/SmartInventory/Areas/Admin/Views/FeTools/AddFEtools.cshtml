<script type="text/javascript">

    $("#ddl_fetools12").on('change', function () {
        CheckfetoolsRole();
    });
    $("#ddl_Fename").on('change', function () {
        CheckfenameRole();
    });
    function CheckfenameRole() {
        if ($("#ddl_Fename").val() == null || $("#ddl_Fename").val() == "") {
            $('#ddl_Fename_chosen').css({ "border": "1px solid red", "border-radius": "0.25rem" });
            return false;
        }
        else {
            $('#ddl_Fename_chosen').css({ "border": "1px solid #ced4da", "border-radius": "0.25rem" });
            return true;
        }
    };
    function CheckfetoolsRole() {
        if ($("#ddl_fetools12").val() == null || $("#ddl_fetools12").val() == "") {
            $('#ddl_fetools12_chosen').css({ "border": "1px solid red", "border-radius": "0.25rem" });
            return false;
        }
        else {
            $('#ddl_fetools12_chosen').css({ "border": "1px solid #ced4da", "border-radius": "0.25rem" });
            return true;
        }
    };
  
    //function ddlfenameblur() {
    //    $('#ddl_Fename').on('blur', function () {
    //        if ($(this).val() === "") {
    //            $(this).addClass('input-validation-error');
    //            alert("FE Name is required");
    //            return false;
    //        } else {
    //            $(this).removeClass('input-validation-error');

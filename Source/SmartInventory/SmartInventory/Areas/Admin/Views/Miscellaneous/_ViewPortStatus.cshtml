@model Models.LogicalViewVM
@using Utility
@using SmartInventory.Settings;
<link href="~/Areas/Admin/Content/css/spectrum.css" rel="stylesheet" />
<script src="~/Areas/Admin/Content/js/spectrum.js"></script>

<!DOCTYPE html>
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />
<div id="dvViewPortStatus">
    <div class="update_panel fullWidth">
        <div class="title">
            <h4>
                Core/Port status settings
            </h4>

        </div>
        @{
            WebGrid grid = new WebGrid(rowsPerPage: Model.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewPortStatus", ajaxUpdateCallback: "onGridHeaderClick('tblPortStatus')");
            grid.Bind(Model.listPortStatus, autoSortAndPage: false, rowCount: Model.totalRecord);
            if (Model.totalRecord > 0)
            {
                grid.PageIndex = Model.currentPage - 1;
            }
        }
        <div class="pad_left">
            @using (Html.BeginForm("ViewPortStatus", "Miscellaneous", FormMethod.Post, new { autocomplete = "off", @id = "frmViewPortStatus" }))
            {

                <div class="form-inline filter-sec">
                    <div class="d-flex">
                        <label class="control-label pr-1">Search By : </label>
                        <div class="--input-width">

                            @Html.DropDownListFor(m => m.searchBy, new List<SelectListItem>
                     {
                       new SelectListItem{ Text="--Select--", Value = "" },
                        new SelectListItem{ Text="Status", Value = "status" },
                     }, new { @id = "ddlSearchBy", @tabindex = "2", @title = "Search By", @class = "chosen-select form-control" })
                        </div>

                    </div>
                    <div class="form-group wtd_set ml-05">
                        <label class="control-label col-sm-4">
                            Search Text :
                        </label>
                        <div class="col-md-8">
                            @Html.TextBoxFor(m => m.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })
                        </div>
                    </div>
                    <div class="form-group wtd_set" id="dvBtnAction">
                        <div class="col-md-8">
                            <button class="btn btn-primary mr-05" id="btnGetSearchResult" name="btnCommandName" value="GetSearchResult" tabindex="5" onclick="return fnGetSearchResult();" type="submit">Search</button>
                            @if (@grid.TotalRowCount > 0)
                            {
                                <input type="button" id="btnViewUserExport" value="Export" class="btn btn-primary mr-05" onclick="ViewPortStatus()" />
                            }
                            else
                            {
                                <input type="button" id="btnViwTPrExport" value="Export" disabled="disabled" class="btn btn-primary mr-05" />
                            }
                            <a href="@Url.Action("ViewPortStatus")" class="btn btn-default mr-05" title="Reset">Reset</a>
                            <span>
                                <input type="button" id="btnAddNew" onclick="AddNewPortStatus(0);" value="Add New" class="btn btn-primary" />
                            </span>
                        </div>
                    </div>
                </div>

                if (Model.listPortStatus.Count > 0)
                {
                    <div id="divUserDetail">
                        <div class="recordCount mb-01"><b>Total Records:<span data="spanTotalRowCount">@grid.TotalRowCount</span></b></div>
                        <div class="table-responsive tble_cls">
                            @grid.GetHtml(tableStyle: "grid",
                                htmlAttributes: new { id = "tblPortStatus" },
                                mode: WebGridPagerModes.All,
                                columns: grid.Columns(
                                           grid.Column("", "Action", format:@<text>
                                                    <a href="#" onclick="AddNewPortStatus(@item.system_id);" class="auto" title="Edit"> <i class="fa fa-pencil action_icon fa-fw m-r-xs"></i></a>
                                                    @if (item.system_id != 1 && item.system_id != 2)
                                                     {
                                                        <a href="javascript:void(0);" onclick="DeletePortStatusById(@item.system_id);" title="Delete"> <i class="fa fa-fw fa-trash" style="font-size: 13px; color: #f50000;"></i></a>
                                                     }
                                        </text>, canSort: false),
grid.Column("status", "Status", format: @<text>@item.status</text>, canSort: true),
grid.Column("color_code", "Color Code", format: @<text><span class="CableMapColrCode" style="background-color:@item.color_code;"> </span>@item.color_code </text>),
grid.Column("is_active", "Is Active", format: @<text>@(item.is_active == true ? "Yes" : "No")</text>, canSort: true),
grid.Column("is_manual_status", "Is Manual", format: @<text>@(item.is_manual_status == true ? "Yes" : "No")</text>, canSort: true),
grid.Column("is_splicing_enabled", "Is Splicing Allowed", format: @<text>@(item.is_splicing_enabled == true ? "Yes" : "No")</text>, canSort: true),
grid.Column("created_by_text", "Created By", format: @<text>@item.created_by_text</text>, canSort: true),
grid.Column("created_on", "Created On", format: @<text>@(item.created_on == null ? item.created_on : MiscHelper.FormatDateTime(item.created_on.ToString()))</text>, canSort: true),
grid.Column("modified_by_text", "Modified By", format: @<text>@item.modified_by_text</text>, canSort: true),
grid.Column("modified_on", "Modified On", format: @<text> @(item.modified_on == null ? item.modified_on : MiscHelper.FormatDateTime(item.modified_on.ToString()))</text>, canSort: true)
))
                            @Html.Hidden("dir", grid.SortDirection)
                            @Html.Hidden("col", grid.SortColumn)
                        </div>
                    </div>
                }
                else
                {
                    <div style="text-align: center; margin-top: 30px;">
                        No Termination Point Found.
                    </div>
                }
            }
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        updateNumberstoFormatedNumber();
        addDefaultSortingIcons("tblPortStatus");
    });
    function ViewPortStatus() {
        window.location = appRoot + 'Miscellaneous/DownloadViewPortStatus';
    }
    function updateNumberstoFormatedNumber() {
        $('span[data]').each(function (index) {
            // Get the value of the data-target attribute for each element
            var targetValue = $(this).data('data');

            // Do whatever you want with the element or its data
            $(this).text(getFormattedNumber($(this).text().trim()));
        });
    }
</script>

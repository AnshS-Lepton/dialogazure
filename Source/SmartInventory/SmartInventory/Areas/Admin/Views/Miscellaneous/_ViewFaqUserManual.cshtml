@model Models.ViewFaqFilter
@using Utility
@using SmartInventory.Settings;
<link href="~/Areas/Admin/Content/css/spectrum.css" rel="stylesheet" />
<script src="~/Areas/Admin/Content/js/spectrum.js"></script>

<!DOCTYPE html>
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />
<div id="dvViewFaquserManual">
    <div class="update_panel fullWidth">
        <div class="title">
            <h4>
                User Manual
            </h4>

        </div>
        @{
            WebGrid grid = new WebGrid(rowsPerPage: Model.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewFaquserManual", ajaxUpdateCallback: "onGridHeaderClick('tblFaqUserManual')");
            grid.Bind(Model.listFaqUserManual, autoSortAndPage: false, rowCount: Model.totalRecord);
            if (Model.totalRecord > 0)
            {
                grid.PageIndex = Model.currentPage - 1;
            }
        }
        <div class="pad_left">
            @using (Html.BeginForm("ViewFaqUserManual", "Miscellaneous", FormMethod.Post, new { autocomplete = "off", @id = "frmViewFaqUserManual" }))
            {

                <div class="form-inline filter-sec">
                    <div class="form-group wtd_set mr-05">
                        <label class="control-label col-sm-4">Search By : </label>
                        <div class="col-md-8">

                            @Html.DropDownListFor(m => m.searchBy, new List<SelectListItem>
                     {
                       new SelectListItem{ Text="-Select-", Value = "" },
                        new SelectListItem{ Text="Category", Value = "category" },
                        new SelectListItem{ Text="File Name", Value = "file_name" },
                     }, new { @id = "ddlSearchBy", @tabindex = "2", @title = "Search By", @class = "chosen-select form-control ml-05" })
                        </div>

                    </div>
                    <div class="form-group wtd_set">
                        <label class="control-label col-sm-4">
                            Search Text :
                        </label>
                        <div class="col-md-8">
                            @Html.TextBoxFor(m => m.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })
                        </div>
                    </div>
                    <div class="form-group wtd_set" id="dvBtnAction">
                        <div class="col-md-8">
                            <button class="btn btn-primary mr-05" id="btnGetSearchResult" name="btnCommandName" value="GetSearchResult" tabindex="5" onclick="return fnGetSearchResult();" type="submit">Search</button>
                            @if (@grid.TotalRowCount > 0)
                            {
                                <input type="button" id="btnViewUserExport" value="Export" class="btn btn-primary  mr-05" onclick="ViewFaqUserManual()" />
                            }
                            else
                            {
                                <input type="button" id="btnViwUserExport" value="Export" disabled="disabled" class="btn btn-primary  mr-05" />
                            }
                            <a href="@Url.Action("ViewFaqUserManual")" class="btn btn-default  mr-05" title="Reset">Reset</a>
                            <span>
                                <input type="button" id="btnAddNew" onclick="AddNewFaqUserManual(0);" value="Add New" class="btn btn-primary" />
                            </span>
                        </div>
                    </div>
                </div>

                if (Model.listFaqUserManual.Count > 0)
                {
                    <div id="divUserDetail">
                        <div class="recordCount mb-01"><b>Total Records:<span data="spanTotalRowCount">@grid.TotalRowCount</span></b></div>
                        <div class="table-responsive tble_cls">
                            @grid.GetHtml(tableStyle: "grid",
                                htmlAttributes: new { id = "tblFaqUserManual" },
                                mode: WebGridPagerModes.All,
                                columns: grid.Columns(
                                           grid.Column("", "Action", format:@<text>
                                                    @*<a href="#" onclick="AddNewFaqUserManual(@item.id);" class="auto" title="Edit"> <i class="fa fa-pencil action_icon fa-fw m-r-xs"></i></a>*@
                                                    <a href="javascript:void(0);" onclick="DeleteUserManualById(@item.id);" title="Delete"> <i class="fa fa-fw fa-trash" style="font-size: 13px; color: #f50000;"></i></a>
                                        </text>, canSort: false
              ),
                      grid.Column("category", "Category", format: @<text>@item.category</text>, canSort: true),
grid.Column("file_name", "File Name", format: @<text>@item.file_name</text>, canSort: true),
grid.Column("file_size", "File Size", format: @<text>@item.file_size_converted</text>, canSort: true),
grid.Column("file_extension", "File Extension", format: @<text>@item.file_extension</text>, canSort: true),
grid.Column("file_url", "File Url", format: @<text>@item.file_url</text>, canSort: true),
grid.Column("created_by_text", "Created By", format: @<text>@item.created_by_text</text>, canSort: true),
grid.Column("created_on", "Created On", format: @<text>@(item.created_on == null ? item.created_on : MiscHelper.FormatDateTime(item.created_on.ToString()))</text>, canSort: true),
grid.Column("modified_by_text", "Modified By", format: @<text>@item.modified_by_text</text>, canSort: true),
grid.Column("modified_on", "Modified On", format: @<text> @(item.modified_on == null ? item.modified_on : MiscHelper.FormatDateTime(item.modified_on.ToString()))</text>, canSort: true)
))
                            @Html.Hidden("dir", grid.SortDirection)
                            @Html.Hidden("col", grid.SortColumn)
                        </div>
                    </div>
                }
                else
                {
                    <div style="text-align: center; margin-top: 30px;">
                        No Faq Found.
                    </div>
                }
            }
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        addDefaultSortingIcons("tblFaqUserManual");
        updateNumberstoFormatedNumber();
    });
    function ViewFaqUserManual() {
        window.location = appRoot + 'Miscellaneous/DownloadFaqUserManual';
    }

    function updateNumberstoFormatedNumber() {
        $('span[data]').each(function (index) {
            // Get the value of the data-target attribute for each element
            var targetValue = $(this).data('data');

            // Do whatever you want with the element or its data
            console.log('Span with data-target = ' + targetValue + ': ' + $(this).text());
            $(this).text(getFormattedNumber($(this).text().trim()));
        });
    }
</script>

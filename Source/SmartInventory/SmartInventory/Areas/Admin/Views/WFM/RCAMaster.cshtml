                                        //    if(!$('[id="lstLayers"]').valid()) {
                                        //        e.preventDefault();
                                        //        return false;
                                        //    }
                                        //    else{
                                        //        return true;
                                        //    }
                                       // });
        </script>
    </div>

</div>
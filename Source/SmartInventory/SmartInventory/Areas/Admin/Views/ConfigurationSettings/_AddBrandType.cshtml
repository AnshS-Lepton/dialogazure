<!DOCTYPE html>
@model Models.Admin.BrandTypeMaster

<div id="dvBrandTypeDetail">

    <div class="col-lg-12" id="dvPageMessage">
        @{Html.RenderPartial("_PageMessage", Model.pageMsg);}

    </div>

    @using (Ajax.BeginForm("SaveBrandTypeDetail", "OSPSettings", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "dvBrandTypeDetail",
        OnSuccess = "onChangebindBrandtype()"
    },
    new { id = "frmBrandTypeDetail", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {

        <div id="dv_BrandType" data-title="Add Brand Type Detail">
            @Html.HiddenFor(m => m.id, new { id = "hdn_Id" })
            @Html.HiddenFor(m => m.type_id, new { id = "hdn_type_Id" })

            <div class="form-group" style="width: 100%; height: 33px;">
                <div class="row">
                    <div class=" col-md-3">
                        <label class=" control-label">
                            Equipment Type:
                        </label>
                    </div>
                    <div class=" col-md-7">

                        @Html.TextBoxFor(m => m.equipment_type, new { @class = "form-control", @id = "txt_BrandType", @readonly = "true" })


                    </div>
                </div>

            </div>



            <div class="form-group" style="width: 100%; height: 33px;">
                <div class="row">
                    <div class=" col-md-3">
                        <label class=" control-label">
                            Brand Name:
                        </label>
                    </div>
                    <div class=" col-md-7">
                        @Html.TextBoxFor(model => model.brand, new { @class = "form-control", @maxlength = "50", @placeholder = "Enter Brand Type Name", @id = "txtbrand_name" })

                    </div>
                </div>

            </div>

            <div class="form-group">
                <div class="row">
                    <div class="col-md-4 form-group" style="display:none">

                        @Html.TextBoxFor(m => m.created_by, new { @class = "form-control", placeholder = "Created By" })

                    </div>
                </div>

            </div>

            <div class="form-group" id="dvBtnAction" style="width: 100%; height: 33px;">
                <div class="row">
                    <div class=" col-md-3"> </div>
                    <div class=" col-md-7  text-right">

                        <input type="submit" class="btn btn-primary" name="btnSaveBrandTypeDetail" onclick="return isValidBrandDetails()" id="btnSaveBrandTypeDetail" value="Save" />
                        <a href="javascript:void(0);" class=" btn btn-default" data-dismiss="modal" id="btnCancelBrandType">Cancel</a>


                    </div>
                </div>
            </div>


        </div>
    }


    <script>

        if ('@Model.id' != 0) {

            btnSaveBrandTypeDetail.value = "Update";

        }

        function isValidBrandDetails() {
            if ($('#txtbrand_name').val() == "") {
                $('#txtbrand_name').css({ "border": "1px solid red" });
                return false;

            }

        }


    </script>

</div>


<!DOCTYPE html>
@model Models.Admin.EquipmentTypeMaster

<div id="dvEquipmentTypeDetail">

    <div class="col-lg-12" id="dvPageMessage">
        @{Html.RenderPartial("_PageMessage", Model.pageMsg);}

    </div>

    @using (Ajax.BeginForm("SaveEquipmentTypeCode", "OSPSettings", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "dvEquipmentTypeDetail",
        OnSuccess = "onChangebindEqiupmenttype()"
    },
    new { id = "frmEquipmentTypeDetail", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {

        <div id="dv_Equipment" data-title="Add Equipment Type Detail">
            @Html.HiddenFor(m => m.id, new { id = "hdn_Id" })
            @Html.HiddenFor(m => m.entity_id, new { id = "hdn_entityId" })

            <div class="form-group" style="width: 100%; height: 33px;">
                <div class="row">
                    <div class=" col-md-3">
                        <label class=" control-label">
                            Entity Type:
                        </label>
                    </div>
                    <div class=" col-md-7">

                        @Html.TextBoxFor(m => m.entity_type, new { @class = "form-control", @id = "txt_EntityType", @readonly = "true" })


                    </div>
                </div>

            </div>



            <div class="form-group" style="width: 100%; height: 33px;">
                <div class="row">
                    <div class=" col-md-3">
                        <label class=" control-label">
                            Equipment Name:
                        </label>
                    </div>
                    <div class=" col-md-7">
                        @Html.TextBoxFor(model => model.type, new { @class = "form-control", @maxlength = "50", @placeholder = "Enter Equipment Name", @id = "txtequipment_name" })

                    </div>
                </div>

            </div>

            <div class="form-group">
                <div class="row">
                    <div class="col-md-4 form-group" style="display:none">

                        @Html.TextBoxFor(m => m.created_by, new { @class = "form-control", placeholder = "Created By" })

                    </div>
                </div>

            </div>

            <div class="form-group" id="dvBtnAction" style="width: 100%; height: 33px;">
                <div class="row">
                    <div class=" col-md-3"> </div>
                    <div class=" col-md-7  text-right">

                        <input type="submit" class="btn btn-primary" name="btnSaveEquipmentDetail" onclick="return isValidEquipmentDetails()" id="btnSaveEquipmentDetail" value="Save" />
                        <a href="javascript:void(0);" class=" btn btn-default" data-dismiss="modal" id="btnCancelEquipmentType">Cancel</a>


                    </div>
                </div>
            </div>


        </div>
    }


    <script>

        if ('@Model.id' != 0) {
           
            btnSaveEquipmentDetail.value = "Update";

        }

        function isValidEquipmentDetails() {
            if ($('#txtequipment_name').val() == "") {
                $('#txtequipment_name').css({ "border": "1px solid red" });
                return false;

            }

        }


    </script>

</div>


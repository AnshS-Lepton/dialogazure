@model Models.Admin.SearchLandBaseLayerSetting

<!DOCTYPE html>
<div class="col-lg-12" id="dvPageMessage">
    @{Html.RenderPartial("_PageMessage", Model.pageMsg);}
</div>
<div id="dvSearchSetting" class="update_panel">
    <div class="title">
        <h4><span class="icon16 icomoon-icon-bars"></span><span>Landbase Search Settings</span></h4>
    </div>
    @using (Html.BeginForm("LandBaseLayerSaveSearchSettings", "LandbaseSettings", FormMethod.Post, new { autocomplete = "off", @id = "frmSearchSetting", enctype = "multipart/form-data", @class = "form-horizontal  pad_left" }))
    {
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Layer type:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.DropDownListFor(m => m.landbase_layer_id, new SelectList(Model.lstLayers.Select(x => new { Value = x.id.ToString(), Text = x.layer_name.ToString() }), "Value", "Text"), "Select Layer Type", new { @class = "chosen-select col-sm-12", @onchange = "LandBaseLayerSearchChange();", @id = "lstLayers" })
                </div>
            </div>
        </div>
        if (Model.landbase_layer_id > 0)
        {
            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label"> Search Attributes:</label>
                    </div>
                    <div class="col-md-8" id="Categories">
                        <ul class="clsAttributes">

                            <li class="clsSelectAll">@Html.CheckBox("chkSelectAll", false) <label>Select All</label></li>
                            @for (int i = 0; i < Model.lstSearchAttributes.Count; i++)
                            {
                                <li>
                                    @if (Model.lstSearchAttributes[i].column_name.ToUpper() == "NETWORK_ID")
                                    {
                                        @Html.CheckBoxFor(m => Model.lstSearchAttributes[i].is_selected, new { @onclick = "return false", @style = " opacity: 0.5;", @checked = true })
                                    }
                                    else
                                    {
                                        @Html.CheckBoxFor(m => Model.lstSearchAttributes[i].is_selected, new { @class = "attr" })
                                    }
                                    <label>@Model.lstSearchAttributes[i].display_name</label>
                                </li>
                                @Html.HiddenFor(m => Model.lstSearchAttributes[i].column_name)
                                @Html.HiddenFor(m => Model.lstSearchAttributes[i].display_name)
                            }

                        </ul>
                    </div>
                </div>
            </div>
            <div class="form-group" id="dvBtnAction">
                <div class="d-flex">
                    <a href="@Url.Action("LandBaseLayerSearchSetting", "LandbaseSettings", new { id = 0 })" class="btn btn-default ml-auto mr-01" title="Reset">Reset</a>
                    <input type="submit" class="btn btn-primary" onclick="return IsValid();" name="btnaction" id="btnSubmit" value="Save" />
                </div>
            </div>
        }
        <div class="clearfix"></div>
    }
</div>
<script>
    $(document).ready(function () {
        $('.chosen-select').chosen({ width: '100%' });
        $('#chkSelectAll').on("click", function () {
            {
                $(".clsAttributes li input[type=checkbox].attr").prop("checked", $(this).prop("checked"));
            }
        });
        $('.attr').on("click", function () {
            {
                var totalAttr = $(".clsAttributes li input[type=checkbox]:not(#chkSelectAll)").length;
                var totalSelected = $(".clsAttributes li input[type=checkbox]:not(#chkSelectAll):checked").length;
                $('#chkSelectAll').prop("checked", totalAttr == totalSelected ? true : false);
            }
        });
    });
</script>


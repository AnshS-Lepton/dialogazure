                        <div class="chips">Termination Set</div>
                        <div class="chips">Suspension Set</div>
                    </div>
                </fieldset>
                <fieldset class="expField">
                    <legend class="expLegend">Operators</legend>
                    <div class="expChips d-flex">
                        <div class="operators">+</div>
                        <div class="operators">-</div>
                        <div class="operators">*</div>
                        <div class="operators">/</div>
                        <div class="operators">mode</div>
                    </div>
                </fieldset>
                <fieldset class="expField fieldPad">
                    <input type="text" placeholder="clamp" class="fieldInput" />

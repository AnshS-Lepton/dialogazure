@model Models.Admin.LayerActionSettings
@*@model Models.Admin.ViewLayerActionNameList*@
<style>
    .noMove, .noMove:hover {
        cursor: not-allowed;
        background-color: #ffcfcf !important;
    }

    .Move {
        cursor: move;
        background-color: white;
    }

    #tblReportColumnsInfo tr:hover:not(.noMove) {
        color: white !important;
    }

    .field-validation-error {
        bottom: auto;
        right: 49px;
    }
</style>
<div id="dvPageMessage">
    @{Html.RenderPartial("_PageMessage", Model.pageMsg);}
</div>
<div id="dvLayerActionSettings" class="update_panel fullWidth">
    <div class="title">
        <h4>Layer Action Settings</h4>
    </div>
    @*@{
            WebGrid grid = new WebGrid(rowsPerPage: Model.objGridAttributes.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewLayerGroupsMapping", ajaxUpdateCallback: "onGridHeaderClick('tblLayerGroupsMapping')");
            grid.Bind(Model.lstLayerGroupsMapping, autoSortAndPage: false, rowCount: Model.objGridAttributes.totalRecord);
            if (Model.objGridAttributes.totalRecord > 0)
            {
                grid.PageIndex = Model.objGridAttributes.currentPage - 1;
            }
        }*@
    @using (Html.BeginForm("SaveLayerActionSettings", "AdvancedSettings", FormMethod.Post, new { autocomplete = "off", @id = "frmReportColumnSettings", enctype = "multipart/form-data", @class = "form-horizontal  pad_left" }))
    {
        <div class="form-group">
            <div class="row">
                <div class="col-md-1">
                    <label class="control-label">
                        Entity Type:
                    </label>
                </div>
                <div class="col-md-4">
                    @Html.DropDownListFor(m => m.layer_id, new SelectList(Model.layerDetails.Select(x => new { Value = x.layer_id.ToString(), Text = x.layer_title.ToString() }), "Value", "Text"), "Select Entity Type", new { @class = "chosen-select col-sm-12", @onchange = "ReportLayerChange();", @id = "lstLayers" })
                </div>
            </div>
        </div>
        if (Model.layer_id > 0)
        {
            <div class="form-inline filter-sec ">

                @*<div class="form-group wtd_set">

                        <label class="control-label col-sm-4">
                            Search By :
                        </label>

                        <div class="col-md-8 wtd_set">

                            @Html.DropDownListFor(m => m.ViewlayerAcionNames.searchBy, new SelectList(Model.lstBindSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), "---Select---", new { @class = "chosen-select form-control", @id = "txtSearchBy" })

                        </div>

                    </div>*@


                <div class="form-group wtd_set">
                    <label class="control-label col-sm-4">
                        Search Text:
                    </label>
                    <div class="col-md-8">
                        @Html.TextBoxFor(m => m.ViewLayerAction.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, }) @*@onkeyup = "SearchActionNames(this.value)"*@
                    </div>
                </div>
                <div class="form-group wtd_set" id="dvBtnAction">
                    <div class="col-md-8">
                        <input type="button" class="btn btn-primary mr-05" name="btnaction" id="btnSubmit" value="Search" onclick="return app.SearchActionNames()" />
                        <input type="button" class="btn btn-default" id="reset" value="Reset" />
                    </div>
                </div>
            </div>
            <div class="d-flex mb-01">
                <span><b>Total Actions: @Model.actionDetails.Count</b></span><span class="ml-auto"><b>Note:</b> Drag drop layerAcionName to reorder actions.</span>
            </div>

            <div class="table-responsive tble_cls">

                <table id="tblReportColumnsInfo" class="grid">
                    <thead>
                        <tr>
                            <th>Action Name</th>
                            <th>Action Title</th>
                            <th>Active</th>
                            <th>Web Action</th>
                            <th>Mobile Action</th>
                            <th>Visible</th>
                            <th>ISP Action</th>
                            <th>OSP Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.actionDetails.Count; i++)
                        {
                            <tr class="Move">
                                <td>
                                    @Model.actionDetails[i].action_name
                                    @Html.HiddenFor(x => x.actionDetails[i].action_name)
                                    @Html.HiddenFor(m => Model.actionDetails[i].action_sequence)
                                </td>
                                <td>
                                    @Html.TextBoxFor(m => Model.actionDetails[i].action_title, new { @class = "form-control actionTitle", @maxlength = "50", Style = " width:90%;" })

                                </td>
                                <td id="tdreportrequired">
                                    @Html.CheckBoxFor(m => Model.actionDetails[i].is_active, new { @class = "attr" })
                                </td>

                                <td id="tdreportrequired">
                                    @Html.CheckBoxFor(m => Model.actionDetails[i].is_web_action, new { @class = "attr" })
                                </td>
                                <td id="tdreportrequired">
                                    @Html.CheckBoxFor(m => Model.actionDetails[i].is_mobile_action, new { @class = "attr" })
                                </td>
                                <td id="tdreportrequired" style="color:@(!Model.actionDetails[i].is_visible ? "red;" : "black;")">
                                    @(Model.actionDetails[i].is_visible ? "Yes" : "No")
                                </td>
                                <td id="tdreportrequired" style="color:@(!Model.actionDetails[i].is_isp_action ? "red;" : "black;")">
                                    @(Model.actionDetails[i].is_isp_action ? "Yes" : "No")
                                </td>
                                <td id="tdreportrequired" style="color:@(!Model.actionDetails[i].is_osp_action ? "red;" : "black;")">
                                    @(Model.actionDetails[i].is_osp_action ? "Yes" : "No")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="d-flex jc-flex-end mt-01" id="dvBtnAction">
                <a href="@Url.Action("LayerActionSettings", "AdvancedSettings", new { id = 0 })" class="btn btn-default mr-05" title="Reset">Reset</a>
                <input type="submit" class="btn btn-primary" name="btnaction" id="btnSubmit" value="Save" />
            </div>
        }
        <div class="clearfix"></div>
    }
</div>
            <script>
                $(document).ready(function () {
                    $('.chosen-select').chosen({ width: '100%' });
                    //checkHeaderCheckbox();
                    checkHeaderCheckbox('tdreportrequired', 'chkSelectAll');
                    checkHeaderCheckbox('tdkmlrequired', 'chkSelectAllKML');
                    $('#chkSelectAll').on("click", function () {
                        {
                            $("#tdreportrequired input[type=checkbox].attr").prop("checked", $(this).prop("checked"));
                        }
                    });
                    $('.attr').on("click", function () {
                        {
                            checkHeaderCheckbox('tdreportrequired', 'chkSelectAll');
                        }
                    });



                    $("#tblReportColumnsInfo  tbody").sortable({
                        items: "tr:not(.noMove)",
                        update: function () {
                            var index = 1;
                            $('#tblReportColumnsInfo  tbody input:hidden[name$="action_sequence"]').each(function () {
                                $(this).attr("value", index);
                                //console.log($(this).attr("id"));
                                //console.log($(this).attr("value"));
                                index++;
                            });
                        }
                    });
                });
                function checkHeaderCheckbox(tdid, chkallid) {
                    var totalAttr = $("#" + tdid + " input[type=checkbox]").length;
                    var totalSelected = $("#" + tdid + " input[type=checkbox]:checked").length;
                    $('#' + chkallid).prop("checked", totalAttr == totalSelected ? true : false);
                }
                function ReportLayerChange() {
                    
                    var _layername = $('#lstLayers option:selected').text();
                    var _layerId = $('#lstLayers option:selected').val();
                    if (_layerId != undefined && _layerId != 0) {
                        window.open(appRoot + '/AdvancedSettings/LayerActionSettings/' + _layerId, "_self");
                    }
                    else {
                        window.open(appRoot + '/AdvancedSettings/LayerActionSettings', "_self");
                    }  
                }
                function reset() {
                    
                    $("#tblReportColumnsInfo tbody tr").show();
                    $("#hdnNoRecFound").hide();
                    $("#txtSearchText").val("");
                }
                $("#reset").on("click", function () {
                    reset();
                    });
            </script>

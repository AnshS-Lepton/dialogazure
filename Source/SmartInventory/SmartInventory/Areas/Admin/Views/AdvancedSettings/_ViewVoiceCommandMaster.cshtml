<!DOCTYPE html>
@model Models.VoiceCommandMaster

@{
    var objUser = (Models.User)Session["userDetail"];
    WebGrid grid = new WebGrid(rowsPerPage: 10, canSort: true, ajaxUpdateContainerId: "dvVoiceCommandMaster", ajaxUpdateCallback: "onGridHeaderClick('tblVoiceCommandMasterDetail')");
    grid.Bind(Model.VoiceCommandDetail, autoSortAndPage: false, rowCount: Model.totalrecords);
}

@using (Html.BeginForm("VoiceCommandMaster", "AdvancedSettings", FormMethod.Post, new { autocomplete = "off", @id = "frmVoiceCommandMaster" }))
{
    <div class="--pad-tn">
        <div class="form-inline filter-sec">
            <div class="form-group wtd_set">
                <label class="control-label col-sm-4">
                    Search By :
                </label>
                <div class="col-md-8">
                    @Html.DropDownListFor(m => m.searchBy, new SelectList(Model.lstBindSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), new { @class = "chosen-select form-control" })

                </div>
            </div>
            <div class="form-group wtd_set">
                <label class="control-label col-sm-4">
                    Search Text:
                </label>

                <div class="col-md-8">
                    @Html.TextBoxFor(m => m.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })
                </div>
            </div>
            <div class="form-group wtd_set" id="dvBtnAction">
                <button class="btn btn-primary mr-05 ml-05" id="btnGetSearchResult" name="btnCommandName" value="GetSearchResult" tabindex="5" onclick="return fnGetSearchResult();" type="submit">Search</button>
                @if (@grid.TotalRowCount > 0)
                {
                    <input type="button" id="btnExport" value="Export" class="btn btn-primary mr-05" />
                }
                else
                {
                    <input type="button" id="btnExport" value="Export" disabled="disabled" class="btn btn-primary mr-05" />
                }
                <a href="@Url.Action("VoiceCommandMaster")" class="btn btn-default" title="Reset">Reset</a>
            </div>
        </div>

        <div id="divVoiceCommandMasterDetail">
            <div class="recordCount mb-01"><b>Total Records:@grid.TotalRowCount</b></div>

            <div class="table-responsive tble_cls">
                @grid.GetHtml(tableStyle: "grid",
             htmlAttributes: new { id = "tblVoiceCommandMasterDetail" },
             mode: WebGridPagerModes.All,
             columns: grid.Columns(

             grid.Column("", "Action", format:@<text><a href="@Url.Action("EditVoiceCommand", "AdvancedSettings", new { id = @item.id })" class="auto" title="Edit"> <i class="fa fa-pencil action_icon fa-fw m-r-xs"></i></a>

            </text>),
grid.Column("actual_command_name", "Command Name", format: @<text>@item.actual_command_name</text>),
grid.Column("command_pronounce", "Command Pronounce", format: @<text>@item.command_pronounce</text>)
))

            </div>

        </div>
    </div>
}
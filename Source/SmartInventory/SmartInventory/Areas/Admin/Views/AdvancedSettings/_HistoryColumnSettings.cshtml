<!DOCTYPE html>
@model Models.Admin.vwLayerColumnSettings
<style>
    .noMove, .noMove:hover {
        cursor: not-allowed;
        background-color: #ffcfcf !important;
    }

    .Move {
        cursor: move;
        background-color: white;
    }

    #tblHistoryColumnsInfo tr:hover:not(.noMove) {
        color: white !important;
        /* background-color: #154777 !important;*/
    }

    .field-validation-error {
        bottom: auto;
        right: 49px;
    }
</style>
<div id="dvPageMessage">
    @{Html.RenderPartial("_PageMessage", Model.pageMsg);}
</div>
<div id="dvHistoryColumnSettings" class="update_panel fullWidth" style="position:relative;">
    <div class="title">
        <h4><span class="icon16 icomoon-icon-bars"></span><span>History Column Settings</span></h4>
    </div>
    @using (Html.BeginForm("SaveHistoryColumnSettings", "AdvancedSettings", FormMethod.Post, new { autocomplete = "off", @id = "frmHistoryColumnSettings", enctype = "multipart/form-data", @class = "form-horizontal  pad_left" }))
    {
        <div class="form-group">
            <div class="row">
                <div class="col-md-2">
                    <label class="control-label">
                        Entity Type:
                    </label>
                </div>
                <div class="col-md-3">
                    @Html.DropDownListFor(m => m.layer_id, new SelectList(Model.lstLayers.Select(x => new { Value = x.layer_id.ToString(), Text = x.layer_title.ToString() }), "Value", "Text"), "Select Entity Type", new { @class = "chosen-select", @onchange = "HistoryLayerChange();", @id = "lstLayers" })
                </div>
            </div>
        </div>
        if (Model.layer_id > 0)
        {
            <div class="d-flex mb-01">
                <span><b>Note:</b> Drag drop rows to reorder columns. </span>
                <span class="ml-auto"><b>Total Columns: @Model.lstLayerColumns.Count</b></span>

            </div>
            <div class="table-responsive tble_cls">

                <table id="tblHistoryColumnsInfo" class="grid">
                    <thead>
                        <tr>
                            <th>@Html.CheckBox("chkSelectAll", false) <label style="margin:0px;"> All</label></th>
                            <th>Column Name</th>
                            <th>Display Name</th>
                            <th>Resource Key</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.lstLayerColumns.Count; i++)
                        {
                            <tr class="@(Model.lstLayerColumns[i].is_required == true?"noMove":"Move")">
                                <td>
                                    @if (Model.lstLayerColumns[i].is_required == true)
                                    {
                                        @Html.CheckBoxFor(m => Model.lstLayerColumns[i].is_active, new { @onclick = "return false", @style = " opacity: 0.5;" })
                                    }
                                    else
                                    {
                                        @Html.CheckBoxFor(m => Model.lstLayerColumns[i].is_active, new { @class = "attr" })
                                    }

                                    @Html.HiddenFor(m => Model.lstLayerColumns[i].id)
                                    @Html.HiddenFor(m => Model.lstLayerColumns[i].column_sequence)

                                </td>
                                <td>
                                    @Model.lstLayerColumns[i].column_name
                                </td>
                                <td>
                                    @Html.TextBoxFor(m => Model.lstLayerColumns[i].display_name, new { @class = "form-control displayName", @maxlength = "30", Style = " width:90%;" })
                                    @Html.ValidationMessageFor(m => Model.lstLayerColumns[i].display_name)
                                </td>
                                <td>
                                    @Html.TextBoxFor(m => Model.lstLayerColumns[i].res_field_key, new { @class = "form-control", Style = " width:90%;" })
                                    @Html.ValidationMessageFor(m => Model.lstLayerColumns[i].res_field_key)
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="d-flex mt-01" id="dvBtnAction">
                <a href="@Url.Action("HistoryColumnSettings", "AdvancedSettings", new { id = 0 })" class="btn btn-default ml-auto mr-05" title="Reset">Reset</a>
                <input type="submit" class="btn btn-primary" name="btnaction" id="btnSubmit" value="Save" />
            </div>
        }
        <div class="clearfix"></div>
    }
</div>
<script>
    $(document).ready(function () {
        $(".displayName").on('keypress', function (event) {
            var regex = new RegExp("^[a-zA-Z0-9_()\\-\\s/]$");
            var key = String.fromCharCode(!event.charCode ? event.which : event.charCode);
            if (!regex.test(key)) {
                event.preventDefault();
                return false;
            }
        })
        $('.chosen-select').chosen({ width: '100%' });
        checkHeaderCheckbox();
        $('#chkSelectAll').on("click", function () {
            {
                $("#tblHistoryColumnsInfo tbody input[type=checkbox].attr").prop("checked", $(this).prop("checked"));
            }
        });
        $('.attr').on("click", function () {
            {
                checkHeaderCheckbox();
            }
        });

        $("#tblHistoryColumnsInfo  tbody").sortable({
            items: "tr:not(.noMove)",
            update: function () {
                var index = 1;
                $('#tblHistoryColumnsInfo  tbody input:hidden[name$="column_sequence"]').each(function () {
                    $(this).attr("value", index);
                    //console.log($(this).attr("id"));
                    //console.log($(this).attr("value"));
                    index++;
                });
            }
        });
    });
    function checkHeaderCheckbox() {
        var totalAttr = $("#tblHistoryColumnsInfo tbody input[type=checkbox]").length;
        var totalSelected = $("#tblHistoryColumnsInfo tbody input[type=checkbox]:checked").length;
        $('#chkSelectAll').prop("checked", totalAttr == totalSelected ? true : false);
    }
    function HistoryLayerChange() {
        var _layername = $('#lstLayers option:selected').text();
        var _layerId = $('#lstLayers option:selected').val();
        if (_layerId != undefined && _layerId != 0) {
            window.open(appRoot + '/AdvancedSettings/HistoryColumnSettings/' + _layerId, "_self");
        }
        else {
            window.open(appRoot + '/AdvancedSettings/HistoryColumnSettings', "_self");
        }
    }
</script>


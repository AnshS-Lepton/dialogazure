@model Models.PageMessage
@if (Model.status == "OK")
{
    <div class="alert alert-success">
        @*<button type="button" class="close" data-dismiss="alert">&times;</button> <i class="fa fa-ok-sign"></i><strong> @Model.message</strong>*@

        <button type="button" class="close" data-dismiss="alert">&times;</button> <i class="fa fa-ok-sign"></i><strong> @( new HtmlString(Model.message))</strong>
        

    </div>
    <script type="text/javascript">
        autoClosePageMessage();
    </script>
}
@if (Model.status == "FAILED" || Model.status == "ERROR")
{
    <div class="alert alert-danger">
        <button type="button" class="close" data-dismiss="alert">&times;</button> <i class="fa fa-ban-circle"></i><strong>@(new HtmlString(Model.message))</strong>

    </div>
    <script type="text/javascript">
        //autoClosePageMessage();
    </script>
}
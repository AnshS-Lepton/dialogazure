@model List<Models.UserModule>

<!DOCTYPE html>
<style>
    .hide {
        display: none !important;
    }

    .show {
        display: block !important;
    }
</style>
<div class="d--flex --gap15">
    <div class="Admin-section">
        <label>
            <input type="checkbox" name="AllLayers" id="CheckAll_Admin" class="allModule allAdmin" onclick="CheckByClass('allAdmin',this)" /><b class="fw-600">Admin</b>
        </label>

        <div>
            <div class="form-input mb-01 fullWidth" id="SearchRegionProvince1">
                <input type="text" class="form-control gridInputWidth searchBox" placeholder="@Resources.Resources.SI_OSP_GBL_GBL_GBL_046" id="txtSearchRegionProvince1">
            </div>
            <div class="boxes--minh col-md-12 column" id="divAdminModule">

                <div id="RegionProvinceArea1">
                    <ul class="mainModule region  admin--treeview" style="display:block;">

                        @{ var count = 0;
                            var count2 = 1;
                            var parentModule = Model.Where(x => x.parent_module_id == 0).OrderBy(x => x.module_sequence).ToList();
                            for (var i = 0; i < parentModule.Count; i++)
                            {
                                if (parentModule[i].type == "Admin")
                                {
                                    <div class="countryName1" data-country1-name="@parentModule[i].module_name"><span style="display:none">@parentModule[i].module_name</span></div>
                                    <li data-country1-name="@parentModule[i].module_name" class="collapsable">
                                        <div class="hitarea collapsable-hitarea"></div>
                                        @*<input id="chk_parent_@parentModule[i].Id" type="checkbox" class="checkbox-custom">*@

                                        @Html.CheckBoxFor(model => parentModule[i].is_selected, new { @class = "allModule allAdmin chkModule module_" + parentModule[i].Id + "", @onclick = "CheckByClass('chkModuleChild_" + parentModule[i].Id + "',this)", @onchange = "CheckModule()", Name = "lstUserModule[" + count + "].is_selected" })
                                        @Html.HiddenFor(model => parentModule[i].Id, new { Name = "lstUserModule[" + count + "].Id" })
                                        @Html.HiddenFor(model => parentModule[i].type, new { Name = "lstUserModule[" + count + "].type" })
                                        @*@Html.HiddenFor(model => parentModule[i].module_name, new { Name = "lstUserModule[" + count + "].module_name" })*@
                                       


                                        <label for="chk_parent_@parentModule[i].Id" style="margin-left:19px;" class="checkbox-custom-label ">
                                            <span id="spnRegionName1" title="@parentModule[i].module_name" class="rname1">@parentModule[i].module_name</span>
                                        </label>

                                        @{count = count + 1;
                                            var childModule = Model.Where(x => x.parent_module_id == parentModule[i].Id).OrderBy(x => x.module_sequence).ToList();
                                            for (var j = 0; j < childModule.Count; j++)
                                            {


                                                <ul class="collapsable province1" style="display: block;">
                                                    <li>
                                                        <img style="margin-top: -8px;" src="~/Areas/Admin/Content/css/images/t.gif" />
                                                        @*<input id="chk_child_@childModule[j].Id" class="checkbox-custom" type="checkbox">*@
                                                        @Html.CheckBoxFor(model => childModule[j].is_selected, new { @class = "allModule allAdmin chkModule chkModuleChild_" + parentModule[i].Id + "", @onchange = "checkModuleSelected(" + parentModule[i].Id + ")", Name = "lstUserModule[" + count + "].is_selected" })
                                                        @Html.HiddenFor(model => childModule[j].Id, new { Name = "lstUserModule[" + count + "].Id" })
                                                        @Html.HiddenFor(model => childModule[j].type, new { Name = "lstUserModule[" + count + "].type" })
                                                        @*@Html.HiddenFor(model => childModule[j].module_name, new { Name = "lstUserModule[" + count + "].module_name" })*@

                                                        <label for="chk_child_@childModule[j].Id" style="margin-left:19px;" class="checkbox-custom-label ">
                                                            <span id="spnLayerName1" title="@childModule[j].module_name" class="pname1">@childModule[j].module_name</span>
                                                        </label>

                                                    </li>
                                                </ul>
                                                count = count + 1;
                                            }
                                        }
                                    </li>
                                }
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="Web-section">
        <label>
            <input type="checkbox" name="AllLayers" id="CheckAll_Web" class="allModule allWeb" onclick="CheckByClass('allWeb',this)" /><b class="fw-600">Web</b>
        </label>
        <div class="">
            <div class="form-input mb-01 fullWidth" id="SearchRegionProvince2">
                <input type="text" class="form-control gridInputWidth gridInputMW searchBox" placeholder="@Resources.Resources.SI_OSP_GBL_GBL_GBL_046" id="txtSearchRegionProvince2">
            </div>
            <div class="boxes--minh col-md-12 column" id="divWebModule">
                <div id="RegionProvinceArea2">
                    <ul class="mainModule region admin--treeview" style="display:block;">

                        @{ //var count = 0;
                            //var parentModule = Model.Where(x => x.parent_module_id == 0).OrderBy(x => x.module_sequence).ToList();
                            for (var i = 0; i < parentModule.Count; i++)
                            {
                                if (parentModule[i].type == "Web")
                                {

                                    <div class="countryName2" data-country2-name="@parentModule[i].module_name"><span style="display:none">@parentModule[i].module_name</span></div>
                                    <li data-country2-name="@parentModule[i].module_name" class="collapsable">
                                        <div class="hitarea collapsable-hitarea"></div>
                                        @*<input id="chk_parent_@parentModule[i].Id" type="checkbox" class="checkbox-custom">*@

                                        @Html.CheckBoxFor(model => parentModule[i].is_selected, new { @class = "allModule allWeb chkModule module_" + parentModule[i].Id + "", @onclick = "CheckByClass1('chkModuleChild_" + parentModule[i].Id + "','chkparent_" + parentModule[i].Id + "',this)", @onchange = "CheckModule()", Name = "lstUserModule[" + count + "].is_selected" })
                                        @Html.HiddenFor(model => parentModule[i].Id, new { Name = "lstUserModule[" + count + "].Id" })
                                        @Html.HiddenFor(model => parentModule[i].type, new { Name = "lstUserModule[" + count + "].type" })
                                        @*@Html.HiddenFor(model => parentModule[i].module_name, new { Name = "lstUserModule[" + count + "].module_name" })*@
                                        @Html.HiddenFor(model => parentModule[i].module_abbr, new { Name = "lstUserModule[" + count + "].module_abbr" })

                                        <label for="chk_parent_@parentModule[i].Id" style="margin-left:19px;" class="checkbox-custom-label ">
                                            <span id="spnRegionName2" title="@parentModule[i].module_name" class="rname2">@parentModule[i].module_name</span>
                                        </label>

                                        @{
                                            count = count + 1;
                                            var childModule = Model.Where(x => x.parent_module_id == parentModule[i].Id).OrderBy(x => x.module_sequence).ToList();
                                            for (var j = 0; j < childModule.Count; j++)
                                            {
                                                <ul class="collapsable province2" style="display: block;">
                                                    <div class="countryName22" data-country22-name="@childModule[j].module_name"><span style="display:none">@childModule[j].module_name</span></div>
                                                    <li data-country22-name="@childModule[j].module_name" class="collapsable">
                                                        <div class="hitarea collapsable-hitarea"></div>
                                                        <img style="margin-top: -8px;" src="~/Areas/Admin/Content/css/images/t.gif" />
                                                        @*<input id="chk_child_@childModule[j].Id" class="checkbox-custom" type="checkbox">*@
                                                        @Html.CheckBoxFor(model => childModule[j].is_selected, new { @class = "allModule allWeb chkModule ch_" + childModule[j].Id + " chkModuleChild_" + parentModule[i].Id + "", @onclick = "CheckByClass('chkModuleSubChild_" + childModule[j].Id + "',this)", @onchange = "checkModuleSelected(" + parentModule[i].Id + ")", Name = "lstUserModule[" + count + "].is_selected" })
                                                        @Html.HiddenFor(model => childModule[j].Id, new { Name = "lstUserModule[" + count + "].Id" })
                                                        @Html.HiddenFor(model => childModule[j].type, new { Name = "lstUserModule[" + count + "].type" })
                                                        @*@Html.HiddenFor(model => childModule[j].module_name, new { Name = "lstUserModule[" + count + "].module_name" })*@
                                                        @Html.HiddenFor(model => parentModule[i].module_abbr, new { Name = "lstUserModule[" + count + "].module_abbr" })
                                                        <label for="chk_child_@childModule[j].Id" style="margin-left:19px;" class="checkbox-custom-label ">
                                                            <span id="spnLayerName2" title="@childModule[j].module_name" class="pname2">@childModule[j].module_name</span>

                                                        </label>

                                                        @* Start *@
                                                        @{
                                                            //count2 = count2 + 1;
                                                            var subchildModule = Model.Where(x => x.parent_module_id == childModule[j].Id).OrderBy(x => x.module_sequence).ToList();


                                                            if (subchildModule.Count > 0)
                                                            {
                                                                count = count + 1;
                                                                for (var k = 0; k < subchildModule.Count; k++)
                                                                {
                                                                    <ul class="collapsable prov" style="display: block; padding-left:15px;">
                                                                                                                                <li>
                                                                                                                                    <img style="margin-top: -8px;" src="~/Areas/Admin/Content/css/images/t.gif" />

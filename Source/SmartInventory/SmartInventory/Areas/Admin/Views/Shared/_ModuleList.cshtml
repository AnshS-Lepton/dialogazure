                                                                                                                                    @Html.HiddenFor(model => subchildModule[k].type, new { Name = "lstUserModule[" + count + "].type" })
                                                                                                                                    @*@Html.HiddenFor(model => subchildModule[k].module_name, new { Name = "lstUserModule[" + count + "].module_name" })*@

                                                        @*<input id="chk_child_@childModule[j].Id" class="checkbox-custom" type="checkbox">*@
                                                        @Html.CheckBoxFor(model => childMobileModule[j].is_selected, new { @class = "allModule allMobile chkModule chkModuleChild_" + parentModule[i].Id + "", @onchange = "checkModuleSelected(" + parentModule[i].Id + ")", Name = "lstUserModule[" + count + "].is_selected" })
                                                        @Html.HiddenFor(model => childMobileModule[j].Id, new { Name = "lstUserModule[" + count + "].Id" })
                                                        @Html.HiddenFor(model => childMobileModule[j].type, new { Name = "lstUserModule[" + count + "].type" })
                                                        @*@Html.HiddenFor(model => childMobileModule[j].module_name, new { Name = "lstUserModule[" + count + "].module_name" })*@

                                                        <label for="chk_child_@childMobileModule[j].Id" style="margin-left:19px;" class="checkbox-custom-label ">
                                                            <span id="spnLayerName3" title="@childMobileModule[j].module_name" class="pname3">@childMobileModule[j].module_name</span>
                                                        </label>

                                                    </li>
                                                </ul>
                                                count = count + 1;
                                            }
                                        }
                                    </li>
                                }
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).on('keyup', '#txtSearchRegionProvince1', function (e) {
         
        //.find('#RegionProvinceArea >.treeview > li').addBack().show()

        $("#RegionProvinceArea1 > .region > li").removeClass('show');
        $("#RegionProvinceArea1 > .region>li > .province1  > li").removeClass('show');
        $('.countryName1').removeClass('show');
        var tval = $(this).val();
        $(".countryName1").addClass('hide');
        $("#RegionProvinceArea1 > .region  > li").addClass('hide').filter(function () {
            // 
            if (tval == " ") {
                return false;
            }
            var text = $(this).children().find('.rname1').attr("title");
            var status = text.toUpperCase().indexOf(tval.toUpperCase()) > -1 ? true : false;
            // var text = $(this).children().find('.rname').text();
            // var status = text.toUpperCase().search(tval.toUpperCase()) != -1 ? true : false;
           
            if (status) {
                $("span:contains(" + $(this).data("country1-name") + ")").parent(".countryName1").removeClass('hide').addClass('show');
            }
            return status;
        }).removeClass('hide').addClass('show');

        $("#RegionProvinceArea1 > .admin--treeview >li > .province1  > li").addClass('hide').filter(function () {
             
            if (tval == " ") {
                return false;
            }
            var text = $(this).find('.checkbox-custom-label').children('span.pname1').attr("title");
            return text.toUpperCase().indexOf(tval.toUpperCase()) > -1 ? true : false;
            // $(this).find('.checkbox-custom-label').children('span.pname').text();
            // return text.toUpperCase().search(tval.toUpperCase()) != -1 ? true : false;
        }).removeClass('hide').addClass('show');
        $("#RegionProvinceArea1 > .admin--treeview  > li.hide").each(function () {
            if (tval == " ") {
                return false;
            }
            if ($(this).children('ul').children('li').hasClass('show')) {
                $(this).removeClass('hide').addClass('show');
                // $(document).find().data("country-name", $(this).data("country-name")).removeClass('hide').addClass('show');
            }
            if ($(this).hasClass('show')) {
                //console.log($(this).data("country-name"));
                $("span:contains(" + $(this).data("country1-name") + ")").parent().removeClass('hide').addClass('show');
            }
        });

        if ($(".show").length > 0) {
            $(".noRecordFound").hide();
        } else {
            $(".noRecordFound").show();
        }
    });
</script>

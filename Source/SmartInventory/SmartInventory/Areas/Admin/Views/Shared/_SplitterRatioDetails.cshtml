@model Models.Admin.LinkBudgetMaster

<!DOCTYPE html>
<div class="form-group">
    <div class="row">
        <div class="col-md-12">
            @if (Model.lstSplitterLoss != null && Model.lstSplitterLoss.Count > 0)
            {
                @*<div class="row">
                    <div class="col-md-4">
                        <label class=" control-label" style="position: absolute;right: -7px; top: 1px;">
                            <i class="clsMandatory">*</i>
                        </label>
                    </div>
                    <div class="col-md-8">
                        <label class=" control-label">
                           <i class="clsMandatory">*</i>
                        </label>
                    </div>
                </div>*@
    <div class="table-responsive tble_cls" style="height: 300px; overflow: auto; text-align: center;">
        <table border="1" class="grid">
            <thead>
                <tr>
                    <th>
                        Port Ratio
                    </th>
                    <th>
                        Loss Value(@SmartInventory.Settings.ApplicationSettings.dBLossUnit)
                    </th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.lstSplitterLoss.Count; i++)
                {
                    <tr>
                        <td>
                            <label for="@Model.lstSplitterLoss[i].splitter_ratio"><span>@Model.lstSplitterLoss[i].splitter_ratio</span></label>
                        </td>
                        <td>

                            @Html.HiddenFor(model => model.lstSplitterLoss[i].id)
                            @Html.HiddenFor(model => model.lstSplitterLoss[i].splitter_ratio)
                            @Html.HiddenFor(model => model.lstSplitterLoss[i].created_by)
                            @Html.HiddenFor(model => model.lstSplitterLoss[i].created_on)
                            @if (Model.is_active == false)
                            {
                                @Html.TextBoxFor(model => model.lstSplitterLoss[i].splitter_loss, new { @readonly = "readonly", @class = "form-control", @onkeypress = "return allowOnlyNumber(event);", @style = "MARGIN: 0 AUTO; width:150px;", @maxlength = "4", @placeholder = "Enter Loss Value" })
                            }
                            else
                            {
                                @Html.TextBoxFor(model => model.lstSplitterLoss[i].splitter_loss, new { @class = "form-control", @onkeypress = "return allowOnlyNumber(event);", @style = "MARGIN: 0 AUTO; width:150px;", @maxlength = "4", @placeholder = "Enter Loss Value" })
                            }

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
            }

        </div>
    </div>
</div>


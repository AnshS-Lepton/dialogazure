
@model Models.Admin.PurposeCodeMaster

<!DOCTYPE html>
<div id="dvPurposeDetail">
    <div id="dvPageMessage">
        @{Html.RenderPartial("_PageMessage", Model.pageMsg);}

    </div>

    @using (Ajax.BeginForm("SavePurposeCode", "Project", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "dvPurposeDetail",
        OnSuccess = "onChangeWorkorderCode()"
    },
    new { id = "frmPurposeDetail", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {

        <div id="dv_purposecode" data-title="Add Purpose Detail">
            <div class="EUTSetting">
                <div class="form-group">
                    <div class="row">
                        <div class="col-md-2"></div>
                        <div class="col-md-3">
                            <label class=" control-label">
                                Network Stage:
                            </label>
                        </div>
                        <div class="col-md-5">
                            @Html.TextBoxFor(m => m.network_stage, new { @class = "form-control", @id = "txt_NetworkStagePurposeCode", @readonly = "true" })
                        </div>
                        <div class="col-md-1"></div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-md-2"></div>
                        <div class="col-md-3">
                            <label class="control-label">
                                Workorder Code:
                            </label>
                        </div>
                        <div class="col-md-5">
                            @Html.TextBoxFor(m => m.workorder_code, new { @class = "form-control", @id = "txt_WorkorderCode_Parent_ForChild", @readonly = "true" })
                        </div>
                        <div class="col-md-1"></div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-md-2"></div>
                        <div class="col-md-3">
                            <label class="control-label">
                                Planning Name<i class="clsMandatory">*</i>:
                            </label>
                        </div>
                        <div class=" col-md-5">
                            @Html.TextBoxFor(model => model.purpose_name, new { @class = "form-control", @maxlength = "150", @placeholder = "Enter Purpose Name", @id = "txtpurpose_name" })
                        </div>
                        <div class="col-md-1"></div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-md-2"></div>
                        <div class=" col-md-3">
                            <label class=" control-label">
                                Planning Code<i class="clsMandatory">*</i>:
                            </label>
                        </div>
                        <div class=" col-md-5">
                            @Html.TextBoxFor(model => model.purpose_code, new { @class = "form-control", @maxlength = "150", @placeholder = "Enter Purpose Code", @id = "txtpurpose_code" })
                        </div>
                        <div class="col-md-1"></div>
                    </div>
                </div>
            </div>
            <div class="footerModal d-flex" id="dvBtnAction">
                <a href="javascript:void(0);" class="btn btn-default ml-auto mr-05" data-dismiss="modal" id="btnCancelPurpose">Cancel</a>
                <input type="submit" class="btn btn-primary" id="btnSavePurposeDetail" onclick="return isValidPurposeCode()" value="Save" />
            </div>
        </div>
        <div>
            @Html.HiddenFor(m => m.workorder_id, new { id = "hdn_workorder" })
            @Html.HiddenFor(m => m.system_id, new { id = "hdn_purposeId" })
            @Html.HiddenFor(m => m.created_by, new { id = "hdn_createdbyId" })
        </div>


        <script type="text/javascript">

      if ($('#txt_NetworkStagePurposeCode').val().toLowerCase() == 'p') {
          $('#txt_NetworkStagePurposeCode').val('Planned');
      }


      if ($('#txt_NetworkStagePurposeCode').val().toLowerCase() == 'a') {
          $('#txt_NetworkStagePurposeCode').val('As Built');
      }


   if ('@Model.system_id' != 0) {
       btnSavePurposeDetail.value = "Update";
       $('#txtpurpose_code').attr('readonly', true);


   }

      function isValidPurposeCode() {
          if ($('#txtpurpose_name').val() == "") {
              $('#txtpurpose_name').css({ "border": "1px solid red" });
              return false;

          }

          if ($('#txtpurpose_code').val() == "") {
              $('#txtpurpose_code').css({ "border": "1px solid red" });
              return false;
          }


      }

        </script>
    }

</div>


@model Models.ViewLayerRightsTempModel
@using Utility
@using SmartInventory.Settings;
<!DOCTYPE html>
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />
<div id="dvViewTemplates">
    <div class="update_panel fullWidth">
        @{
            WebGrid grid = new WebGrid(rowsPerPage: Model.objGridAttributes.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewTemplates", ajaxUpdateCallback: "onGridHeaderClick('gridTemplateMaster')");
            grid.Bind(Model.lstLayerRightTemplates, autoSortAndPage: false, rowCount: Model.objGridAttributes.totalRecord);
            if (Model.objGridAttributes.totalRecord > 0)
            {
                grid.PageIndex = Model.objGridAttributes.currentPage - 1;
            }
        }

        <div class="title">
            <h4>
                View Entity Templates
            </h4>
        </div>
        <div class="pad_left">
            @using (Html.BeginForm("ViewTemplates", "Template", FormMethod.Post, new { autocomplete = "off", @id = "frmViewUsers" }))
            {
                <div class="form-inline filter-sec">
                    <div class="d-flex mr-01">
                        <label class="control-label mr-05">Search By : </label>
                        <div class="--input-widthMd">
                            @Html.DropDownListFor(m => m.objGridAttributes.searchBy, new SelectList(Model.lstSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), new { @class = "chosen-select form-control" })
                        </div>

                    </div>
                    <div class="d-flex">
                        <label class="control-label mr-05">
                            Search Text:
                        </label>
                        <div class="--input-widthMd">
                            @Html.TextBoxFor(m => m.objGridAttributes.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })
                        </div>
                    </div>

                    <div class="ml-01" id="dvBtnAction">
                        <button class="btn btn-primary" id="btnGetSearchResult" name="btnCommandName" value="GetSearchResult" tabindex="5" type="submit">Search</button>
                        <a href="@Url.Action("ViewTemplates")" class="btn btn-default ml-05" title="Reset">Reset</a>
                    </div>
                </div>
                <div>
                    @if (Model.lstLayerRightTemplates.Count > 0)
                    {
                        <div class="recordCount mb-01"><b>Total Records:<span data="spanTotalRowCount">@grid.TotalRowCount</span></b></div>
                        <div class="table-responsive tble_cls">
                            @grid.GetHtml(tableStyle: "grid",
                                     htmlAttributes: new { id = "gridTemplateMaster" },
                                     mode: WebGridPagerModes.All,
                                     columns: grid.Columns(
                                           grid.Column("", "Action", format:@<text>
                                                    <a href="AddTemplate/@item.id" class="auto" title="Edit"> <i class="fa fa-pencil action_icon fa-fw m-r-xs"></i></a>
                                                    <a href="javascript:void(0);" onclick="fnDeleteTemplate(@item.id);" title="Delete"> <i class="fa fa-fw fa-trash" style="font-size: 13px; color: #f50000;"></i></a>
                                        </text>, canSort: false
     ),
         grid.Column(header: "S.No.", format: item => item.WebGrid.Rows.IndexOf(item) + 1 + Math.Round(Convert.ToDouble(grid.TotalRowCount / grid.PageCount) / grid.RowsPerPage) * grid.RowsPerPage * grid.PageIndex),
         grid.Column("template_name", "Template Name", format: @<text>@item.template_name</text>, canSort: true),

grid.Column("created_by_text", "Created By", format: @<text>@item.created_by_text</text>, canSort: true),
grid.Column("created_on", "Created On", format: @<text>@(item.created_on == null ? item.created_on : MiscHelper.FormatDateTime(item.created_on.ToString()))</text>, canSort: true),
grid.Column("modified_by_text", "Modified By", format: @<text>@item.modified_by_text</text>, canSort: true),
grid.Column("modified_on", "Modified On", format: @<text> @(item.modified_on == null ? item.modified_on : MiscHelper.FormatDateTime(item.modified_on.ToString())) </text>, canSort: true)
))
                            @Html.Hidden("dir", grid.SortDirection)
                            @Html.Hidden("col", grid.SortColumn)
                            @*@Html.Hidden("objGridAttributes.searchText", Model.objGridAttributes.searchText)*@

                        </div>

                    }
                    else
                    {
                        <div style="text-align: center; margin-top: 30px;">
                            No Entity Template Found.
                        </div>
                    }
                </div>

                @*<footer class="panel-footer">
                        <div class="row">
                            <div class="col-sm-4 hidden-xs">
                            </div>
                            <div class="col-sm-4 text-center">
                                <small class="text-muted inline m-t-sm m-b-sm">
                                    @if (Model.lstLayerRightTemplates.Count() > 0)
                                    {
                                        @:Showing @((grid.RowsPerPage) * (grid.PageIndex) + 1) to @((grid.RowsPerPage) * (grid.PageIndex) + grid.Rows.Count) of @Model.objGridAttributes.totalRecord items
                            }
                                </small>
                            </div>
                            <div class="col-sm-4 text-right text-center-xs">
                            </div>
                        </div>
                    </footer>*@
            }
        </div>
    </div>
    <script>
        $(document).ready(function () {
            updateNumberstoFormatedNumber();
            addDefaultSortingIcons("gridTemplateMaster");
        });
        function fnDeleteTemplate(id) {
            confirm("Are you sure you want to delete this record?", function () {
                ajaxReq('Template/deletetemplate', { id: id }, false, function (resp) {
                    if (resp.status == true) {
                        alert(resp.message);
                        location.reload();
                    }
                    else
                        alert(resp.message);
                }, true, true);
            });
        }
        function updateNumberstoFormatedNumber() {
            $('span[data]').each(function (index) {
                // Get the value of the data-target attribute for each element
                var targetValue = $(this).data('data');

                // Do whatever you want with the element or its data
                $(this).text(getFormattedNumber($(this).text().trim()));
            });
        }
    </script>
</div>







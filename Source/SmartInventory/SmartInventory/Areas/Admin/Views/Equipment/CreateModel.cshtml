<!DOCTYPE html>
<div class="row margin-all-0 grid-color-box">
    <div class="col-md-wt equipadd">

        <div class="GridColorBox">
            <h4> Grid Color</h4>
            <label class="GridColor"><input type="radio" name="GridCheckColor" checked value="Green"><span class="Gridcheck Green"></span></label>
            <label class="GridColor"><input type="radio" name="GridCheckColor" value="Createpink"><span class="Gridcheck pink"></span></label>
            <label class="GridColor"><input type="radio" name="GridCheckColor" value="CreateBlue"><span class="Gridcheck Blue"></span></label>
            <label class="GridColor"><input type="radio" name="GridCheckColor" value="CreateOrange"><span class="Gridcheck Orange"></span></label>
            <label class="GridColor"><input type="radio" name="GridCheckColor" value="CreateRed"><span class="Gridcheck Red"></span></label>
            <label class="GridColor"><input type="radio" name="GridCheckColor" value="CreateGray"><span class="Gridcheck Gray"></span></label>
        </div>


        <div class="dimensions_panel dimensionsContext" style="display: none;">
            <h4><span class="modelText" id="modelText">Equipment </span> Dimensions (mm)</h4>
            <div class="row">
                <div class="col-md-4">
                    <label>Length</label>

                    @Html.TextBoxFor(m => m.height, new { @class = "form-control dimension-element", @id = "modelHeight", placeholder = "1M", type = "number", min = "1", @maxlength = "6" })
                </div>

                <div class="col-md-4">
                    <label>Width</label>

                    @Html.TextBoxFor(m => m.width, new { @class = "form-control dimension-element", @id = "modelWidth", placeholder = "1M", type = "number", min = "1", @maxlength = "6" })
                </div>

                <div class="col-md-4" hidden>
                    <label>Depth</label>

                    @Html.TextBoxFor(m => m.depth, new { @class = "form-control dimension-element", @id = "modelDepth", placeholder = "1M", type = "number", min = "1", @maxlength = "6", @readonly = "readonly" })
                </div>
            </div>
            <div class="row border_width">
                <div class="col-md-6">
                    <label>Border Thickness</label>
                </div>
                <div class="col-md-6">
                    @Html.TextBoxFor(m => m.border_width, new { @class = "form-control", @id = "modelBorderWidth", placeholder = "1M", type = "number", min = "1" })
                </div>
            </div>
        </div>

        <div class="dimensions_panel unit_panel" style="display: none;">
            <div class="row">
                <div class="col-md-12">
                    <label>Length in Unit (@ApplicationSettings.RackUnitSize mm)</label>

                    @Html.TextBoxFor(m => m.unit_size, new { @class = "form-control dimension-element col-md-6", @id = "modelUnit", placeholder = "1M", type = "number", min = "1", @maxlength = "6" })
                </div>
            </div>
        </div>
        <div class="BorderColorContext" style="display: none;">
            <div class="row">
                <div class="col-md-12">
                    <label>Border Color</label>

                    @*@Html.TextBoxFor(m => m.border_color, new { @class = "form-control  col-md-6", @id = "borderColor", placeholder = "Border Color"})*@
                    <select class="form-control  col-md-6" id="borderColor" name="border_color">
                        <option value="#6E6E6E" @if (Model.border_color == "#6E6E6E") { <text> selected</text>}>Default</option>
                        <option value="#E1E1E1" @if (Model.border_color == "#6E6E6E") { <text> selected</text>}>White</option>
                        <option value="#4997DF" @if (Model.border_color == "#4997DF")
                        { <text>selected</text>}>Blue</option>
                        <option value="#ECD934" @if (Model.border_color == "#ECD934")
                        { <text>selected</text>}>Yellow</option>
                        <option value="#E2494E" @if (Model.border_color == "#E2494E")
                        { <text>selected</text>}>Red</option>
                        <option value="#34995E" @if (Model.border_color == "#34995E")
                        { <text>selected</text>}>Green</option>
                    </select>
                </div>
            </div>

        </div>


        <div class="LibraryTitle" style="display: none;">

            <h4>Library </h4>
        </div>
        <div class="RadioDivCreate" style="display: none;">
            <div class="LibCalls">
                @*<div class="RadioFunction">
                        <div class="radio">
                            <label class="Custombtn chk">
                                 Equipments
                            <input type="radio" name="LibFilterCheck" value="true">
                            <span class="Custombtncheck bdrRound">
                                </span>

                            </label>
                        </div>



                    </div>*@


            </div>
        </div>

        <div class="SpecifyNo" style="display: none;">
            <h4>Specify No.</h4>
            <div class="row">
                <div class="col-md-4"><img src="~/Areas/Admin/Content/images/col.svg" /><input class="form-control" data-val="true" id="rowCount" name="Length" placeholder="9" type="number" value="" min="1"></div>
                <div class="col-md-4"><img src="~/Areas/Admin/Content/images/row.svg" /><input class="form-control" data-val="true" id="colCount" name="Width" placeholder="9" type="number" value="" min="1"></div>
                <div class="col-md-4"><label>No.</label><input class="form-control disabled" data-val="true" id="totalCount" name="totalCount" placeholder="81" type="text" value="" readonly="readonly"></div>
            </div>

        </div>

        <select class="form-control DivSelect" id="selectLibTypes" name="Div Select" style="display: none;">
            @*<option>Line</option>*@
        </select>



        <div class="svgDiv" style="display: none;">
            <div class="fa fa-search searchIcon searchModel" data-original-title="" title=""></div>
            <input type="text" class="form-control searchBox endtoruds searchModel" placeholder="Search Model" id="SearchModel" autocomplete="off" maxlength="30" data-original-title="" title="">



            <div class="svgscroll">
                <svg id="library" style="width:100%;overflow:hidden;">
                </svg>
                <label style="text-align:center;" id="lblmsg"></label>
            </div>
        </div>



        <div class="not_selected" style="display: none;">

            <h4>Specify Model</h4>Select the model to begin with the workspace.

        </div>
    </div>

    <div class="col-md-ww">


        <div class="table-responsive tble_over_hide header_CreateEquip">
            <div class="row">
                <div class="col-md-3"><span>Model Workspace<br /> <b>Scale : 1M(Grid Module) = @ApplicationSettings.WorkspaceScale mm</b> </span></div>
                <div class="col-md-2">
                    <label>Model</label>
                    <i class="lockModel fa fa-lock lock" aria-hidden="true" style="visibility:hidden"></i>

                    @*@Html.DropDownListFor(m => m.model_id, new SelectList(Model.lstModel.Select(x => new { Value = x.id, Text = x.value }), "Value", "Text"), "Select Model", new { @class = "chosen-select form-control", @id = "selectModel" })*@
                    <select id="selectModel" class="chosen-select form-control">
                        <option>Select Model</option>
                        @foreach (var m in Model.lstModel)
                        {
                            <option value="@m.id" data-has-type="@m.has_type">@m.value</option>
                        }
                    </select>
                    @Html.HiddenFor(m => m.model_id, new { @id = "hdnModelId" })
                    @Html.HiddenFor(m => m.is_editable, new { @id = "isEditable" })
                </div>
                <div class="col-md-2">
                    <label>Type</label>
                    <i class="lockModel fa fa-lock lock" aria-hidden="true" style="visibility:hidden"></i>

                    @Html.DropDownListFor(m => m.model_type_id, new SelectList(Model.lstModelType.Select(x => new { Value = x.id, Text = x.value }), "Value", "Text"), "Select Type", new { @class = "chosen-select form-control", @id = "selectModelType" })
                    @Html.HiddenFor(m => m.model_type_id, new { @id = "hdnModelTypeId" })
                </div>
                <div class="col-md-3 lineHT ">
                    @*<input type="button" id="btnAddModeltype" value="Create New Type" data-toggle="modal" data-target="#model2" class="btn btn-default">*@
                    <input type="button" id="createModel" value="Create" class="btn btn-primary">
                    <input type="button" id="resetWorkspace" value="Reset" class="btn btn-gray" disabled="disabled">

                </div>
                <div class="col-md-2">
                    <input type="button" disabled="disabled" class="btn btn-primary float-right" name="btnaction" id="openSaveModel" value="Save Model" data-toggle="modal" data-target="#modelDetailModal">
                </div>
            </div>

        </div>

        <div id="workAreaContext" class="table-responsive EquipTableCreate" data-color="Green">
            <svg id="workspace" style="width:100%;height:100%;">
                <rect id="resizeBoundry" width="0" height="0" style="fill:transparent;stroke:#787474"></rect>
                <circle id="resizeTopLeft" r="0" style="fill:#fff;stroke:#000;z-index:10"></circle>
                <circle id="resizeBottomRight" r="0" style="fill:#fff;stroke:#000;z-index:10"></circle>
                <svg id="tempModel"></svg>
                <svg id="verticalRuler"></svg>
                <svg id="horizontalRuler"></svg>
                <div id="subMenuContext" class="rightPopup" style="display: none;">
                    <div class="list-group">
                        <a href="#" class="list-group-item" id="copySubMenuContext"><i class="fa fa-copy"></i>  Copy</a>
                        <a href="#" class="list-group-item" id="rotateSubMenuContext"><i class="fa fa-refresh"></i> Rotate 90&#176</a>
                        <a href="#" class="list-group-item" id="renameSubMenuContext"><i class="fa fa-edit"></i> Rename</a>
                        <a href="#" class="list-group-item" id="labelFormatSubMenuContext"><i class="fa fa-edit"></i> Label Format</a>

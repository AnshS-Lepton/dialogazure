            </div>
            <div class="modal-body modelEquipBody">
                @Html.Partial("_ModelDetailSetup")

            </div>
            <div class="modal-footer modelEquipFoot">
                @*<button type="button" class="btn btn-primary rightbtn" data-dismiss="modal">Open Workspace</button>*@
                <button type="button" class="btn btn-primary" id="saveModel">Save</button>

                <button type="button" class="btn btn-gray" data-dismiss="modal">Cancel</button>

            </div>
        </div>

    </div>
</div>


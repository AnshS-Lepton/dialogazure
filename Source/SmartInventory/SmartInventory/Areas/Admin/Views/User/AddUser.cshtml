@using Models;
@model Models.User
@using SmartInventory.Settings;
@Html.HiddenFor(m => m.pageMsg.status, new { id = "submit_status" })

@{var objUser = (User)Session["userDetail"];
    bool ispanprmvendorvisible = true;
    }

<style>

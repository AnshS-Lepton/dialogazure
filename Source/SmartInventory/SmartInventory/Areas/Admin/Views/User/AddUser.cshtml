<!DOCTYPE html>
<div id="dvPageMessage" style="@(Model.IsSubmit == true ? "display:none;" : "display: block;")">
    @{Html.RenderPartial("_PageMessage", Model.pageMsg);}
    @{
        var prms_id = Model.formInputSettings.Count > 0 ? Model.formInputSettings.Where(m => m.form_feature_name.ToLower() == formFeatureName.prms_id.ToString() && m.form_feature_type.ToLower() == formFeatureType.field.ToString() && m.is_active == true).FirstOrDefault() : null;
     }
</div>
<div class="title">
    <h4>
        <span class="icon16 icomoon-icon-bars"></span><span>@(Model.user_id > 0 ? "Update User" : "Add User")</span>
    </h4>
</div>

<div class="clsUserContainer">
    <div id="dvUserDetail">

        @using (Html.BeginForm("SaveUser", "User", FormMethod.Post, new { autocomplete = "off", @id = "frmUserInfo", enctype = "multipart/form-data", @class = "form-horizontal" }))
        {
            @Html.HiddenFor(m => m.user_id)
            @Html.ValidationSummary(true)

            if (Model.IsUserinLimit)
            {
                <div class="bs-stepper">
                    <div class="bs-stepper-header" role="tablist" style="height: 35px;">
                        <!-- your steps here -->
                        <div class="step" data-target="#userdetails">
                            <button type="button" class="step-trigger" role="tab">
                                <img src="@Url.Content("~/Areas/Admin/Content/images/check_new.png")" id="chkImg_userdetails" class="checkStep" />
                                <span class="bs-stepper-circle userdetails_circle">1</span>
                                <span class="bs-stepper-label">User Details</span>
                            </button>
                        </div>
                        <div class="line"></div>
                        <div class="step" data-target="#modulerights-part">
                            <button type="button" class="step-trigger" role="tab">
                                <img src="@Url.Content("~/Areas/Admin/Content/images/check_new.png")" id="chkImg_modulerights" class="checkStep" />
                                <span class="bs-stepper-circle modulerights_circle">2</span>
                                <span class="bs-stepper-label">Module Rights</span>
                            </button>
                        </div>
                        <div class="line"></div>
                        <div class="step" data-target="#workarea-part">
                            <button type="button" class="step-trigger" role="tab">
                                <img src="@Url.Content("~/Areas/Admin/Content/images/check_new.png")" id="chkImg_workarea" class="checkStep" />
                                <span class="bs-stepper-circle workarea_circle">3</span>
                                <span class="bs-stepper-label">Work Area Details</span>
                            </button>
                        </div>
                    </div>
                    <div class="update_panel clsStepsContainer fullWidth">
                        <!-- your steps content here -->
                        <div id="userdetails" class="content">
                            <div id="UserDetails_data" style="@(Model.IsSubmit == true ? "display:none;" : "display: block;")">
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                User Name<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.user_name, new { @class = "form-control", @maxlength = "50", @placeholder = "Enter User Name", @onkeypress = "return validateSpecialChars(event,'_.-');" })
                                            <img style="width:21px;" class="GifImg" id="ImgUsername" />
                                            @* @Html.ValidationMessageFor(model => model.user_name)*@
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Full Name<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.name, new { @class = "form-control", autocomplete = "do-not-show-ac", @maxlength = "50", @placeholder = "Enter Full Name", @id = "txtfullname" })
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Email Id<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.user_email, new {@class = "form-control", autocomplete = "do-not-show-ac", @maxlength = "50", @placeholder = "Enter Email Id" })
                                            @*@Html.ValidationMessageFor(model => model.user_email)*@
                                            <img style="width:21px;" class="GifImg" id="ImgUserEmail" />
                                        </div>
                                    </div>
                                </div>
                                @if (string.IsNullOrEmpty(ApplicationSettings.ADFSEndPoint))
                                {
                                    <div class="form-group">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label class="control-label">
                                                    Password<i class="clsMandatory">*</i>:
                                                </label>
                                            </div>
                                            <div class="col-md-7">
                                                <div class="password">
                                                    @*@Html.ValidationMessageFor(model => model.password)*@
                                                    @Html.TextBoxFor(model => model.password, new { @class = "form-control", @minlength = "8", @maxlength = "20", @placeholder = "Enter Password", @title = "1 lower and 1 upper case letter. 1 number and 1 special character. Minimum 8 character long!" })
                                                    <img style="width:21px;" class="GifImg" id="ImgPwd" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Mobile Number<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.mobile_number, new {@class = "form-control", autocomplete = "do-not-show-ac",  @onkeypress = "return allowOnlyNumber(event);",  @placeholder = "Enter Mobile Number", @minlength = "9", @maxlength = "15", @title = "Mobile Number should be Minimum 9 & Miximum 15 character long!" })
                                            @* @Html.ValidationMessageFor(model => model.password)*@
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                User Role<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.DropDownListFor(m => m.role_id, new SelectList(Model.lstRole.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "ddl_UserRole", @onchange = "onChangeUserRole();updateModuleList();", @required = true })
                                            @Html.HiddenFor(m => m.role_id)
                                            <button class="btn btn-primary ViewRolebtn" type="button" onclick="return ViewRolePermissionPopup(this);">View</button>
                                        </div>
                                    </div>
                                </div>
                                <div id="divReportingManager" class="form-group">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Reporting Manager<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @if (Model.is_multi_manager_allowed)
                                            {
                                                @Html.DropDownListFor(m => m.manager_id, new SelectList(Model.lstRM.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), new { @class = "chosen-select col-sm-12", @multiple = "multiple", @id = "ddl_UserReportingManager", @onchange = "onChangeRMId();", @required = true })
                                                @*@Html.ValidationMessageFor(m => m.manager_id)*@
                                            }
                                            else
                                            {
                                                @Html.DropDownListFor(m => m.manager_id, new SelectList(Model.lstRM.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), new { @class = "chosen-select col-sm-12", @id = "ddl_UserReportingManager", @onchange = "onChangeRMId();", @required = true })
                                            }
                                            @Html.HiddenFor(m => m.multi_manager_ids)
                                            @Html.HiddenFor(m => m.is_multi_manager_allowed)
                                        </div>
                                    </div>
                                </div>
                                <div id="divApplicationAccess" class="form-group">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Application Access<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">

                                            @Html.DropDownListFor(m => m.application_access, new List<SelectListItem>
                 {
new SelectListItem{ Text="-Select-", Value = "" },
                    new SelectListItem{ Text="Web", Value = "WEB" },
                    new SelectListItem{ Text="Mobile", Value = "MOBILE" },
                    new SelectListItem{ Text="Both", Value = "BOTH" }
                 }, new { @id = "ddlApplication", @tabindex = "2", @title = "Application Access", @class = "chosen-select form-control", @onchange = "onChangeApllicationAccess()" })



                                        </div>
                                    </div>
                                </div>
                                <div id="divcompanyname" class="form-group" style="display:none;">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Company Name:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.company_name, new { @class = "form-control", @maxlength = "100", @placeholder = "Enter Company Name" })
                                        </div>
                                    </div>
                                </div>

                                <div id="divwarehousecode" class="form-group" style="display:none">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Warehouse Code:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @*@Html.TextBoxFor(model => model.warehouse_code, new { @class = "form-control", @maxlength = "100", @placeholder = "Enter Warehouse Code" })*@
                                            @Html.DropDownListFor(m => m.warehouse_code, new SelectList(Model.lstWarehouseCode.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", multiple = "multiple", @id = "ddl_WarehouseCode", @onchange = "onChangeWarehouseCode()" })
                                            @Html.HiddenFor(m => m.multi_warhouse_code)
                                        </div>
                                    </div>
                                </div>
                                <div id="divcapacity" class="form-group" style="display:none;">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Capacity:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.capacity, new { @class = "form-control", @maxlength = "10", @onkeypress = "return allowOnlyNumber(event);", @placeholder = "Enter Capacity" })
                                        </div>
                                    </div>
                                </div>

                                <div id="divusertype" class="form-group">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                User Type<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">

                                            @*@Html.DropDownListFor(m => m.user_type, new List<SelectListItem>
                                            {
                                                new SelectListItem{ Text="-Select-", Value = "" },
                                               new SelectListItem{ Text="Jio", Value = "own",Selected = true },
                                               new SelectListItem{ Text="Partner", Value = "partner" },
                                              }, new { @id = "ddluser_type", @tabindex = "2", @title = "User Type", @class = "chosen-select form-control" })*@
                                            @Html.DropDownListFor(m => m.user_type, new SelectList(Model.lstUserType.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "ddluser_type" })

                                        </div>
                                    </div>
                                </div>

                                <div id="divpan" class="form-group" style="@(ispanprmvendorvisible? Html.Raw("display:block") : Html.Raw("display:none"))">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                PAN:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.pan, new { @class = "form-control uppercase", @maxlength = "10", @minlength = "10", @placeholder = "Enter PAN" })
                                        </div>
                                    </div>
                                </div>
                                <div id="divprmsid" class="form-group" style="@(ispanprmvendorvisible? Html.Raw("display:block") : Html.Raw("display:none"))">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                PRMS Id:
                                            </label>
                                        </div>
                                        @*<div class="col-md-7">
                                            @Html.TextBoxFor(model => model.prms_id, new { @class = "form-control ", style = "background-color:#e9ecef;", @readonly = "readonly" })
                                        </div>*@
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.prms_id,
                                            SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(new
                                            {
                                                @class = "form-control",
                                                @placeholder = "Enter PRMS ID",
                                            }, (prms_id != null) ? (prms_id.is_readonly == true) ? new { @readonly = "readonly" } : null : null))
                                        </div>
                                    </div>
                                </div>
                                <div id="divvendorid" class="form-group" style="@(ispanprmvendorvisible? Html.Raw("display:block") : Html.Raw("display:none"))">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Vendor Id:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.TextBoxFor(model => model.vendor_id, new { @class = "form-control", disabled = "disabled", @readonly = "readonly" })
                                        </div>
                                    </div>
                                </div>
                                    <div class="form-group" style="margin-bottom:0px;">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label class="control-label">
                                                    Is Admin Rights Allowed?
                                                </label>
                                            </div>
                                            <div class="col-md-7">
                                                @Html.CheckBoxFor(m => m.is_admin_rights_enabled, new { @class = "chk", id = "isadminrghts", @onclick = "isAdminChecked()" })
                                            </div>
                                        </div>
                                    </div>
                                <div class="form-group" style="margin-bottom:0px;">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                Is Active?
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.CheckBoxFor(m => m.is_active, new { @class = "chk" })
                                            <button class="btn btn-primary Nextbtn">Next ></button>
                                        </div>
                                    </div>
                                </div>
                                <div style="display:none">
                                    <div class="row">
                                        <div class="col-md-4 form-group">
                                            @Html.TextBoxFor(m => m.created_by, new { @class = "form-control", placeholder = "Created By" })
                                        </div>
                                    </div>
                                </div>
                                @if (string.IsNullOrEmpty(ApplicationSettings.ADFSEndPoint))
                                {
                                    <div class="row">
                                        <div class="col-md-11">
                                            <p style="background-color:#cce6ff;color:#0044cc;padding:4px;white-space: initial;font-size: 12px;">
                                                <b style="color:#0044cc;">Password Rules:</b>
                                                1 lower and 1 upper case letter.1 number and 1 special character (@@,#,$,%,&). Minimum length 8 characters.
                                            </p>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div id="SubmitDiv" style="margin-top: 150px;min-height: 300px;width:100%;top:40%;text-align:center;position:relative;@(Model.IsSubmit == true ? "display: block;" : "display:none;")">
                                <img src="@Url.Content("~/Areas/Admin/Content/images/check.png")" id="chkImg_workarea" style="height:32px;width:32px;margin:auto;@ViewBag.showSubmitDiv" />
                                <div id="Success-Msg" style="color:green"><b>Success</b></div>
                                <div id="Success-Msg"><b>@Model.pageMsg.message</b></div>
                            </div>
                        </div>
                        <div id="modulerights-part" class="content">
                            <div id="module-data" style="@(Model.IsSubmit == true ? "display:none;" : "display: block;")">
                                <div class="all-section">
                                    <label>
                                        <input type="checkbox" name="AllLayers" id="CheckAll_Module" class="allModule" onclick="CheckByClass('allModule',this)" /><b>Select All</b>
                                    </label>
                                    @*<div class="col-md-4"><span class="btn btn-primary collapseAll">Collapse All</span></div>
                                    <div class="col-md-4"><span class="btn btn-primary expandAll">Expand All</span></div>*@
                                </div>
                                <div>
                                    <div id="partionTable">
                                        @Html.Partial("_ModuleList", Model.lstUserModule)
                                    </div>
                                </div>
                                <div id="ServiceFacilityJobOrder">
                                    @*@Html.Partial("_ServiceFacilityJobOrderList", Model.lstViewServiceFacilityJobOrder)*@
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <label style="color:red; display:none;" id="errModule"><b>* Aleast one module right should be given!</b></label>
                                    </div>
                                </div>
                                <div class="form-group" id="dvBtnAction">
                                    <div class="row">
                                        <div class="col-md-4"> </div>
                                        <div class="col-md-7">
                                            <button class="btn btn-primary Previousbtn">Previous</button>
                                            <button class="btn btn-primary Nextbtn" style="float:none">Next ></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="workarea-part" class="content">
                            <div id="workarea-data" style="@(Model.IsSubmit == true ? "display:none;" : "display: block;")">

                                <div id="divregion" class="form-group" style="min-height: 250px;">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                @Resources.Resources.SI_ADM_GBL_NET_FRM_001<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.DropDownList("ddlCountry", new SelectList(Model.lstCountry.Select(x => new { Value = x.Value.ToString(), Text = x.Text }), "Value", "Text"), new { @class = "chosen-select form-control", multiple = "multiple", @id = "ddlCountry" })
                                            @Html.HiddenFor(m => m.selectedCountry)
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                @Resources.Resources.SI_ADM_GBL_NET_FRM_002<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @*@Html.DropDownList("ddlregion", new SelectList(Model.lstRegion.Select(x => new { Value = x.Value.ToString(), Text = x.Text }), "Value", "Text"), new { @class = "chosen-select form-control", multiple = "multiple", @id = "ddlregion" })*@
                                            @Html.DropDownList("ddlregion", new SelectList(string.Empty, "Value", "Text"), new { @class = "chosen-select form-control", multiple = "multiple", @id = "ddlregion" })
                                            @Html.HiddenFor(m => m.selectedRegion)
                                        </div>
                                    </div>
                                    <div class="row" style="height:10px;"></div>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <label class="control-label">
                                                @Resources.Resources.SI_ADM_GBL_NET_FRM_003<i class="clsMandatory">*</i>:
                                            </label>
                                        </div>
                                        <div class="col-md-7">
                                            @Html.DropDownList("ddlState", new SelectList(string.Empty, "Value", "Text"), new { @class = "chosen-select form-control", multiple = "multiple", @id = "ddlState" })
                                            @Html.HiddenFor(m => m.selectedProvinces)
                                        </div>
                                    </div>
                                    <div class="row" style="height:10px;"></div>
                                    @if (Convert.ToBoolean(System.Configuration.ConfigurationManager.AppSettings["isWFMUser"]) == true)
                                    {
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label class="control-label">
                                                    @Resources.Resources.SI_ADM_GBL_NET_FRM_004<i class="clsMandatory">*</i>:
                                                </label>

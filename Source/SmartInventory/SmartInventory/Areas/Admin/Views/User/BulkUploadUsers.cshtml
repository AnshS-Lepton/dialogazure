                @*grid.Column("status", "Status", format: @<text>@item.status</text>, canSort: false),*@
grid.Column("total_record", "Total", format: @<text>@item.total_record</text>, canSort: false),
grid.Column("success_record", "Success", format: @<text>@item.success_record</text>, canSort: false),
grid.Column("failed_record", "Failed", format: @<text>@item.failed_record</text>, canSort: false),
grid.Column("status_message", "Status Message", format: @<text>@item.status_message</text>, canSort: false),
grid.Column("err_description", "Error Description", format: @<text>@item.err_description</text>, canSort: false),
grid.Column("created_date", "Upload On", format: @<text>@(item.created_date == null ? item.created_date : MiscHelper.FormatDateTime(item.created_date.ToString()))</text>, canSort: false),

                    {
                        <input type="button" class="btn btn-danger CustomError" onclick="fnDownloadBulkUserUploadLogs('@item.id', 'FAILED');" title="@Resources.Resources.SI_OSP_DU_NET_FRM_001" value="@Resources.Resources.SI_GBL_GBL_NET_FRM_081" />
                    }
                    else
                    {
                        <input type="button" class="btn btn-danger CustomErrorDisabled" title="@Resources.Resources.SI_OSP_DU_NET_FRM_001" value="@Resources.Resources.SI_GBL_GBL_NET_FRM_081" />

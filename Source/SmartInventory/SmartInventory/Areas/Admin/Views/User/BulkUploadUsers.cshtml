    function UploadFile(controlId, postUrl) {
        // 
        $("#dvProgress").show();
        var formData = new FormData();
        var userid=  $('#loginId_UserId').val();
        //formData.append("usrid", "1");
        formData.append("usrid", userid);
        var totalFiles = document.getElementById(controlId).files.length;
        if (totalFiles > 0) {
            if (isValidFileExtn(controlId)) {
                // 
                var filecontrol = $('#' + controlId);
                var file = filecontrol.get(0);
                file = file.files;
                for (var i = 0; i < file.length; i++) {
                    //formData.append(file[i].name, file[i]);
                    formData.append(filecontrol.prop("name"), file[i]);
                }
            }
            else {
                $("#dvProgress").hide();
                alert("Please select file having extensions.xls or.xlsx only!");
                return false;
            }
        }
        else {
            $("#dvProgress").hide();
            alert("Please select a file!");
            return false;
        }
        PostFile(formData, postUrl);
    }
    function PostFile(formdata, posturl) {
        // 
        var access_token = $('#access_token').val();
        $.ajax({
            type: "POST",
            url: posturl,
            data: formdata,
            async: true,
            contentType: false,
            processData: false,
            async: true,
            headers: { Authorization: 'Bearer ' + access_token},
            //beforeSend: function () {},
            success: function (response) {
                // 
                $("#dvProgress").hide();
                if (response.error_message.toLowerCase() == "success" && response.status.toLowerCase() == "ok") {
                    $("#dvProgress").hide();
                    //refresh the page so that log will reflect in grid view
                    window.location = window.location;
                } else {
                    alert(response.status + " : " + response.error_message);
                }
            },
            error: function (error) {
                $("#dvProgress").hide();
                alert(error);
            }
        });
    }

    function isValidFileExtn(controlid) {
        var ext = $('#' + controlid).val().split('.').pop().toLowerCase();
        if ($.inArray(ext, ['xls', 'xlsx']) == -1) {
            return false;
        }
        return true;
    }
</script>

                    <div class="col-md-2 form-inline">
                        <input type="file" name="postedFile" id="postedFile" accept=".xls,.xlsx">
                        <input type="button" id="clearExcelFile" class="cancel" value="X" style="display: none;">
                    </div>
                    <div class="col-md-9">
                        <input type="submit" id="upload" value="Upload" class="btn btn-success" />

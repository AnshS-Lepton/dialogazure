    }

    .CustomSuccessDisabled {
        color: gray;
        background-color: white;
        border-radius: 4px 0px 0px 4px;
        border-color: #949292;
        outline: none;
        padding: 2px 8px;
        border-right-width: 0px;
        font-size: 12px;
        cursor: not-allowed !important;
    }


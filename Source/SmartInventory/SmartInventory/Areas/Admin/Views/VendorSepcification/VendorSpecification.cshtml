@model Models.Admin.VendorSpecificationMaster
@using Models;
@using SmartInventory.Settings;
@{
    int rackLayer = 46;
}
<!DOCTYPE html>
<div id="dvPageMessage">
    @{
        Html.RenderPartial("_PageMessage", Model.pageMsg);
    }
    @{
        var cost_per_unit = Model.formInputSettings.Count > 0 ? Model.formInputSettings.Where(m => m.form_feature_name.ToLower() == formFeatureName.cost_per_unit.ToString() && m.form_feature_type.ToLower() == formFeatureType.field.ToString() && m.is_active == true).FirstOrDefault() : null;
        var service_cost_per_unit = Model.formInputSettings.Count > 0 ? Model.formInputSettings.Where(m => m.form_feature_name.ToLower() == formFeatureName.service_cost_per_unit.ToString() && m.form_feature_type.ToLower() == formFeatureType.field.ToString() && m.is_active == true).FirstOrDefault() : null;
    }
</div>
<div id="dvInfoVendorSpecification" class="update_panel">
    <div class="title">
        <h4 id="heading">Add Vendor Specification</h4>
    </div>
    @using (Html.BeginForm("SaveVendorSpecification", "VendorSepcification", FormMethod.Post, new { autocomplete = "off", @id = "frmInfoVendorspecification", enctype = "multipart/form-data", @class = "form-horizontal  pad_left" }))
    {
        @Html.HiddenFor(m => m.unit_input_type);
        @Html.HiddenFor(m => m.id);
        @Html.HiddenFor(m => m.created_by);
        @Html.HiddenFor(m => m.created_on);
        @Html.HiddenFor(m => m.layer_name);
        @Html.HiddenFor(m => m.accessories_id);
        @Html.HiddenFor(m => m.layer_id);
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Category<i class="clsMandatory">*</i>:
                    </label>
                </div>
                <div class="col-md-8">
                    @if (Model.id > 0)  // to disable the control and put an overlay not to open choosen dropdown
                    {
                        <div class="col-sm-8" style="position: absolute;height: 28px; z-index: 1000; width: 92%;"></div>
                    }
                    <select name="@Html.NameFor(x=> x.layer_id )"
                            id="selectCategory"
                            class="chosen-select form-control"
                            onchange="OnCategoryChange();">
                        <option value="0-0">-Select-</option>
                        <optgroup value="" label="Entity">
                            @foreach (var category in Model.entity_categories)
                            {
                                <option value="@category.category_key"
                                        @if (category.category_key == Model.category_key) { <text> selected </text> }
                                        data-layer-id="@category.layer_id"
                                        data-accessories-id="@category.accessories_id">
                                    @category.display_name
                                </option>
                            }
                        </optgroup>
                        <optgroup value="" label="Other">
                            @foreach (var category in Model.other_categories)
                            {
                                <option value="@category.category_key"
                                        @if (category.category_key == Model.category_key) { <text> selected </text> }
                                        data-layer-id="@category.layer_id"
                                        data-accessories-id="@category.accessories_id">
                                    @category.display_name
                                </option>
                            }
                        </optgroup>
                    </select>
                </div>
            </div>
        </div>
        if (Model.is_specification_allowed == "True")
        {
            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            @(Model.layer_name + " Type")
                            <i class="clsMandatory">*</i> :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.DropDownListFor(m => m.specify_type, new SelectList(Model.lstSpecifyType.Select(x => new { Value = x.key, Text = x.value }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @onchange = "return validateDropdown(this.id);" })
                    </div>
                </div>
            </div>
        }
        if (!string.IsNullOrWhiteSpace(Model.layer_name) && Model.layer_name.ToUpper() == "MICRODUCT")
        {
            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            Number Of Ways<i class="clsMandatory">*</i> :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.DropDownListFor(m => m.specify_type, new SelectList(Model.lstNoOfWays.Select(x => new { Value = x.dropdown_key, Text = x.dropdown_value }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "NoOfWays", @onchange = "return validateDropdown(this.id);" })
                    </div>
                </div>
            </div>
        }
        if (!string.IsNullOrWhiteSpace(Model.layer_name) && Model.layer_name.ToUpper() == "SPLITTER")
        {
            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            Splitter Type<i class="clsMandatory">*</i> :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.DropDownListFor(m => m.specify_type, new SelectList(Model.lstSplitterType.Select(x => new { Value = x.dropdown_key, Text = x.dropdown_value }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "ddlSplliterType", @onchange = "updatePortRatio(this.id);" })
                    </div>
                </div>
            </div>
        }
        @*if (!string.IsNullOrWhiteSpace(Model.layer_name) && Model.layer_name.ToUpper() == "CABLE")
        {
            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            Cable Category<i class="clsMandatory">*</i> :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.DropDownListFor(m => m.specify_type, new SelectList(Model.lstCableCategory.Select(x => new { Value = x.dropdown_key, Text = x.dropdown_value }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "ddlCableCategory", @onchange = "updatePortRatio(this.id);" })
                    </div>
                </div>
            </div>
        }*@
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Specification<i class="clsMandatory">*</i>:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.specification, new { @class = "form-control", @maxlength = "100", @placeholder = "Enter Specification", @id = "specification" })
                </div>
            </div>
        </div>


        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Vendor<i class="clsMandatory">*</i>:
                    </label>
                </div>
                <div class="col-md-8">
                    @if (Model.id > 0)  // to disable the control and put an overlay not to open choosen dropdown
                    {
                        <div class="col-sm-8" style="position: absolute;height: 28px; z-index: 1000; width: 92%;"></div>
                    }
                    @Html.DropDownListFor(m => m.vendor_id, new SelectList(Model.lstAllVendor.Select(x => new { Value = x.key, Text = x.value }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @onchange = "return validateDropdown(this.id);" })


                </div>
            </div>
        </div>
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Item Code<i class="clsMandatory">*</i>:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.code, new { @class = "form-control", @maxlength = "50", @placeholder = "Enter Item Code", @onkeypress = "return fn_restrictdecimal(event,this);" })
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Item Type<i class="clsMandatory">*</i>:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.DropDownListFor(m => m.item_type, new SelectList(Model.listItemType.Select(x => new { Value = x.value, Text = x.key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "txtitemtype" })

                </div>
            </div>
        </div>
        //if (Model.item_type == "WCR")
        //{
        <div class="form-group" id="textcheckbox" style="display:none">
            <div class="row">
                <div class="col-md-4">
                </div>
                <div class="col-md-8">
                    <span><label for="txtisBRFS" style="margin-right:6px; margin-bottom:0;"> @Html.CheckBoxFor(m => m.is_brfs)</label></span>
                    <span>B-RFS Item</span>

                    <span style="margin-left:40px"><label style="margin-right:6px; margin-bottom:0;" for="txtisARFS">@Html.CheckBoxFor(m => m.is_arfs)</label></span>
                    <span>A-RFS Item</span>


                    <span style="margin-left:22px"><label style="margin-right:6px; margin-bottom:0;" for="txtisCRFS">@Html.CheckBoxFor(m => m.is_crfs)</label></span>
                    <span>C-RFS Item</span>
                </div>
            </div>
        </div>
        // }
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Unit Measurement<i class="clsMandatory">*</i>:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.DropDownListFor(m => m.unit_measurement, new SelectList(Model.listUnitMeasurement.Select(x => new { Value = x.value, Text = x.key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "txtunit_measurement" })

                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Cost Per Unit/meter(@ApplicationSettings.Currency)<i class="clsMandatory">*</i>:
                    </label>
                </div>
                @*<div class="col-md-8">
                        @Html.TextBoxFor(model => model.cost_per_unit, new { @class = "form-control", @id = "txtcost", @placeholder = "Enter Cost", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);" })
                    </div>*@
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.cost_per_unit,
                    SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(new
                    {
                        @class = "form-control",
                        @id = "txtcost",
                        @placeholder = "Enter Cost",
                        @onkeydown = "return ValidateNumberDecimal(this,event,8,2);"
                    }, (cost_per_unit != null) ? (cost_per_unit.is_readonly == true) ? new { @readonly = "readonly" } : null : null))
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Service Cost Per Unit/meter(@ApplicationSettings.Currency)<i class="clsMandatory">*</i>:
                    </label>
                </div>
                @*<div class="col-md-8">
                        @Html.TextBoxFor(model => model.service_cost_per_unit, new { @class = "form-control", @placeholder = "Enter Service Cost", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);" })
                    </div>*@
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.service_cost_per_unit,
                    SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(new
                    {
                        @class = "form-control",
                        @placeholder = "Enter Service Cost",
                        @onkeydown = "return ValidateNumberDecimal(this,event,8,2);"
                    }, (service_cost_per_unit != null) ? (service_cost_per_unit.is_readonly == true) ? new { @readonly = "readonly" } : null : null))
                </div>
            </div>
        </div>
        if (Model.layer_id > 0 && !string.IsNullOrWhiteSpace(Model.unit_input_type))
        {
            if (Model.unit_input_type.ToLower() == "port")
            {
                <div class="form-group">
                    <div class="row">
                        <div class="col-md-4">
                            <label class="control-label">
                                Total Ports<i class="clsMandatory">*</i>:
                            </label>
                        </div>
                        <div class="col-md-8">
                            @Html.TextBoxFor(model => model.no_of_port, new { @class = "form-control", @maxLength = "4", @onkeypress = "return isNumber(event)", @onkeyup = "return validateTextbox(this.id);" })
                        </div>
                    </div>
                </div>

            }
            else if (Model.unit_input_type.ToLower() == "iopddl")
            {
                <div class="form-group">
                    <div class="row">
                        <div class="col-md-4">
                            <label class="control-label" id="lbl_IOP">
                                @(Model.layer_name == EntityType.Cable.ToString() ? "Fiber Count" : "Port Ratio") <i class="clsMandatory">*</i>:
                            </label>
                        </div>
                        <div class="col-md-8">
                            @Html.DropDownListFor(m => m.iop_value, new SelectList(Model.lstIOPDetails.Select(x => new { Value = x.dropdown_key.ToString(), Text = x.dropdown_key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "ddlPortRatio", @onchange = "return validateDropdown(this.id);" })
                        </div>
                    </div>
                </div>
                if (Model.layer_name == EntityType.Cable.ToString())
                {
                    <div class="form-group">
                        <div class="row">
                            <div class="col-md-4">
                                <label class="control-label">
                                    No Of Tube<i class="clsMandatory">*</i>:
                                </label>
                            </div>
                            <div class="col-md-8" id="no_of_tube">
                                @Html.TextBoxFor(model => model.no_of_tube, new { @class = "form-control", @id = "no_of_tube_val", @maxlength = "4", @placeholder = "Enter No of tube", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);" })
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="row">
                            <div class="col-md-4">
                                <label class="control-label">
                                    No Of Core Per Tube<i class="clsMandatory">*</i>:
                                </label>
                            </div>
                            <div class="col-md-8" id="no_of_core_per_tube">
                                @Html.TextBoxFor(model => model.no_of_core_per_tube, new { @class = "form-control", @maxlength = "4", @id = "no_of_core_per_tube_val", @placeholder = "Enter No of core per tube", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);" })
                            </div>
                        </div>
                    </div>
                }
            }
        }

        if (Model.layer_id == rackLayer)
        {<div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            Length (in meter)
                            <i class="clsMandatory">*</i> :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.TextBoxFor(model => model.length, new { @class = "form-control", @placeholder = "Enter Length", @onkeyup = "return isDecimalDigit(this);" })
                    </div>
                </div>
            </div>

            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            Width (in meter) <i class="clsMandatory">*</i> :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.TextBoxFor(model => model.width, new { @class = "form-control", @placeholder = "Max to 2 Mtr", @onkeyup = "return isDecimalLimit(this);" })
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            No. of Units(1 unit = @ApplicationSettings.RackUnitSize mm)<i class="clsMandatory">*</i>:
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.TextBoxFor(model => model.no_of_units, new { @class = "form-control", @placeholder = "Enter Number of Units", @maxLength = "3", @onkeyup = "return isNumber(event);", @onchange = "onChangeUnits()" })
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            Height (in meter) <i class="clsMandatory">*</i> :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.TextBoxFor(model => model.height, new { @class = "form-control", @placeholder = "Enter Number of Units for Height", @onkeyup = "return isDecimalDigit(this);", @readonly = "true" })
                    </div>
                </div>
            </div>

            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            Border Width (in mm) :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.TextBoxFor(model => model.border_width, new { @class = "form-control", @placeholder = "Enter Border Width", @onkeyup = "return isDecimalDigit(this);" })
                    </div>
                </div>
            </div>

            <div class="form-group">
                <div class="row">
                    <div class="col-md-4">
                        <label class="control-label">
                            Border Color :
                        </label>
                    </div>
                    <div class="col-md-8">
                        @Html.TextBoxFor(model => model.border_color, new { @class = "form-control", @placeholder = "Enter Border Color" })
                    </div>
                </div>
            </div>

        }
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Sub Category 1:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.subcategory_1, new { @class = "form-control", @maxlength = "100", @placeholder = "Enter Sub Category 1" })
                </div>
            </div>
        </div>
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Sub Category 2:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.subcategory_2, new { @class = "form-control", @maxlength = "100", @placeholder = "Enter Sub Category 2" })
                </div>
            </div>
        </div>
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Sub Category 3:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.subcategory_3, new { @class = "form-control", @maxlength = "100", @placeholder = "Enter Sub Category 3" })
                </div>
            </div>
        </div>


        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Is Master?
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.CheckBoxFor(m => m.is_master, new { @class = "chk", @id = "IsMaster", @onchange = "fnChkIsEnabled(this)" })
                </div>
            </div>
        </div>


        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">Item Master Code:</label>
                </div>
                <div class="col-md-8">
                    @Html.DropDownListFor(m => m.item_master_code, new SelectList(Model.listItemMasterCode.Select(x => new { Value = x.value, Text = x.key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "txt_item_master_code" })

                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Extra Percentage<i class="clsMandatory">*</i>:
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.TextBoxFor(model => model.extra_percentage, new { @class = "form-control", @id = "txtextra_length", @placeholder = "Enter Extra length", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);" })
                </div>
            </div>
        </div>
        <div class="form-group">
            <div class="row">
                <div class="col-md-4">
                    <label class="control-label">
                        Is Active?
                    </label>
                </div>
                <div class="col-md-8">
                    @Html.CheckBoxFor(m => m.is_active, new { @class = "chk" })
                </div>
            </div>
        </div>
        <div id="dvBtnAction">
            <div class="row">
                <div class="col-md-4"> </div>
                <div class="col-md-8 text-right">
                    <a href="@Url.Action("AddVendorSpecification",new { id=0})" class="btn btn-default mr-05" title="Reset">Reset</a>
                    <input type="submit" class="btn btn-primary" name="btnaction" id="btnSubmit" value="Save" />@*onclick="return app.checkCblTotalCore()"*@

                </div>
            </div>
        </div>
    }
    <script type="text/javascript">
    $(document).ready(function () {
         
            if (@Model.id > 0) {
                $('#no_of_tube_val').attr('readonly', 'True');
                $('#no_of_core_per_tube_val').attr('readonly', 'True');
                $('#heading').text("Update Vendor Specification");
            }
            //else {
            //    $('#no_of_tube_val').next().addClass('divDisabled').trigger("chosen:updated");
            //    $('#no_of_core_per_tube_val').next().addClass('divDisabled').trigger("chosen:updated");
            //}
            var e = document.getElementById('txtitemtype');
            var item_type_value = e.options[e.selectedIndex].value;

            if (item_type_value == "WCR") {
                document.getElementById('textcheckbox').style.display = "block";
            }
            //callFormValidator("frmInfoVendorspecification");
            //$('#selectCategory').val(@Model.layer_id);
            console.log('@Model.category_key');
            $('.chosen-select').chosen({ width: '100%' });
            //$('select').show();

            if ('@Model.id' != 0) {
                btnSubmit.value = "Update";
                $('#layer_id').next().addClass('chosen-disabled');
                $('#vendor_id').next().addClass('chosen-disabled');
                $('#specification').attr('readonly', 'True');
                $('#code').attr('readonly', 'True');
            }

        $("#btnSubmit").on("click", function (e) {
                var status = true;
                if (!validateDropdown('selectCategory')) { status = false; }
                if (!validateDropdown('vendor_id')) { status = false; }
                if (!validateDropdown('iop_value')) { status = false; }


                if (!validateTextbox('no_of_port')) { status = false; }
                if (!validateDropdown('txtunit_measurement')) { status = false; }
                if (!validateDropdown('txtitemtype')) { status = false; }
                if (!validateDropdown('NoOfWays')) { status = false; }

                if (!validateDropdown('txtitem_master_code')) { status = false; }
            if (!validateDropdown('ddlCableCategory')) { status = false; }
            if (!validateDropdown('ddlPortRatio')) { status = false; }
                if (!status) { e.preventDefault(); }
            });

            $('#txt_item_master_code').next().addClass('divDisabled').trigger("chosen:updated");
            var ValidateId = @Model.id > 0 ? true : false;
            var ChkIsMaster = $('#IsMaster').is(":checked");
            if (ValidateId == true && ChkIsMaster == true) {
                $('#IsMaster').addClass("divDisabled");
            }
        });

        $('#txtitemtype').on('change', function (event) {
             
            var e = document.getElementById('txtitemtype');
            var item_type_value = e.options[e.selectedIndex].value;

            if (item_type_value == "WCR") {
                document.getElementById('textcheckbox').style.display = "block";
            }
            else {
                document.getElementById('textcheckbox').style.display = "none";
            }

        });



        function validateDropdown(elementId) {

            if ($('#selectCategory option:selected').text().indexOf('Patch Cord') > -1 && elementId == 'iop_value') {

                return true;

            } else {
                 
                if ($('#' + elementId).length > 0) {
                    var value = $('#' + elementId).val();

                    if (value == null || value == "" || value == "0-0") {
                        $('#' + elementId).next().addClass('input-validation-error').removeClass('valid');
                        return false;
                    }
                    else {
                        $('#' + elementId).next().addClass('valid').removeClass('input-validation-error');
                        return true;
                    }
                }

                return true;
            }
        }

        function validateTextbox(elementId) {
            if ($('#' + elementId).length > 0) {
                var value = $('#' + elementId).val();

                if (value == null || value == "" || parseFloat(value) == 0.0) {
                    $('#' + elementId).addClass('input-validation-error').removeClass('valid');
                    return false;
                }
                else {
                    $('#' + elementId).addClass('valid').removeClass('input-validation-error');
                    return true;
                }
            }
            return true;
        }

        function OnCategoryChange() {
            
            //var _layerId = $('#selectCategory option:selected').val();
            let categoryData = $('#selectCategory option:selected').data();
            let _layerId = categoryData.layerId;
            let accessoriesId = categoryData.accessoriesId;
            if (_layerId != undefined && accessoriesId != undefined) {
                window.open(appRoot + '/VendorSepcification/AddVendorSpecification?layerId=' + _layerId + '&accessoriesId=' + accessoriesId, "_self");
            }
            else {
                window.open(appRoot + '/VendorSepcification/AddVendorSpecification/', "_self");
            }
        }

        function isNumber(evt) {
            evt = (evt) ? evt : window.event;
            var charCode = (evt.which) ? evt.which : evt.keyCode;
            if (charCode > 31 && (charCode < 48 || charCode > 57)) {
                return false;
            }
            return true;
        }

        function isDecimalDigit(evt) {
            var ex = /^\d{1,2}\.?\d{0,2}$/;
            if (ex.test(evt.value)) {
                if (evt.value.indexOf('.') == -1 && evt.value.length > 2)
                    evt.value = evt.value.substr(0, evt.value.length - 1);
                return true;
            }
            evt.value = evt.value.substr(0, evt.value.length - 1);
            return false;
        }
        function isDecimalLimit(evt) {
            if (evt.value == 2) {
                return true;
            }
            var ex = /^[0|1]\.?\d{0,2}$/;
            if (ex.test(evt.value)) {
                if (evt.value.indexOf('.') == -1 && evt.value.length > 1)
                    evt.value = evt.value.substr(0, evt.value.length - 1);
                return true;
            }
            evt.value = evt.value.substr(0, evt.value.length - 1);
            return false;
        }

        function onChangeHeight() {
            let height = parseFloat($('#height').val());
            $('#no_of_units').val(height * 1000 / 50);
        }
        function onChangeUnits() {
            let unit = parseFloat($('#no_of_units').val());
            $('#height').val(parseFloat(unit * 50 / 1000));
        }

        function fn_restrictdecimal(evt, obj) {
            var charCode = (evt.which) ? evt.which : event.keyCode;
            if (charCode == 46)
                return false;
            else {
                return true;
            }
        }
        function fnChkIsEnabled() {
             
            var ChkIsMaster = $('#IsMaster').is(":checked");
            if (ChkIsMaster == false) {
                $('#txt_item_master_code').next().removeClass("divDisabled").trigger("chosen:updated");
            }
            else {
                $('#txt_item_master_code').next().addClass("divDisabled").trigger("chosen:updated");
                $("#txt_item_master_code").val('').trigger("chosen:updated");
            }
        }
        $("#btnSubmit").on("click", function (e) {
             
            var category = $('#selectCategory option:selected').text().trim();
            if (category == "Cable") {
                return app.checkCblTotalCore();
            }
        });

        $("#fiberCountIn").on('change', function (e) {

            var ddlFiberCount = $("#fiberCountIn_chosen").children('a').text().trim();
            if (ddlFiberCount != "Select Fiber Count") {

                ddlFiberCount = ddlFiberCount.split(' ');
                $('#no_of_tube').val('1').attr('readonly', false);
                $('#no_of_core_per_tube').val(ddlFiberCount[0]).attr('readonly', false);
                $('#total_core').val(ddlFiberCount[0]);
            }
            else {
                $('#no_of_tube').val(0);
                $('#no_of_core_per_tube').val(0);
                $('#total_core').val(0);
            }
        });

        $("#ddlPortRatio").on('change', function (e) {
            
            var ddlFiberCount = $("#ddlPortRatio").val();
            if (ddlFiberCount != "Select Fiber Count") {

                ddlFiberCount = ddlFiberCount.split(' ');
                $('#no_of_tube_val').val('1').attr('readonly', false);
                $('#no_of_core_per_tube_val').val(ddlFiberCount[0]).attr('readonly', false);
            }
            else {
                $('#no_of_tube').val(0);
                $('#no_of_core_per_tube').val(0);
            }
        });
        function updatePortRatio() {
            
            $('#ddlPortRatio').empty();
            $('#ddlPortRatio').append($("<option></option>").val('').html('-Select-'));
            let id = 0;
            var splitter_Type = $('#ddlSplliterType').val();
            ajaxReq('VendorSepcification/BindSplitterPortRatio', { id: id, splitterType: splitter_Type }, false, function (resp) {
                 
                if (resp.length > 0)
                {
                    $.each(resp, function (data, value)
                    {
                        $('#ddlPortRatio').append($("<option ></option>").val(value.dropdown_key).html(value.dropdown_value));
                    });
                }
                else {
                    $('#ddlPortRatio').empty();
                    $('#ddlPortRatio').append($("<option></option>").val('').html('-Select-'));

                }
                $('#ddlPortRatio').trigger("chosen:updated");
            }, true, true);
        }
    </script>

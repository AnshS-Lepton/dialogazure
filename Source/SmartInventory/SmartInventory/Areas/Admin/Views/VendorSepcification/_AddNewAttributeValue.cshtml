
@model Models.Admin.dropdown_master




<!DOCTYPE html>
<div id="dvAttributeDetail">

    <div class="col-lg-12" id="dvPageMessage">
        @{Html.RenderPartial("_PageMessage", Model.pageMsg);}

    </div>

    @using (Ajax.BeginForm("SaveAttributeDetail", "VendorSepcification", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "dvAttributeDetail",
        OnSuccess = "GetUnittype()"

    },
    new { id = "frmAttributeDetail", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {

        <div id="dv_attributevalue" data-title="Add Attribute Detail">
            @Html.HiddenFor(m => m.id, new { id = "hdnsystem_Id" })
            @Html.HiddenFor(m => m.created_by, new { id = "hdn_createdbyId" })
            @Html.HiddenFor(m => m.dropdown_type, new { id = "hdn_dropdown_type" })
            @Html.HiddenFor(m => m.entity_name, new { id = "hdn_entity_name" })
            @Html.HiddenFor(m => m.layer_id, new { id = "hdn_entity_id" })
            @Html.HiddenFor(m => m.dropdown_value, new { id = "hdn_dd_value" })


            <div class="form-group">
                <div class="row">
                    <div class=" col-md-3">
                        <label class=" control-label">
                            Input Port:
                        </label>
                    </div>
                    <div class=" col-md-7">
                        @Html.TextBoxFor(model => model.inputport, new { @class = "form-control", @maxlength = "3", @id = "txtvendorspec_inputport" })

                    </div>
                </div>

            </div>


            <div class="form-group">
                <div class="row">
                    <div class=" col-md-3">
                        <label class=" control-label">
                            OutPut Port:
                        </label>
                    </div>
                    <div class=" col-md-7">
                        @Html.TextBoxFor(model => model.outputport, new { @class = "form-control", @maxlength = "3", @id = "txtvendorspec_outputport" })


                    </div>

                </div>

            </div>



            <div class="form-group" id="dvBtnAction">
                <div class="row">
                    <div class="col-md-3"> </div>
                    <div class="col-md-7  text-right">

                        <input type="submit" class="btn btn-primary" name="btnSaveDetail" onclick="return isValidDetails()" id="btnSaveDetail" value="Save" />

                        <a href="javascript:void(0);" class=" btn btn-default" data-dismiss="modal" id="btnCancel">Cancel</a>


                    </div>
                </div>
            </div>


        </div>
    }


    <script>

        @*if ('@Model.id' != 0) {
            btnSaveDetail.value = "Update";
            //$('#txtproject_code').attr('readonly', true);
        }*@

        function isValidDetails() {
            if ($('#txtvendorspec_inputport').val() == "" || $('#txtvendorspec_inputport').val() == "0") {
                $('#txtvendorspec_inputport').css({ "border": "1px solid red" });
                return false;

            }

            if ($('#txtvendorspec_outputport').val() == "" || $('#txtvendorspec_outputport').val() == "0") {
                $('#txtvendorspec_outputport').css({ "border": "1px solid red" });
                return false;
            }


        }

        $(document).ready(function () {
            $("#txtvendorspec_inputport, #txtvendorspec_outputport").keypress(function (e) {
                //if the letter is not digit then don't type anything
                if (e.which != 8 && e.which != 0 && (e.which < 48 || e.which > 57)) {
                    return false;
                }
            });

        })






    </script>

</div>




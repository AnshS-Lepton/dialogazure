        <div id="fsRouteFreq">
            <fieldset class="fset" id="fsWorkingDays">
                <legend class="the-legend">Working Days</legend>
                @Html.HiddenFor(m => m.userTimeSheetInput.working_days, new { @id = "working_days" })
                <div class="form-group row">
                    <div class="col-sm-offset-2 col-sm-10">
                        <div class="checkbox d-flex-check">
                            <label><input type="checkbox" class="working_days" name="chkWeekays" id="chkIsActive2" value="2"> Mon</label>
                            <label><input type="checkbox" class="working_days" name="chkWeekays" id="chkIsActive3" value="3"> Tue</label>

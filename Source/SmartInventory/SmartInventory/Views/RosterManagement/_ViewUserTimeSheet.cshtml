<script>
    var sp = new Main();
    var AR = new UserTimeSheet();



    $(function () {


        // 
        //Enable validator on the form..
        $.validator.unobtrusive.parse("#frmUserTimeSheet");
        // //select2 js for drop-down list
        //$("#dvAssignRouteContainer .chosen-select").select2();
        //$("#dvUserTimeSheetContainer .chosen-select").select2("destroy").select2({});
        //initialize assign route js file
        //  ar.initapp();
        // ar.fnconpostchange();
        //$('#dvUserTimeSheetContainer select').select2({ width: '100%' });
        sp.setDateTimeCalendar_SurveyNew("userTimeSheetInput_start_date", "userTimeSheetInput_end_date", "imgStartDate", "imgEndDate", true);
        //$(".sptimepicker").find('.select2-container').hide();
        //$(".sptimepicker").children('select').removeclass('select2-offscreen');
        $(document).ready(function () {

            var workingDays = $("#working_days").val();


            if (workingDays != 0) {
                workingDays = workingDays.split(',');
                $.each(workingDays, function (index, value) {
                    var selChkDay = value - 2;
                    $('input[name=chkWeekays]:eq(' + selChkDay + ')').attr("checked", true);
                });
            }





            $('.working_days').on("click", function () {
                var text = "";
                $('.working_days:checked').each(function () {
                    text += $(this).val() + ',';
                });

                text = text.substring(0, text.length - 1);
                $('#working_days').val(text);

            });






        });
    });



</script>



                        }
                        @if (Model.system_id > 0 && layerDetail != null)
                        {
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-PIF")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_025 @(Model.lstUserModule.Contains("ENT-DTL-PIF")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-PIF") ? "" : "block;")"

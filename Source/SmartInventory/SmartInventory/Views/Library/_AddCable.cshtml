    function validateTextboxLowFrom(elementId) {
        if ($('#' + elementId).length > 0) {
            var value = $('#' + elementId).val();
            if ($('#SelectedNetworkStatus').val() != 'Spectra' && (value == 'undefined' || value == null || value == "")) {
                $('#' + elementId).addClass('input-validation-error').removeClass('valid');
                return false;
            }
            else {

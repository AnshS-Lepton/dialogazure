                    <div class="col-md-6 col-sm-6" data-DarkFiber="true" data-Enterprise="false" data-SmallCell="false" data-FTTH="false">
                        <label class="control-label col-md-6 col-sm-6">@Resources.Resources.SI_OSP_GBL_NET_GBL_146<i class="clsMandatory">*</i>:</label>
                        <div class="col-md-6 col-sm-6 mrgn_btm">
                            @Html.TextBoxFor(m => m.LMCCableInfo.no_of_pits, new { @class = "form-control", @maxlength = "4", @id = "txtNoOfPITs", @onkeypress = "return si.allowOnlyNumber(event);" })

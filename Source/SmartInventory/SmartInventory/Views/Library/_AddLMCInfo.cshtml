            @if (Model.LMCCableInfo.system_id > 0)
            {
                <fieldset class="the-fieldset">
                    <legend class="the-legend">@Resources.Resources.SI_OSP_CAB_NET_FRM_047</legend>
                    <div class="col-md-12 col-sm-12 UploadAction" style="margin-left: -6px;">
                        <div class="col-md-6 col-sm-6" id="divDocumentUpload" style="display:flex; text-decoration:underline;">
                            <input type="file" class="file" name="LMCDocUpload" id="LMCDocUpload">
                            <a href="#" onclick="si.LMCInfo.attachment.upload(@Model.LMCCableInfo.system_id,'Cable');" value="Upload" id="btnUploadDocument">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_008</a>
                            <a href="#" onclick="si.LMCInfo.clear();" value="Clear" id="btnClearDocument">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_009</a>

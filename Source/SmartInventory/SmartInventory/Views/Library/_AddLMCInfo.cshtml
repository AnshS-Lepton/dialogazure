@model Models.CableMaster
@using SmartInventory.Settings;
@helper pageMessage()
{
{ Html.RenderPartial("_PageMessage", Model.LMCCableInfo.objPM); }

}
<style>
    #dvLMCInfo .col-md-6 {
        /*padding-left: 0px;*/
        padding-left: 13px;
    }

    #dvLMCInfo .mrgn_btm {
        height: 25px;
    }

    .ui-menu-item {
        /*// padding-left:15px;*/
        margin: 0;
        padding: 6px 0px 6px 20px;
        list-style: none;
        background-repeat: no-repeat;
        background-position: left center;
        background-size: 17px;
        border-bottom: 1px solid #dedbdb;
        margin-left: 5px;
        margin-right: 5px;
        max-width: 165px !important;
        overflow: hidden;
        height: auto;
    }

    .ui-state-focus {
        border-width: 0px 0px 0px 0px !important;
        border-bottom: 1px solid #dedbdb !important;
        background-color: #bab3b3 !important;
    }

    .TickCrossicon {
        position: absolute;
        font-size: 13px;
        right: 0;
        margin: 6px 18px 0px 0px;
    }

        .TickCrossicon i {
            background: #00ba8a;
            color: #fff;
            padding: 4px;
            border-radius: 19px;
            height: 18px;
            width: 19px;
            cursor: pointer;
            float: right;
            margin: -3px 2px;
            font-size: 12px;
        }

    .crossIcon {
        display: none;
    }

    .tickIcon {
        display: none;
    }

    .detailsicon {
        display: none;
    }

    #dvcustomerpopup {
        position: absolute;
        background: white;
        height: auto;
        border: 1px solid;
        margin-left: 201px;
        z-index: 1000;
        top: 141px;
        display: none;
    }

        #dvcustomerpopup table {
            width: 97%;
            height: auto;
            font-size: 13px;
            margin: 5px;
        }

            #dvcustomerpopup table tr:nth-child(odd) {
                background: white;
            }

            #dvcustomerpopup table tr:nth-child(even) {
                background: #f1f4f7;
            }

            #dvcustomerpopup table tr td:first-child {
                width: 105px;
            }

            #dvcustomerpopup table tr td {
                padding: 5px;
            }

        #dvcustomerpopup .headerInfo {
            width: 100%;
            height: 27px;
            background: #31bd72;
            text-align: center;
            vertical-align: middle;
            color: white;
            font-size: 16px;
            font-weight: bold;
        }

    .GifImg {
        width: 22px;
        cursor: pointer;
        margin-top: -5px;
    }
</style>

                    </div>
                    <div class="col-md-6 col-sm-6" data-DarkFiber="false" data-Enterprise="true" data-SmallCell="true" data-FTTH="false">
                        <label class="control-label col-md-6 col-sm-6">@Resources.Resources.SI_OSP_GBL_NET_GBL_140<i class="clsMandatory">*</i>:</label>
                        <div class="col-md-6 col-sm-6 mrgn_btm">
                            @Html.TextBoxFor(m => m.LMCCableInfo.pop_latitude, new { @class = "form-control", @maxlength = "12", @id = "txtPOPLat", @onkeypress = "return allowNumberwithOneDot(event,'txtPOPLat');" })
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-6" data-DarkFiber="false" data-Enterprise="true" data-SmallCell="true" data-FTTH="false">
                        <label class="control-label col-md-6 col-sm-6">@Resources.Resources.SI_OSP_GBL_NET_GBL_141<i class="clsMandatory">*</i>:</label>
                        <div class="col-md-6 col-sm-6 mrgn_btm">
                            @Html.TextBoxFor(m => m.LMCCableInfo.pop_longitude, new { @class = "form-control", @maxlength = "12", @id = "txtPOPLong", @onkeypress = "return allowNumberwithOneDot(event,'txtPOPLong');" })
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-6" data-DarkFiber="true" data-Enterprise="true" data-SmallCell="false" data-FTTH="false">
                        <label class="control-label col-md-6 col-sm-6">@Resources.Resources.SI_OSP_GBL_NET_GBL_142<i class="clsMandatory">*</i>:</label>
                        <div class="col-md-6 col-sm-6 mrgn_btm">
                            @Html.TextBoxFor(m => m.LMCCableInfo.ibd_length, new { @class = "form-control", @maxlength = "4", @id = "txtIBDLength", @onkeypress = "return si.allowNumberwithOneDot(event,'txtIBDLength');" })
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-6" data-DarkFiber="true" data-Enterprise="false" data-SmallCell="false" data-FTTH="false">
                        <label class="control-label col-md-6 col-sm-6">@Resources.Resources.SI_OSP_GBL_NET_GBL_143<i class="clsMandatory">*</i>:</label>
                        <div class="col-md-6 col-sm-6 mrgn_btm">
                            @Html.TextBoxFor(m => m.LMCCableInfo.route_no, new { @class = "form-control", @maxlength = "50", @id = "txtRouteNo" })
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-6" data-DarkFiber="true" data-Enterprise="false" data-SmallCell="false" data-FTTH="false">
                        <label class="control-label col-md-6 col-sm-6">@Resources.Resources.SI_OSP_GBL_NET_GBL_144<i class="clsMandatory">*</i>:</label>
                        <div class="col-md-6 col-sm-6 mrgn_btm">
                            @Html.TextBoxFor(m => m.LMCCableInfo.route_details, new { @class = "form-control", @maxlength = "50", @id = "txtRouteDetails" })
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-6" data-DarkFiber="true" data-Enterprise="false" data-SmallCell="false" data-FTTH="false">
                        <label class="control-label col-md-6 col-sm-6">@Resources.Resources.SI_OSP_GBL_NET_GBL_145<i class="clsMandatory">*</i>:</label>
                        <div class="col-md-6 col-sm-6 mrgn_btm">
                            @Html.TextBoxFor(m => m.LMCCableInfo.ri_length, new { @class = "form-control", @maxlength = "4", @id = "txtRILength", @onkeypress = "return si.allowNumberwithOneDot(event,'txtRILength');" })

            }

</div>
<div class="ModalFooter d-flex" id="dvLMCCableFooter">

    @if (Model.LMCCableInfo.system_id == 0)
    {
        <a href="javascript:void(0);" class="btn btn-default ml-auto" data-dismiss="modal" id="btnCancelLMCInfo">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
        <button type="button" class="btn btn-primary ml-05" name="actionTab" id="btnLMCCable" value="LMCInfoTab" onclick="updateLMCInfo();">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>

    }

    else if (Model.LMCCableInfo.system_id != 0)
    {
        <a href="javascript:void(0);" class="btn btn-default ml-auto" data-dismiss="modal" id="btnCancelSiteInfo">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
        <button type="button" class="btn btn-primary ml-05" name="actionTab" id="btnSiteInfo" value="SiteInfoTab" onclick="updateLMCInfo();">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_003</button>
    }
</div>

<script type="text/javascript">
    $(document).ready(function () {
        $('.chosen-select').chosen({ width: '100%' });
        callFormValidator("frmAddCable");
        si.SiteInfo.setDateTimeCalendar('txtPermitDate', 'img_permit_date', '', true);

        if ('@Model.LMCCableInfo.lmc_type' == '') {

            $('#ddlLMCType').val('FTTH').trigger('chosen:updated');
        }
        showHideLMCAttribute($('#ddlLMCType').val().replace(/\s+/g, ''));
        if ('@Model.LMCCableInfo.system_id' > 0) {
            $('.tickIcon').css('display', 'block');
            $('.detailsicon').css('display', 'block');
            $('.crossIcon').css('display', 'none');
        }
         
        if ('@Model.LMCCableInfo.lmc_type' == "Small Cell") {
            ShowCascadedSiteName('ddlLMCCascadedStandalone');
        }

    });

    $('#ddlLMCType').on('change', function () {
         
        var ddlValue = $(this).val().replace(/\s+/g, '');
        $('div[data-' + ddlValue + '="true"]  .form-control').removeClass('input-validation-error').addClass('valid');
        $('div[data-' + ddlValue + '="true"] .chosen-container').removeClass('input-validation-error').addClass('valid');

        clearformvalue();

        showHideLMCAttribute(ddlValue);

    });

    $('#txtRILength,#txtIBDLength,#txtUGLength,#txtISCLength,#txtOTLLength,#txtOTMLength,#txtOTDRLength').on('input', function () {
        this.value = this.value.match(/^\d+\.?\d{0,2}/);
    });


    function updateLMCInfo() {
         
        var a = $('#txtCustomerSystemId').val();
        var b = $('#customer_system_id').val();
        var ddlValue = $('#ddlLMCType').val().replace(/\s+/g, '');
        var ImgTick = document.getElementById("ImgTick");
        var _unique = "";
        if (ddlValue == '') {
            $('#ddlLMCType').next().addClass('input-validation-error');
            return false;
        }
        if (ddlValue == "DarkFiber") {
            _unique = "PO Number"
        }
        else if (ddlValue == "Enterprise") {
            _unique = "PO Number"
        }
        else if (ddlValue == "SmallCell") {
            _unique = "Customer Site Id"
        }
        else if (ddlValue == "FTTH") {
            _unique = "PAF No."
        }

        if ($(".crossIcon").css("display") === "block")
        {
            alert(String.Format(Resources.Resources.SI_OSP_GBL_JQ_FRM_093, _unique, _unique));
            return false;
        }
        //if (ImgTick.style.display === "none")
        //{
        //    alert(_unique+' does not exists.Please enter a valid ' +_unique+' !');
        //    return false;
        //}

        $('#dvLMCInfo div[data-' + ddlValue + '="true"]  .form-control[data-val="true"]').removeClass('input-validation-error').addClass('valid');
        $.each($('#dvLMCInfo div[data-' + ddlValue + '="true"] .form-control[data-val="true"]'), function (index, item) {
            if ($(this).val().trim() == '' || $(this).val().trim() == null) {
                if ($(this).hasClass("chosen-select")) {
                    $(this).next().addClass('input-validation-error');
                } else {
                    $(this).addClass('input-validation-error');
                }

            }
        });

        $('#hdnCableTab').val('LMCInfoTab');
        if ($('div[data-' + ddlValue + '="true"] .form-control[data-val="true"]').filter(function () {
            return $(this).val().trim() == '' || $(this).val().trim() == null;
        }).length == 0) {
            $('#frmAddCable').submit();
        }


    }

    function showHideLMCAttribute(_lmcType) {
        if (_lmcType != null && _lmcType != undefined) {

            $('div[data-' + _lmcType + '="true"]').show();
            $('div[data-' + _lmcType + '="false"]').hide();

            // Form validation based on LMC TYPE
            $('div[data-' + _lmcType + '="false"] .form-control').attr('data-val', false);
            $('div[data-' + _lmcType + '="true"] .form-control').attr('data-val', true);
        }

    }

    function clearformvalue() {
        $("#ddlLMCCascadedStandalone").val('').trigger('chosen:updated');
        $("#txtCustomerSiteId").val('');
        $("#txtRtnName").val('');
        $("#ddlRTNBuildingSiteTappingPoint").val('').trigger('chosen:updated')
        $("#txtCascadeSiteName").val('');
        $("#txtOTDRLength").val('0');
        $("#txtOTMLength").val('0');
        $("#txtOTLLength").val('0');
        $("#txtISCLength").val('0');
        $("#txtUGLength").val('0');
        $("#txtCoreused").val('0');
        $("#txtCoreNumbers").val('');
        $("#txtPOPType").val('');
        $("#txtPermitDate").val('');
        $("#ddlTerminationDetails").val('').trigger('chosen:updated')
        $("#txtPOPInfraProvider").val('');
        $("#txtNoOfPatchCord").val('0');
        $("#txtPAFNO").val('');
        $("#txtROWRIDeposit").val('');
        $("#txthandhole").val('');
        $("#txtPONumber").val('');
        $("#txtPOPName").val('');
        $("#txtPOPLat").val('');
        $("#txtPOPLong").val('');
        $("#txtIBDLength").val('0');
        $("#txtRouteNo").val('');
        $("#txtRouteDetails").val('');
        $("#txtPOPInfraId").val('');
        $("#txtNoOfPITs").val('0');
        $('.tickIcon').css('display', 'none');
        $('.detailsicon').css('display', 'none');
        $('.crossIcon').css('display', 'none');
    }

    function validateSiteCustomer(_searchText, _columnName) {
         
        var _lmcType = $('#ddlLMCType').val().replace(/\s+/g, '');
        if (_searchText.length > 0) {

            ajaxReq('Library/validateSiteCustomer', { searchText: _searchText, columnName: _columnName, lmcType: _lmcType }, true, function (resp) {
                 
                if (resp.status != 'OK') {
                    // $('#IconCross').attr('src', 'Content/images/cross.gif');
                    // $("#ImgTick").hide();
                    //  $("#IconCross").show();
                    //  $("#iconViewDetails").hide();

                    $('.tickIcon').css('display', 'none');
                    $('.detailsicon').css('display', 'none');
                    $('.crossIcon').css('display', 'block');
                }
                
                else {
                    // $('#ImgTick').attr('src', 'Content/images/tick_1.gif');
                    // $("#ImgTick").show();
                    // $("#iconViewDetails").show();
                    // $("#IconCross").hide();
                    if (resp.status == 'OK') {
                        $('#txtCustomerSystemId').val(resp.result.customer_system_id);
                    }
                    $('.crossIcon').css('display', 'none');
                    $('.tickIcon').css('display', 'block');
                    $('.detailsicon').css('display', 'block');
                }

            })

        }
        else {
            // $("#IconCross").hide();
            //$("#ImgTick").hide();
            //  $("#iconBldMapp").hide();

            $('.tickIcon').css('display', 'none');
            $('.detailsicon').css('display', 'none');
            $('.crossIcon').css('display', 'none');
        }
    }

    function showDetails(_text, _columnName) {
         
        var _searchTextPAFNO = $('#txtPAFNO').val();
        var _searchTextPONO = $('#txtPONumber').val();
        var _searchTextCustomerSiteId = $('#txtCustomerSiteId').val();
        var _lmcType = $('#ddlLMCType').val().replace(/\s+/g, '');
        if (_searchTextPAFNO.length > 0) {
            ajaxReq('Library/validateSiteCustomer', { searchText: _searchTextPAFNO, columnName: _columnName, lmcType: _lmcType }, true, function (resp) {
                 
                if (resp.status = 'OK') {
                    if (resp.result != null && resp.result != undefined) {
                        $('#tblCustomerinfo tr').remove();
                        var i = 0;

                        $.each(resp.result, function (key, value) {
                            if (value == null) {
                                value = "";
                            }
                            $('#tblCustomerinfo').append(' <tr class="' + ((i % 2 == 0) ? ('#dvcustomerpopup table tr:nth-child(add)') : ('#dvcustomerpopup table tr:nth-child(even)')) + '"><td width="105">' + key + '</td><td>:</td><td>' + value + '</td></tr>');

                            i++;
                        });
                        $('#dvcustomerpopup').slideToggle();
                    }
                }
            }, true, true);
        }

        if (_searchTextPONO.length > 0) {
            ajaxReq('Library/validateSiteCustomer', { searchText: _searchTextPONO, columnName: _columnName, lmcType: _lmcType }, true, function (resp) {
                 
                if (resp.status = 'OK') {
                    if (resp.result != null && resp.result != undefined) {
                        $('#tblCustomerinfo tr').remove();
                        var i = 0;

                        $.each(resp.result, function (key, value) {
                            if (value == null) {
                                value = "";
                            }
                            if (key == 'customer_system_id') {
                                $('#txtCustomerSystemId').val(value);
                                return false;
                            }

                            $('#tblCustomerinfo').append('<tr class="' + ((i % 2 == 0) ? ('#dvcustomerpopup table tr:nth-child(add)') : ('#dvcustomerpopup table tr:nth-child(even) ')) + '"><td width="105">' + key + '</td><td>:</td><td>' + value + '</td></tr>');

                            i++;

                        });

                        $('#dvcustomerpopup').slideToggle();
                    }
                }
            }, true, true);
        }

        if (_searchTextCustomerSiteId.length > 0) {
            ajaxReq('Library/validateSiteCustomer', { searchText: _searchTextCustomerSiteId, columnName: _columnName, lmcType: _lmcType }, true, function (resp) {
                 
                if (resp.status = 'OK') {
                    if (resp.result != null && resp.result != undefined) {
                        $('#tblCustomerinfo tr').remove();
                        var i = 0;

                        $.each(resp.result, function (key, value) {
                            if (value == null) {
                                value = "";
                            }
                            $('#tblCustomerinfo').append(' <tr class="' + ((i % 2 == 0) ? ('#dvcustomerpopup table tr:nth-child(add)') : ('#dvcustomerpopup table tr:nth-child(even)')) + '"><td width="105">' + key + '</td><td>:</td><td>' + value + '</td></tr>');

                            i++;
                        });
                        $('#dvcustomerpopup').slideToggle();
                    }
                }
            }, true, true);
        }
    }
    $(document).mouseup(function (e) {
        var container = $('#dvcustomerpopup');

        // if the target of the click isn't the container nor a descendant of the container
        if (!container.is(e.target) && container.has(e.target).length === 0) {
            container.hide();
        }
    });

    function ShowCascadedSiteName(_Selected) {
         
        var _lmcType = $('#ddlLMCType').val().replace(/\s+/g, '');
        var selectedValue = $('#' + _Selected).val();
        if (selectedValue == "Standalone") {
            $('.hideStandalone').attr('data-SmallCell', 'false');
            $("#txtCascadeSiteName").val('');
            $("#dvCascaded").hide();


        }
        else {
            // $("#txtCascadeSiteName").prop("readonly", false);
            $("#dvCascaded").show();
            $('.hideStandalone').attr('data-SmallCell', 'true');
        }
    }
</script>
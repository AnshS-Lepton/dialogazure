                        <div class="col-md-6 col-sm-6 mrgn_btm">
                            @Html.TextBoxFor(m => m.LMCCableInfo.permit_date, "{0:dd-MMM-yyyy}", new { @class = "form-control clsReadOnly", @readonly = true, placeholder = "DD-MMM-YYYY", @id = "txtPermitDate" })

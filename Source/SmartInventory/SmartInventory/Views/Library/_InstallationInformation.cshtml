@model Models.IInstallationInfo
<!DOCTYPE html>
<div class="form-group">

    <label class="control-label col-md-2 col-sm-2">@Resources.Resources.SI_OSP_GBL_GBL_GBL_250 :</label>
    <div class="col-md-4 col-sm-4 mrgn_btm_ins">
        @Html.TextBoxFor(m => m.installation_number, new { @id = "txtInstallationNumber", @class = "form-control" })
    </div>
    <label class="control-label col-md-2 col-sm-2">@Resources.Resources.SI_OSP_GBL_GBL_GBL_251 :</label>
    <div class="col-md-4 col-sm-4 mrgn_btm_ins">
        @Html.TextBoxFor(m => m.installation_year, new { @id = "txtInstallationYear", @class = "form-control" })
    </div>
</div>

<div class="form-group">
    <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_GBL_GBL_GBL_252 :</label>
    <div class="col-md-4 col-sm-4 ">
        @Html.TextBoxFor(m => m.production_year, new { @id = "txtProductionYear", @class = "form-control" })
    </div>
    <label class="control-label col-md-2 col-sm-2">@Resources.Resources.SI_OSP_GBL_GBL_FRM_086 :</label>
    <div class="col-md-4 col-sm-4 mrgn_btm_ins">
        @Html.TextBoxFor(m => m.installation_company, new { @id = "txtInstallationCompany", @class = "form-control" })
    </div>
</div>

<div class="form-group">
    <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_GBL_GBL_GBL_254 :</label>
    <div class="col-md-4 col-sm-4 ">
        @Html.TextBoxFor(m => m.installation_technician, new { id = "txtInstallationTechnician", @class = "form-control" })
    </div>
    <label class="control-label col-md-2 col-sm-2" for="txtinstallation">@Resources.Resources.SI_OSP_GBL_GBL_GBL_255 :</label>
    <div class="col-md-4 col-sm-4 mrgn_btm_ins">
        @Html.TextBoxFor(m => m.installation, new { id = "txtInstallation", @class = "form-control" })
    </div>
</div>


<script>

    $(document).ready(function () {

        $(document).on('click', 'form button[type=submit]', function (e) {
            var selected_ownership = $("input[name='rdbOwnershipType']:checked").val();
            if (selected_ownership == 'Third Party' && $('#txt3rdPartyVendor').val() == '' && $('#txt3rdPartyVendor').val() == null) {
                $('#txt3rdPartyVendor').next().addClass('input-validation-error');
                return false;
            }
            if (selected_ownership == "Third Party" && $('#txt3rdPartyVendor').val() == "") {
                $('#txt3rdPartyVendor').next().addClass('input-validation-error');
                return false;
            }
            if (selected_ownership == "Third Party" && $('#txtCircuitId').val() == "") {
                $('#txtCircuitId').addClass('input-validation-error');
                return false;
            }
        });
    });
</script>

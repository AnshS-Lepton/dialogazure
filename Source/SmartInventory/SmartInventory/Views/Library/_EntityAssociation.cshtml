@model Models.AssociateEntity
@Html.HiddenFor(m => m.system_id, new { id="hdnAssociateSystemId" })
<!DOCTYPE html>
<div class="libDetail" style="height:220px;">
    <div class="libTabContent">
        <!-- Tab panes -->
        <div class="tab-content">
            <div class="tab-pane active" id="GISInfo">
                <fieldset class="the-fieldset" style="padding-bottom: 81px;">
                    <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_GBL_FRM_007</legend>
                    <div class="form-group" id="divParentEntity">
                        <label class="control-label col-sm-4" for="txtSubAreaName">@Resources.Resources.SI_OSP_GBL_GBL_GBL_005<i class="clsMandatory"></i>:</label>
                        <div class="col-sm-8">
                            @Html.DropDownListFor(m => m.entity_type, new SelectList(new List<SelectListItem>
                                {
                               
                                new SelectListItem{ Text="Tree", Value = "Tree" },
                                new SelectListItem{ Text="Manhole", Value = "Manhole" },
                                new SelectListItem{ Text="Pole", Value = "Pole" }
                                }
                                , "Value", "Text"), "--Select--", new { id = "ddlParentEntType", @class = "chosen-select col-sm-12" })
                        </div>
                    </div>
                    <div class="form-group" style="padding-top:20px;">
                        <label class="control-label col-sm-4" for="txtSubAreaName"><span id="spnEntity">@Resources.Resources.SI_OSP_GBL_NET_RPT_127</span><i class="clsMandatory"></i>:</label>
                        <div class="col-sm-8">
                            @Html.DropDownListFor(m => m.entity_system_id, new SelectList(Model.listBufferEntity.Select(x => new { Value = x.system_id.ToString(), Text = x.network_id }), "Value", "Text"), "--Select--", new { id = "ddlallParentEntity", @class = "chosen-select col-sm-12" })
                        </div>
                    </div>
                </fieldset>
            </div>
        </div>
    </div>
    <div class="form-group ModalFooter" id="dvBtnAction">
        <div class="col-sm-10 col-sm-offset-2" style="float: right; text-align: right; padding-right: 25px;">
            <button type="submit" class="btn btn-primary" id="bttnAssociateEntity">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
            <a href="javascript:void(0);" class="btn btn-default" data-dismiss="modal" id="btnCableCancel" onclick="$('#closeModalPopup').trigger("click");">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
        </div>
    </div>
    <div class="clearfix"></div>
</div>
<script>
    $(document).ready(function () {
        $('.chosen-select').chosen({ width: '100%' });     
    });
</script>
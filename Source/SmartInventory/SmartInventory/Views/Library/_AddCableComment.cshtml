@using SmartInventory.Settings;
<!DOCTYPE html>
<div class="tab-pane fade in active show">
    <div class="container-fluid BdrSet" style="max-height: 370px;overflow: auto;">
        <div class="row padRow">
            <div class="form-group">
                    <div>
                        <label class="control-label col-md-8 col-sm-8" style="padding-top: 15px;width: auto;">@String.Format(Resources.Resources.SI_OSP_CAB_NET_FRM_072, ApplicationSettings.CableExtraLengthPercentage)</label>
                        <label class="control-label col-md-8 col-sm-8" style="padding-top: 6px;padding-bottom: 6px;">@Resources.Resources.SI_OSP_BUL_NET_FRM_010</label>
                        <div class="col-md-10 col-sm-10 mrgn_btm">
                            <input type="text" class="form-control" maxlength="500" placeholder="@Resources.Resources.SI_OSP_BUL_NET_FRM_022" id="txtcomment" />
                        </div>
            </div>
        </div>
    </div>
    <div class="form-group ModalFooter" id="dvcablecommentFooter" style="border-top: 1px solid #bdbcbc;">
        <div class="col-md-6 col-sm-6 ModalFooterControll">
            <input type="button" class="btn btn-primary" id="btnUpdateRemarks" name="btnaction" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004"/>
            <a href="javascript:void(0);" class="btn btn-default" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
        </div>
    </div>
    <div class="clearfix"></div>
    </div>
</div>

<script type="text/javascript">
    $("#btnUpdateRemarks").on("click", function () {
         
        if ($('#txtcomment').val() == '' || $('#txtcomment').val() == null || $('#txtcomment').val() == undefined) {
            $("#txtcomment").addClass('input-validation-error');
            return false;
        }
        else {
            $('#hdncblComment').val($('#txtcomment').val());
            $("#txtcomment").removeClass('input-validation-error');           
            $("#closeChildPopup").trigger("click");
            $("#frmAddCable").submit();
        }
    });
</script>

    function formPost() {

        if (parseInt($('#txtcsahomepass').val()) > parseInt($('#hdnnohomepassmaxlength').val())) {
            alert('Number of Home Pass can not be greater than ' + parseInt($('#hdnnohomepassmaxlength').val()));
            return false;
        }


            $('#frmAddCSA').submit();
    }
    $("#ulCsa li a").on("click", function () {
        var url = $(this).attr('href');
        if (url == '#Reference') {
            $("#ModalPopUp .modal-md").animate({ 'width': url == '#Reference' ? '750px' : '600px' });
            $('div#dvBtnAction').show();

        }
        else {
            $("#ModalPopUp .modal-md").animate({ 'width': '600px' });
            $('div#dvBtnAction').show();
            $(".dropMenu").hide();
        }

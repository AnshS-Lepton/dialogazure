@model List<Models.ROWAttachments>

@if (Model != null && Model.Count > 0)
{
    var isDesplayAction = true;
    if (!string.IsNullOrEmpty(Model[0].current_row_stage) &&
        (Model[0].current_row_stage == "Approved" || Model[0].current_row_stage == "Rejected"))
    {
        isDesplayAction = false;
    }
    else if (!string.IsNullOrEmpty(Model[0].current_row_stage) && Model[0].current_row_stage == "Applied" && Model[0].row_stage == "Apply")
    {
        isDesplayAction = false;
    }
    //else if (!string.IsNullOrEmpty(Model[0].current_row_stage) && (Model[0].current_row_stage == Model[0].row_stage))
    //{ isDesplayAction = false; }
    <div class="form-group">
        <div class="col-sm-8 UploadAction"></div>
        <div class="col-sm-4 icon-Download cptr" onclick="si.ROW.attachment.downLoadFile(@Model[0].row_system_id,'@Model[0].row_stage');" id="divDownloadDocuments" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_048" style="float:right; text-align:right;"> @Resources.Resources.SI_OSP_GBL_NET_FRM_049	</div>
    </div>
    <div class="form-group" id="divATAttachment">

        <table class="webgrid" id="ulROWDocumentUpload">
            <thead>
                <tr class="webGridHeader">
                    <th scope="col" class="">@Resources.Resources.SI_OSP_ROW_NET_FRM_091</th>
                    <th scope="col" class="">@Resources.Resources.SI_OSP_GBL_GBL_GBL_029</th>
                    <th scope="col" class="">@Resources.Resources.SI_OSP_GBL_GBL_GBL_030</th>
                    <th scope="col" class="">@Resources.Resources.SI_OSP_GBL_GBL_GBL_031</th>
                    @if (isDesplayAction)
                    {
                        <th scope="col" class="hidetd">@Resources.Resources.SI_OSP_GBL_GBL_GBL_028</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="liDocumentUpload_@item.id"
                        data-entity-id="@item.row_system_id"
                        data-system-id="@item.id"
                        data-image-location="@item.file_location"
                        data-image-name="@item.file_name">
                        <td data-attachment-type="@item.upload_type">@item.upload_type</td>
                        <td data-file-name="@item.file_name">
                            <input id="hdEntityType" type="hidden" value="ROW" />
                            <a style="cursor:pointer;" href="Main/DownloadFile?path=@item.file_location&name=@item.file_name" title="@item.file_name">@(item.org_file_name.Length > 30 ? item.org_file_name.Substring(0, 30) + "..." : item.org_file_name)</a>
                        </td>
                        <td style="text-align:center;">@item.file_size_converted</td>
                        <td style="text-align:center;">@item.uploaded_by</td>
                        @if (isDesplayAction)
                        {
                            <td class="hidetd"><div class="col-sm-1 icon-Close cptr" onclick="si.ROW.attachment.deleteFile(@item.id,@item.row_system_id,'@item.row_stage');" id="divDeleteDocuments" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_050" style="text-align:center;color:red;"></div></td>
                        }
                    </tr>
                }
            </tbody>
        </table>


    </div>
}
else
{

}

<script>
    $(document).ready(function () {
        $('.UploadAction [title!=""]').tooltip({ title: '', html: true, placement: "top" });
        $('#divDocument [title!=""]').tooltip({ title: '', html: true, placement: "top" });
    });

</script>

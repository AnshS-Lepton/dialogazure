@model Models.ViewGroupLibrary
@using SmartInventory.Settings;
@using Models;
@{
    Layout = null;
}
<style>
    .Associated {
        background-color: #ffb399;
    }

    .child {
        background-color: #ebf4f5;
    }

    .cloneDependent th {
        font-weight: bold;
        border-width: 1px;
        padding: 8px;
        border-style: solid;
        border-color: #666666;
        background-color: #dedede;
        font: 1000px
    }

    .cloneDependent th, .cloneDependent td {
        padding: 5px;
        border: 1px solid #ccc;
    }

        .cloneDependent th label {
            font-weight: bold;
            background-color: #dedede;
        }

    .ModelFooterInfo {
        float: left;
        font-style: normal;
        /* color: #7E7E7E; */
        font-size: 14px;
        /* padding: 0px 5px; */
    }
</style>

<!DOCTYPE html>
@using (Ajax.BeginForm("SaveGroupLibrary", "Library", new AjaxOptions
{
    HttpMethod = "POST",
    UpdateTargetId = "dvModalBody",
    LoadingElementId = "dvProgress",
    OnSuccess = "si.OnSuccessGroupLibrary",
    Confirm = "All selected child and associated entities along with selected accessories will be saved as<b> Group library </b> with this entity.<br/>Do you want to continue?"
},
new { id = "frmSaveClone", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
{
    <div class="TabContent--max-over">
        @Html.HiddenFor(m => m.system_id)
        @Html.HiddenFor(m => m.entity_type)
        @if (Model.lstCloneDependent.Count > 0 || Model.geomType == GeometryType.Line.ToString() || Model.is_accessories_required)
        {
            <div class="form-group row">
                <div class="col-md-4">
                    <label>Name  <i class="clsMandatory">*</i>:</label>
                </div>
                <div class="col-md-8">
                    @Html.TextBoxFor(m => m.name, new { @class = "form-control ", @id = "txtname", @maxlength = "50" })
                </div>
            </div>
            <div class="form-group row">
                <div class="col-md-4">
                    <label>Description<i class="clsMandatory">*</i>:</label>
                </div>
                <div class=" col-md-8">
                    @Html.TextBoxFor(m => m.description, new { @class = "form-control ", @id = "txtdescription", @maxlength = "100" })
                </div>
            </div>
            <div class="form-group row">
                <div class="col-md-4">
                </div>
                <div class="col-md-8">
                    @{
                        string Assoctitle = (Model.is_accessories_required == true ? "" : Resources.Resources.SI_OSP_GBL_GBL_FRM_184);
                        string Assocdvdisabled = (Model.is_accessories_required == true ? "" : "dvdisabled");
                    }

                    <div id="divAccessories" title="@Assoctitle"> @Html.CheckBoxFor(m => m.is_accessories_required, new { @class = Assocdvdisabled })<b style="margin-left:5px;">@Resources.Resources.SI_OSP_GBL_GBL_FRM_177</b></div>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-md-4">
                </div>
                <div class="col-md-8 d-flex">
                    <b>@Resources.Resources.SI_OSP_GBL_NET_FRM_500 : @Model.associatedEntityCount</b>
                    <b class="ml-10">@Resources.Resources.SI_OSP_GBL_GBL_FRM_178 : @Model.childEntityCount</b>
                </div>
            </div>

            <table id="tbcloneDependent" class="grid" cellpadding="0" cellspacing="0">
                <thead>
                    <tr>
                        <th>
                            <input id="selectAll" type="checkbox"><label for='selectAll'> @Resources.Resources.SI_OSP_GBL_GBL_GBL_037</label>
                        </th>
                        <th>@Resources.Resources.SI_GBL_GBL_NET_FRM_098</th>
                        <th>@Resources.Resources.SI_OSP_GBL_GBL_GBL_001</th>
                        <th>@Resources.Resources.SI_OSP_GBL_GBL_GBL_160</th>
                        <th>@Resources.Resources.SI_OSP_GBL_GBL_FRM_179</th>
                    </tr>
                </thead>
              
                <tbody id="tbodycloneDependent">

                    @for (int i = 0; i < Model.lstCloneDependent.Count; i++)
                    {                        
                            string title = (Model.lstCloneDependent[i].is_accessories_placed == true ? "" : Resources.Resources.SI_OSP_GBL_GBL_FRM_184);
                            string dvdisabled = (Model.lstCloneDependent[i].is_accessories_placed == true ? "" : "dvdisabled");
                        <tr class="@(Model.lstCloneDependent[i].is_child_entity == true ? "child" : "" ) @(Model.lstCloneDependent[i].is_associated_entity == true ? "Associated" : "" ) ">
                            <td>
                                @Html.CheckBoxFor(m => Model.lstCloneDependent[i].is_include_in_clone, new { @class = "CheckAll-clone" })
                            </td>
                            <td>
                                @Model.lstCloneDependent[i].layer_title

                            </td>
                            <td>
                                @Model.lstCloneDependent[i].network_id

                            </td>
                            <td>
                                @Model.lstCloneDependent[i].display_name
                            </td>
                            <td title="@title">
                                @Html.CheckBoxFor(m => Model.lstCloneDependent[i].is_accessories_placed, new { @class = dvdisabled })
                            </td>
                            @Html.HiddenFor(m => Model.lstCloneDependent[i].network_id)
                            @Html.HiddenFor(m => Model.lstCloneDependent[i].display_name)
                            @Html.HiddenFor(m => Model.lstCloneDependent[i].system_id)
                            @Html.HiddenFor(m => Model.lstCloneDependent[i].entity_type)
                            @Html.HiddenFor(m => Model.lstCloneDependent[i].is_child_entity)
                            @Html.HiddenFor(m => Model.lstCloneDependent[i].is_associated_entity)
                        </tr>
                        }
                    


                </tbody>



            </table>

        }
        @if(Model.lstCloneDependent.Count==0)
        {
            <div>

                <label class="control-label col-sm-12" style="text-align: center">
                    <b>@Resources.Resources.SI_OSP_GBL_GBL_FRM_180</b>
                </label>
            </div>
        }
    </div>
    <div class="d-flex ModalFooter" id="dvBtnAction">

        @if (Model.lstCloneDependent.Count > 0)
        {
            <div class="col-md-6">
                <div style="float: left;">
                    <div style="width: 14px; height: 14px; background-color: #ffb399; border: 1px solid grey; margin-top: 2px; float: left; margin-left: -10px; margin-right: 10px; "></div> <b>@Resources.Resources.SI_OSP_GBL_GBL_FRM_182</b>
                </div>
                <div style="float:left;">
                    <div style="width: 14px; height: 14px; background-color: #65b4db; border: 1px solid grey; margin-top: 2px; float: left; margin-right: 10px; margin-left: 10px"></div> <b>@Resources.Resources.SI_OSP_GBL_GBL_FRM_183</b>
                </div>
            </div>
        }
        <div class="ml-auto">
            <a href="javascript:void(0);" class="btn btn-default mr-01" data-dismiss="modal" id="btnCancelAssignRoute" onclick="CloneDependentCancle()">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
            <input type="submit" class="btn btn-primary @(Model.lstCloneDependent.Count > 0 || Model.geomType==GeometryType.Line.ToString()||Model.is_accessories_required? "" : "dvdisabled")" id="btnSaveClone" onclick="return isFormValid()" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004" />
        </div>
    </div>

}
<script>
    $(document).ready(function () {
        //$("#selectAll").trigger("click");
        //$(".CheckAll-clone").trigger("click");
        $("#selectAll").prop("checked", true);
        $(".CheckAll-clone").prop("checked", true);


    })
    function CloneDependentCancle() {
        $("#closeModalPopup").trigger("click");
    }
    $("#selectAll").on("click", function () {
        $(".CheckAll-clone").prop("checked", $(this).prop("checked"));
    });

    $(".CheckAll-clone").on("click", function () {
        if (!$(this).prop("checked")) {
            $("#selectAll").prop("checked", false);
        }
    });
    function isFormValid() {
         

        if ($("#txtname").val() == "") {
            $('#txtname').css('border-color', 'red');
            return false;
        } else {
            $('#txtname').css('border-color', '');
        }
        if ($("#txtdescription").val() == "") {
            $('#txtdescription').css('border-color', 'red');
            return false;
        }
        else {
            $('#txtdescription').css('border-color', '');
        }
    }
</script>

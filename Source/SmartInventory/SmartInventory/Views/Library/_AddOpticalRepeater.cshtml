        <div class="TabContent--max-over">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"tab-pane active":"tab-pane active dvdisabled")" id="GISInfo">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_GBL_GBL_052 </legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtADBCode">
                                @Resources.Resources.SI_OSP_GBL_GBL_GBL_001
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }
                                :
                            </label>
                            <div class="col-sm-4">
                                <div id="txtMaskedNetworkId"></div>
                            </div>
                            <label class="control-label col-sm-2" for="txtBDBName">
                                @Resources.Resources.SI_OSP_GBL_NET_FRM_059
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }:
                            </label>
                            <div class="col-sm-45">
                                @Html.TextBoxFor(m => m.opticalrepeater_name,
                                 SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(
                                   new
                                   {
                                       @id = "txtOpticalRepeaterName",
                                       @class = "form-control",
                                       @maxlength = "50",
                                       autocomplete = "do-not-show-ac",
                                   }, (Model.networkIdType == "M" ? new { @required = true } : null)))
                                @*@Html.TextBoxFor(m => m.opticalrepeater_name, new { @class = "form-control", @id = "txtOpticalRepeaterName", @maxlength = "50" })*@
                            </div>
                        </div>
                        <div class="form-group row" style="display:none;">
                            <label class="control-label col-sm-2" for="txtLatitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_011<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.latitude, new { @class = "form-control", @id = "txtLatitude", @readonly = true })
                            </div>
                            <label class="control-label col-sm-2" for="txtLongitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_012<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.longitude, new { @class = "form-control", @id = "txtLongitude", @readonly = true })
                            </div>
                        </div>
                        <div class="form-group">
                            @CustomCoordinate()
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="ddlAmplifierType">@Resources.Resources.SI_OSP_GBL_GBL_GBL_215:</label>
                            <div class="col-sm-4">
                                @Html.DropDownListFor(m => m.amplifier_type, new SelectList(Model.lstAmplifierType.Select(x => new { Value = x.dropdown_key, Text = x.dropdown_value }), "Value", "Text"), "--Select--", new { @class = "chosen-select col-sm-12" })
                            </div>
                            <label class="control-label col-sm-2" for="txtAmplifierModel">@Resources.Resources.SI_OSP_GBL_GBL_GBL_216:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.amplifier_model, new { @class = "form-control", @id = "txtAmplifierModel" })
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2 " for="txtAmplifierWavelength">@Resources.Resources.SI_OSP_GBL_GBL_GBL_217 <br /> (nm):</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.amplifier_wavelength, new { @class = "form-control", @id = "txtAmplifierWavelength", @maxlength = "10" })
                            </div>
                            <label class="control-label col-sm-2 noWhiteSpa" for="txtSignalBoostValue">@Resources.Resources.SI_OSP_GBL_GBL_GBL_218  (@SmartInventory.Settings.ApplicationSettings.dBLossUnit):</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.signal_boost_value, new { @class = "form-control", @id = "txtSignalBoostValue", @onkeypress = "return allowNumberOnly(event,this);" })
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtNoiseFigure">@Resources.Resources.SI_OSP_GBL_GBL_GBL_219 (@SmartInventory.Settings.ApplicationSettings.dBLossUnit):</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.noise_figure, new { @class = "form-control", @id = "txtNoiseFigure" })
                            </div>
                            <label class="control-label col-sm-2 noWhiteSpa" for="txtSpecialGainFlatness">@Html.Raw(Resources.Resources.SI_OSP_GBL_GBL_GBL_220) (@SmartInventory.Settings.ApplicationSettings.dBLossUnit):</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.special_gain_flatness, new { @class = "form-control", @id = "txtSpecialGainFlatness" })
                            </div>

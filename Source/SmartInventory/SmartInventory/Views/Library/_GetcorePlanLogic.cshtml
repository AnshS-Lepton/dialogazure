@using Models
@model Models.FMSMaster
<style>
    .webgrid th, .webgrid td {
        border: none;
        padding: 5px;
    }
</style>
<link href="~/Content/css/HPSMTicket.css" rel="stylesheet" />

<div class="space-pad">
    <div class="row form-group">
    </div>
        <div class="row form-group">
            <label class="control-label col-md-2 col-sm-2">
                ODF1
            </label>
            <div class="col-md-4 col-sm-4">
                @*@Html.DropDownListFor(x => x.network_id, new SelectList(Model.lstODFdetails.Select(x => new { Value = x.network_id, Text = x.network_id }), "Value", "Text"), " -Select ODF1-", new { @class = "chosen-select form-control", @id = "ddlNetworkid1", @required = "required" })*@
               
                <input type="text" id="txtODF1" class="input-sm form-control" placeholder="Search ODF" onclick="if (this.value == 'Search ODF') { this.value = '' }" onblur="if(this.value==''){this.value='Search ODF'}" autocomplete="off">
          
                </div>
            <label class="control-label col-md-2 col-sm-2">
                ODF2
            </label>
        <div class="col-md-4 col-sm-4">
            @*@Html.DropDownListFor(x => x.network_id, new SelectList(Model.lstODFdetails.Select(x => new { Value = x.network_id, Text = x.network_id }), "Value", "Text"), " -Select ODF2-", new { @class = "chosen-select form-control", @id = "ddlNetworkid2", @required = "required" })*@
            
             <input type="text" id="txtODF2" class="input-sm form-control" placeholder="Search ODF2" onclick="if (this.value == 'Search ODF') { this.value = '' }" onblur="if(this.value==''){this.value='Search ODF'}" autocomplete="off">            
        </div>
        </div>
        <div class="row form-group">
            <label class="control-label col-md-2 col-sm-2">
                Required Core
            </label>
            <div class="col-md-4 col-sm-4">
                @Html.TextBoxFor(m => m.requiredcore, new { @id = "txtRequiredCore", @class = "input-sm form-control", @required = "required" })
               
            </div>
            <div class="col-md-6 col-sm-6 d-flex">
                <button type="button" class="ml-auto btn btn-default" onclick="si.checkAvailability();" id="btnCheckAvailability">Accessibility</button>

                <button type="button" class="btn btn-success ml-10" onclick="si.showReport();" id="btnShowReport">Show Report</button>
            </div>
        </div>

        <div class="row form-group">
            <label class="control-label col-md-2 col-sm-2">
               FiberLink <span class="vdesc"></span>
            </label>
            <div class="col-md-4 col-sm-4">
                @*@Html.DropDownListFor(x => x.system_id, new SelectList(Model.lstFiberlinkdetails.Select(x => new { Value = x.system_id, Text = x.network_id }), "Value", "Text"), " -Select fiberLink-", new { @class = "chosen-select form-control", @id = "ddlfiberlink" })*@
                <input type="text" id="txtfiberlink" class="input-sm form-control" placeholder=" Search FiberLink" onclick="if (this.value == 'Search FiberLink') { this.value = '' }" onblur="if(this.value==''){this.value='Search FiberLink'}" autocomplete="off">
            </div>

            <div class="col-md-6 col-sm-6 d-flex">
                <button type="button" class="ml-auto btn btn-success ml-10" onclick="validate();" disabled="disabled" id="btnSubmit">Submit</button>

            </div>
        </div>

    </div>


<script>
    $(document).ready(function () {
        $("input.numbers-only").on("paste", function () {
            var thisvalue = this;
            setTimeout(function () {
                var OnlyNumber = new RegExp(/^[0-9]{1,10}$/);

                if (!OnlyNumber.test(thisvalue.value)) {
                    thisvalue.value = "";
                }
            }, 0);
        });
        $('.chosen-select').chosen({ placeholder_text_multiple: '-All-', width: '100%' });
        //----------------------------------------------ODF1-------------------------------------------------------------------
        $('#txtODF1').on('keyup', function (e) {
            debugger;
            $('#txtODF1').autocomplete({

                source: function (request, response) {
                    debugger;
                   // var ntxt = request
                    var IsSrchValid = false;
                    //IsSrchValid = request.term.length >= 3 && (ntxt.length == 0 || ntxt.length == 1) ? true : ntxt.length > 1 && ntxt[1].length >= 3 ? true : false;
                    IsSrchValid = request.term.length >= 3  ? true : false;
                    if (IsSrchValid) {
                        var res = ajaxReq('Library/GetSearchResult', { searchText: request.term, search_type: 'ODF' }, true, function (data) {
                            if (data.length == 0) {
                                var result = [
                                    {
                                        label: 'No match Found'
                                    }
                                ];
                                response(result);
                                $("#txtODF1").removeClass('ui-autocomplete-loading');
                            }
                            else {
                                response($.map(data, function (item) {
                                    return {
                                        label: item.network_id
                                    }
                                }))
                            }
                        }, true, false);
                    }
                    else { $("#txtODF1").removeClass('ui-autocomplete-loading'); }
                },
                minLength: 3,
                select: function (event, ui) {
                    debugger;
                    if (ui.item.label == 'No match Found') {
                        // this prevents "no results" from being selected
                        event.preventDefault();
                        $("#txtODF1").removeClass('ui-autocomplete-loading');
                    }
                    else {
                        event.preventDefault();

                        if (ui.item.networ_id != null) {
                            $("#txtODF1").val(ui.item.network_id);

                            $("#txtODF1").removeClass('ui-autocomplete-loading');
                        }
                        else {
                            $("#txtODF1").val(ui.item.label);
                        }
                    }
                },
                open: function () {
                    $(this).removeClass("ui-corner-all").addClass("ui-corner-top");
                },
                close: function () {
                    $(this).removeClass("ui-corner-top").addClass("ui-corner-all");
                }
            });
        });
        //----------------------------------------------ODF2-------------------------------------------------------------------
        $('#txtODF2').on('keyup', function (e) {
            debugger;
            $('#txtODF2').autocomplete({

                source: function (request, response) {
                    debugger;
                    // var ntxt = request
                    var IsSrchValid = false;
                    //IsSrchValid = request.term.length >= 3 && (ntxt.length == 0 || ntxt.length == 1) ? true : ntxt.length > 1 && ntxt[1].length >= 3 ? true : false;
                    IsSrchValid = request.term.length >= 3 ? true : false;
                    if (IsSrchValid) {
                        var res = ajaxReq('Library/GetSearchResult', { searchText: request.term, search_type: 'ODF' }, true, function (data) {
                            if (data.length == 0) {
                                var result = [
                                    {
                                        label: 'No match Found'
                                    }
                                ];
                                response(result);
                                $("#txtODF2").removeClass('ui-autocomplete-loading');
                            }
                            else {
                                response($.map(data, function (item) {
                                    return {
                                        label: item.network_id
                                    }
                                }))
                            }
                        }, true, false);
                    }
                    else { $("#txtODF2").removeClass('ui-autocomplete-loading'); }
                },
                minLength: 3,
                select: function (event, ui) {
                    debugger;
                    if (ui.item.label == 'No match Found') {
                        // this prevents "no results" from being selected
                        event.preventDefault();
                        $("#txtODF2").removeClass('ui-autocomplete-loading');
                    }
                    else {
                        event.preventDefault();

                        if (ui.item.networ_id != null) {
                            $("#txtODF2").val(ui.item.network_id);

                            $("#txtODF2").removeClass('ui-autocomplete-loading');
                        }
                        else {
                            $("#txtODF2").val(ui.item.label);
                        }
                    }
                },
                open: function () {
                    $(this).removeClass("ui-corner-all").addClass("ui-corner-top");
                },
                close: function () {
                    $(this).removeClass("ui-corner-top").addClass("ui-corner-all");
                }
            });
        });
       // ----------------------------------------------FiberLink---------------------------------------------------------------------------
        $('#txtfiberlink').on('keyup', function (e) {
            debugger;
            $('#txtfiberlink').autocomplete({

                source: function (request, response) {
                    debugger;
                    // var ntxt = request
                    var IsSrchValid = false;
                    //IsSrchValid = request.term.length >= 3 && (ntxt.length == 0 || ntxt.length == 1) ? true : ntxt.length > 1 && ntxt[1].length >= 3 ? true : false;
                    IsSrchValid = request.term.length >= 3 ? true : false;
                    if (IsSrchValid) {
                        var res = ajaxReq('Library/GetSearchResult', { searchText: request.term,search_type:'fiberlink' }, true, function (data) {
                            if (data.length == 0) {
                                var result = [
                                    {
                                        label: 'No match Found'
                                    }
                                ];
                                response(result);
                                $("#txtfiberlink").removeClass('ui-autocomplete-loading');
                            }
                            else {
                                response($.map(data, function (item) {
                                    return {
                                        label: item.network_id
                                    }
                                }))
                            }
                        }, true, false);
                    }
                    else { $("#txtfiberlink").removeClass('ui-autocomplete-loading'); }
                },
                minLength: 3,
                select: function (event, ui) {
                    debugger;
                    if (ui.item.label == 'No match Found') {
                        // this prevents "no results" from being selected
                        event.preventDefault();
                        $("#txtfiberlink").removeClass('ui-autocomplete-loading');
                    }
                    else {
                        event.preventDefault();

                        if (ui.item.networ_id != null) {
                            $("#txtfiberlink").val(ui.item.network_id);

                            $("#txtfiberlink").removeClass('ui-autocomplete-loading');
                        }
                        else {
                            $("#txtfiberlink").val(ui.item.label);
                        }
                    }
                },
                open: function () {
                    $(this).removeClass("ui-corner-all").addClass("ui-corner-top");
                },
                close: function () {
                    $(this).removeClass("ui-corner-top").addClass("ui-corner-all");
                }
            });
        });
    });
    
    function validate() {
        debugger;
        if ($("#txtfiberlink").val()==""){ alert('Fiber Link can not be empty'); return false; }
        
        if ($("#txtODF1").val() == $("#txtODF2").val()) { alert('ODF1 and OD2 can not be same'); return false; }

        var number = Number($("#txtRequiredCore").val());

        if (isNaN(number)) {
            $("#btnSubmit").prop("disabled", false);
            alert("Invalid input: " + "Please enter a valid number.");
            return false;

        } else if (number < 1 || number > 48) {
            $("#btnSubmit").prop("disabled", false);
            alert("Invalid input: " + "The required core must be between 1 and 48.");
            return false;
        }
        else { si.saveCorePlanLogic(); }
    }

    
    

</script>
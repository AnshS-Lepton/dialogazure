@using Models
@model Models.FMSMaster
<style>
    .webgrid th, .webgrid td {
        border: none;
        padding: 5px;
    }

    .pose-plus {
        position: absolute;
        right: -28px;
        top: 0;
        z-index: 9;
    }

        .pose-plus button {
            min-height: 28px;
        }

        .pose-plus i {
            line-height: 21px;
        }
</style>
<link href="~/Content/css/HPSMTicket.css" rel="stylesheet" />
@Html.HiddenFor(m => m.requiredcore, new { @id = "hdnCheckforCLP" })
@Html.HiddenFor(m => m.lstFiberlinkdetails.FirstOrDefault().network_id, new { @id = "hdnFiberLinkNetworkId" })
<div class="space-pad">
    <div class="row form-group">
    </div>
    <div class="row form-group">
        <label class="control-label col-md-2 col-sm-2">
            ODF1 <i class="clsMandatory">*</i>
        </label>
        <div class="col-md-4 col-sm-4">
            @*@Html.DropDownListFor(x => x.network_id, new SelectList(Model.lstODFdetails.Select(x => new { Value = x.network_id, Text = x.network_id }), "Value", "Text"), " -Select ODF1-", new { @class = "chosen-select form-control", @id = "ddlNetworkid1", @required = "required" })*@
            <a href="#" class="iconBaricomoon" title="@Resources.Resources.GBL_GBL_GBL_JQ_GBL_001">
                <span class="icon-info" id="pEntity" data-Entity="0" onclick="core_planner_info_tool(this)"></span>
            </a>
            <input type="text" id="txtODF1" class="input-sm form-control" placeholder="Search ODF/SpliceClosure" onclick="if (this.placeholder !== '') { this.placeholder = '' }" onblur="if(this.placeholder===''){this.placeholder='Search ODF/SpliceClosure'}" autocomplete="off">

        </div>
        <label class="control-label col-md-2 col-sm-2">
            ODF2<i class="clsMandatory">*</i>
        </label>
        <div class="col-md-4 col-sm-4">
            @*@Html.DropDownListFor(x => x.network_id, new SelectList(Model.lstODFdetails.Select(x => new { Value = x.network_id, Text = x.network_id }), "Value", "Text"), " -Select ODF2-", new { @class = "chosen-select form-control", @id = "ddlNetworkid2", @required = "required" })*@
            <a href="#" class="iconBaricomoon" title="@Resources.Resources.GBL_GBL_GBL_JQ_GBL_001">
                <span class="icon-info" id="sEntity" data-Entity="1" onclick="core_planner_info_tool(this)"></span>
            </a>
            <input type="text" id="txtODF2" class="input-sm form-control" placeholder="Search ODF/SpliceClosure" onclick="if (this.placeholder !== '') { this.placeholder = '' }" onblur="if(this.placeholder===''){this.placeholder='Search ODF/SpliceClosure'}" autocomplete="off">
        </div>
    </div>
    <div class="row form-group">
        <label class="control-label col-md-2 col-sm-2">
            Required Core <i class="clsMandatory">*</i>
        </label>
        <div class="col-md-4 col-sm-4">
            @Html.TextBoxFor(m => m.requiredcore, new { @id = "txtRequiredCore", @class = "input-sm form-control", @maxlength = "2", @required = "required" })

        </div>
        <div class="col-md-6 col-sm-6 d-flex">
            <button type="button" class="ml-auto btn btn-default" onclick="si.checkAvailability();" id="btnCheckAvailability">Check Feasibility</button>

            <button type="button" class="btn btn-success ml-10" onclick="si.showReport();" id="btnShowReport">Download Report</button>
        </div>
    </div>

    <div class="row form-group">
        <label class="control-label col-md-2 col-sm-2">
            FiberLink <i class="clsMandatory">*</i><span class="vdesc"></span>
        </label>
        <div class="col-md-4 col-sm-4">
            @*@Html.DropDownListFor(x => x.system_id, new SelectList(Model.lstFiberlinkdetails.Select(x => new { Value = x.system_id, Text = x.network_id }), "Value", "Text"), " -Select fiberLink-", new { @class = "chosen-select form-control", @id = "ddlfiberlink" })*@
            <input type="text" id="txtfiberlink" class="input-sm form-control" placeholder="@Resources.Resources.SI_ISP_GBL_GBL_GBL_035 @Resources.Resources.SI_OSP_GBL_NET_FRM_421 / @Resources.Resources.SI_OSP_GBL_GBL_GBL_001" onclick="if (this.placeholder !== '') { this.placeholder = '' }" onblur="if(this.placeholder===''){this.placeholder='@Resources.Resources.SI_ISP_GBL_GBL_GBL_035 @Resources.Resources.SI_OSP_GBL_NET_FRM_421 / @Resources.Resources.SI_OSP_GBL_GBL_GBL_001'}" autocomplete="off">
            <div class="pose-plus"><button class="btn btn-primary" id="btncreatelinkCPL" title="Create new fiberlink"><i class="fa fa-plus"></i></button> </div>
        </div>

        <div class="col-md-6 col-sm-6 d-flex">
            <button type="button" class="ml-auto btn btn-success ml-10" onclick="validate();" disabled="disabled" id="btnSubmit">Submit</button>

        </div>
    </div>
</div>

<script src="~/Content/js/core_planner/core_plan_logic.js"></script>
        padding: 6px 0px 6px 20px;
        list-style: none;
        background-repeat: no-repeat;
        background-position: left center;
        background-size: 17px;
        border-bottom: 1px solid #dedbdb;
        margin-left: 5px;
        margin-right: 5px;
        max-width: 165px !important;
        overflow: hidden;
        height: auto;
    }
    .WrapText {
        width: 140px;
        overflow: hidden;
        display: inline-block;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ui-state-focus {
        border-width: 0px 0px 0px 0px !important;
        border-bottom: 1px solid #dedbdb !important;
        background-color: #bab3b3 !important;
    }
     .TickCrossicon {
        /*position: absolute;*/
        position: relative;
        font-size: 13px;
        right: 0;
        /*margin: 6px 18px 0px 0px;*/
       margin: -19px 0px 0px 66px;
    }

        .TickCrossicon i {

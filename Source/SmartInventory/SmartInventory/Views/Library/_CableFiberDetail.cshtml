
@model Models.CableFiberDetail
@using Models;
@using SmartInventory.Settings;
@{

    WebGrid grid = new WebGrid(source: Model.ViewCableFiberDetail, canSort: false, canPage: false);
    var userModuleList = (List<string>)Session["ApplicableModuleList"];
    var editPermission = Utility.MiscHelper.GetLayerEditPermission(Model.cable_id, (List<NetworkLayer>)Session["NerworkLayerDetails"], Model.cable_network_status, EntityType.Cable.ToString());

}


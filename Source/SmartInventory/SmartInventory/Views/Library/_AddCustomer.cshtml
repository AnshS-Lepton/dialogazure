                    <span class="spanSide go-right"><i class="fa fa-angle-right" aria-hidden="true"></i></span>
                    <span class="spanSide" id="dropdown" style="border-left: 1px solid #b9b7b7;     margin-left: -4px;"><i class="fa fa-angle-down" aria-hidden="true"></i></span>
                    <div class="arrowDropUp"></div>
                    <div class="dropMenu">
                        <div class="alltabs">@Resources.Resources.SI_OSP_CAB_NET_FRM_014</div>
                        <ul>
                            <li class="active"><a class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010 @(Model.lstUserModule.Contains("ENT-DTL-GI")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "block;")"
                             href="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"#GISInfo":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>
                            <li><a  class="@(Model.lstUserModule.Contains("ENT-DTL-IASC")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_004 @(Model.lstUserModule.Contains("ENT-DTL-IASC")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-IASC") ? "" : "block;")"
                              href="@(Model.lstUserModule.Contains("ENT-DTL-IASC")?"#ItemAsso":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_004</a></li>
                            @if (layerDetail != null && layerDetail.is_pod_association_allowed)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-COAS")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_159 @(Model.lstUserModule.Contains("ENT-DTL-COAS")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-COAS") ? "" : "block;")"
                              href="@(Model.lstUserModule.Contains("ENT-DTL-COAS")?"#PODAssoctn":"")" id="Pod_Association" onclick="si.GetPODAssociationDetail('@Model.geom', '@Model.system_id','@EntityType.Customer.ToString()', '@Model.primary_pod_system_id', '@Model.secondary_pod_system_id');" data-toggle="tab">@layer_Detail.layer_title <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_159 </label></a></li>
                            }
                            <!--Reigon Additional Attribute to show the partial view-->
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ADA")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_FRM_222 @(Model.lstUserModule.Contains("ENT-DTL-ADA")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ADA") ? "" : "block;")"
                               href="@(Model.lstUserModule.Contains("ENT-DTL-ADA")?"#AdditionalAttributes":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_FRM_222</a></li>
                            <!--End Reigon Additional Attribute-->
                            @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_reference_allowed == true)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_537 @(Model.lstUserModule.Contains("ENT-DTL-ENR")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENR") ? "" : "block;")"
                                href="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"#Reference":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="TabContent--max-over">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"tab-pane active":"tab-pane active dvdisabled")" id="GISInfo">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_GBL_GBL_052 </legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtCustomerCode">
                                @Resources.Resources.SI_OSP_CUS_NET_FRM_001
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }
                                :
                            </label>
                            <div class="col-sm-4">
                                @*<div id="txtMaskedNetworkId"></div>*@
                                @if (Model.system_id > 0)
                                {
                                    @Html.TextBoxFor(m => m.network_id, new { @class = "form-control clsReadOnly numbers-only", @minlength = "6", @maxlength = "7", @id = "txtNetworkId", @readonly = true })
                                }
                                else
                                {
                                    Model.network_id = string.Empty;
                                    @Html.TextBoxFor(m => m.network_id, new { @class = "form-control numbers-only", @onkeypress = "return allowOnlyNumber(event);", @minlength = "6", @maxlength = "7", @id = "txtNetworkId" })
                                    @Html.ValidationMessageFor(model => model.network_id)
                                }
                            </div>
                            <label class="control-label col-sm-2" for="txtCustomerName">
                                @Resources.Resources.SI_OSP_GBL_NET_FRM_059
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }:
                            </label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.customer_name,
                                    SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(
                               new
                               {
                                   @class = "form-control",
                                   @maxlength = "50",
                                   autocomplete = "do-not-show-ac"
                               }, (Model.networkIdType == "M" ? new { @required = true } : null)))
                                @*@Html.TextBoxFor(m => m.customer_name, new { @class = "form-control", @maxlength = "50" })*@
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtLatitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_011<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.latitude, new { @class = "form-control clsReadOnly", @readonly = true })
                            </div>
                            <label class="control-label col-sm-2" for="txtLongitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_012<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.longitude, new { @class = "form-control clsReadOnly", @readonly = true })
                            </div>
                        </div>
                        <div class="form-group row">
                            @CustomCoordinate()
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtPinCode">@Resources.Resources.SI_OSP_GBL_GBL_GBL_009:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.pin_code, new { @class = "form-control", @onkeypress = "return si.allowOnlyNumber(event);", @maxlength = "6", @minlength = "6", autocomplete = "new-password" })
                                @Html.ValidationMessageFor(model => model.pin_code)
                            </div>
                            <label class="control-label col-sm-2" for="ddlActivationStatus">@Resources.Resources.SI_OSP_GBL_NET_FRM_001:</label>
                            <div class="col-sm-4">
                                @Html.DropDownListFor(m => m.activation_status, new SelectList(Model.lstActivationStatus.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "Select Activation Status", new { @class = "chosen-select col-sm-12", @style = "padding:0;", @id = "ddlActivationStatus" })
                            </div>

                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtAddress">@Resources.Resources.SI_OSP_GBL_GBL_GBL_008:</label>
                            <div class="col-sm-10">
                                @Html.TextBoxFor(m => m.address, new { @class = "form-control", @id = "txtAddress", @maxlength = "100", autocomplete = "do-not-show-ac" })
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtActivationDate">@Resources.Resources.SI_OSP_GBL_NET_FRM_002 :</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.activation_date, new { @class = "form-control clsReadOnly", placeholder = "DD-MMM-YYYY", @readonly = true, @style = "background:#fff;" })
                                <img id="imgActvDate" class="assign-calen" src="~/Content/images/calendar.png" />
                            </div>
                            <label class="control-label col-sm-2" for="txtDeactivationDate">@Resources.Resources.SI_OSP_GBL_NET_FRM_003 :</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.deactivation_date, new { @class = "form-control clsReadOnly", placeholder = "DD-MMM-YYYY", @readonly = true, @style = "background:#fff;" })
                                <img id="imgDeactDate" class="assign-calen" src="~/Content/images/calendar.png" />
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="ddlActivationStatus">@Resources.Resources.SI_OSP_CUS_NET_GBL_001:</label>
                            <div class="col-sm-4">
                                @Html.DropDownListFor(m => m.customer_type, new SelectList(Model.lstCustomerType.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "Select Customer Type", new { @class = "chosen-select col-sm-12", @style = "padding:0;", @id = "ddlCustomerType" })
                            </div>
                            <label class="control-label col-sm-2" for="ddlservicetype">@Resources.Resources.SI_OSP_GBL_GBL_FRM_171:</label>
                            <div class="col-sm-4">
                                @Html.DropDownListFor(m => m.SelectedServiceType, new SelectList(Model.lstServiceType.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @style = "padding:0;", @id = "ddlCustomerServiceType" })
                            </div>

                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtMobPhone">@Resources.Resources.SI_OSP_GBL_GBL_FRM_172<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.mobile_no, new { @class = "form-control numbers-only", @maxlength = "10", @onkeypress = "return allowOnlyNumber(event);" })
                                @Html.ValidationMessageFor(model => model.mobile_no)
                            </div>
                            <label class="control-label col-sm-2" for="txtMobPhone">@Resources.Resources.SI_OSP_GBL_GBL_FRM_173:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.phone_no, new { @class = "form-control numbers-only", @maxlength = "11", @onkeypress = "return allowOnlyNumber(event);" })
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtMobPhone">@Resources.Resources.SI_OSP_STR_NET_FRM_055:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.email_id, new { @class = "form-control ", @maxlength = "100" })
                                @Html.ValidationMessageFor(model => model.email_id)

                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_GBL_GBL_GBL_006</label>
                            <div class="col-sm-10">
                                @Html.TextAreaFor(m => m.remarks, new { @class = "form-control textarea-maxlen-validate", @maxlength = "100" })
                            </div>
                        </div>
                    </fieldset>
                    @if (Model.lstUserModule.Contains("PROJ"))
                    {
                        <fieldset class="the-fieldset">
                            <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_GBL_FRM_001</legend>
                            @ProjectSpecifications()
                        </fieldset>
                    }
                    <div>
                        @GeographicDetails()
                    </div>
                </div>
                <div class="tab-pane" id="ItemAsso">
                    @Html.Partial("~/Views/ItemTemplate/_ItemAssociation.cshtml", Model.objIspEntityMap)
                </div>
                <div class="tab-pane" id="PODAssoctn"></div>
                <!--Reigon Additional Attribute to show the partial view-->
                <div class="tab-pane" id="AdditionalAttributes">
                    @AdditionalAttributes()
                </div>
                <!--End Reigon Additional Attribute-->
                <div class="tab-pane" id="Reference">
                    @Reference()
                </div>
            </div>
        </div>
        <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"d-flex ModalFooter":"d-flex ModalFooter dvdisabled")" id="dvBtnAction">
            @if (Model.system_id > 0)
            {
                <div class="ModelFooterInfo">
                    <label for="txtLongitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_007:</label>
                    <label class="model-label-info" title="@(Model.created_on != null ? Utility.MiscHelper.FormatDateTime(Model.created_on.ToString()) : string.Empty)">@(Model.created_on != null ? Utility.MiscHelper.TimeAgo(Model.created_on.ToString()) : string.Empty)</label>
                </div>
            }
            <div class="ml-auto">
                <a href="javascript:void(0);" class="btn btn-default mr-01" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                @if (Model.system_id > 0)
                {
                    <button type="button" onclick="formPost();" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnUpdateArea" disabled="disabled">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_003</button>
                }
                else
                {
                    <button type="button" onclick="formPost();" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnSaveArea" disabled="disabled">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
                }

            </div>
        </div>
    }
</div>
<script>
                var inputs = [];
                $(document).ready(function () {
                     
                    callFormValidator("frmAddCustomer");
                    si.setSurveyDateTimeCalendar("activation_date", "imgActvDate", "0", false);
                    si.setSurveyDateTimeCalendar("deactivation_date", "imgDeactDate", "0", false);

                    $('.chosen-select').chosen({ width: '100%' });
                    EnableDisableUpdateButton("frmAddCustomer", '@Model.system_id' > 0 ? "btnUpdateArea" : "btnSaveArea");

                    //APPLY INPUT MASK ON NETWORK ID..
                    @*getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');
        $("#frmAddCustomer").on("submit", function () {
            $("#network_id").val($("#txtMaskedNetworkId").dxTextBox("option", "text").toUpperCase());
        });*@
                    //Region Additional-Attributes
                    $("#frmAddCustomer").on("submit", function () {
                         if (@ApplicationSettings.IsCustomerExtraValidationRequired) {
                        var CustomerType = $('#ddlCustomerType').val();
                        var CustomerService = $('#ddlCustomerServiceType').val();
                        if (CustomerType == '') {
                            $('#ddlCustomerType_chosen').addClass('input-validation-error');
                            return false;
                        }
                        else {
                            $('#ddlCustomerType_chosen').removeClass('input-validation-error');

                        }

                        if (CustomerService != null) {
                            $('#ddlCustomerServiceType_chosen').removeClass('input-validation-error');
                        }
                        else {
                            $('#ddlCustomerServiceType_chosen').addClass('input-validation-error');
                            return false;

                        }
                    }
                        //For AdditionalAttributes to set json and saving
                        additionalAttributesUtility.SetJsonValue("#frmOtherInfo", "#hdnOtherInfo");
                        //end region Additional-Attributes
                    });
                    //end region

                    $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });

                    //-----------------
                    $("#ddlCustomerServiceType").attr('data-placeholder', "Select Service Type").trigger("chosen:updated");
                    var SelectedServiceTypes = '@Model.service_type';
                    $("#ddlCustomerServiceType").val(SelectedServiceTypes.split(',')).trigger("chosen:updated");
                });
                function formPost() {

                    //$('#parent_system_id').val(0);
                    //$('#parent_entity_type').val('Province');
                    if ($('#ddlUnitList').length > 0 && $('#ddlUnitList').val() != '' && $('#ddlUnitList').val() != '0') {
                        $('#parent_system_id').val($('#ddlUnitList').val());
                        $('#parent_entity_type').val('UNIT');
                        $('#parent_network_id').val($('#ddlUnitList :selected').text());
                    } else if ($('#ddlStructureList').val() != '') {
                        $('#parent_system_id').val($('#ddlStructureList').val());
                        $('#parent_entity_type').val('Structure');
                        $('#parent_network_id').val($('#ddlStructureList :selected').text());
                    }
                    if (si.isValidAssociation()) {
                        $("#frmAddCustomer").submit();
                    }
                }

                $("input.numbers-only").on("paste", function () {
                    var thisvalue = this;
                     
                    setTimeout(function () {
                        var OnlyNumber = new RegExp(/^[0-9]{1,10}$/);
                         
                        if (!OnlyNumber.test(thisvalue.value.trim())) {
                            thisvalue.value = "";
                        }
                        else {
                            thisvalue.value = thisvalue.value.trim();
                        }

                    }, 0);
                });

    function Validate_NetworkId() {
         
                    if ('@Model.system_id' == 0 && $('#txtNetworkId').val() != '') {
                         
                        var inputLength = $('#txtNetworkId').val().length;
                        var canId = $('#txtNetworkId').val();
                        var ret = false;
                        if (inputLength <= 0 || inputLength > 7) {
                            // Validate network id for duplicate....
                            //Ajax method
                            //alert('Customer code should be 1 to 7 character long!');
                            ret = false;
                        }
                        else {
                            ajaxReq('Library/IsNetworkIdExist', { networkId: canId, entityType: 'Customer', networkStage: 'P' }, false, function (resp) {
                                if (resp != undefined && resp.status == 'OK') {
                                    alert(MultilingualKey.SI_OSP_CUS_JQ_FRM_001);
                                    ret = false;
                                }
                                else {
                                    ret = true;
                                }
                            }, true, false);
                        }
                    }
                    else {
                        return true;
                    }
                    return ret;
                }



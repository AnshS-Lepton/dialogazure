@model List<Models.TrenchCustomerDetailsAttachment>
@if (Model != null && Model.Count > 0)
{
    <div class="form-group" style="text-align:right;">
        <div class="col-sm-8 UploadAction"></div>
        @*<div class="col-sm-4 icon-Download cptr" onclick="si.EntityMaintainenceCharges.attachment.downLoadFile(@Model[0].entity_system_id);" id="divDownloadDocuments" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_048" style="float:right; text-align:right;">@Resources.Resources.SI_OSP_GBL_NET_FRM_049</div>*@
    </div>
    int cnt = 0;
    <div class="form-group" style="padding-top: 2px;">
        <table class="grid" id="ulDocumentUpload">
            <thead>
                <tr class="webGridHeader">
                    <th>SNo.</th>
                    <th>File Name</th>
                    <th>File Size</th>
                    <th>File Type</th>
                    <th>Uploaded By</th>
                    <th>Uploaded On</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {

                    cnt++;
                    <tr id="liDocumentUpload_@item.id"
                        data-entity-id="@item.customer_id"
                        data-system-id="@item.trench_id"
                        data-image-location="@item.file_location"
                        data-image-name="@item.file_name">
                        <td>@cnt</td>
                        @*<td>
                                <a style="cursor:pointer;" href="Main/DownloadFileById?id=@item.id">@item.org_file_name</a>
                            </td>*@
                        <td style="text-align:left;">
                            @item.org_file_name
                        </td>
                        <td style="text-align:center;">@item.file_size_converted</td>
                        <td style="text-align:center;">@item.file_extension.Replace(".", "")</td>
                        <td style="text-align:center;">@item.uploaded_by_name</td>
                        <td style="text-align:center;">@item.uploadedon</td>
                        @*<td><div class="col-sm-1 icon-Close cptr" onclick="si.EntityMaintainenceCharges.attachment.deleteFile(@item.id,@item.entity_system_id,@item.entity_type);" id="divDeleteDocuments" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_050" style="text-align:center;color:red;"></div></td>*@
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

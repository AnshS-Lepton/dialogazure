<script type="text/javascript">
    var inputs = [];
    $(document).ready(function () {
        callFormValidator("frmAddDuct");
        $('.chosen-select').chosen({ width: '100%' });
        EnableDisableUpdateButton("frmAddDuct", @Model.system_id > 0 ? "btnUpdateSubArea" : "btnSaveDuct");
        //APPLY INPUT MASK ON NETWORK ID..
        getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');
        $('#no_of_ducts_created').val('1').trigger('chosen:updated')

        $("#frmAddDuct").on("submit", function () {
            $("#network_id").val($("#txtMaskedNetworkId").dxTextBox("option", "text").toUpperCase());
            si.upperCaseNetWorkId();
            //For AdditionalAttributes to set json and saving
            additionalAttributesUtility.SetJsonValue("#frmOtherInfo", "#hdnOtherInfo");
            //end region Additional-Attributes
            if (!entityReferencevalidation())
                return false;

            if(!entityMaintainence())
                return false;
        });

        $("#btnSaveDuct").on("click", function (e) {


            var calculatedLen = parseFloat($("#calculated_length").val());
            var manualLen = parseFloat($("#manual_length").val());

            if (calculatedLen == 0) {
                alert( MultilingualKey.SI_OSP_GBL_JQ_FRM_118);//Calculated length should be greater than 0 !!
                return false;
            }

            if (calculatedLen > manualLen) {
                alert( MultilingualKey.SI_OSP_GBL_JQ_GBL_002);//Calculated length should be equal or smaller than manual length !!
                return false;
            }
        });

        //$(".emptyColorPicker").spectrum({
        //    allowEmpty: true,
        //    preferredFormat: "hex"
        //});
        $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });
        @*if (@Model.system_id> 0 ) {
            $('#duct_count').prop('disabled', true).trigger("chosen:updated");
        }*@

    });
    function formPost() {

        if ($('#txtbomsubcategory').val() == '') {
            $('#txtbomsubcategory').next().addClass('input-validation-error');
            return false;
        }

        else {
            $("#frmAddDuct").submit();
        }
    }

</script>


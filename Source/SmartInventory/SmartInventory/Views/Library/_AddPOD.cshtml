}
<style>
    div.scrollmenu {
        background-color: #f8f8f8;
        white-space: nowrap;
        font-size: 14px;
        display: flex;
        border-bottom: 1px solid #efefef;
        position: relative;
    }

    div.scrollerhide {
        overflow: hidden;
    }

        div.scrollerhide .nav-tabs {
            display: flex;
        }

            div.scrollerhide .nav-tabs > li > a {
                padding: 7px 8px;
                font-weight: normal;
            }


    .spanSide {
        padding: 8px 10px;
        background-color: #efefef;
        cursor: pointer;
        font-size: 16px;
        height: 100%;
        top: 8px;
        position: relative;
    }

    .scrollmenu .overflow a {
        display: inline-block;
        color: #6a6a6a;
        text-align: center;
        padding: 7px 12px;
        text-decoration: none;
        border-radius: 0px;
    }

        .scrollmenu .overflow a:hover {
            background-color: #30be74;
            color: #fff;
            border-radius: 0px;
        }

    .dropMenu ul li a {
        color: #6a6a6a;
        text-decoration: none;
        border-radius: 0px;
    }
    /* Track */
    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    /* Handle */
    ::-webkit-scrollbar-thumb {
        background: #888;
    }

        /* Handle on hover */
        ::-webkit-scrollbar-thumb:hover {
            background: #555;
        }

    .dropMenu {
        position: absolute;
        width: 200px;
        height: 250px;
        background-color: white;
        right: 0px;
        margin: 0px 4px 0px 0px;
        box-shadow: #ccc 0px 0 10px;
        overflow: auto;
        color: #888;
        display: none;
        top: 28px;
        z-index: 9;
    }

        .dropMenu ul {
            padding: 0px;
            margin: 35px 0px 0px;
        }

            .dropMenu ul li {
                list-style: none;
                padding: 8px 0px 8px 10px;
                cursor: pointer;
            }

                .dropMenu ul li:hover {
                    background-color: #efefef;
                    border-left: 3px solid #02bb8a;
                    font-weight: 600;
                }


        .dropMenu .alltabs {
            width: 198px;
            padding: 10px;
            background-color: #f8f8f8;
            position: fixed;
        }

    .arrowDropUp {
        width: 0;
        height: 0;
        border-left: 8px solid transparent;
        border-right: 8px solid transparent;
        border-bottom: 8px solid #ffffff;
        position: absolute;
        z-index: 12;
        right: 0px;
        margin: 20px 10px 0px 0px;
        display: none;
    }

    .dropMenu::-webkit-scrollbar-thumb {
        background: #02bb8a;
    }

    .activeSideMenu {
        background-color: #efefef;
        border-left: 3px solid #02bb8a;
        font-weight: 600;
    }

    .go-left {
        border-right: 1px solid #b9b7b7;
    }

    .go-right {
        border-left: 1px solid #b9b7b7;
    }
</style>

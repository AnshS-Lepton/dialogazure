                                @Html.DropDownListFor(m => m.aerial_location, new SelectList(Model.listaerialLocation.Select(x => new { Value = x.dropdown_value, Text = x.dropdown_key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control" })

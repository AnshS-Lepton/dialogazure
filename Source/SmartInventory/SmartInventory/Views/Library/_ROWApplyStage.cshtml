}

<script type="text/javascript">
    //AddATStatusRow
    var inputs = [];
    $(document).ready(function () {
        $('#txtRiRate,#txtAccessCharge').on('input', function () {
            this.value = this.value.match(/^\d+\.?\d{0,2}/);
        });
        $("#btnApplyRow").on("click", function () {
            var isValid=true;
            isValid=validateROW();
            if($('#starta_type').val()!='' && $('#ddlROWChargeTemplates').val()=='')
            {
                alert(MultilingualKey.SI_OSP_ROW_JQ_FRM_001);
                return false;
            }
            if($('#txtPulledCables').val()!='' && $('#txtPulledCables').val()!=null)
            {
                isValid=si.ROW.isAttachmentTypeValid(true);
            }
            if(isValid)
            {
                $('#frmApplyROW').submit();
            }
        });

        $('#ApplyStage .control-label[title!=""]').tooltip({ title: '', html: true, placement: "bottom" });
        //$('.mrgn_btm,.control-label').addClass('customWidth');
        $("#btnAddRemarks").on("click", function () {
            var RowIndex = $('#divRemarks .rowremarks ').length;
            AddRemarkRow(RowIndex,@Model.row_system_id,'Apply','divRemarks');
        });
        $('.chosen-select').chosen({ width: '100%' });
        callFormValidator("frmApplyROW");
        si.setDateTimeCalendar("rowApplydate", "imgApplyDate", false, false);
        if ('@Model.system_id' > 0)
        {
            $('#divROWApplyActions').hide();
            $('.UploadAction,#btnAddRemarks').hide();
        }
        else
        {
            $.each($("input[type='text']"), function (i, item) {
                if($(item).val()==0)
                {
                    $(item).val(null);
                }
            })
            $('#txtRiRate').on('keyup', function() {
                var riAmount=si.ROW.setRIAmount();
            })
            $('#txtAccessCharge').on('keyup', function() {
                var nonRefundableAmount= si.ROW.getNonRefundableAmount($('#txtAccessCharge').val(),'@Model.route_length');
                $('#txtNonRefundableDepositAmount').val(nonRefundableAmount);
                var totalAmount= si.ROW.getTotalAmount();
                if(!isNaN(totalAmount)){ $('#txtTotalAmount').val(totalAmount);}

            })
        }
    });

    function validateROW() {

        if ('@Model.rowType' == 'PIT' && ($('#applied_pit').val() == '' || $('#applied_pit').val() == null || $('#applied_pit').val() == 0)) {
            alert(MultilingualKey.SI_OSP_ROW_JQ_FRM_002 );
            return false;
        }
        return true;
    }
</script>
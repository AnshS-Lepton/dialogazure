@model IList<Models.FaultStatusHistory>
@using Utility;
@{
    WebGrid webGrid = new WebGrid(source: Model, canSort: false, canPage: false);
}

<div style="min-height:260px; width: 99%; background-color: white;padding-left: 14px;margin-top: 10px;">

    @if (Model.Count != 0)
    {
        @webGrid.GetHtml(
            htmlAttributes: new { @id = "WebGrid", @style = "width: 100%;" },
            tableStyle: "webgrid",
                         headerStyle: "webGridHeader",
                            alternatingRowStyle: "alt",
        columns: webGrid.Columns(

                             webGrid.Column("fault_status", Resources.Resources.SI_OSP_GBL_GBL_GBL_014),
                             webGrid.Column("fault_status_updated_on", Resources.Resources.SI_OSP_GBL_NET_FRM_387, format: @<text> @(item.fault_status_updated_on == null ? item.fault_status_updated_on : MiscHelper.FormatDate(item.fault_status_updated_on.ToString())) </text>),
                             //webGrid.Column("created_on", "Modified On", format: @<text> @(item.created_on == null ? item.created_on : MiscHelper.FormatDateTime(item.created_on.ToString())) </text>),
                             webGrid.Column("updated_by",Resources.Resources.SI_OSP_GBL_NET_FRM_383),
                             webGrid.Column("requested_by", Resources.Resources.SI_OSP_GBL_NET_FRM_384, format:@<text><span style="white-space: normal; word-break:break-all">@item.requested_by</span></text>),
                             webGrid.Column("rca", Resources.Resources.SI_OSP_GBL_NET_FRM_386, format:@<text><span style="white-space: normal; word-break:break-all">@item.rca</span></text>)
                             ))
}
else
{
        <div class="nr-found">
            <span>@Resources.Resources.SI_OSP_GBL_NET_RPT_042!</span>
        </div>
    }
</div>



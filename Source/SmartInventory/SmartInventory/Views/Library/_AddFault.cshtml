@model Models.Fault
@using Models;
@using SmartInventory.Settings;

@helper pageMessage()
{
    { Html.RenderPartial("_PageMessage", Model.objPM); }

}
@helper CustomCoordinate()
{
    { Html.RenderPartial("~/Views/Library/_CustomCoordinate.cshtml", (ICustomCoordinate)Model); }
}
@helper Reference()
{
    { Html.RenderPartial("~/Views/Library/_Reference.cshtml", (IReference)Model); }
}
@helper GeographicDetails()
{
    { Html.RenderPartial("~/Views/Library/_GeographicDetails.cshtml", (IGeographicDetails)Model); }
}
@{
    var layerDetail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.Fault.ToString().ToUpper()).FirstOrDefault() : null;
    var editPermission = Utility.MiscHelper.GetLayerEditPermission(Model.system_id, (List<NetworkLayer>)Session["NerworkLayerDetails"], NetworkStatus.P.ToString(), EntityType.Fault.ToString());
    var layer_Detail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.POD.ToString().ToUpper()).FirstOrDefault() : null;

}

<style>
    .SelectEntityToolTip {
        height: auto;
        background-color: #fff;
        width: 114px;
        text-align: center;
        color: #838383;
        margin-bottom: 20px;
    }

        .SelectEntityToolTip:hover {
            visibility: visible;
        }

    #ddlSelectEntity_chosen {
        width: 100% !important;
    }
</style>
<!DOCTYPE html>
<div>
    @using (Ajax.BeginForm("SaveFault", "Library", new AjaxOptions
    {
        HttpMethod = "POST",
        LoadingElementId = "dvProgress",
        UpdateTargetId = "dvModalBody",
        OnBegin = "return ValidateNetworkId(" + Model.system_id + ",'" + Model.network_id + "','" + Model.networkIdType + "','" + EntityType.Fault.ToString() + "');"

    },
                new { id = "frmAddFault", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {


        @Html.HiddenFor(m => m.region_id)
        @Html.HiddenFor(m => m.province_id)
        @Html.HiddenFor(m => m.system_id)
        @Html.HiddenFor(m => m.geom)
        @Html.HiddenFor(m => m.parent_system_id)
        @Html.HiddenFor(m => m.networkIdType)
        @Html.HiddenFor(m => m.network_id)
        @Html.HiddenFor(m => m.parent_entity_type)
        @Html.HiddenFor(m => m.modified_on, new { Value = Model.modified_on != null ? ((DateTime)Model.modified_on).ToString("dd-MMM-yyyy HH:mm:ss.fffff") : "" })
        @Html.HiddenFor(m => m.fault_entity_system_id, new { @id = "faultEntitySystemId" })
        <!-- Message Pop-up -->
        @pageMessage()
        <div class="libTabs">
            <div class="scrollmenu">
                <div><span class="spanSide go-left" id="spnRightMenu" style="display:none;"><i class="fa fa-angle-left" aria-hidden="true"></i></span></div>
                <div class="scrollerhide overflow-hidden">
                    <ul class="nav nav-tabs tabs-left">

                        <li class="active"><a class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010 @(Model.lstUserModule.Contains("ENT-DTL-GI")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "block;")"
                          href="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"#GISInfo":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>

                        @if (Model.system_id > 0 && layerDetail != null)
                        {
                            <li><a href="#dvFaultStatusHistory" onclick="si.GetFaultStautsHistory('@Model.system_id');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_373</a></li>
                        }
                        @if (layerDetail != null && layerDetail.is_pod_association_allowed)
                        {
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-COAS")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_159 @(Model.lstUserModule.Contains("ENT-DTL-COAS")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-COAS") ? "" : "block;")"
                            href="@(Model.lstUserModule.Contains("ENT-DTL-COAS")?"#PODAssoctn":"")" id="Pod_Association" onclick="si.GetPODAssociationDetail('@Model.geom', '@Model.system_id','@EntityType.Fault.ToString()', '@Model.primary_pod_system_id', '@Model.secondary_pod_system_id');" data-toggle="tab">@layer_Detail.layer_title <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_159</label></a></li>
                        }
                        <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENS")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_152 @(Model.lstUserModule.Contains("ENT-DTL-ENS")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENS") ? "" : "block;")"
                          href="@(Model.lstUserModule.Contains("ENT-DTL-ENS")?"#NwEntityHistory":"")" id="Nw_EntityHistory" onclick="si.GetNetworkEntityHistory('@Model.system_id','@EntityType.Fault.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_152</a></li>
                        @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_reference_allowed == true)
                        {
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_537 @(Model.lstUserModule.Contains("ENT-DTL-ENR")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENR") ? "" : "block;")"
                           href="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"#Reference":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                        }

                    </ul>
                </div>
                <div id="divRightMenu" style="display:none;">
                    <span class="spanSide go-right"><i class="fa fa-angle-right" aria-hidden="true"></i></span>
                    <span class="spanSide" id="dropdown" style="border-left: 1px solid #b9b7b7;     margin-left: -4px;"><i class="fa fa-angle-down" aria-hidden="true"></i></span>
                    <div class="arrowDropUp"></div>
                    <div class="dropMenu">
                        <div class="alltabs">@Resources.Resources.SI_OSP_CAB_NET_FRM_014</div>
                        <ul>
                            <li class="active"><a class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010 @(Model.lstUserModule.Contains("ENT-DTL-GI")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "block;")"
                              href="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"#GISInfo":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>

                            @if (Model.system_id > 0 && layerDetail != null)
                            {
                                <li><a href="#dvFaultStatusHistory" onclick="si.GetFaultStautsHistory('@Model.system_id');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_373</a></li>
                            }
                            @if (layerDetail != null && layerDetail.is_pod_association_allowed)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-COAS")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_159 @(Model.lstUserModule.Contains("ENT-DTL-COAS")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-COAS") ? "" : "block;")"
                                   href="@(Model.lstUserModule.Contains("ENT-DTL-COAS")?"#PODAssoctn":"")" id="Pod_Association" onclick="si.GetPODAssociationDetail('@Model.geom', '@Model.system_id','@EntityType.Fault.ToString()', '@Model.primary_pod_system_id', '@Model.secondary_pod_system_id');" data-toggle="tab">@layer_Detail.layer_title <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_159</label></a></li>
                            }
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENS")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_152 @(Model.lstUserModule.Contains("ENT-DTL-ENS")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENS") ? "" : "block;")"
                                href="@(Model.lstUserModule.Contains("ENT-DTL-ENS")?"#NwEntityHistory":"")" id="Nw_EntityHistory" onclick="si.GetNetworkEntityHistory('@Model.system_id','@EntityType.Fault.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_152</a></li>
                            @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_reference_allowed == true)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_537 @(Model.lstUserModule.Contains("ENT-DTL-ENR")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENR") ? "" : "block;")"
                               href="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"#Reference":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="TabContent--max-over">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"tab-pane active":"tab-pane active dvdisabled")" id="GISInfo">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_NET_FRM_218</legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtFaultCode">
                                @Resources.Resources.SI_OSP_GBL_GBL_GBL_001
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }
                                :
                            </label>
                            <div class="col-sm-4">
                                <div id="txtMaskedNetworkId"></div>

                            </div>
                            <label class="control-label col-sm-2" for="txtFaultId">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_NET_FRM_429:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.fault_id, new { @class = "form-control", @id = "txtFaultId", @maxlength = "50", @readonly = true })
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtLatitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_106:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.latitude, new { @class = "form-control", @id = "txtLatitude", @readonly = true })
                            </div>
                            <label class="control-label col-sm-2" for="txtLongitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_012:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.longitude, new { @class = "form-control", @id = "txtLongitude", @readonly = true })
                            </div>
                        </div>
                        <div class="form-group">
                            @CustomCoordinate()
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtTicketType">@Resources.Resources.SI_OSP_GBL_NET_FRM_376<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.DropDownListFor(m => m.business_type, new SelectList(Model.lstBusinessType.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "Select Business Type", new { @class = "chosen-select col-sm-12", @style = "padding:0;", @onchange = "si.ddlChangeRemoveCss(this.id, 'business_type');" })
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtAddress">@Resources.Resources.SI_OSP_GBL_GBL_GBL_008<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-10">
                                @Html.TextBoxFor(m => m.address, new { @class = "form-control", @id = "txtAddress", @maxlength = "200", autocomplete = "do-not-show-ac" })

                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtFaulttype">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_GBL_GBL_023<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4 ui-widget">
                                @Html.TextBoxFor(m => m.fault_type, new { @class = "form-control", @id = "txtFaultType", @maxlength = "50", @onkeyup = "si.GetAutoFaultType();" })

                            </div>

                            <label class="control-label col-sm-2 SelectEntityToolTip" for="txtFaultEntity" title="@String.Format(Resources.Resources.SI_OSP_GBL_GBL_FRM_016, ApplicationSettings.SplitCableBuffer)">@Resources.Resources.SI_OSP_GBL_NET_GBL_211<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4" id="dvselectEntity">
                                @*@Html.DropDownListFor(m => m.select_entity, new SelectList(Model.lstEntitiesNearbyFault.Select(x => new { Value = x.system_id.ToString(), Text = x.entity_type }), "Value", "Text"), "Select Entity", new { @id="ddlSelectEntity", @class = "chosen-select col-sm-12", @style = "padding:0;", @onchange = "si.ddlChangeRemoveCss(this.id, 'fault_entity_type');" })*@
                                @*<select name="ddlSelectEntity" id="ddlSelectEntity" class="chosen-select form-control" onchange="si.ddlChangeRemoveCss(this.id, 'fault_entity_type');">*@
                                <select id="ddlSelectEntity" name="@Html.NameFor(m => m.select_entity)" class="chosen-select col-sm-12" style="padding:0;" onchange="si.ddlChangeRemoveCss(this.id, 'select_entity');" data-val="true" data-val-required="The select_entity field is required.">

                                    <option value="0">Select Entity</option>

                                    @foreach (var item in Model.lstEntitiesNearbyFault)
                                    {
                                        //if (Convert.ToInt32(@item.system_id) == Convert.ToInt32(@Model.select_entity))
                                        if (Convert.ToInt32(@item.system_id) == Convert.ToInt32(@Model.select_entity == "" ? "0" : @Model.select_entity))
                                        {
                                            <option value="@item.system_id" selected="selected" data-network-id="@item.common_name">@item.entity_type</option>
                                        }
                                        else
                                        {
                                            <option value="@item.system_id" data-network-id="@item.common_name">@item.entity_type</option>
                                        }

                                    }
                                </select>
                                @*<select id="ddlSelectEntity" name="@Html.NameFor(m => m.select_entity)"  class = "chosen-select col-sm-12" style = "padding:0;" onchange = "si.ddlChangeRemoveCss(this.id, 'select_entity');" data-val="true" data-val-required="The select_entity field is required.">
                    <option value="0">--select--</option>
                    @if (Model.lstEntitiesNearbyFault.Count > 0)
                    {
                        foreach (var entity in Model.lstEntitiesNearbyFault)
                        {
                            var selected = entity.entity_type == Convert.ToString(Model.select_entity) ? "selected" : "";
                            <option value="@entity.entity_type" data-entity-systemId="@entity.system_id" data-entity-latlong="@entity.centroid_geom" @selected>@entity.entity_type</option>
                        }
                    }
                </select>*@
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtFaultEntityType">@Resources.Resources.SI_OSP_GBL_NET_FRM_020:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.fault_entity_type, new { @id = "txtFaultEntityType", @class = "form-control clsReadOnly", @readonly = true })
                            </div>
                            <label class="control-label col-sm-2" for="txtFaultEntityNetworkId">@Resources.Resources.SI_OSP_GBL_NET_FRM_379:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.fault_entity_network_id, new { @class = "form-control numbers-only", @id = "txtFaultEntityNetworkId", @readonly = true })
                            </div>

                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtFaultReason">@layerDetail.layer_title @Resources.Resources.SI_GBL_GBL_NET_FRM_109<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-10">
                                @Html.TextBoxFor(m => m.fault_reason, new { @class = "form-control", @id = "txtFaultReason", @maxlength = "200" })

                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtTicketType">@Resources.Resources.SI_OSP_GBL_NET_FRM_133:</label>
                            <div class="col-sm-4">
                                @Html.DropDownListFor(m => m.fault_ticket_type, new SelectList(Model.lstTicketType.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "Select Ticket Type", new { @class = "chosen-select col-sm-12", @style = "padding:0;", @onchange = "si.ddlChangeRemoveCss(this.id, 'fault_ticket_type');" })

                            </div>
                            <label class="control-label col-sm-2" for="txtTicketID">@Resources.Resources.SI_OSP_GBL_NET_RPT_025:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.fault_ticket_id, new { @class = "form-control numbers-only", @id = "txtTicketID", @maxlength = "50" })

                            </div>

                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtFaultReason">@Resources.Resources.SI_OSP_GBL_GBL_GBL_006:</label>
                            <div class="col-sm-10">
                                @Html.TextAreaFor(m => m.remarks, new { @class = "form-control textarea-maxlen-validate", @id = "txtRemarks", @maxlength = "100" })

                            </div>
                        </div>

                    </fieldset>
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_NET_FRM_381</legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtFaulttype">@Resources.Resources.SI_OSP_GBL_GBL_GBL_014<i class="clsMandatory">*</i>:</label>


                            @if (Model.system_id == 0)
                            {
                                <div class="col-sm-4 dvdisabled">
                                    @Html.DropDownListFor(m => m.objFaultStatusHistory.fault_status, new List<SelectListItem> { new SelectListItem { Text = "Unresolved", Value = "Unresolved" } }, new { @id = "ddlFaultStatus", @class = "chosen-select col-sm-12", @style = "padding:0;" })

                                </div>
                            }
                            else
                            {
                                <div class="col-sm-4">
                                    @Html.DropDownListFor(m => m.objFaultStatusHistory.fault_status, new SelectList(Model.objFaultStatusHistory.lstFaultStatus.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "Select Status", new { @id = "ddlFaultStatus", @class = "chosen-select col-sm-12", @style = "padding:0;", @onchange = "si.ddlChangeRemoveCss(this.id, 'objFaultStatusHistory_fault_status');" })
                                </div>
                            }



                            <label class="control-label col-sm-2" for="txtFaultStatusUpdated">@Resources.Resources.SI_OSP_GBL_NET_FRM_382<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.objFaultStatusHistory.fault_status_updated_on, "{0:dd-MMM-yyyy}", new { @class = "form-control clsReadOnly", @readonly = true, placeholder = "DD-MMM-YYYY", @id = "txtFaultStatusUpdated" })
                                <img id="imgFaultDate" class="assign-calen" src="~/Content/images/calendar.png" />

                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtFaulttype">@Resources.Resources.SI_OSP_GBL_NET_FRM_383<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.objFaultStatusHistory.updated_by, new { @class = "form-control", @id = "txtUpdatedBy", @maxlength = "50", @readonly = true })
                            </div>
                            <label class="control-label col-sm-2" for="txtFaultEntity">@Resources.Resources.SI_OSP_GBL_NET_FRM_384<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.objFaultStatusHistory.requested_by, new { @class = "form-control", @id = "ddlFaultentity", @maxlength = "50" })

                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_GBL_NET_FRM_385:</label>
                            <div class="col-sm-10">
                                @Html.TextBoxFor(m => m.objFaultStatusHistory.request_comment, new { @class = "form-control", @id = "txtRemarks", @maxlength = "100" })

                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_GBL_NET_FRM_386:</label>
                            <div class="col-sm-10">
                                @Html.TextBoxFor(m => m.objFaultStatusHistory.rca, new { @class = "form-control", @id = "txtRCA", @maxlength = "200", @onkeyup = "removecss();" })

                            </div>
                        </div>
                    </fieldset>
                    <div>@GeographicDetails()</div>

                </div>
                <div class="tab-pane" id="dvFaultStatusHistory">
                </div>
                <div class="tab-pane" id="PODAssoctn"></div>
                <div id="NwEntityHistory" class="tab-pane"></div>
                <div class="tab-pane" id="Reference">
                    @Reference()
                </div>
            </div>
        </div>

        <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"d-flex ModalFooter":"d-flex ModalFooter dvdisabled")" id="dvBtnAction">
            @if (Model.system_id > 0)
            {
                <div class="ModelFooterInfo">
                    <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_014:</label>
                    @*<label class="control-label model-label-info">@(Model.network_status != null ? Utility.MiscHelper.GetNetworkStatus(Model.network_status.ToUpper()) : string.Empty)</label>*@
                    <label for="txtLongitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_007:</label>
                    <label class="model-label-info" title="@(Model.created_on != null ? Utility.MiscHelper.FormatDateTime(Model.created_on.ToString()) : string.Empty)">@(Model.created_on != null ? Utility.MiscHelper.TimeAgo(Model.created_on.ToString()) : string.Empty)</label>
                </div>
            }
            <div class="ml-auto">
                <a href="javascript:void(0);" class="btn btn-default mr-01" data-dismiss="modal" id="btnCancelFault">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                @if (Model.system_id > 0)
                {
                    <button type="button" onclick="formPost();" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnUpdateFault">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_003</button>
                }
                else
                {
                    <button type="button" onclick="formPost();" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnSaveFault">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
                }

            </div>
        </div>
        <div class="clearfix"></div>
    }
</div>
<script type="text/javascript">

                $(document).ready(function () {
                    callFormValidator("frmAddFault");
                    $('.chosen-select').chosen({ width: '100%' });

@model Models.ROWMaster
@using Models;
@using SmartInventory.Settings;
@helper pageMessage()
{
    { Html.RenderPartial("_PageMessage", Model.objPM); }
}
@helper ProjectSpecifications()
{
    { Html.RenderPartial("~/Views/Library/_ProjectSpecification.cshtml", (IProjectSpecification)Model); }
}
@helper Reference()
{
    { Html.RenderPartial("~/Views/Library/_Reference.cshtml", (IReference)Model); }
}
@{
    var layerDetail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.ROW.ToString().ToUpper()).FirstOrDefault() : null;
    var editPermission = Utility.MiscHelper.GetLayerEditPermission(Model.system_id, (List<NetworkLayer>)Session["NerworkLayerDetails"], NetworkStatus.P.ToString(), EntityType.ROW.ToString());
}
<style>
    .dvdisabledlink {
        cursor: not-allowed;
        opacity: 0.4;
    }
</style>
<!DOCTYPE html>
<div>

    <div class="libTabs">
        <div class="scrollmenu">
            <div><span class="spanSide go-left" id="spnRightMenu" style="display:none;"><i class="fa fa-angle-left" aria-hidden="true"></i></span></div>
            <div id="RowScroll" class="scrollerhide overflow-hidden">
                <ul class="nav nav-tabs tabs-left">
                    @*<li class="active"><a id="linkGISInfo" class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"dvDisabled":"")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010 @(Model.lstUserModule.Contains("ENT-DTL-GI")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "block;")" href="#GISInfo" data-toggle="tab" onclick="$('#divGISInfoRowFooter').show();">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>*@
                    <li class="active"><a id="linkGISInfo" class="@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "dvDisabled")"title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010" style="display:block !important;" href="#GISInfo"data-toggle="tab"onclick="$('#divGISInfoRowFooter').show();"> @Resources.Resources.SI_OSP_GBL_GBL_GBL_010 </a></li>
                    <li class="@(Model.system_id==0?"dvdisabled":"")"><a id="linkApplyStage" href="#ApplyStage" data-toggle="tab" onclick="si.ROW.getApplyStage('@Model.system_id','@Model.geom_type','@Model.row_type','@Model.isPITApplied','@editPermission.ToString()')">@Resources.Resources.SI_OSP_ROW_NET_FRM_003</a></li>
                    <li class="@(!Model.isROWApplied?"dvdisabled":"")"><a href="#ApproveStage" data-toggle="tab" onclick="si.ROW.getApproveStage('@Model.system_id','@Model.geom_type','@Model.row_type','@editPermission.ToString()')">@Resources.Resources.SI_OSP_ROW_NET_FRM_004</a></li>
                    <li class="@(!Model.is_approve?"dvdisabled":"")"><a href="#Association" data-toggle="tab">@Resources.Resources.SI_OSP_ROW_NET_FRM_005</a></li>
                    <li class="@((!Model.is_approve ||layerDetail == null || !layerDetail.is_maintainence_charges_enabled)?"dvdisabled":"")"><a href="#tabMaintainenceCharges" onclick="si.GetMaintainenceCharges('@Model.system_id','@EntityType.ROW.ToString()' ,'@editPermission.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_ROW_NET_FRM_006</a></li>
                    @if (Model.system_id > 0 && layerDetail != null)
                    {
                        <li><a href="#Reference" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                    }
                </ul>
            </div>
            <div id="divRightMenu" style="display:none;">
                <span class="spanSide go-right"><i class="fa fa-angle-right" aria-hidden="true"></i></span>
                <span class="spanSide" id="dropdown" style="border-left: 1px solid #b9b7b7;     margin-left: -4px;"><i class="fa fa-angle-down" aria-hidden="true"></i></span>
                <div class="arrowDropUp"></div>
                <div class="dropMenu">
                    <div class="alltabs">@Resources.Resources.SI_OSP_CAB_NET_FRM_014</div>
                    <ul>
                        @*<li class="active"><a id="linkGISInfo" class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010 @(Model.lstUserModule.Contains("ENT-DTL-GI")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"#GISInfo":"")" data-toggle="tab" onclick="$('#divGISInfoRowFooter').show();">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>*@
                        <li class="active"><a id="linkGISInfo"class="@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "roledisabled")"title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010"style="display:block !important;"href="#GISInfo"data-toggle="tab"onclick="$('#divGISInfoRowFooter').show();">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a> </li>
                        <li class="@(Model.system_id==0?"":"roledisabled")"><a id="linkApplyStage" href="#ApplyStage" data-toggle="tab" onclick="si.ROW.getApplyStage('@Model.system_id','@Model.geom_type','@Model.row_type','@Model.isPITApplied','@editPermission.ToString()')">@Resources.Resources.SI_OSP_ROW_NET_FRM_003</a></li>
                        <li class="@(!Model.isROWApplied?"":"roledisabled")"><a href="#ApproveStage" data-toggle="tab" onclick="si.ROW.getApproveStage('@Model.system_id','@Model.geom_type','@Model.row_type','@editPermission.ToString()')">@Resources.Resources.SI_OSP_ROW_NET_FRM_004</a></li>
                        <li class="@(!Model.is_approve?"":"roledisabled")"><a href="#Association" data-toggle="tab">@Resources.Resources.SI_OSP_ROW_NET_FRM_005</a></li>
                        <li class="@((!Model.is_approve ||layerDetail == null || !layerDetail.is_maintainence_charges_enabled)?"":"roledisabled")"><a class="@(Model.lstUserModule.Contains("ENT-DTL-MC")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_ROW_NET_FRM_006 @(Model.lstUserModule.Contains("ENT-DTL-MC")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-MC") ? "" : "block;")"
                           href="#tabMaintainenceCharges" onclick="si.GetMaintainenceCharges('@Model.system_id','@EntityType.ROW.ToString()' ,'@editPermission.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_ROW_NET_FRM_006</a></li>
                        @if (Model.system_id > 0 && layerDetail != null)
                        {
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_537 @(Model.lstUserModule.Contains("ENT-DTL-ENR")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENR") ? "" : "block;")"
                            href="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"#Reference":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="TabContent--max-over">
        <!-- Tab panes -->
        <div class="tab-content">
            <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"tab-pane active":"tab-pane active dvdisabled")" id="GISInfo">
                @using (Ajax.BeginForm("SaveRow", "Library", new AjaxOptions
                {
                    HttpMethod = "POST",
                    UpdateTargetId = "dvModalBody",
                    LoadingElementId = "dvProgress",
                    //OnFailure = "si.handleError",
                    OnBegin = "return ValidateNetworkId(" + Model.system_id + ",'" + Model.network_id + "','" + Model.networkIdType + "','" + EntityType.ROW.ToString() + "');"
                },
new { id = "frmAddROW", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
                {
                    @Html.HiddenFor(m => m.system_id)
                    @Html.HiddenFor(m => m.region_id)
                    @Html.HiddenFor(m => m.province_id)
                    @Html.HiddenFor(m => m.geom)
                    @Html.HiddenFor(m => m.parent_system_id)
                    @Html.HiddenFor(m => m.networkIdType)
                    @Html.HiddenFor(m => m.network_id)
                    @Html.HiddenFor(m => m.geom_type)
                    @Html.HiddenFor(m => m.modified_on, new { Value = Model.modified_on != null ? ((DateTime)Model.modified_on).ToString("dd-MMM-yyyy HH:mm:ss.fffff") : "" })
                    @Html.HiddenFor(m => m.centerLineGeom)
                    @Html.HiddenFor(m => m.buffer_width)
                    <!-- Message Pop-up -->
                    @pageMessage()
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@Resources.Resources.SI_OSP_ROW_NET_FRM_094</legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtAreaCode">
                                @Resources.Resources.SI_OSP_GBL_GBL_GBL_001
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }
                                :
                            </label>
                            <div class="col-sm-4">
                                <div id="txtMaskedNetworkId"></div>

                            </div>
                            <label class="control-label col-sm-2" for="txtAreaName">
                                @Resources.Resources.SI_OSP_GBL_NET_FRM_059
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }:
                            </label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.row_name,
                               SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(
                                 new
                                 {
                                     @class = "form-control",
                                     @maxlength = "50",
                                 }, (Model.networkIdType == "M" ? new { @required = true } : null)))
                                @*@Html.TextBoxFor(m => m.row_name, new { @class = "form-control", @maxlength = "50" })*@
                            </div>
                        </div>

                        <div id="txtMasked"></div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtRegionName">@Resources.Resources.SI_OSP_GBL_GBL_GBL_002	<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.region_name, new { @class = "form-control", @readonly = true })

                            </div>
                            <label class="control-label col-sm-2" for="txtProvinceName">@Resources.Resources.SI_OSP_GBL_GBL_GBL_003<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.province_name, new { @class = "form-control", @readonly = true })
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_GBL_GBL_GBL_004	<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.parent_network_id, new { @class = "form-control clsReadOnly", @readonly = true })
                            </div>
                            <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_GBL_GBL_GBL_005<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.parent_entity_type, new { @class = "form-control clsReadOnly", @readonly = true })
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_ROW_NET_FRM_002<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-10 @((Model.isROWApplied || (Model.row_type=="PIT" && Model.isPITApplied))?"dvdisabled":"")">
                                @Html.DropDownListFor(m => m.row_type,
                    new List<SelectListItem>
                   {
                       new SelectListItem{ Text="Line", Value = "Line" },
                       new SelectListItem{ Text="PIT", Value = "PIT" },
                    }, "--Select--", new { @class = "chosen-select col-sm-12" })
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_GBL_GBL_GBL_006:</label>
                            <div class="col-sm-10">
                                @Html.TextAreaFor(m => m.remarks, new { @class = "form-control textarea-maxlen-validate", @maxlength = "1000", @style = "resize:none;" })
                            </div>

                        </div>
                    </fieldset>

                    if (Model.lstUserModule.Contains("PROJ"))
                    {
                        <fieldset class="the-fieldset">
                            <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_GBL_FRM_001</legend>
                            @ProjectSpecifications()
                        </fieldset>
                    }

                    <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"d-flex ModalFooter":"d-flex ModalFooter dvdisabled")" id="dvBtnAction">
                        @if (Model.system_id > 0)
                        {
                            <div class="ModelFooterInfo">
                                <label class="control-label" for="txtLongitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_007:</label>
                                <label class="control-label model-label-info" title="@(Model.created_on != null ? Utility.MiscHelper.FormatDateTime(Model.created_on.ToString()) : string.Empty)">@(Model.created_on != null ? Utility.MiscHelper.TimeAgo(Model.created_on.ToString()) : string.Empty)</label>
                            </div>
                        }
                        <div class="ml-auto" id="divGISInfoRowFooter">
                            <a href="javascript:void(0);" class="btn btn-default mr-01" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                            @if (Model.system_id > 0)
                            {
                                <button type="submit" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnUpdateROW" disabled="disabled">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_003</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnSaveROW" disabled="disabled">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
                            }

                        </div>
                    </div>
                }

            </div>
            <div class="tab-pane" id="ApplyStage">
                @Html.Action("ApplyStage", "Library", new { rowSystemId = Model.system_id, geomType = Model.geom_type, rowType = Model.row_type, rowStage = Model.row_stage })
            </div>
            <div class="tab-pane" id="ApproveStage">
                @Html.Action("ApproveReject", "Library", new { rowSystemId = Model.system_id, geomType = Model.geom_type, rowType = Model.row_type, rowStage = Model.row_stage })
            </div>
            <div class="tab-pane" id="Association">
                @Html.Action("ROWAssociation", "Library", new { systemId = Model.system_id, entityType = Models.EntityType.ROW.ToString(), networkId = Model.network_id })
            </div>
            <div class="tab-pane" id="tabMaintainenceCharges" >
                <div id="dvMaintainenceCharges"></div>
            </div>
            <div class="tab-pane" id="Reference">
                @Reference()
            </div>
        </div>
    </div>

    <div class="clearfix"></div>

</div>

<script>
            var inputs = [];
            $(document).ready(function () {
                callFormValidator("frmAddROW");
                $('.chosen-select').chosen({ width: '100%' });

                EnableDisableUpdateButton("frmAddROW", @Model.system_id > 0 ? "btnUpdateROW" : "btnSaveROW");

                //APPLY INPUT MASK ON NETWORK ID..
                getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');

                // IN AJAX.BEGINFORM , ON ONBEGIN EVENT WE CAN NOT SET VALUE TO CONTROL AS FORM DATA IS ALREADY SERIALIZED BEFORE CALLING ONBEGIN
                // TO ACHIVE THE SAME (CHANGE FIELD VALUE) WE USED THE FORM ON SUBMIT METHOD
                $("#frmAddROW").on("submit", function () {
                    si.upperCaseNetWorkId();
                });
                $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });
                $('#btnSaveROWCharges').on('click',function(){
                    $('#frmAddROW').submit();
                });

            });
</script>

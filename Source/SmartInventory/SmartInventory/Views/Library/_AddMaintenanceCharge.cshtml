@model Models.EntityMaintainenceCharges
@using SmartInventory.Settings;
@helper pageMessage()
{
    { Html.RenderPartial("_PageMessage", Model.objPM); }

}
<!DOCTYPE html>
<div class="libDetail">
    @using (Ajax.BeginForm("SaveMaintenanceCharge", "Library", new AjaxOptions
    {
        HttpMethod = "POST",
        LoadingElementId = "dvProgress",
        Confirm = Resources.Resources.SI_OSP_GBL_NET_FRM_156,
        // UpdateTargetId = "dvChildModalBody",
        OnSuccess = "si.EntityMaintainenceCharges.maintenanceResponse(" + Model.id + "," + Model.entity_id + ",'" + Model.entity_type + "');"
    },
                                         new { id = "frmAddCharge", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {
        @Html.HiddenFor(m => m.id, new { id = "hdnMaintenanceChargeId" })
        @Html.HiddenFor(m => m.entity_id)
        @Html.HiddenFor(m => m.entity_type, new { id = "hdnEntityType" })
        <div class="libTabContent">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="tab-pane active">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@Resources.Resources.SI_OSP_ROW_NET_FRM_080</legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_ROW_NET_FRM_081<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.DropDownListFor(m => m.type_of_activity_charge,
                               new SelectList(Model.listTypeOfActivityCharge.Select(x => new { Value = x.dropdown_value, Text = x.dropdown_key }),
                               "Value", "Text"),
                               "-Select-", new { @class = "chosen-select form-control", id = "ddlActivityChargetype" })
                            </div>
                            <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_ROW_NET_FRM_082<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.DropDownListFor(m => m.charge_category, new SelectList(Model.listChargeCategory.Select(x => new { Value = x.dropdown_value, Text = x.dropdown_key }), "Value", "Text"),
                                 "-Select-", new { @class = "chosen-select form-control", id = "ddlChargeCategory" })
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_ROW_NET_FRM_083<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.activity_start_date, "{0:dd-MMM-yyyy}", new { id = "txtActivityStartDate", @class = "form-control clsReadOnly", @readonly = true, placeholder = "DD-MMM-YYYY", @style = "background:#fff;" })
                                <img id="imgActivityStartDate" class="assign-calen" src="~/Content/images/calendar.png" style="margin-top:1px;" />
                            </div>
                            <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_ROW_NET_FRM_084<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.activity_end_date, "{0:dd-MMM-yyyy}", new { id = "txtActivityEndDate", @class = "form-control", @readonly = true, placeholder = "DD-MMM-YYYY", @style = "background:#fff;" })
                                <img id="imgActivityEndDate" class="assign-calen" src="~/Content/images/calendar.png" style="margin-top:1px;" />
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtTotalCost">@string.Format(Resources.Resources.SI_OSP_ROW_NET_FRM_085, ApplicationSettings.Currency)<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.total_cost, new { @class = "form-control", @maxlength = "12", @onkeypress = "return allowNumberwithOneDot(event, 'total_cost');" })
                            </div>
                            <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_GBL_GBL_GBL_006:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.remark, new { @class = "form-control", @maxlength = "150" })

                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>
        <div class="ModalFooter d-flex" id="dvBtnAction">
            <button type="button" class="btn btn-primary ml-10" style="display:none;">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_010</button>
            <a href="javascript:void(0);" class="btn btn-default ml-auto" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
            <button type="submit" class="btn btn-primary ml-10">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
         </div>

    }
</div>
<script type="text/javascript">
    $(document).ready(function () {
        $('#total_cost').on('input', function () {
            this.value = this.value.match(/^\d+\.?\d{0,2}/);
        });
        callFormValidator("frmAddCharge");
        $('.chosen-select').chosen({ width: '100%' });
        si.EntityMaintainenceCharges.setCalendar('txtActivityStartDate', 'imgActivityStartDate','txtActivityEndDate', 'imgActivityEndDate', false, true,'ROW');
        //si.EntityMaintainenceCharges.setCalendar('txtActivityEndDate', 'imgActivityEndDate', '', true);
        if ('@Model.id' == 0 && '@Model.entity_type' == 'ROW') {
            var accessChargeDate = GetFormattedDate(DateFormatter($('#txtAccessChargeDate').val()));
            var currentAccessChargeDate = new Date(accessChargeDate);
            var activityEndDate = new Date(currentAccessChargeDate);
            activityEndDate.setDate(activityEndDate.getDate() + 365);
            $('#txtActivityStartDate').val(accessChargeDate);
            $('#txtActivityEndDate').val(GetFormattedDate(activityEndDate));
        } else {
            $('#txtActivityStartDate,#txtActivityEndDate').val(GetFormattedDate(new Date()));
        }
    });
</script>

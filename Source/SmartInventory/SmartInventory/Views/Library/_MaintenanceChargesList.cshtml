@model List<Models.EntityMaintainenceCharges>
@using SmartInventory.Settings;
<style>
    .webgrid th {
        color: #fff;
    }
</style>

<!DOCTYPE html>
<div class="table-responsive tble_cls">
    @if (Model.Count > 0)
    {
        <table id="tblRecurringCharges" class="webgrid" cellpadding="0" cellspacing="0">
            <thead class="webGridHeader">
                <tr>
                    <th scope="col">@Resources.Resources.SI_OSP_GBL_NET_FRM_052</th>
                    <th scope="col">@Resources.Resources.SI_OSP_GBL_NET_FRM_053</th>
                    <th scope="col">@Resources.Resources.SI_OSP_GBL_NET_FRM_054</th>
                    <th scope="col">@Resources.Resources.SI_OSP_ROW_NET_FRM_084</th>
                    <th scope="col">@string.Format(Resources.Resources.SI_OSP_GBL_NET_FRM_055,ApplicationSettings.Currency)</th>
                    <th scope="col">@Resources.Resources.SI_OSP_GBL_GBL_GBL_006</th>                    
                    @*<th scope="col">Action</th>*@
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model.Select((value, i) => new { i, value }))
                {
                    var value = item.value;
                    var index = item.i;
                    <tr class="@(index % 2 == 0 ? "alt" : "")">
                        <td>@value.type_of_activity_charge</td>
                        <td>@value.charge_category</td>
                        <td>@value.activityStartDate</td>
                        <td>@value.activityEndDate</td>
                        <td>@value.total_cost</td>
                        <td>@value.remark</td>
                        @*<td>
                            <a href="#" onclick="si.EntityMaintainenceCharges.addCharges('@value.id','@value.entity_id','@value.entity_type')" class="dropdown-toggle">
                                <i class="fa fa-fw fa-edit" title="Edit" tabindex="5"></i>
                            </a>
                        </td>*@
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

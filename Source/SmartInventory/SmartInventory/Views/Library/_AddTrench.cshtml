</div>
<script type="text/javascript">
    var inputs = [];
    $(document).ready(function () {
        if ($('#manufacture_year').length > 0) {
            si.setDateTimeCalendar("manufacture_year", "imgManufactureYear", false, false);
        }
          if ('@a_location_code.is_required' == 'True') {
            $('#ddlALocationCode').attr('required', true);
        }
         if ('@b_location_code.is_required' == 'True') {
            $('#ddlBLocationCode').attr('required', true);
        }

        callFormValidator("frmAddTrench");
        $('.chosen-select').chosen({ width: '100%' });


        ajaxReq('Library/GetExecutionmethod', {
            entityId: '@Model.system_id', entityType: 'Trench'
        }, true, function (resp) {
            $("#Execution").html(resp);
            if ('@Model.system_id' > 0) {
                popup.disablebuttonWhenEditDisabled('@editPermission.ToString()');
            }
            $("#Execution").css('background-image', 'none');
        }, false, false);

        EnableDisableUpdateButton("frmAddTrench", @Model.system_id > 0 ? "btnUpdateSubArea" : "btnSaveTrench");

        //APPLY INPUT MASK ON NETWORK ID..
        getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');

        $("#frmAddTrench").on("submit", function () {
            if ($('#txtTrenchHeight').val() <= 0) {
                $('#txtTrenchHeight').css('border-color', 'red');
                return false;
            }
            else if ($('#txtTrenchWidth').val() <= 0){
                $('#txtTrenchWidth').css('border-color', 'red');
                return false;
            }
            $("#network_id").val($("#txtMaskedNetworkId").dxTextBox("option", "text").toUpperCase());
            si.upperCaseNetWorkId();
            //For AdditionalAttributes to set json and saving
            additionalAttributesUtility.SetJsonValue("#frmOtherInfo", "#hdnOtherInfo");
            //end region Additional-Attributes
            if (!entityReferencevalidation())
                return false;

            if(!entityMaintainence())
                return false;

        });
        $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });
    });
    function ValidateHeight() {

        if ($('#txtTrenchHeight').val() <= 0 || $('#txtTrenchHeight').val()=='') {
            $('#txtTrenchHeight').css('border-color', 'red');
        }
        else {
            $('#txtTrenchHeight').css('border-color', '');
        }

    }
    function ValidateWidth() {
        if ($('#txtTrenchWidth').val() <= 0 || $('#txtTrenchWidth').val()=='') {
            $('#txtTrenchWidth').css('border-color', 'red');
        }
        else {
            $('#txtTrenchWidth').css('border-color', '');
        }
    }
    function formPost() {

        if ($('#txtbomsubcategory').val() == '') {
            $('#txtbomsubcategory').next().addClass('input-validation-error');
            return false;
        }

        else {
            $("#frmAddTrench").submit();
        }
    }
</script>
<style>
       #PODAssoctn {
        background-image: url('@Url.Content("~/content/images/loading_new.gif")');
        background-position: center;
        background-repeat: no-repeat;
    }
</style>


@model Models.SplitCable
@using SmartInventory.Settings;
@using Models;
@{
    var startEndReading = Model.formInputSettings.Count > 0 ? Model.formInputSettings.Where(m => m.form_feature_name.ToLower() == formFeatureName.start_end_reading.ToString() && m.form_feature_type.ToLower() == formFeatureType.feature.ToString() && m.is_active == true).FirstOrDefault() : null;
}
@helper pageMessage()
{
    {
        Html.RenderPartial("_PageMessage", Model.objPM);
    }
}

<!DOCTYPE html>
<div>
    @using (Ajax.BeginForm("saveSplitCable", "Library", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "dvModalBody",
        OnBegin = "return isFormValid();",
        LoadingElementId = "dvProgress",
        Confirm = Resources.Resources.SI_OSP_GBL_NET_FRM_176
    },
                    new { id = "frmShowSplitCable", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal", isConfirm = "1" }))
    {
        @Html.HiddenFor(m => m.split_entity_networkId)
        @Html.HiddenFor(m => m.split_entity_type)
        @Html.HiddenFor(m => m.split_entity_system_id)
        @Html.HiddenFor(m => m.split_cable_system_id)
        @Html.HiddenFor(m => m.split_entity_network_status)
        @Html.HiddenFor(m => m.splitCore)
        @Html.HiddenFor(m => @startEndReading, new { @id = "startEndReading" })

        @pageMessage()

        <div class="TabContent--max-over">
            @if (Model.cables.Count > 0)
            {

                <fieldset class="the-fieldset">

                    @*@Resources.Resources.SI_OSP_SC_NET_FRM_007 (@Resources.Resources.SI_OSP_ONT_NET_FRM_005  @ApplicationSettings.SplitCableBuffer @Resources.Resources.SI_OSP_GBL_GBL_GBL_034)*@
                    <legend class="the-legend">@String.Format(Resources.Resources.SI_OSP_SC_NET_FRM_007, ApplicationSettings.SplitCableBuffer)</legend>

                    <div>
                        <table id="infoTable" border="0" cellspacing="0" cellpadding="5" class="ElementsList grid">
                            <tbody>
                                @if (Model.cables != null && Model.cables.Count > 0)
                                {
                                    foreach (var item in Model.cables)
                                    {
                                        <tr>
                                            <td width="20px">
                                                <input type="radio" class="Cable_address" name="Cable" value="@item.common_name" s_id="@item.system_id" data-network-status="@item.network_status" cbl_display_name="@item.display_name" />
                                            </td>
                                            <td>@item.common_name</td>
                                            <td>
                                                <a href="#" onclick="si.ShowEntityOnMap('@item.system_id','@item.entity_type','@item.geom_type');$(popup.DE.MinimizeModel).trigger('click');" class="dropdown-toggle" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_036">
                                                    <i class="fa fa-globe fa-fw m-r-xs"></i>
                                                </a>
                                                <a href="#" onclick="si.GetSliptCableFiberDetail('@item.system_id','Split')" class="dropdown-toggle" title="@Resources.Resources.SI_OSP_SC_NET_FRM_008">
                                                    <i class="glyphicon glyphicon-eye-open"></i>
                                                </a>
                                            </td>
                                            @*<td class="cptr" onmouseout="si.removeInfoHoverItem()"
                                                    onmouseover="si.focusItmInfoHover('@item.system_id','@item.entity_type', '@item.geom_type',this)">
                                                    <input type="radio" name="Cable" value="@item.common_name" s_id="@item.system_id" />
                                                    <span onmouseout="si.removeInfoHoverItem()" onmouseover="si.focusItmInfoHover('@item.system_id','@item.entity_type', '@item.geom_type',this)">@item.common_name</span>
                                                    <span style="float: right;"><a class="btn btn-small btn-primary" href="#FiberDetail" onclick="si.GetSliptCableFiberDetail('@item.system_id');" data-toggle="tab">Fiber Details</a></span>
                                                </td>*@
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                </fieldset>

                <fieldset class="the-fieldset">
                    <legend class="the-legend">@Resources.Resources.SI_OSP_SC_NET_FRM_009</legend>
                    <div class="form-group" style="text-align: center;">
                        <fieldset class="the-fieldset">
                            <legend class="the-legend">@Resources.Resources.SI_OSP_SC_NET_FRM_010</legend>
                            <div class="form-group">
                                <label class="control-label col-sm-2" for="txtCableCode">
                                    @Resources.Resources.SI_OSP_GBL_GBL_GBL_001 <i class="clsMandatory">*</i>:
                                </label>
                                <div class="col-sm-45">
                                    @Html.TextBoxFor(m => m.cable_one_network_id, new { @class = "form-control clsReadOnly", @readonly = true })
                                    @Html.ValidationMessageFor(model => model.cable_one_network_id)
                                </div>
                                <label class="control-label col-sm-2" for="txtCableName">@Resources.Resources.SI_OSP_CAB_NET_FRM_008<i class="clsMandatory">*</i>:</label>
                                <div class="col-sm-45">
                                    @Html.TextBoxFor(m => m.cable_one_name, new { @class = "form-control clsReadOnly" })
                                    @Html.ValidationMessageFor(model => model.cable_one_name)
                                </div>
                            </div>
                            @if (ApplicationSettings.isterminationpointenable)
                            {
                                <div class="form-group">
                                    <label class="control-label col-sm-2" for="txtStartPoint">@Resources.Resources.SI_OSP_GBL_NET_FRM_035<i class="clsMandatory">*</i>:</label>
                                    <div class="col-sm-45">
                                        @Html.TextBoxFor(m => m.cable_one_a_location, new { @class = "form-control clsReadOnly", @readonly = true })
                                        @Html.ValidationMessageFor(model => model.cable_one_a_location)
                                    </div>

                                    <label class="control-label col-sm-2" for="txtEndPoint">@Resources.Resources.SI_OSP_GBL_NET_FRM_036<i class="clsMandatory">*</i>:</label>
                                    <div class="col-sm-45">
                                        @Html.TextBoxFor(m => m.cable_one_b_location, new { @class = "form-control clsReadOnly", @readonly = true })
                                        @Html.ValidationMessageFor(model => model.cable_one_b_location)
                                    </div>

                                </div>
                            }


                            @if (startEndReading != null)
                            {
                                <div class="form-group">
                                    <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_CAB_NET_FRM_015<i class="clsMandatory" id="icnfstartreading"></i>:</label>
                                    <div class="col-sm-45">

                                        @Html.TextBoxFor(m => m.cable_one_start_reading,
                                            SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(new
                                            {
                                                @class = "form-control",
                                                @maxlength = "10",
                                                @onkeypress = "return allowNumberwithOneDot(event,'cable_one_start_reading');"
                                            }))

                                    </div>
                                    <label class="control-label col-sm-2" for="txtSubAreaName">@Resources.Resources.SI_OSP_CAB_NET_FRM_016<i class="clsMandatory" id="icnfendreading"></i>:</label>
                                    <div class="col-sm-45">
                                        @Html.TextBoxFor(m => m.cable_one_end_reading,
                                            SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(
                                                new
                                                {
                                                    @class = "form-control",
                                                    @maxlength = "10",
                                                    @onkeypress = "return allowNumberwithOneDot(event,'cable_one_end_reading');"
                                                })
                                            )
                                    </div>
                                </div>
                            }

                            <div class="form-group">
                                <label class="control-label col-sm-2" for="txtSubAreaName">@Html.Raw(Resources.Resources.SI_OSP_SC_NET_FRM_011)<i class="clsMandatory">*</i>:</label>
                                <div class="col-sm-45">
                                    @Html.TextBoxFor(m => m.cable_one_measured_length, new { @class = "form-control clsReadOnly", @readonly = true })
                                    @Html.ValidationMessageFor(model => model.cable_one_measured_length)
                                </div>
                                <label class="control-label col-sm-2" for="txtRemarks">@Html.Raw(Resources.Resources.SI_OSP_SC_NET_FRM_012)<i class="clsMandatory" id="icncableonecalclength">*</i>:</label>
                                <div class="col-sm-45">
                                    @Html.TextBoxFor(m => m.cable_one_calculated_length,
                                                        SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(new
                                                        {
                                                            @class = "form-control",
                                                            @onkeypress = "return allowNumberwithOneDot(event,'cable_one_calculated_length');",
                                                            @maxlength = "10"
                                                        }, (startEndReading != null) ? new { @readonly = "readonly" } : null))
                                </div>

                            </div>

                        </fieldset>

                        <fieldset class="the-fieldset">
                            <legend class="the-legend">@Resources.Resources.SI_OSP_SC_NET_FRM_013</legend>
                            <div class="form-group">
                                <label class="control-label col-sm-2" for="txtCableCode">
                                    @Resources.Resources.SI_OSP_GBL_GBL_GBL_001 <i class="clsMandatory">*</i>:
                                </label>
                                <div class="col-sm-45">
                                    @Html.TextBoxFor(m => m.cable_two_network_id, new { @class = "form-control clsReadOnly", @readonly = true })
                                    @Html.ValidationMessageFor(model => model.cable_two_network_id)
                                </div>
                                <label class="control-label col-sm-2" for="txtCableTwoName">@Resources.Resources.SI_OSP_CAB_NET_FRM_008<i class="clsMandatory">*</i>:</label>
                                <div class="col-sm-45">
                                    @Html.TextBoxFor(m => m.cable_two_name, new { @class = "form-control clsReadOnly" })
                                    @Html.ValidationMessageFor(model => model.cable_two_name)
                                </div>
                            </div>
                            @if (ApplicationSettings.isterminationpointenable)
                            {
                                <div class="form-group">
                                    <label class="control-label col-sm-2" for="txtStartPoint">@Resources.Resources.SI_OSP_GBL_NET_FRM_035<i class="clsMandatory">*</i>:</label>
                                    <div class="col-sm-45">
                                        @Html.TextBoxFor(m => m.cable_two_a_location, new { @class = "form-control clsReadOnly", @readonly = true })
                                        @Html.ValidationMessageFor(model => model.cable_two_a_location)
                                    </div>

                                    <label class="control-label col-sm-2" for="txtEndPointe">@Resources.Resources.SI_OSP_GBL_NET_FRM_036<i class="clsMandatory">*</i>:</label>
                                    <div class="col-sm-45">
                                        @Html.TextBoxFor(m => m.cable_two_b_location, new { @class = "form-control clsReadOnly", @readonly = true })
                                        @Html.ValidationMessageFor(model => model.cable_two_b_location)
                                    </div>
                                </div>
                            }
                            @if (startEndReading != null)
                            {
                                <div class="form-group">
                                    <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_CAB_NET_FRM_015)<i class="clsMandatory" id="icnsstartreading"></i>:</label>
                                    <div class="col-sm-45">
                                        @Html.TextBoxFor(m => m.cable_two_start_reading,
                                            SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(new
                                            {
                                                @class = "form-control",
                                                @maxlength = "10",
                                                @onkeypress = "return allowNumberwithOneDot(event,'cable_two_start_reading');"
                                            }, null))
                                    </div>
                                    <label class="control-label col-sm-2" for="txtSubAreaName">@Resources.Resources.SI_OSP_CAB_NET_FRM_016<i class="clsMandatory" id="icnsendreading"></i>:</label>
                                    <div class="col-sm-45">
                                        @Html.TextBoxFor(m => m.cable_two_end_reading,
                                            SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(
                                                new
                                                {
                                                    @class = "form-control",
                                                    @maxlength = "10",
                                                    @onkeypress = "return allowNumberwithOneDot(event,'cable_two_end_reading');"
                                                }, null)
                                            )
                                    </div>
                                </div>
                            }
                            <div class="form-group">
                                <label class="control-label col-sm-2" for="txtSubAreaName">@Html.Raw(Resources.Resources.SI_OSP_SC_NET_FRM_011)<i class="clsMandatory">*</i>:</label>
                                <div class="col-sm-45">
                                    @Html.TextBoxFor(m => m.cable_two_measured_length, new { @class = "form-control clsReadOnly", @readonly = true })
                                    @Html.ValidationMessageFor(model => model.cable_two_measured_length)
                                </div>
                                <label class="control-label col-sm-2" for="txtRemarks">@Html.Raw(Resources.Resources.SI_OSP_SC_NET_FRM_012)<i class="clsMandatory" id="icncabletwocalclength">*</i>:</label>
                                <div class="col-sm-45">
                                    @Html.TextBoxFor(m => m.cable_two_calculated_length,
                                                        SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(new
                                                        {
                                                            @class = "form-control",
                                                            @onkeypress = "return allowNumberwithOneDot(event,'cable_two_calculated_length');",
                                                            @maxlength = "10"
                                                        }, (startEndReading != null) ? new { @readonly = "readonly" } : null))
                                </div>

                            </div>

                        </fieldset>

                    </div>

                </fieldset>
            }
            else
            {

                @*@Resources.Resources.SI_OSP_SC_NET_FRM_014 (@Resources.Resources.SI_OSP_ONT_NET_FRM_005  @ApplicationSettings.SplitCableBuffer @Resources.Resources.SI_OSP_GBL_GBL_GBL_034)*@
                <div style="text-align:center; margin:50px;"><b>@String.Format(Resources.Resources.SI_OSP_SC_NET_FRM_014, ApplicationSettings.SplitCableBuffer) !! </b></div>

            }


        </div>
        if (Model.cables.Count > 0)
        {
            <div class="d-flex ModalFooter" id="dvBtnAction">
                <input class="btn btn-small btn-danger ml-auto mr-01" type="Button" id="btnCableProcess" value="@Resources.Resources.SI_OSP_SC_NET_FRM_015" onclick="si.getNewCableDetails()">
                <input type="submit" class="btn btn-small btn-primary d-flex " name="btnaction" id="btnSplitCable" value="@Resources.Resources.SI_OSP_SC_NET_FRM_006" />
            </div>

        }
        <div class="clearfix"></div>
    }
</div>


<script>
    $(document).ready(function () {
        callFormValidator("frmShowSplitCable");
    });
    function isFormValid() {
         
        if ($('#cable_one_network_id').val() == "" && $('#cable_one_network_id').val() == "") {
            alert('Please click on process cable !');
        }
        else {
            if (startEndReading == null) {
                //---------------------------------------------------------------------------------------------------------------------
                if ((parseFloat($('#cable_one_end_reading').val()) != 0 || parseFloat($('#cable_one_start_reading').val()) != 0) && (parseFloat($('#cable_one_end_reading').val()) <= parseFloat($('#cable_one_start_reading').val()))) {
                    alert(MultilingualKey.SI_OSP_GBL_JQ_FRM_017);
                    return false;
                }

                if ((($('#cable_one_start_reading').length == 0) && $('#cable_one_end_reading').length == 0) || (parseFloat($('#cable_one_calculated_length').val()) != 0)) {
                    var cabelOneStatus = ValidateCableLenght('#cable_one_measured_length', '#cable_one_calculated_length', 'Cable 1');
                    if (cabelOneStatus == false) {
                        return false;
                    }
                }
                if ((($('#cable_one_start_reading').length == 0) && $('#cable_one_end_reading').length == 0) || (parseFloat($('#cable_one_calculated_length').val()) == 0)) {

                    alert("	Cable 1 calculated length should be greater or equal to Cable 1 measured length !");
                    return false;
                }
                if (((($('#cable_one_start_reading').length != 0) && $('#cable_one_end_reading').length != 0) && $('#cable_one_measured_length').val() > $('#cable_one_calculated_length').val()) || (parseFloat($('#cable_one_calculated_length').val()) == 0)) {

                    alert("Cable 1 end reading can not be less then or equal to Cable 1 start reading!");
                    return false;
                }
                //-------------------------------------------------------------------------------------------------------------------
                if ((($('#cable_two_start_reading').length == 0) && $('#cable_two_end_reading').length == 0) || (parseFloat($('#cable_two_calculated_length').val()) == 0)) {

                    alert("Cable 2 end reading can not be less then or equal to Cable 2 start reading!");
                    return false;
                }
                if ((parseFloat($('#cable_two_end_reading').val()) != 0 || parseFloat($('#cable_two_start_reading').val()) != 0) && (parseFloat($('#cable_two_end_reading').val()) <= parseFloat($('#cable_two_start_reading').val()))) {
                    alert(MultilingualKey.SI_OSP_GBL_JQ_FRM_018);
                    return false;
                }
                if (($('#cable_two_start_reading').length == 0 && $('#cable_two_end_reading').length == 0) || (parseFloat($('#cable_two_calculated_length').val()) != 0)) {
                    var cabletwoStatus = ValidateCableLenght('#cable_two_measured_length', '#cable_two_calculated_length', 'Cable 2');

                    if (cabletwoStatus == false) {
                        return false;
                    }
                }
                if (((($('#cable_two_start_reading').length != 0) && $('#cable_two_end_reading').length != 0) && $('#cable_two_measured_length').val() > $('#cable_two_calculated_length').val()) || (parseFloat($('#cable_two_calculated_length').val()) == 0)) {

                    alert("Cable 1 end reading can not be less then or equal to Cable 1 start reading!");
                    return false;
                }


            }
            else {
                if (parseFloat($('#cable_one_measured_length').val()) != 0 && parseFloat($('#cable_one_calculated_length').val()) != 0 && parseFloat($('#cable_one_calculated_length').val()) < parseFloat($('#cable_one_measured_length').val())) {
                    alert("	Cable 1 calculated length should be greater or equal to Cable 1 measured length !");
                    return false;
                }
                if (parseFloat($('#cable_two_measured_length').val()) != 0 && parseFloat($('#cable_two_calculated_length').val()) != 0 && parseFloat($('#cable_two_calculated_length').val()) < parseFloat($('#cable_two_measured_length').val())) {
                    alert("	Cable 2 calculated length should be greater or equal to Cable 2 measured length!");
                    return false;
                }
                if (parseFloat($('#cable_one_calculated_length').val()) < parseFloat($('#cable_one_measured_length').val())) {
                    alert("Cable 1 calculated length should be greater or equal to Cable 1 measured length!");
                    return false;
                }
                if (parseFloat($('#cable_two_calculated_length').val()) < parseFloat($('#cable_two_measured_length').val())) {
                    alert("Cable 2 calculated length should be greater or equal to Cable 2 measured length!");
                    return false;
                }
            }
        }

    }
    $('.Cable_address').click(function () {
         
        $('#cable_one_network_id').val('');
        $('#cable_one_name').val('');
        $('#cable_one_start_reading').val('');
        $('#cable_one_end_reading').val('');
        $('#cable_one_measured_length').val('');
        $('#cable_one_calculated_length').val('');
        $('#cable_two_network_id').val('');
        $('#cable_two_name').val('');
        $('#cable_two_start_reading').val('');
        $('#cable_two_end_reading').val('');
        $('#cable_two_measured_length').val('');
        $('#cable_two_calculated_length').val('');
    }); 
</script>

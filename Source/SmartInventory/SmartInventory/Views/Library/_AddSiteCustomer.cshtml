@model Models.Customer
 
@helper pageMessage()
{
{ Html.RenderPartial("_PageMessage", Model.objPM); }
    
}
<style>
    #dvSiteCustomerForm .col-md-6 {
        padding-left: 0px;
    }

    #dvSiteCustomerForm .mrgn_btm {
        height: 25px;
            margin-bottom: 10px;
    }
   #divDocumentUpload {
    display: inline-block;
    padding-left: 5px;
}

    #divDocumentUpload input[type=file] {
        display: block;
    }
    #divDocumentUpload a, #divDocumentUpload a:visited {
        text-decoration:none;color:#01a3c6;font-family:helvetica;padding:0.3em;border-radius:0.2em;
    }
    #divDocumentUpload .icon-close,#divDocumentUpload cptr {
    text-align: center;
    color: red;
}
     #ulSiteCustomerGrid a, #ulSiteCustomerGrid a:visited {
        text-decoration:none;color:#01a3c6;font-family:helvetica;padding:0.3em;border-radius:0.2em;
    }
    #ulSiteCustomerGrid .icon-close {
    text-align: center;
    color: red;
}
.UploadAction {
    padding: 10px 0px 0px 0px;
    margin-bottom: 10px;
} 
/*a, a:visited {}*/

   .assign-calen {
    position: absolute;
    float: right;
    top: 3px;
    /* margin-right: 5px; */
    cursor: pointer;
    /* margin-right: 0px; */
    right: 19px;
}
   
</style>


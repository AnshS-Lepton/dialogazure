                                    <a href="#" onclick="SiteCustomer.SiteCustomerInfo.attachment.upload(@Model.system_id,'Customer',@Model.site_id);" value="Upload" id="btnUploadDocument">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_008</a>
                                    <a href="#" onclick="SiteCustomer.SiteCustomerInfo.clear();" value="Clear" id="btnClearDocument">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_009</a>
                                </div>
                                <div class="col-md-6 col-sm-6" id="divDocumentUpload"></div>
                            </div>


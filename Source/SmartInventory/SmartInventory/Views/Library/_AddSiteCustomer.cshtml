                    <button type="button" class="btn btn-primary" id="btnSaveSiteCust" onclick="ValidateCustomer();">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>

                }
                else if (Model.system_id > 0)
                {
                    <a href="javascript:void(0);" class="btn btn-default" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                    <button type="button" class="btn btn-primary" id="btnSaveSiteCust" onclick="ValidateCustomer();">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_008</button>


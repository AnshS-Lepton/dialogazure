                        @*-------------------------------------------------Added By Manoj------------------------------------------------------------------*@
                        <div class="form-group row">
                            <label class="col-md-2 col-sm-2" for="txtarea">Area:</label>
                            <div class="col-md-4 col-sm-4">
                                @Html.TextBoxFor(m => m.area, new { @class = "form-control " })

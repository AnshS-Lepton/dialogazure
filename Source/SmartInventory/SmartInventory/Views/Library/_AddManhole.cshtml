                                <label class="col-md-2 col-sm-2 white-space" for="txtProvinceName">@Resources.Resources.SI_OSP_MH_NET_FRM_006:</label>
                                <div class="col-md-4 col-sm-4">
                                    @Html.DropDownListFor(m => m.construction_type, new SelectList(Model.listConstructionType.Select(x => new { Value = x.dropdown_value, Text = x.dropdown_key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control" })

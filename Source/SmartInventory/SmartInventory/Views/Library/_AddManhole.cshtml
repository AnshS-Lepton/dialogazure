                                    @Html.DropDownListFor(m => m.mcgm_ward, new SelectList(Model.MCGMWardIn.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_key.ToString() }), "Value", "Text"), "--Select--", new { @class = "chosen-select col-sm-12", @style = "padding:0;" })
                                </div>
                        }
                        <div class="form-group row">
                            @if (constructionType != null)

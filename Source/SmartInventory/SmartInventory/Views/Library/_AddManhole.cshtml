                            <label class="col-md-2 col-sm-2" for="txtAuthority">Authority:</label>
                            <div class="col-md-4 col-sm-4">
                                @Html.TextBoxFor(m => m.authority, new { @class = "form-control", @id = "txtParentCode" })
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-md-2 col-sm-2" for="txtRouteName">Route Name:</label>
                            <div class="col-md-4 col-sm-4">
                                @Html.DropDownListFor(m => m.selected_route_ids, new SelectList(Model.lstRouteInfo.Select(x => new { Value = x.cable_id, Text = x.route_id+" - ("+ x.entity_network_id+")" }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", id = "txtrouteInfo" })
                            </div>
                        </div>
                        @*----------------------------------------------------------------------------------------------------------------------------------------------*@



                        <div class="form-group row">
                            <label class="col-md-2 col-sm-2" for="txtAddress">@Resources.Resources.SI_OSP_GBL_GBL_GBL_008:</label>
                            <div class="col-md-10 col-sm-10">
                                @Html.TextBoxFor(m => m.address, new { @class = "form-control", @id = "txtAddress", @maxlength = "100", autocomplete = "do-not-show-ac" })

                            @ProjectSpecifications()
                        </fieldset>
                    }
                    <div>@GeographicDetails()</div>
                </div>
                <div class="tab-pane" id="ItemSpecf">
                    @ManholeTemplateMaster()
                </div>

                <div class="tab-pane" id="LoopMangment"></div>
                <div class="tab-pane" id="PODAssoctn"></div>
                <div id="dvRefrence" class="tab-pane"></div>
                <div class="tab-pane" id="BarCodeInfo"></div>
                <div class="tab-pane" id="dvAT"></div>
                <div class="tab-pane" id="dvMaintainenceCharges"></div>
                <div id="NwEntityHistory" class="tab-pane"></div>

@model Models.StructureMaster
@using Models;
@using SmartInventory.Settings;

@helper pageMessage()
{

    { Html.RenderPartial("_PageMessage", Model.pageMsg); }

}
@helper pageShaftInfo()
{
    { Html.RenderPartial("_AddShaftInfo", Model); }
}

@helper pageFloorInfo()
{
    { Html.RenderPartial("_AddFloorInfo", Model); }
}
@helper Reference()
{
    { Html.RenderPartial("~/Views/Library/_Reference.cshtml", (IReference)Model); }
}
@helper GeographicDetails()
{
    { Html.RenderPartial("~/Views/Library/_GeographicDetails.cshtml", (IGeographicDetails)Model); }
}

@{
    var layerDetail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.Structure.ToString().ToUpper()).FirstOrDefault() : null;
    var editPermission = Utility.MiscHelper.GetLayerEditPermission(Model.system_id, (List<NetworkLayer>)Session["NerworkLayerDetails"], Model.network_status, EntityType.Structure.ToString());
    var objUser = (User)Session["userDetail"];
}


<style type="text/css">


#dvSiteInfo {
    background-image: url('@Url.Content("~/content/images/loading_new.gif")');
    background-position: center;
    background-repeat: no-repeat;
}

</style>
<!DOCTYPE html>
<div>
    @using (Ajax.BeginForm("SaveStructure", "Library", new AjaxOptions
    {
        HttpMethod = "POST",
        LoadingElementId = "dvProgress",
        UpdateTargetId = "dvModalBody",
        OnSuccess = "SaveSiteInfo",
    },
        new { id = "frmStructureEntity", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {
        @*@Html.AntiForgeryToken()
            @Html.ValidationSummary(true)*@
        @Html.HiddenFor(m => m.building_id)
        @Html.HiddenFor(m => m.region_id)
        @Html.HiddenFor(m => m.province_id)
        @Html.HiddenFor(m => m.created_by)
        @Html.HiddenFor(m => m.system_id, new { id = "hdnStructureId" })
        @Html.HiddenFor(m => m.created_on)
        @Html.HiddenFor(m => m.parent_system_id)
        @Html.HiddenFor(m => m.networkIdType)
        @Html.HiddenFor(m => m.parent_entity_type)
        @Html.HiddenFor(m => m.parent_network_id)
        @Html.HiddenFor(m => m.prevShaftWithoutRiser)
        @Html.HiddenFor(m => m.geom)
        @Html.HiddenFor(m => m.longitude)
        @Html.HiddenFor(m => m.latitude)
        @Html.HiddenFor(m => m.modified_on, new { Value = Model.modified_on != null ? ((DateTime)Model.modified_on).ToString("dd-MMM-yyyy HH:mm:ss.fffff") : "" })
        @Html.HiddenFor(m => m.network_status)
        if (objUser.user_type.ToLower() == "vendor")
        {
            @Html.HiddenFor(m => m.source_ref_id, new { id = "dvNTId" })
            @Html.HiddenFor(m => m.source_ref_type, new { id = "NETWORK_TICKET" })
        }
        <input type="hidden" value="Structure" id="hdnEntityType" />
        <input name="actionTab" type="hidden" value="GISInfoTab" id="hdnStructureTab" />
        <div class="libTabs">
            <div class="scrollmenu">
                <div><span class="spanSide go-left" id="spnRightMenu" style="display:none;"><i class="fa fa-angle-left" aria-hidden="true"></i></span></div>
                <div class="scrollerhide overflow-hidden">
                    <ul class="nav nav-tabs tabs-left" id="ulStructureTabs">
                        <li class="active"><a class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010 @(Model.lstUserModule.Contains("ENT-DTL-GI")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"#GISInfo":"")" data-toggle="tab" id="linkGisInfoTab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>
                        <li><a href="#ShaftInfo" data-toggle="tab" id="linkShaftTab">@Resources.Resources.SI_OSP_STR_NET_FRM_001</a></li>
                        <li><a href="#FloorInfo" data-toggle="tab" id="linkFloorTab">@Resources.Resources.SI_OSP_STR_NET_FRM_002</a></li>
                        @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_at_enabled)
                        {
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ACT")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_033 @(Model.lstUserModule.Contains("ENT-DTL-ACT")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ACT") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-ACT")?"#dvAT":"")" onclick="si.GetATAcceptance('@Model.system_id','@EntityType.Structure.ToString()','@editPermission.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_033</a></li>
                        }
                        @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_site_enabled)
                        {
                            <li><a href="#dvSiteInfo" onclick="si.GetSiteInformation('@Model.system_id','@editPermission.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_STR_NET_FRM_003</a></li>
                        }
                        <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENS")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_152 @(Model.lstUserModule.Contains("ENT-DTL-ENS")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENS") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-ENS")?"#NwEntityHistory":"")" id="Nw_EntityHistory" onclick="si.GetNetworkEntityHistory('@Model.system_id','@EntityType.Structure.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_152</a></li>
                        @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_reference_allowed == true)
                        {
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_537 @(Model.lstUserModule.Contains("ENT-DTL-ENR")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENR") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"#Reference":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                        }
                    </ul>
                </div>
                <div id="divRightMenu" style="display:none;">
                    <span class="spanSide go-right"><i class="fa fa-angle-right" aria-hidden="true"></i></span>
                    <span class="spanSide" id="dropdown" style="border-left: 1px solid #b9b7b7;     margin-left: -4px;"><i class="fa fa-angle-down" aria-hidden="true"></i></span>
                    <div class="arrowDropUp"></div>
                    <div class="dropMenu">
                        <div class="alltabs">@Resources.Resources.SI_OSP_GBL_NET_FRM_062</div>
                        <ul>
                            <li class="active"><a class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010 @(Model.lstUserModule.Contains("ENT-DTL-GI")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"#GISInfo":"")" data-toggle="tab" id="linkGisInfoTab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>
                            <li><a href="#ShaftInfo" data-toggle="tab" id="linkShaftTab">@Resources.Resources.SI_OSP_STR_NET_FRM_001</a></li>
                            <li><a href="#FloorInfo" data-toggle="tab" id="linkFloorTab">@Resources.Resources.SI_OSP_STR_NET_FRM_002</a></li>
                            @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_at_enabled)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ACT")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_033 @(Model.lstUserModule.Contains("ENT-DTL-ACT")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ACT") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-ACT")?"#dvAT":"")" onclick="si.GetATAcceptance('@Model.system_id','@EntityType.Structure.ToString()','@editPermission.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_033</a></li>
                            }
                            @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_site_enabled)
                            {
                                <li><a href="#dvSiteInfo" onclick="si.GetSiteInformation('@Model.system_id','@editPermission.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_STR_NET_FRM_003</a></li>
                            }
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENS")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_152 @(Model.lstUserModule.Contains("ENT-DTL-ENS")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENS") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-ENS")?"#NwEntityHistory":"")" id="Nw_EntityHistory" onclick="si.GetNetworkEntityHistory('@Model.system_id','@EntityType.Structure.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_152</a></li>
                            @if (Model.system_id > 0 && layerDetail != null)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_537 @(Model.lstUserModule.Contains("ENT-DTL-ENR")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENR") ? "" : "block;")" href="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"#Reference":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <!-- Message Pop-up -->
        @pageMessage()
        <div class="TabContent--max-over">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"tab-pane active":"tab-pane active dvdisabled")" id="GISInfo">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_GBL_GBL_052 </legend>

                        <div class="form-group">
                            <label class="control-label col-sm-4" for="txtBuildingCode">
                                @Resources.Resources.SI_OSP_STR_NET_FRM_004
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }
                                :
                            </label>
                            <div class="col-sm-8">
                                @Html.TextBoxFor(m => m.network_id, Model.networkIdType == NetworkIdType.A.ToString() ? (object)new { @class = "form-control", @readonly = true, @data_val = "false" } : (Model.system_id > 0 ? (object)new { @class = "form-control", @readonly = true } : (object)new { @class = "form-control" }))
                            </div>

                        </div>

                        <div class="form-group">
                            <label class="control-label col-sm-4" for="txtStructureName">
                                @Resources.Resources.SI_OSP_GBL_NET_FRM_059
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }:
                            </label>
                            <div class="col-sm-8">
                                @Html.TextBoxFor(m => m.structure_name,
                                 SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(
                                   new
                                   {
                                       @class = "form-control",
                                       @maxlength = "50",
                                       autocomplete = "do-not-show-ac"
                                   }, (Model.networkIdType == "M" ? new { @required = true } : null)))
                                @Html.ValidationMessageFor(model => model.structure_name)
                            </div>


                        </div>
                        <div class="form-group">
                            <label class="control-label col-sm-4" for="txtLongLat">@Resources.Resources.SI_OSP_STR_NET_FRM_006<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-8">
                                @{ Model.geom = Model.geom.Replace(" ", ",");}
                                @Html.TextBoxFor(m => m.geom, new { @class = "form-control", @readonly = true })
                            </div>

                        </div>

                        @*<div class="form-group">
                                <label class="control-label col-sm-4" for="txtNoOfShaft">No of Shafts<i class="clsMandatory">*</i>:</label>
                                <div class="col-sm-8">
                                    @Html.TextBoxFor(m => m.no_of_shaft, new { @class = "form-control", @onkeypress = "return si.allowOnlyNumber(event);", @onpaste = "return false;", @maxlength = "3" })
                                </div>
                            </div>*@
                        @*<div class="form-group">
                                <label class="control-label col-sm-4" for="txtNoOfFloor">No of Floor<i class="clsMandatory">*</i>:</label>
                                <div class="col-sm-8">
                                    @Html.TextBoxFor(m => m.no_of_floor, new { @class = "form-control", @onkeypress = "return si.allowOnlyNumber(event);", @onpaste = "return false;", @maxlength = "3" })
                                    @Html.ValidationMessageFor(model => model.no_of_floor)
                                </div>
                            </div>*@
                        <div class="form-group">
                            <label class="control-label col-sm-4" for="txtNoOfFlat">@Resources.Resources.SI_OSP_STR_NET_FRM_007<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-8">
                                @Html.TextBoxFor(m => m.no_of_flat, new { @class = "form-control numbers-only", @id = "no_of_flat", @onkeypress = "return si.allowOnlyNumber(event);", @maxlength = "4" })
                                @Html.ValidationMessageFor(model => model.no_of_flat)
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="control-label col-sm-4" for="txtNoOfOccupants">@Resources.Resources.SI_OSP_STR_NET_FRM_008<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-8">
                                @Html.TextBoxFor(m => m.no_of_occupants, new { @class = "form-control numbers-only", @onkeypress = "return si.allowOnlyNumber(event);", @maxlength = "4" })
                                @Html.ValidationMessageFor(model => model.no_of_occupants)
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="control-label col-sm-4" for="txtStruBusinessPass">@Resources.Resources.SI_OSP_STR_NET_FRM_009<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-8">
                                @Html.TextBoxFor(m => m.business_pass, new { @class = "form-control numbers-only", @onkeypress = "return si.allowOnlyNumber(event);", @maxlength = "4" })
                                @Html.ValidationMessageFor(model => model.business_pass)
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="control-label col-sm-4" for="txtStruHomePass">@Resources.Resources.SI_OSP_STR_NET_FRM_010<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-8">
                                @Html.TextBoxFor(m => m.home_pass, new { @class = "form-control numbers-only", @onkeypress = "return si.allowOnlyNumber(event);", @maxlength = "4" })
                                @Html.ValidationMessageFor(model => model.home_pass)

                            </div>
                        </div>
                        <div class="form-group">
                            <label class="control-label col-sm-4" for="txtStructureName">@Resources.Resources.SI_OSP_GBL_GBL_GBL_006:</label>
                            <div class="col-sm-8">
                                @Html.TextBoxFor(m => m.remarks, new { @class = "form-control", @maxlength = "100" })
                            </div>


                        </div>
                    </fieldset>
                    <div>
                        @GeographicDetails()
                    </div>
                </div>
                <div class="tab-pane" id="ShaftInfo" style="min-height:260px;">
                    <div class="form-group">
                        <label class="control-label col-sm-4" for="txtNoOfShaft" style="padding-left:0 !important;">@Resources.Resources.SI_OSP_STR_NET_FRM_011<i class="clsMandatory"></i>:</label>
                        <div class="col-sm-2" style="padding-top: 7px;">

                            <span id="spTotalShaft"></span>
                        </div>
                    </div>
                    @pageShaftInfo()

                </div>

                <div class="tab-pane" id="FloorInfo" style="min-height:260px;">
                    <div class="form-group">
                        <label class="control-label col-sm-4" for="txtNoOfFloor" style="padding-left:0 !important;">@Resources.Resources.SI_OSP_STR_NET_FRM_012<i class="clsMandatory"></i>:</label>
                        <div class="col-sm-2" style="padding-top: 7px;">

                            <span id="spTotalFloor"></span>
                        </div>
                    </div>
                    @pageFloorInfo()

                </div>

                <div class="tab-pane" id="dvAT"></div>
                <div class="tab-pane" id="dvSiteInfo"></div>
                <div id="NwEntityHistory" class="tab-pane"></div>
                <div class="tab-pane" id="Reference">
                    @Reference()
                </div>
            </div>
        </div>

        <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"d-flex ModalFooter":"d-flex ModalFooter dvdisabled")" id="dvBtnAction">
            @if (Model.system_id > 0)
            {
                <div class="ModelFooterInfo">
                    <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_014:</label>
                    <label class="model-label-info">@(Model.network_status != null ? Utility.MiscHelper.GetNetworkStatus(Model.network_status.ToUpper()) : string.Empty)</label>
                    @*<label class="control-label" for="txtLongitude">Created On:</label>*@
                    <label class="model-label-info" title="@(Model.created_on != null ? Utility.MiscHelper.FormatDateTime(Model.created_on.ToString()) : string.Empty)"> @Resources.Resources.SI_OSP_GBL_GBL_GBL_007: @(Model.created_on != null ? Utility.MiscHelper.TimeAgo(Model.created_on.ToString()) : string.Empty)</label>
                </div>
            }
            <div class="ml-auto">

                @if (Model.system_id == 0)
                {
                    @*<button type="button" class="btn btn-primary" id="btnSaveStructure" onclick="si.updateStructure();">Save</button>*@
                    <a href="javascript:void(0);" class="btn btn-default mr-01" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                    <input type="button" formmethod="post" class="btn btn-primary  @(editPermission==true?"":"dvdisabled")" name="actionTab" id="btnSaveStructure" onclick="si.updateStructure();" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004" />

                }

                else if (Model.system_id != 0)
                { <a href="javascript:void(0);" class="btn btn-default mr-01" data-dismiss="modal" id="btnCancelStructure">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                <input type="button" formmethod="post" class="btn btn-primary  @(editPermission==true?"":"dvdisabled")" id="btnUpdateStructure" onclick="si.updateStructure();" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_003" />
                @*<input type="button" formmethod="post" class="btn btn-primary" name="update" id="btnUpdateStructure" onclick="si.updateStructure();" value="Update" />*@

            }
            </div>
        </div>
        <div class="clearfix"></div>
    }
</div>

<script>
                $(document).ready(function () {
                     
                    callFormValidator("frmStructureEntity");
                    if ('@Model.system_id' != 0) {
                        $('#infoTB .dragStructure').hide();
                    }

                    $("#spTotalShaft").text('@Model.no_of_shaft');
                    $("#spTotalFloor").text('@Model.no_of_floor');

                    $('#system_id').val('@Model.system_id');
                    $('.chosen-select').chosen({ width: '100%' });

                    if ('@Model.system_id' == 0) {

                        //if ($('#no_of_shaft').val() == 0)
                        //    $('#no_of_shaft').val('');
                        //if ($('#no_of_floor').val() == 0)
                        //    $('#no_of_floor').val('');

                        if ($('#no_of_flat').val() == 0)
                            $('#no_of_flat').val('');
                        if ($('#no_of_occupants').val() == 0)
                            $('#no_of_occupants').val('');

                        if ($('#business_pass').val() == 0)
                            $('#business_pass').val('');
                        if ($('#home_pass').val() == 0)
                            $('#home_pass').val('');
                    }
                    $('#ModalPopUp .modal-dialog').width(480);
                    $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });


                });


                @*if ('@editPermission' == 'False') {
                    document.getElementById("btnUpdateStructure").disabled = true;
                }
                else {
                    document.getElementById("btnUpdateStructure").disabled = false;
                }*@



                $("input.numbers-only").on("paste", function () {
                    var thisvalue = this;

                    setTimeout(function () {
                        var OnlyNumber = new RegExp(/^[0-9]{1,10}$/);
                         
                        if (!OnlyNumber.test(thisvalue.value)) {
                            thisvalue.value = "";
                        }
                    }, 0);
                });


                $("#ulStructureTabs li a").on("click", function () {
                     
                    var url = $(this).attr('href'); //
                    if (url == '#dvAT') {
                        $("#ModalPopUp .modal-lg").animate({ 'width': url == '#dvAT' ? '750px' : '480px' });
                        //$('#dvBtnAction').show();
                        $('div#dvBtnAction').show();

                    }
                    else if (url == '#dvSiteInfo') {
                        $('.refreshIcon').slideToggle();
                        $("#ModalPopUp .modal-lg").animate({ 'width': url == '#dvSiteInfo' ? '750px' : '480px' });

                        //$('#dvBtnAction').hide();
                        $('div#dvBtnAction').hide();

                    }
                    else {
                        $("#ModalPopUp .modal-lg").animate({ 'width': '480px' });
                        //$('#dvBtnAction').show();
                        $('div#dvBtnAction').show();
                        $(".dropMenu").hide();
                    }
                    //scrollview();

                });
                $("#divRightMenu .dropMenu ul li a").on("click", function () {
                     
                    var url = $(this).attr('href'); //
                    if (url == '#dvAT') {
                        $("#ModalPopUp .modal-lg").animate({ 'width': url == '#dvAT' ? '750px' : '480px' });
                        $('#dvBtnAction').show();

                    }
                    else if (url == '#dvSiteInfo') {
                        $('.refreshIcon').slideToggle();
                        $("#ModalPopUp .modal-lg").animate({ 'width': url == '#dvSiteInfo' ? '750px' : '480px' });

                        $('#dvBtnAction').hide();

                    }
                    else {
                        $("#ModalPopUp .modal-lg").animate({ 'width': '480px' });
                        $('#dvBtnAction').show();
                    }
                    //scrollview();

                });
                $('.go-right').on("click", function (event) {
                    var pos = $('div.overflow-hidden').scrollLeft() + 160;
                    $('div.overflow-hidden').css("scroll-behavior", "smooth");
                    $('div.overflow-hidden').scrollLeft(pos);

                });
                $('.go-left').on("click", function (event) {
                    var pos = $('div.overflow-hidden').scrollLeft() - 160;
                    $('div.overflow-hidden').css("scroll-behavior", "smooth");
                    $('div.overflow-hidden').scrollLeft(pos);
                });

                $(document).ready(function () {
                     
                    $("#dropdown").on("click", function () {
                       // $(".dropMenu").slideToggle();
                       $(".arrowDropUp").toggle();
                    });

                    $('.dropMenu ul li').on("click", function () {
                        $('.dropMenu ul li').removeClass("activeSideMenu ");
                        $(this).addClass("activeSideMenu");
                    });

                });

                $(document).ready(function () {
                     
                    $('#divRightMenu .dropMenu ul li a').click(
                       function () {
                           si.autoScroll(this);
                       }
                       );
                    //scrollview();
                   // setTimeout(function () {
                        //var allTabWidth = 0;
                        //$.each($('.libTabs .tabs-left li'), function (indx, itm) {
                        //    allTabWidth += $(this).width();
                        //});
                        //if (allTabWidth > $('#dvModalBody').width()) {
                        //    $('#spnRightMenu,#divRightMenu').show();
                        //}
                   // }, 500)

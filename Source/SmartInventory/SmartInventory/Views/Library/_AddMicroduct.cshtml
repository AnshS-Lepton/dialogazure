                    <span class="spanSide go-right"><i class="fa fa-angle-right" aria-hidden="true"></i></span>
                    <span class="spanSide" id="dropdown" style="border-left: 1px solid #b9b7b7; margin-left: -4px;"><i class="fa fa-angle-down" aria-hidden="true"></i></span>
                    <div class="arrowDropUp"></div>
                    <div class="dropMenu">
                        <div class="alltabs">@Resources.Resources.SI_OSP_CAB_NET_FRM_014</div>
                        <ul>
                            <li class="active"><a class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_010 @(Model.lstUserModule.Contains("ENT-DTL-GI")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GI") ? "" : "block;")"
                             href="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"#GISInfo":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>
                            <li><a  class="@(Model.lstUserModule.Contains("ENT-DTL-ISP")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_005 @(Model.lstUserModule.Contains("ENT-DTL-ISP")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ISP") ? "" : "block;")"
                               href="@(Model.lstUserModule.Contains("ENT-DTL-ISP")?"#ItemSpecf":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_005</a></li>
                            @if (layerDetail != null && layerDetail.is_pod_association_allowed)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-COAS")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_159 @(Model.lstUserModule.Contains("ENT-DTL-COAS")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-COAS") ? "" : "block;")"
                                 href="@(Model.lstUserModule.Contains("ENT-DTL-COAS")?"#PODAssoctn":"")" id="Pod_Association" onclick="si.GetPODAssociationDetail('@Model.geom', '@Model.system_id','@EntityType.Microduct.ToString()', '@Model.primary_pod_system_id', '@Model.secondary_pod_system_id');" data-toggle="tab">@layer_Detail.layer_title <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_159</label></a></li>
                            }
                            @if (layerDetail != null && layerDetail.is_reference_allowed)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-GRF")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_006 @(Model.lstUserModule.Contains("ENT-DTL-GRF")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-GRF") ? "" : "block;")"
                                href="@(Model.lstUserModule.Contains("ENT-DTL-GRF")?"#dvRefrence":"")" onclick="si.getEntityReference('@Model.system_id','@EntityType.Microduct.ToString()','@editPermission.ToString()');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_006</a></li>
                            }
                            <!--Reigon Additional Attribute to show the partial view-->
                            <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ADA")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_GBL_FRM_222 @(Model.lstUserModule.Contains("ENT-DTL-ADA")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ADA") ? "" : "block;")"
                                 href="@(Model.lstUserModule.Contains("ENT-DTL-ADA")?"#AdditionalAttributes":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_FRM_222</a></li>
                            <!--End Reigon Additional Attribute-->
                            @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_reference_allowed == true)
                            {
                                <li><a class="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_537 @(Model.lstUserModule.Contains("ENT-DTL-ENR")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-DTL-ENR") ? "" : "block;")"
                                href="@(Model.lstUserModule.Contains("ENT-DTL-ENR")?"#Reference":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="TabContent--max-over">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"tab-pane active":"tab-pane active dvdisabled")" id="GISInfo">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@layerDetail.layer_title </legend>
                        <div class="form-group">
                            <label class="control-label col-md-2 col-sm-2 " for="txtDuctCode">
                                @Resources.Resources.SI_OSP_GBL_GBL_GBL_001
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }
                                :
                            </label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                <div id="txtMaskedNetworkId"></div>

                            </div>
                            <label class="control-label col-md-2 col-sm-2 ">
                                @Resources.Resources.SI_OSP_GBL_NET_FRM_059
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }:
                            </label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.TextBoxFor(m => m.microduct_name,
                                   SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(
                              new
                              {
                                  @class = "form-control",
                                  @maxlength = "50"
                              }, (Model.networkIdType == "M" ? new { @required = true } : null)))


                            </div>



                            <label class="control-label col-md-2 col-sm-2 ">@Resources.Resources.SI_OSP_GBL_NET_FRM_035:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.TextBoxFor(m => m.a_location, new { @class = "form-control clsReadOnly", @readonly = true })
                            </div>

                            <label class="control-label col-md-2 col-sm-2 ">@Resources.Resources.SI_OSP_GBL_NET_FRM_036:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.TextBoxFor(m => m.b_location, new { @class = "form-control clsReadOnly", @readonly = true })
                            </div>


                            <label class="control-label col-md-2 col-sm-2 ">@Resources.Resources.SI_OSP_GBL_GBL_GBL_009:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.TextBoxFor(m => m.pin_code, new { @class = "form-control", @onkeypress = "return si.allowOnlyNumber(event);", @maxlength = "6", @minlength = "6", autocomplete = "new-password" })
                                @Html.ValidationMessageFor(model => model.pin_code)
                            </div>
                            <label class="control-label col-md-2 col-sm-2 ">@Resources.Resources.SI_OSP_DUC_NET_FRM_011:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">

                                @Html.TextBoxFor(m => m.no_of_cables, new { @class = "form-control clsReadOnly", @maxlength = "10" })

                            </div>




                            <label class="control-label col-md-2 col-sm-2 " for="txtSubAreaName">@Resources.Resources.SI_OSP_DUC_NET_FRM_005:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.TextBoxFor(m => m.calculated_length, new { @class = "form-control clsReadOnly", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);", @readonly = true, @maxlength = "10" })
                            </div>
                            <label class="control-label col-md-2 col-sm-2 " for="txtSubAreaName">@Resources.Resources.SI_OSP_DUC_NET_FRM_006:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.TextBoxFor(m => m.manual_length, new { @class = "form-control", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);" })
                            </div>

                            <label class="control-label col-md-2 col-sm-2 ">@Resources.Resources.SI_OSP_DUC_NET_FRM_008:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.TextBoxFor(m => m.inner_dimension, new { @class = "form-control", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);" })
                            </div>
                            <label class="control-label col-md-2 col-sm-2 ">@Resources.Resources.SI_OSP_DUC_NET_FRM_007:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.TextBoxFor(m => m.outer_dimension, new { @class = "form-control", @onkeydown = "return ValidateNumberDecimal(this,event,8,2);" })
                            </div>


                        </div>


                        <div class="form-group">
                            <label class="control-label col-md-2 col-sm-2 ">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_GBL_GBL_023:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.DropDownListFor(m => m.microduct_type, new SelectList(Model.MicroductTypeIn.Select(x => new { Value = x.dropdown_key, Text = x.dropdown_value }), "Value", "Text"), "--Select--", new { @class = "chosen-select col-sm-12" })
                            </div>

                            <label class="control-label col-md-2 col-sm-2 ">@Resources.Resources.SI_OSP_DUC_NET_RPT_009:</label>
                            <div class="col-md-4 col-sm-4  mrgn_btm">
                                @Html.DropDownListFor(m => m.color_code, new SelectList(Model.MicroductColorIn.Select(x => new { Value = x.dropdown_key, Text = x.dropdown_value }), "Value", "Text"), "--Select--", new { @class = "chosen-select col-sm-12" })
                            </div>

                        </div>
                        <div class="form-group">
                            @OwnershipInfo()
                        </div>
                        <div>@AdditionalFields()</div>
                        <div class="form-group">
                            <div class="form-group">
                                <label class="control-label col-md-2 col-sm-2" for="txtMaterialType">@Resources.Resources.SI_OSP_DUC_NET_FRM_020:</label>
                                <div class="col-md-4 col-sm-4 ">
                                    @Html.DropDownListFor(m => m.material_type, new SelectList(Model.lstMaterialType.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "--Select--", new { @class = "chosen-select col-sm-12", @style = "padding:0;" })
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="control-label col-md-2 col-sm-2" for="txtInternalDiameter">@Resources.Resources.SI_OSP_DUC_NET_FRM_021:</label>
                            <div class="col-md-4 col-sm-4 ">
                                @Html.DropDownListFor(m => m.internal_diameter, new SelectList(Model.lstInternalDiameter.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "--Select--", new { @class = "chosen-select col-sm-12", @style = "padding:0;" })
                            </div>
                            <label class="control-label col-md-2 col-sm-2" for="txtExternalDiameter">@Resources.Resources.SI_OSP_DUC_NET_FRM_022:</label>
                            <div class="col-md-4 col-sm-4 ">
                                @Html.DropDownListFor(m => m.external_diameter, new SelectList(Model.lstExternalDiameter.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "--Select--", new { @class = "chosen-select col-sm-12", @style = "padding:0;" })
                            </div>
                        </div>
                        <div class="form-group" style="margin-right:14px;">
                            @AcquireFrom()
                        </div>
                        <div class="form-group">
                            <label class="control-label col-md-2 col-sm-2 ">@Resources.Resources.SI_OSP_GBL_GBL_GBL_006:</label>
                            <div class="col-sm-10 col-md-10">
                                @Html.TextAreaFor(m => m.remarks, new { @class = "form-control textarea-maxlen-validate", @maxlength = "1000" })
                            </div>
                        </div>
                    </fieldset>
                    @if (Model.lstUserModule.Contains("PROJ"))
                    {
                        <fieldset class="the-fieldset">
                            <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_GBL_FRM_001</legend>
                            @ProjectSpecifications()
                        </fieldset>
                    }
                    <div>
                        @GeographicDetails()
                    </div>
                </div>
                <div class="tab-pane" id="ItemSpecf">
                    @MicorductTemplateMaster()
                </div>
                <div id="dvRefrence" class="tab-pane"></div>
                <div class="tab-pane" id="PODAssoctn"></div>
                <div class="tab-pane" id="BarCodeInfo"></div>
                <div class="tab-pane" id="dvAT"></div>
                <div class="tab-pane" id="dvMaintainenceCharges"></div>
                <!--Reigon Additional Attribute to show the partial view-->
                <div class="tab-pane" id="AdditionalAttributes">
                    @AdditionalAttributes()
                </div>
                <!--End Reigon Additional Attribute-->
                <div class="tab-pane" id="Reference">
                    @Reference()
                </div>
            </div>
        </div>



        <div class="@(Model.lstUserModule.Contains("ENT-DTL-GI")?"d-flex ModalFooter":"d-flex ModalFooter dvdisabled")" id="dvBtnAction">
            @if (Model.system_id > 0)
            {
                <div class="ModelFooterInfo">
                    <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_014:</label>
                    <label class="model-label-info">@(Model.network_status != null ? Utility.MiscHelper.GetNetworkStatus(Model.network_status.ToUpper()) : string.Empty)</label>
                    <label for="txtLongitude">@Resources.Resources.SI_OSP_GBL_GBL_GBL_007:</label>
                    <label class="model-label-info" title="@(Model.created_on != null ? Utility.MiscHelper.FormatDateTime(Model.created_on.ToString()) : string.Empty)">@(Model.created_on != null ? Utility.MiscHelper.TimeAgo(Model.created_on.ToString()) : string.Empty)</label>
                </div>
            }
        <div class="ml-auto">
            <a href="javascript:void(0);" class="btn btn-default mr-01" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>

            @if (Model.system_id > 0)
            {
                <button type="button" onclick="formPost()" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnUpdateItemTemplate" disabled="disabled">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_003</button>
            }
            else
            {
                <button type="button" onclick="formPost()" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnSaveItemTemplate" disabled="disabled">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
            }

        </div>
        </div>
    }
</div>
<script type="text/javascript">
    var inputs = [];
    $(document).ready(function () {

        callFormValidator("frmAddMicroduct");
        $('.chosen-select').chosen({ width: '100%' });
        $('#specification').chosen().on('change',function (event) {
            var dID = $(this).val();
            bindVendor(dID);
        });
        $('#ddlVendor').chosen().on('change',function (event) {
            var specfi = $("#specification option:selected").val(); //
            var vandorid = $(this).val();
            var entitytype = $('#entityType').val();
            bindCateSubcat(entitytype, specfi, vandorid);
        });
        $('#ddlType').chosen().on('change',function (event) {
            var dID = $(this).val();
            bindBrand(dID);
        });
        $('#ddlBrand').chosen().on('change',function (event) {
            var dID = $(this).val();
            bindModel(dID);
        });
        EnableDisableUpdateButton("frmAddMicroduct", @Model.system_id > 0 ? "btnUpdateItemTemplate" : "btnSaveItemTemplate");

        //$("#MicroductMaster_network_id").val()
        //APPLY INPUT MASK ON NETWORK ID..
        getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');
        $("#frmAddMicroduct").on("submit", function () {
            $("#network_id").val($("#txtMaskedNetworkId").dxTextBox("option", "text").toUpperCase());
            si.upperCaseNetWorkId();
            //For AdditionalAttributes to set json and saving
            additionalAttributesUtility.SetJsonValue("#frmOtherInfo", "#hdnOtherInfo");
            //end region Additional-Attributes
            if (!entityReferencevalidation())
                return false;
            if (!entityMaintainence())
                return false;
            return true;
        });
        $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" }); 
    });
    function formPost() {
        debugger;

              

        $('#no_of_ways').val($("#ddlNoOfWays").val());
        if ($('#txtbomsubcategory').val() == '') {
            $('#txtbomsubcategory').next().addClass('input-validation-error');
            return false;
        }
        if ($('#ddlNoOfWays').val() == '') {
            $('#ddlNoOfWays').next().addClass('input-validation-error');
            $('a[href="#ItemSpecf"]').tab('show');
            return false;
        }       
        else {
            $("#frmAddMicroduct").submit();
        }
        
    }


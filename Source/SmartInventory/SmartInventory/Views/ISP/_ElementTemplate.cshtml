@model IEnumerable<Models.NetworkLayer>

<!DOCTYPE html>
<div class="d-flex mb-01">
    <label class="control-label upperCase">@Resources.Resources.SI_ISP_GBL_NET_FRM_019</label>
</div>
<div class="form-group">
    <div class="icon-SEARCH searchIcon"></div>
    <div><input type="text" class="form-control searchBox endtoruds" placeholder="@Resources.Resources.SI_ISP_GBL_NET_FRM_020" id="txtSearchElement" autocomplete="off" maxlength="30" /></div>
</div>
<div class="ISPElementList">
    @foreach (var item in Model)
    {
        <div class="ElementboxParent" data-entity-type="@item.layerTitle" data-is-shaft-element="@item.is_shaft_element" data-is-floor-element="@item.is_floor_element" title="@item.layerTitle" data-parent-entities="@item.parentEntities">
            <div class="ElementBox">
                @if (item.isTemplateRequired)
                {
                    <div class="clsTemplateIcon @((item.isTemplateRequired && item.templateId > 0) ? "templateFilled" : "")" data-href="@item.templateFormUrl" data-lyrname="@item.layerName" data-title="@item.layerTitle" data-roleid="@ViewBag.UserRoleId">T</div>
                }
                <div class="ElementTemplate icon-@item.layerName.ToUpper()  lib-@item.layerName.ToUpper() @(item.is_isp_layer_freezed_in_library==true?"dvdisabled":"")" data-template-id="@item.templateId" data-is-template-required="@item.isTemplateRequired" data-entity-type="@item.layerName" data-is-isp-child-layer="@item.is_isp_child_layer" data-is-isp-parent-layer="@item.is_isp_parent_layer">
                    @*@(item.layerTitle.Length > 4 ? item.layerTitle.Substring(0, 4) : item.layerTitle)*@
                </div>
            </div>
            <div class="entityName @(item.is_isp_layer_freezed_in_library==true?"dvdisabled":"")">@(item.layerTitle.Length > 10 ? item.layerTitle.Substring(0,10).ToString()+"...": item.layerTitle)</div>
        </div>
    }
    @if (Model == null) {
    <div id="divNoRecordFound" class="nr-found flex100">
        <span>@Resources.Resources.SI_ISP_GBL_GBL_GBL_001</span>
    </div>
    }
</div>

<script>
    $(document).ready(function () {
        $('.UploadAction [title!=""]').tooltip({ title: '', html: true, placement: "top" });
        $('#divImage [title!=""]').tooltip({ title: '', html: true, placement: "top" });
        $(".img_parentcheck").on("click", function () {
            CheckUnCheckAll('img_parentcheck', false, 'img_childcheck', false);
        })
        $(".img_childcheck").on("click", function () {
            CheckUnCheckAllOnSingle('img_parentcheck', false, 'img_childcheck', false);
        });

    });
    function DownloadImgDocs(systemid, Location) {
         
        var ettType = $("#infoTB").attr("att_entitytype");
        isp.downloadImgDocsByID('.ImagesContainer', '.img_doc_childcheck', 'Main/DownloadFiles', systemid, Location, ettType);
    }
    function deleteImgDocs(systemid, RefreshFn) {
        isp.deleteImgDocsByID('.ImagesContainer', '.img_doc_childcheck', 'Main/DeleteEntityImages', systemid, RefreshFn, '', 'Image');

    }
</script>

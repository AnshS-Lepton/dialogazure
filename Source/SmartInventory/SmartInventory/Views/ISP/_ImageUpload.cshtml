else
{
    <div class="UploadBody">
        <div class="col-sm-12 UploadDivlabel Marginbottom" id="divDraggFile" style="text-align:center">
            <img src="~/Content/images/Imageemptystate.svg" class="Marginbottom" /><br />
        </div>

        <div class="col-sm-12 UploadDivlabel" id="divImageUpload">
            <label class="btn btn-warning">
                <input type="file" name="ImgUpload" id="ImgUpload" class="btn btn-gray-img">@Resources.Resources.SI_ISP_GBL_NET_FRM_042

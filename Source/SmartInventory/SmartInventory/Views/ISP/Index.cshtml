@model Models.ISP.ISPViewModel

@using SmartInventory.Settings;

@{
    Models.NetworkLayer rackLayer = (Models.NetworkLayer)TempData["RackRolesData"] == null ? new Models.NetworkLayer() : (Models.NetworkLayer)TempData["RackRolesData"];

    Models.NetworkLayer equipmentLayer = (Models.NetworkLayer)TempData["EquipmentRolesData"] == null ? new Models.NetworkLayer() : (Models.NetworkLayer)TempData["EquipmentRolesData"];
}
<script src="~/Content/js/jspdf.min.js"></script>
<script src="~/Content/js/canvg.min.js"></script>
<script src="~/Content/js/html2canvas.js"></script>
<style>
    #divConnectionFilter {
        position: absolute;
        left: 32%;
        z-index: 9999;
        background: #fff;
        top: 25%;
        width: 600px;
        display: none;
        box-shadow: 0px 12px 32px #00000033 !important;
    }
   /* #rackViewDisplay > .svgDiv {
    background: none;
    margin: 0;
    border-radius: 5px;
    border: none;
    padding: 0px;
    position: relative;
}*/
  
   #rackLibFilterContext > .RadioDivCreate .RadioFunction {
    width: auto;
    white-space:nowrap;
}
   #rackLibFilterContext > .LibCell {
    float: left;
    border-radius: 5px;
    width: 100%;
}


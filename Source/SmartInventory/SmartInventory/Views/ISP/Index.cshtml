<!DOCTYPE html>
<div class="ISPTabs">
    <ul class="nav nav-tabs tabs-left">
        @if (Model.StructureId > 0)
        {
            <li id="tabIspView" class="active">
                <a href="#ISPInfo" data-toggle="tab" data-isp="true">@Resources.Resources.SI_ISP_GBL_NET_FRM_001</a>
            </li>
        }
        <li id="tabRoomView" class="event" style="display:none;">
            <a href="#RoomView" data-toggle="tab" data-room="true">@Resources.Resources.SI_ISP_GBL_NET_FRM_002</a>
            <i id="closeRoomView" class="icon-close"></i>
        </li>
        <li  id="tabEquipmentView" class="" style="display:none;">
            <a href="#divEquipmentView" id="linkEquipmentView" data-toggle="tab"  data-equipment="true">Equipment View</a>
            <i id="closeEquipmentView" class="icon-close"></i>
        </li>
    </ul>
</div>





<div class="tab-content">
    @if (Model.StructureId > 0)
    {
        <div id="ISPInfo" class="tab-pane active">
            <div class="ISP-Content">
                <div id="divleftMenu" class="leftMenu">
                    <div class="neLibrary icon-library" data-panel-class="clslibraryEntity" title="@Resources.Resources.SI_ISP_GBL_NET_FRM_003"></div>
                    <div class="neLayer icon-layers" data-panel-class="clsNetworkLayer" title="@Resources.Resources.SI_ISP_GBL_NET_FRM_004"></div>
                    <div class="ispInfoTool icon-Entity-Info" data-panel-class="clsInfoTool" title="@Resources.Resources.SI_ISP_GBL_NET_FRM_005"></div>
                </div>
                <div id="divStructureInfo">
                    <div>
                        @Html.Partial("_Library")
                    </div>

                    <div id="divISPNetworkLayer">
                        @Html.Partial("_NetworkLayer", Model.NetworkLayerElements)
                    </div>
                    <div id="divEntityInformation">
                        @Html.Partial("_Information", Model.entityInformation)
                    </div>
                    
                </div>
                <div id="divSplicingWindow" class="leftPanel">

                </div>


                


                @Ajax.ActionLink("ISP", "StructureInfo", "ISP", new { structureId = Model.StructureId }, new AjaxOptions { LoadingElementId = "dvProgress", UpdateTargetId = "divStructureView", InsertionMode = InsertionMode.Replace, OnSuccess = "isp.bindStructureEvents()" }, new { style = "display:none;", id = "ancrStructureInfo" })
                <div id="divStructureView">
                    @Html.Partial("_StructureInfo", Model)
                </div>
                <div class="ISP-Tool">
                    @if (Model.lstUserModule.Contains("MNS"))
                    {
                        <div class="wirelineTool icon-Manual-Splicing" id="divManualSplicing" title="@Resources.Resources.SI_ISP_GBL_NET_FRM_006"></div>
                    }
                    @if (Model.lstUserModule.Contains("CPF"))
                    {
                        <div class="wirelineTool icon-Connection-Path-finder" id="divCPF" title="@Resources.Resources.SI_ISP_GBL_NET_FRM_007" onclick="splicing.SinglePathFind(true);" style="display:none"></div>
                    }
                    <div class="ispInfoTool wirelineTool icon-information" id="divInformation" title="@Resources.Resources.SI_ISP_GBL_NET_FRM_008"></div>
                </div>
                <div class="ISPlegend" style="display: none;">
                    <div class="info_ISPlegend_bg">
                        <h5>Legend</h5>
                        <span class="icon-close ml-auto" onclick="isp.ClosedISPLegend()"></span>
                    </div>
                    <div class="LegendContent">

                    </div>
                </div>
            </div>
        </div>
    }

    <div id="RoomView" class="tab-pane " style="display:none;">
        <div id="divConnectionFilter"></div>
        <div class="ISP-Content">
            <div id="divRoomleftMenu" class="leftMenu">
                <div id="navRoomLib" class="neLibrary icon-library activeISPTab" data-panel-class="clsRoomlib" title="@Resources.Resources.SI_ISP_GBL_NET_FRM_003"></div>
                <div id="navRoomInfo" class="ispInfoTool icon-Entity-Info" data-panel-class="clsRoomInfo" title="@Resources.Resources.SI_ISP_GBL_NET_FRM_010"></div>
            </div>
        </div>

        <div id="roomLeftPanel" class="clsRoomlib leftPanel" style="display:none;">
            @Html.Partial("_RoomLibrary")
        </div>

        <div id="roomRackInfo" class="clsRoomInfo leftPanel" style="display:none;">
            @Html.Partial("_Information", Model.entityInformation)
        </div>
            

                    @*<h4 class="modal-title">@Resources.Resources.SI_OSP_GBL_NET_FRM_451</h4>
                </div>*@

            

        <div id="divRoomStructureView" class="roomViewPanel">
            @Html.HiddenFor(x => x.POPId, new { @id = "ispPOPId" })
            @Html.HiddenFor(x => x.POPType, new { @id = "ispPOPType" })
            @Html.Partial("_RoomView")
        </div>
        
    </div>
    <div id="divEquipmentView" style="display:none;">

    </div>
    <footer class="ISPFooter" id="ISPFooter" style="display:none;">
        <div class="row">
            <div class="col-md-2"></div>
            <div class="col-md-10">
                @*<i class="fa fa-bars" aria-hidden="true"></i>*@
                <div id="rackTabContext">

                </div>
            </div>
        </div>
    </footer>
    <div id="divConnectionContainer" style="position: relative;z-index: 999;height: 452px;top: 68px;width: 858px;margin: 0 auto;background-color: #fff;display:none;border:1px solid #8080803d;box-shadow: 16px 16px 16px #8080805e"></div>
    @*@Html.Partial("_ConnectionEditor")*@
</div>



@model List<Models.DocumentResult>
@using SmartInventory.Settings;

<!DOCTYPE html>
<div id="UploadIspRefLink">
    <div class="popBody">
        <div class="form-group row">
            <label class="control-label col-sm-4" for="DocrefLinkText"> Display Name:<i class="clsMandatory">*</i></label>
            <div class="col-sm-8">
                <input type="text" id="DocrefLinkText" maxlength="190" class="form-control">
            </div>
        </div>
        <div class="form-group row">
            <label class="control-label col-sm-4" for="DocrefLink">Reference Link:<i class="clsMandatory">*</i></label>
            <div class="col-sm-8">
                <input type="text" id="DocrefLink" maxlength="498" class="form-control">
            </div>
        </div>
    </div>
    <div class="ModalFooter" id="dvBtnActionRefLink">
        <a href="javascript:void(0);" class="btn btn-warning ml-auto mr-01" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
        <button type="submit" class="btn btn-primary" onclick="isp.uploadRefLink();" id="btnSaveRefLink">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
    </div>
</div>




<script>
        $(document).ready(function () {
            notAllowZero('#cable_calculated_length');
            setMeasuredLength('#cable_calculated_length', '#cable_measured_length');
            callFormValidator("frmAddCable");
            $('.chosen-select').chosen({ width: '100%' });

            //APPLY INPUT MASK ON NETWORK ID..
            getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');

            $("#frmAddCable").on("submit", function () {
                $("#network_id").val($("#txtMaskedNetworkId").dxTextBox("option", "text").toUpperCase());
            });

            $("#btnSaveCable").on("click", function (e) {
                if ((parseFloat($('#end_reading').val()) != 0 || parseFloat($('#start_reading').val()) != 0) && (parseFloat($('#end_reading').val()) <= parseFloat($('#start_reading').val()))) {
                    alert(MultilingualKey.SI_OSP_GBL_JQ_FRM_052);
                    return false;
                }
                if ($('#cable_type').val() != 'ISP') {
                    if (parseFloat($('#cable_calculated_length').val()) < parseFloat($('#cable_measured_length').val())) {
                        alert(MultilingualKey.SI_ISP_GBL_JQ_GBL_049, 'warning', 'warning');
                        return false;
                    }
                }
            });
            $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });

        });
        $("#fiberCountIn").on('change', function (e) {

            var ddlFiberCount = $("#fiberCountIn_chosen").children('a').text().trim();
            if (ddlFiberCount != "Select Fiber Count") {

                ddlFiberCount = ddlFiberCount.split(' ');
                $('#no_of_tube').val('1').attr('readonly', false);
                $('#no_of_core_per_tube').val(ddlFiberCount[0]).attr('readonly', false);
                $('#total_core').val(ddlFiberCount[0]);
            }
            else {
                $('#no_of_tube').val(0);
                $('#no_of_core_per_tube').val(0);
                $('#total_core').val(0);
            }

        });
    function formPost() {
         
        if ($('#txtbomsubcategory').val() == '') {
            $('#txtbomsubcategory').next().addClass('input-validation-error');
            return false;
        }
        else {
            $("#frmAddCable").submit();
        }
    }

</script>


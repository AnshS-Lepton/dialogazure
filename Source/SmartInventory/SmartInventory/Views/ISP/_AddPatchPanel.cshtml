@model Models.PatchPanelMaster
@using Models;
@using SmartInventory.Settings;
@helper PatchPanelTemplateMaster()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_PatchPanelTemplateMaster.cshtml", (PatchPanelTemplateMaster)Model); }
}

@helper ProjectSpecifications()
{
    { Html.RenderPartial("~/Views/Library/_ProjectSpecification.cshtml", (IProjectSpecification)Model); }
}
@helper OwnershipInfo()
{
    { Html.RenderPartial("~/Views/Library/_OwnershipInfo.cshtml", (IOwnershipInfo)Model); }
}
@helper AcquireFrom()
{
    { Html.RenderPartial("~/Views/Library/_AcquireFrom.cshtml", (IAcquireFrom)Model); }
}
@helper CustomCoordinate()
{
    { Html.RenderPartial("~/Views/Library/_CustomCoordinate.cshtml", (ICustomCoordinate)Model); }
}
@helper pageMessage()
{
    { Html.RenderPartial("_PageMessage", Model.objPM); }

}
@helper Reference()
{
    { Html.RenderPartial("~/Views/Library/_Reference.cshtml", (IReference)Model); }
}
@helper GeographicDetails()
{
    { Html.RenderPartial("~/Views/Library/_GeographicDetails.cshtml", (IGeographicDetails)Model); }
}
@helper AdditionalFields()
{
    { Html.RenderPartial("~/Views/Library/_AdditionalFields.cshtml", (IAdditionalFields)Model); }
}
@{
    var layerDetail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.PatchPanel.ToString().ToUpper()).FirstOrDefault() : null;
    var layer_Detail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.POD.ToString().ToUpper()).FirstOrDefault() : null;
    var editPermission = Utility.MiscHelper.GetLayerEditPermission(Model.system_id, (List<NetworkLayer>)Session["NerworkLayerDetails"], Model.network_status, EntityType.PatchPanel.ToString());
}
<!DOCTYPE html>
<div class="libDetail">
    @using (Ajax.BeginForm("SavePatchPanel", "ISP", new AjaxOptions
    {
        HttpMethod = "POST",
        LoadingElementId = "dvProgress",
        UpdateTargetId = "dvModalBody",
        OnBegin = "return ValidateNetworkId(" + Model.system_id + ",'" + Model.network_id + "','" + Model.networkIdType + "','" + EntityType.PatchPanel.ToString() + "');",
        OnSuccess = "isp.SuccessSave"

    },
                new { id = "frmAddPatchPanel", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {

        @Html.HiddenFor(m => m.system_id)
        @Html.HiddenFor(m => m.objIspEntityMap.structure_id)
        @Html.HiddenFor(m => m.parent_system_id)
        @Html.HiddenFor(m => m.networkIdType)
        @Html.HiddenFor(m => m.parent_entity_type)
        @Html.HiddenFor(m => m.network_id)
        @Html.HiddenFor(m => m.objIspEntityMap.floor_id, new { id = "floor_id" })
        @Html.HiddenFor(m => m.objIspEntityMap.shaft_id, new { id = "shaft_id" })
        @Html.HiddenFor(m => m.objIspEntityMap.id)
        @Html.HiddenFor(m => m.pSystemId)
        @Html.HiddenFor(m => m.pEntityType)
        @Html.HiddenFor(m => m.pNetworkId)
        @Html.HiddenFor(m => m.modified_on, new { Value = Model.modified_on != null ? ((DateTime)Model.modified_on).ToString("dd-MMM-yyyy HH:mm:ss.fffff") : "" })
        @Html.HiddenFor(m => m.geom)
        <!-- Message Pop-up -->
        @pageMessage()
        <div class="libTabs">
            <div class="scrollmenu">
                <div><span class="spanSide go-left" id="spnRightMenu" style="display:none;"><i class="fa fa-angle-left" aria-hidden="true"></i></span></div>
                <div class="scrollerhide overflow-hidden">
                    <ul class="nav nav-tabs tabs-left">

                        <li class="active"><a href="#GISInfo" data-toggle="tab">@Resources.Resources.SI_ISP_GBL_GBL_GBL_005</a></li>
                        <li><a href="#ItemSpecf" data-toggle="tab">@Resources.Resources.SI_ISP_GBL_GBL_GBL_006</a></li>
                        @if (Model.system_id > 0)
                        {
                            <li><a href="#PortInfo" onclick="isp.GetPortInfo('@Model.system_id',@Model.model,'PatchPanel','ISP');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_025</a></li>
                        }
                        @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_barcode_enabled)
                        {
                            <li><a href="#BarCodeInfo" onclick="isp.GetBarCode('@Model.system_id','@EntityType.PatchPanel.ToString()');" data-toggle="tab">@Resources.Resources.SI_ISP_GBL_GBL_GBL_019</a></li>
                        }
                        @if (Model.system_id > 0)
                        {
                            <li><a href="#LoopMangment" id="lnk_LoopMangment" onclick="isp.GetLoopMangmentDetail('@Model.latitude', '@Model.longitude', '@Model.system_id','@EntityType.PatchPanel.ToString()','@Model.objIspEntityMap.structure_id');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_032</a></li>
                        }
                        @if (layerDetail != null && layerDetail.is_pod_association_allowed)
                        {
                            <li><a href="#PODAssoctn" id="Pod_Association" onclick="isp.GetPODAssociationDetail('@Model.geom', '@Model.system_id','@EntityType.PatchPanel.ToString()', '@Model.primary_pod_system_id', '@Model.secondary_pod_system_id');" data-toggle="tab">@layer_Detail.layer_title <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_159</label></a></li>
                        }
                        @if (Model.system_id > 0 && layerDetail != null)
                        {
                            <li><a href="#Reference" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                        }
                    </ul>
                </div>
                <div id="divRightMenu" style="display:none;">
                    <span class="spanSide go-right"><i class="fa fa-angle-right" aria-hidden="true"></i></span>
                    <span class="spanSide" id="dropdown" style="border-left: 1px solid #b9b7b7;margin-left: -4px;"><i class="fa fa-angle-down" aria-hidden="true"></i></span>
                    <div class="arrowDropUp"></div>
                    <div class="dropMenu">
                        <div class="alltabs">@Resources.Resources.SI_OSP_CAB_NET_FRM_014</div>
                        <ul>
                            <li><a href="#GISInfo" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_010</a></li>
                            <li><a href="#ItemSpecf" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_005</a></li>
                            @if (Model.system_id > 0)
                            {
                                <li><a href="#PortInfo" onclick="isp.GetPortInfo('@Model.system_id',@Model.model,'PatchPanel','ISP');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_025</a></li>
                            }
                            @if (Model.system_id > 0 && layerDetail != null && layerDetail.is_barcode_enabled)
                            {
                                <li><a href="#BarCodeInfo" onclick="isp.GetBarCode('@Model.system_id','@EntityType.PatchPanel.ToString()');" data-toggle="tab">@Resources.Resources.SI_ISP_GBL_GBL_GBL_019</a></li>
                            }
                            @if (Model.system_id > 0)
                            {
                                <li><a href="#LoopMangment" id="lnk_LoopMangment" onclick="isp.GetLoopMangmentDetail('@Model.latitude', '@Model.longitude', '@Model.system_id','@EntityType.PatchPanel.ToString()','@Model.objIspEntityMap.structure_id');" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_GBL_GBL_032</a></li>
                            }
                            @if (layerDetail != null && layerDetail.is_pod_association_allowed)
                            {
                                <li><a href="#PODAssoctn" id="Pod_Association" onclick="isp.GetPODAssociationDetail('@Model.geom', '@Model.system_id','@EntityType.PatchPanel.ToString()', '@Model.primary_pod_system_id', '@Model.secondary_pod_system_id');" data-toggle="tab">@layer_Detail.layer_title <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_159</label></a></li>
                            }
                            @if (Model.system_id > 0 && layerDetail != null)
                            {
                                <li><a href="#Reference" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_537</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="libTabContent">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="tab-pane active" id="GISInfo">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_GBL_GBL_052 </legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtPatchPanelCode">
                                @layerDetail.layer_title @Resources.Resources.SI_GBL_GBL_NET_FRM_213
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }
                                :
                            </label>
                            <div class="col-sm-4">
                                <div id="txtMaskedNetworkId"></div>

                            </div>
                            <label class="control-label col-sm-2" for="txtPatchPanelName">
                                @Resources.Resources.SI_OSP_GBL_NET_FRM_059
                                @if (Model.networkIdType == NetworkIdType.M.ToString())
                                {
                                    <i class="clsMandatory">*</i>
                                }:
                            </label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.patchpanel_name,
                                  SmartInventory.Helper.CustomHtmlHelper.GetHtmlAttributes(
                                    new
                                    {
                                        @class = "form-control ",
                                        @maxlength = "50",
                                        @id = "txtPatchPanelName"
                                    }, (Model.networkIdType == "M" ? new { @required = true } : null)))
                                @*@Html.TextBoxFor(m => m.patchpanel_name, new { @class = "form-control", @id = "txtPatchPanelName", @maxlength = "50" })*@
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtLatitude">@Resources.Resources.SI_ISP_GBL_GBL_GBL_012<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.latitude, new { @class = "form-control", @id = "txtLatitude", @readonly = true })
                            </div>
                            <label class="control-label col-sm-2" for="txtLongitude">@Resources.Resources.SI_ISP_GBL_GBL_GBL_010<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.longitude, new { @class = "form-control", @id = "txtLongitude", @readonly = true })
                            </div>
                        </div>
                        <div class="form-group">
                            @CustomCoordinate()
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtRegionName">@Resources.Resources.SI_ISP_GBL_GBL_GBL_017:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.parent_network_id, new { @class = "form-control clsReadOnly", @readonly = true })
                            </div>
                            <label class="control-label col-sm-2" for="txtPinCode">@Resources.Resources.SI_ISP_GBL_GBL_GBL_014:</label>
                            <div class="col-sm-4">
                                @Html.TextBoxFor(m => m.pincode, new { @class = "form-control numbers-only", @id = "txtPinCode", @onkeypress = "return si.allowOnlyNumber(event);", @maxlength = "6", @minlength = "6", autocomplete = "new-password" })
                                @Html.ValidationMessageFor(m => m.pincode)
                            </div>

                        </div>
                        <div class="form-group">
                            @OwnershipInfo()
                        </div>
                        <div class="form-group">
                            @AcquireFrom()
                        </div>
                        <div>
                            @AdditionalFields()
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-md-2 col-sm-2" for="txtPatchPaneltype">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_GBL_GBL_023<i class="clsMandatory">*</i>:</label>
                            <div class="col-sm-4">
                                @*@Html.DropDownListFor(m => m.patchpanel_type, new SelectList(Model.listPatchPanelType.Select(x => new { Value = x.dropdown_value, Text = x.dropdown_key }), "Value", "Text"), "--Select--", new { @class = "chosen-select form-control  chosen-container-single input-validation-error" })*@
                                @Html.DropDownListFor(m => m.patchpanel_type, new SelectList(Model.listPatchPanelType.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "--Select--", new { @class = "chosen-select col-sm-12", @style = "padding:0;" })

                            </div>
                            @*<label class="control-label col-md-2 col-sm-2" for="txtAcquireFrom">@Resources.Resources.SI_GBL_GBL_GBL_GBL_010:</label>
            <div class="col-sm-45">
                @Html.TextBoxFor(m => m.acquire_from, new { @class = "form-control" })
            </div>*@
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtAddress">@Resources.Resources.SI_ISP_GBL_GBL_GBL_015:</label>
                            <div class="col-sm-10">
                                @Html.TextBoxFor(m => m.address, new { @class = "form-control", @id = "txtAddress", @maxlength = "100" })
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtRemarks">@Resources.Resources.SI_OSP_GBL_GBL_GBL_006:</label>
                            <div class="col-sm-10">
                                @Html.TextAreaFor(m => m.remarks, new { @class = "form-control textarea-maxlen-validate", @id = "txtRemarks", @maxlength = "1000" })
                            </div>
                        </div>
                    </fieldset>
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@Resources.Resources.SI_ISP_GBL_GBL_GBL_016</legend>
                        @ProjectSpecifications()
                    </fieldset>
                    <div>@GeographicDetails()</div>
                </div>
                <div class="tab-pane" id="ItemSpecf">
                    @PatchPanelTemplateMaster()
                </div>
                <div class="tab-pane" id="LoopMangment"></div>
                <div class="tab-pane" id="PODAssoctn"></div>
                <div id="PortInfo" class="tab-pane">
                </div>
                <div class="tab-pane" id="BarCodeInfo"></div>
                <div class="tab-pane" id="Reference">
                    @Reference()
                </div>
            </div>
        </div>

        <div class="ModalFooter" id="dvBtnAction">
            @if (Model.system_id > 0)
            {
                <div class="d-flex ModelFooterInfo">
                    <label>@Resources.Resources.SI_OSP_GBL_GBL_GBL_014:</label>
                    <label class="model-label-info">@(Model.network_status != null ? Utility.MiscHelper.GetNetworkStatus(Model.network_status.ToUpper()) : string.Empty)</label>
                    <label for="txtLongitude">@Resources.Resources.SI_ISP_GBL_GBL_GBL_004:</label>
                    <label class="model-label-info" title="@(Model.created_on != null ? Utility.MiscHelper.FormatDateTime(Model.created_on.ToString()) : string.Empty)">@(Model.created_on != null ? Utility.MiscHelper.TimeAgo(Model.created_on.ToString()) : string.Empty)</label>
                </div>
            }
            <div class="mr-auto">
                <a href="javascript:void(0);" class="btn btn-warning mr-01" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                @if (Model.system_id > 0)
                {
                    <button type="button" onclick="formPost()" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnUpdatePatchPanel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_003</button>
                }
                else
                {
                    <button type="button" onclick="formPost()" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" id="btnSavePatchPanel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
                }

            </div>
        </div>
    }
</div>
<script>
    var inputs = [];
    $(document).ready(function () {
        callFormValidator("frmAddPatchPanel");
        $('.chosen-select').chosen({ width: '100%' });
        //APPLY INPUT MASK ON NETWORK ID..
        getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');

        $("#frmAddPatchPanel").on("submit", function () {
            $("#network_id").val($("#txtMaskedNetworkId").dxTextBox("option", "text").toUpperCase());
        });
        $('#system_id').val('@Model.system_id');
        $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });
    });

    $("input.numbers-only").on("paste", function () {
        var thisvalue = this;

        setTimeout(function () {
            var OnlyNumber = new RegExp(/^[0-9]{1,10}$/);
             
            if (!OnlyNumber.test(thisvalue.value)) {
                thisvalue.value = "";
            }
        }, 0);
    });

    $("#divRightMenu .dropMenu ul li a").on("click", function () {

        var url = $(this).attr('href'); //
    });
    function formPost() {
         
        if ($('#txtbomsubcategory').val() == '') {
            $('#txtbomsubcategory').next().addClass('input-validation-error');
            return false;
        }
        else {
            $("#frmAddPatchPanel").submit();
        }
    }

</script>
<style>
        #LoopMangment,#PODAssoctn,#PortInfo {
        background-image: url('@Url.Content("~/content/images/loading_new.gif")');
        background-position: center;
        background-repeat: no-repeat;
    }
</style>
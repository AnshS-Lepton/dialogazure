@model Models.ViewOSPCPFModel
@using Utility;
@using Models;
@using SmartInventory.Settings;
@{
    var layerDetail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.Cable.ToString().ToUpper()).FirstOrDefault() : null;

    WebGrid grid = new WebGrid(canPage: false, canSort: false, ajaxUpdateContainerId: "dvViewConnectionPathFinder", ajaxUpdateCallback: "onGridHeaderClick('tblConnectionPathFinderInfo')");
    grid.Bind(Model.lstConnectionInfo, autoSortAndPage: false, rowCount: Model.objFilterAttributes.totalRecord);
}
@Scripts.Render("~/bundles/endToEndSchematic/Scripts")
<style>
    .dropbox {
        position: absolute;
        width: 80px !important;
        height: auto;
        background-color: #fff;
        right: 0px;
        margin: 0;
        box-shadow: 0px 1px 3px #b3b3b3;
        border-radius: 2px;
        text-align: left;
        font-size: 14px;
        z-index: 10000;
        display: none;
    }

    #tblConnectionPathFinderInfo {
        width: 100%;
    }

    #dvViewConnectionPathFinder ::-webkit-scrollbar-thumb {
        background: #9999ff;
    }

    .fullWidth {
        width: 100%;
    }

    .width50 {
        width: 50%;
    }

    .smtopBpad {
        padding-top: 7.5px;
        padding-bottom: 7px;
    }
</style>

<!DOCTYPE html>
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />
<div>
    @using (Ajax.BeginForm("ConnectionPathFinder", "Splicing", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "dvModalBody",
        LoadingElementId = "dvProgress",
    },

                                                <a onclick="SaveSchematicDiagram('pdf', 'dvSchematicView');" class="btn btn-success" title="@Resources.Resources.SI_ISP_GBL_JQ_FRM_001" style="font-size:18px; color: #e60000; background-color:transparent;"><i class="fa fa-file-pdf-o"></i></a>

grid.Column("destination_display_name", Resources.Resources.SI_OSP_ONT_NET_RPT_020, format: @<text>@item.destination_display_name</text>),
grid.Column("destination_cable_calculated_length", "Destination Cable Calculated Length(meter)", format: @<text>@(item.destination_cable_calculated_length != null?(@Math.Round(Convert.ToDouble(@item.destination_cable_calculated_length), 2)):@item.destination_cable_calculated_length)</text>),
grid.Column("destination_tray_display_name", Resources.Resources.SI_OSP_GBL_GBL_FRM_147, format: @<text>@item.destination_tray_display_name</text>),
grid.Column("destination_port_no", Resources.Resources.SI_OSP_ONT_NET_RPT_022,

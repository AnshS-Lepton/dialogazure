                                                <span id="btnCPFexportToKML" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_010" class="btn" @string.Format((grid.TotalRowCount == 0) ? "disabled" : "")>@Resources.Resources.SI_GBL_GBL_NET_FRM_043</span>

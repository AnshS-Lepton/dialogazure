<script src="~/Content/js/Utility.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        splicing.initApp();
        $('.chosen-select').chosen({ width: '100%', disable_search_threshold: '5' });
        $('#dvSchematicViewContainer #pageSize_chosen').css('width', '40%')
        if ('@Model.objFilterAttributes.totalRecord' == 0) {
            $('#txt_transmit').val(0);
        }

        $("#tblConnectionPathFinderInfo tbody tr").each(function (i, row) {
            var $actualRow = $(row);
            if ($actualRow.find('input[id^=hdnIsBackwardPath]').val().toUpperCase() == "FALSE") {
                $actualRow.addClass('downStream');
            }
            else {
                $actualRow.addClass('upStream');
            }
            $actualRow.attr('data-calculated-length', $actualRow.find('input[id^=hdncalculatedLength]').val());
            $actualRow.attr('data-measured-length', $actualRow.find('input[id^=hdnMeasuredLength]').val());
            $("#tblConnectionPathFinderInfo tbody tr").css('display', 'table-row')
        });

        $($("#tblConnectionPathFinderInfo tbody tr.downStream")[0]).addClass('conTerningPoint');
        $($("#tblConnectionPathFinderInfo tbody tr.upStream")[0]).addClass('conTerningPoint');
        UpdateFormattedNumbers();

    });
    @*splicing.upStream = null;
    splicing.downStream = null;
    if ('@Model.upStreamPath' != '' && '@Model.upStreamPath' != null) {
        PdfPortNo = $("#ddlCore option:selected").text();
        equipmentId = $('#equipment_id').val();
        splicing.upStream = '@Model.upStreamPath'.replace(/&quot;/g, '"');
        SchematicView(splicing.upStream, "#dvSchematicView", 870, 320);
        $('#divCPFPrint').show();
        $('#dvSchematicView').removeClass('divErrorMessage');
    }
    if ('@Model.downStreamPath' != '' && '@Model.downStreamPath' != null) {
        PdfPortNo = $("#ddlCore option:selected").text();
        equipmentId = $('#equipment_id').val();
        splicing.downStream = '@Model.downStreamPath'.replace(/&quot;/g, '"');
        $('#divCPFPrint').show();
        $('#dvSchematicView').removeClass('divErrorMessage');
    }*@


    function UpdateFormattedNumbers() {
        // Get the table element
        const table = document.getElementById('tblConnectionPathFinderInfo');

        // Loop through the rows
        if (table && table.rows) {
            for (let rowIndex = 0; rowIndex < table.rows.length; rowIndex++) {
                const row = table.rows[rowIndex];


                // Loop through the cells in the row
                for (let cellIndex = 0; cellIndex < row.cells.length; cellIndex++) {
                    const cell = row.cells[cellIndex];

                    // Extract data from the cell
                    const cellData = cell.textContent.trim();

                    // Do something with the cell data
                    if ($.isNumeric(cellData))
                        row.cells[cellIndex].textContent = getFormattedNumber(cellData);
                }
            }
        }
    }
</script>




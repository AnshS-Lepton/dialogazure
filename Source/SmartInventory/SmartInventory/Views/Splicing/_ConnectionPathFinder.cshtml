                                        <div style="border: 1px solid grey;max-height: 300px;">
                                            <div id="dvSchematicView"> </div>

                                        </div>
                                    </div>*@
                            </div>
                        }

                        <div class="nr-found" style="display:@(Model.lstConnectionInfo.Count==0?"display;":"none;")" id="divNoRecordExist">
                            <span> @Resources.Resources.SI_OSP_ONT_NET_RPT_024</span>
                        </div>
                    </div>
                    <div id="OpticalLinkBudget" class="tab-pane">

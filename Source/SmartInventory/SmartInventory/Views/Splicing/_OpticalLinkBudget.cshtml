@model Models.ViewOSPCPFModel
@using Utility;
@{
    WebGrid grid = new WebGrid(canPage: false, canSort: true, ajaxUpdateContainerId: "dvViewOpticalLinkBudget", ajaxUpdateCallback: "onGridHeaderClick('tblOpticalLinkBudgetInfo')");
    grid.Bind(Model.lstConnectionInfo, autoSortAndPage: false, rowCount: Model.objFilterAttributes.totalRecord);

}


<style>
    .forward {
        float: left;
        height: 22px;
        width: 22px;
        background-color: rgb(27, 148, 97);
        /*border: 2px solid;*/
        border-radius: 50%;
    }

    .backward {
        float: left;
        height: 22px;
        width: 22px;
        background-color: rgb(217, 220, 223);
        /*border: 2px solid;*/
        border-radius: 50%;
    }

    .text {
        float: left;
        padding-right: 5px;
        padding-left: 5px;
        font-weight: 700;
        padding-top: 2px;
    }
</style>

<div class="libDetail">
    @using (Ajax.BeginForm("OpticalLinkBudgetSeprate", "Splicing", new AjaxOptions
{
    HttpMethod = "POST",
    UpdateTargetId = "dvModalBody",
    OnBegin = ""
},
new { id = "frmOpticalLinkBudget", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {
        @Html.HiddenFor(m => m.objFilterAttributes.entity_type)
        @Html.HiddenFor(m => m.objFilterAttributes.entityid)
        @Html.HiddenFor(m => m.objFilterAttributes.port_no)
        @Html.HiddenFor(m => m.entity_geomid)
        @Html.HiddenFor(m => m.backword_path_type, new {@id = "hdn_pathType" })
        

        <div class="libTabs">
            <ul class="nav nav-tabs tabs-left">
                <li class="active"><a href="#OpticalLinkBudgetSeprate" data-toggle="tab">Optical Link Budget</a></li>

            </ul>


        </div>
        <div class="libTabContent" style="overflow: visible; max-height: fit-content;">
            <!-- Tab panes -->
            <div class="tab-content">

                <div class="tab-pane active" id="OpticalLinkBudgetSeprate">



                    <div class="form-group">
                        <label class="control-label col-sm-2" for="txtpathtype_id">Path Type<i class="clsMandatory">*</i>:</label>
                        <div class="col-sm-10" style="padding-left:23px">
                            @*<input type="radio" id="rdo_ForwardPath" name="IsbackwordOrForword" value="false" checked onclick="SelectRadio('rdo_ForwardPath')"> Forward Path &nbsp;&nbsp;
            <input type="radio" id="rdo_BackwardPath" name="IsbackwordOrForword" value="true" onclick="SelectRadio('rdo_BackwardPath')"> Backward Path*@



                            @if (Model.backword_path_type == false)
                            {
                                @*@Html.RadioButtonFor(model => model.backword_path_type, "false", new { @checked = true })*@
                                <label class="Custom_Radio_Buttons" style="padding-left:120px;">@Html.RadioButtonFor(i => i.backword_path_type, "false", new { @checked = true, @onchange = "SelectRadio();" }) <span class="checkmark"> <spam style="width: 230px; float: left; margin-left: 20px; font-size:12px;">Forward Path</spam></span></label>
                                <label class="Custom_Radio_Buttons" style="padding-left:120px;">@Html.RadioButtonFor(i => i.backword_path_type, "true", new { @onchange = "SelectRadio();" }) <span class="checkmark"> <spam style="width: 230px; float: left; margin-left: 20px; font-size:12px;">Backward Path</spam></span></label>
                                @*@Html.HiddenFor(m => m.backword_path_type)*@

                            }
                            else
                            {
                                <label class="Custom_Radio_Buttons" style="padding-left:120px;">@Html.RadioButtonFor(i => i.backword_path_type, "false", new { @onchange = "SelectRadio();" }) <span class="checkmark"> <spam style="width: 230px; float: left; margin-left: 20px; font-size:12px;">Forward Path</spam></span></label>
                                <label class="Custom_Radio_Buttons" style="padding-left:120px;">@Html.RadioButtonFor(i => i.backword_path_type, "true", new { @checked = true, @onchange = "SelectRadio();" }) <span class="checkmark"> <spam style="width: 230px; float: left; margin-left: 20px; font-size:12px;">Backward Path</spam></span></label>
                                @*@Html.HiddenFor(m => m.backword_path_type)*@
                            }




                        </div>

                    </div>


                    <div class="form-group">
                        <label class="control-label col-sm-2" for="txtEquipment_id">Equipment ID<i class="clsMandatory">*</i>:</label>
                        <div class="col-sm-10" style="padding-left:23px">
                            @Html.TextBoxFor(m => m.equipment_id, new { @class = "form-control", @maxlength = 100 })
                        </div>

                    </div>


                 
                 



                    <div class="form-group">
                        <label class="control-label col-sm-2" for="ddlport">Core/Port<i class="clsMandatory">*</i>:</label>

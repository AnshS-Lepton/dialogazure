                            <select id="ddlCore" name="ddlCore" class="chosen-select col-sm-12" style="padding:0;" onchange="osp.ddlopticalCore(this);">
                                <option value="0">--Select--</option>
                                @if (grid.TotalRowCount > 0)
                                {
                                    foreach (var item in Model.lstEquipementCore)
                                    {
                                        <option value=@item.port_value @string.Format((Model.objFilterAttributes.port_no == @item.port_value) ? "selected" : "")>@item.port_text </option>
                                    }
                                }
                            </select>
                        </div>
                    </div>


                    <div class="form-group" style="display:none" >
                        <label class="control-label col-sm-2" for="ddlport">Source Id<i class="clsMandatory">*</i>:</label>
                        <div class="col-sm-10" style="padding-left:23px">

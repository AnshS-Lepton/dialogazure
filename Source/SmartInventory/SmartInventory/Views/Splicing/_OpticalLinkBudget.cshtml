                            <select id="ddl_AEnd" name="ddl_AEnd" class="chosen-select col-sm-12" style="padding:0;">
                                
                                @if (grid.TotalRowCount > 0)
                                {
                                    
                                     <option value=@Model.lstConnectionInfo.Select(m=> m.source_network_id).FirstOrDefault()>@Model.lstConnectionInfo.Select(m => m.source_network_id).FirstOrDefault() </option>
                                    
                                    @*foreach (var item in Model.lstConnectionInfo.Select(m => m.source_network_id).FirstOrDefault())
                                    {
                                        <option value=@item>@item </option>
                                    }*@
                                }
                            </select>
                        </div>
                    </div>


                    <div class="form-group" style="display:none">
                        <label class="control-label col-sm-2" for="ddlport">Destination Id<i class="clsMandatory">*</i>:</label>
                        <div class="col-sm-10" style="padding-left:23px">
                            <span id="path_type"></span>
                            @*@bool value = true;*@
                            @*<script>
                            
                                $('input[name=IsbackwordOrForword]').change(function () {
                                    var radioValue = $("input[name='IsbackwordOrForword']:checked").val();
                                    alert(radioValue);

                                })

                            </script>*@



                            <select id="ddl_BEnd" name="ddl_BEnd" class="chosen-select col-sm-12" style="padding:0;">
                                
                                @if (grid.TotalRowCount > 0)
                                { 
                                   if (@Model.backword_path_type == false)
                                   { 
                                    @*<option value=@Model.lstConnectionInfo.Select(m=> m.destination_network_id).Distinct().LastOrDefault()>@Model.lstConnectionInfo.Select(m=> m.destination_network_id).Distinct().LastOrDefault() </option>*@
                                   
                                    @*<option value=@Model.lstConnectionInfo.Where(m=> m.is_backward_path == false).Select(m=> m.destination_network_id).Distinct().LastOrDefault()>@Model.lstConnectionInfo.Where(m => m.is_backward_path == false).Select(m => m.destination_network_id).Distinct().LastOrDefault() </option>*@
                                    
                                
                                    <option value=@Model.lstConnectionInfo.Where(m=> m.is_backward_path == false).Select(m=> m.destination_network_id).Distinct().LastOrDefault()>@Model.lstConnectionInfo.Where(m => m.is_backward_path == false).Select(m => m.destination_network_id).Distinct().LastOrDefault() </option>

                                   }
                                   
                                else
                                   {
                                   
                                    <option value=@Model.lstConnectionInfo.Where(m=> m.is_backward_path == true).Select(m=> m.destination_network_id).Distinct().LastOrDefault()>@Model.lstConnectionInfo.Where(m => m.is_backward_path == true).Select(m => m.destination_network_id).Distinct().LastOrDefault() </option>
                                   }
                                    
                                    //foreach (var item in Model.lstConnectionInfo.Select(m => m.destination_network_id).Distinct())
                                    //{
                                    //    <option value=@item>@item </option>
                                    //}
                                }
                            </select>



                        </div>
                    </div>


                    <div class="form-group">
                        <label class="control-label col-sm-2" for="ddlport">Wavelength (nm)<i class="clsMandatory">*</i>:</label>
                        <div class="col-sm-10" style="padding-left:23px; width:240px">
                            <select id="ddl_waveLength" name="ddl_waveLength" class="chosen-select col-sm-12" style="padding:0;">
                                <option value="0">--Select--</option>
                                @if (grid.TotalRowCount > 0)
                                {
                                    foreach (var item in Model.lstWave_length)
                                    {
                                        <option value=@item.wavelength_id>@item.wavelength_value </option>
                                    }
                                }
                            </select>
                        </div>

                        <label class="control-label col-sm-2" for="txtTransmit">Transmit Power (db)<i class="clsMandatory">*</i>:</label>
                        <div class="col-sm-10" style="padding-left:23px; width:240px">
                            @Html.TextBoxFor(m => m.txtTransmit, new { @class = "form-control allownumeric_value", @maxlength = 5, @id = "txt_transmit" })
                        </div>


                    </div>



                    <div class="form-group ModalFooter" style="height:1px;" id="dvBtnActionForOpticalLink">

                        <label class="control-label col-sm-2" for="txtTransmit">Receiving power (db) :</label>
                        <div class="col-sm-3" style="padding-left:23px; width:1px">

                            <label id="txt_receving" name="txt_receving" class="control-label col-sm-2"></label>

                        </div>


                        <div class="col-sm-7 " style="float: right; text-align: right; padding-right: 25px;">
                            <button type="submit" class="btn btn-primary" id="btnShowRoute" style="display:none">Show Route</button>
                            <input type="button" id="btnopticalExport" value="Export" class="btn btn-primary" style="display:none;" />
                            <input type="button" id="btnCalculate" value="Calculate" onclick="osp.BindOpticalLinkGridForSeprate()" class="btn btn-primary" />
                            <button type="button" class="btn btn-default" onclick="OpticalLinkClearButton()" id="btnOpticalLinkClearClear">Clear</button>
                        </div>

                    </div>


                    <div class="clearfix"></div>


                    <div class="form-group">

                        <div id="div_bindOpticalLinkGrid" style="width: 100%; height:auto; overflow-x: auto; overflow-y:auto">  </div>

                        </div>



                </div>

            </div>
        </div>

    }

</div>


<script type="text/javascript">


    //## Optical Link Details

  
    function OpticalLinkClearButton() {
        

        $('#equipment_id').val('');
        $('#ddl_AEnd, #ddl_BEnd, #ddl_waveLength').val('0').trigger('chosen:updated');

        $('#ddlCore').empty();
        $('#ddlCore').append($("<option></option>").val('0').html('--Select--'));
        $('#ddlCore').trigger("chosen:updated");
        

        $('#txt_transmit').val(0);
        $('#txt_receving').text('');
        $('#div_bindOpticalLinkGrid').empty();
        $('#btnopticalExport').hide();
        

    }


    // allow only numeric value in optical link
    $(".allownumeric_value").on("keypress keyup blur", function (event) {

        $(this).val($(this).val().replace(/[^\d].+/, ""));

        if ((event.which < 48 || event.which > 57)) {
            event.preventDefault();
        }

        if ((this.value.length == 0 && event.which == 48)) {

            return false;
        }


    });


    if ('@Model.objFilterAttributes.totalRecord' == 0) {
        $('#txt_transmit').val(0);
    }


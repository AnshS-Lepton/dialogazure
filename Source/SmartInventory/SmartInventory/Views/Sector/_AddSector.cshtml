<script type="text/javascript">
                var inputs = [];
                $(document).ready(function () {
                    if(@Model.system_id >0)
                    {
                        var sector_type=$('#sector_type').val();

                        $('#ddlSectorType option[value="'+sector_type+'"]').attr('selected', 'selected').trigger("chosen:updated");

                    }

                    setTimeout(function(){
                        setDivInitData();
                    },300);
                    $(document).on('change input', '#frmAddSector :input', function(){
                        setTimeout(function(){
                            validateDivDataforChange();
                        },300);
                    });

                    var splitURL=[];

                    $("#ddlSectorType").on('change', function(){
                         
                        $('#ddlFrequency option').removeAttr('disabled').trigger("chosen:updated");
                        var a = $('option:selected', this).attr('parent')
                        var url = a;
                        splitURL = url.split('#');
                        var sum=0

                        $("#ddlFrequency option").each(function()
                        {
                             
                            var t =$(this).val();
                            var isInclud=splitURL.includes(t);
                            if(isInclud){
                                $('#ddlFrequency option[value="'+t+'"]').attr('disabled', false).trigger("chosen:updated");

                            }
                            else{
                                $('#ddlFrequency option[value="'+t+'"]').attr('disabled', true).trigger("chosen:updated");

                            }
                        });
                        $('#ddlFrequency').trigger("chosen:updated");
                    });



                    callFormValidator("frmAddSector");
                    $('.chosen-select').chosen({ width: '100%' });
                    $('#specification').chosen().on('change',function (event) {
                        var dID = $(this).val();
                        bindVendor(dID);
                    });
                    $('#ddlVendor').chosen().on('change',function (event) {
                        var specfi = $("#specification option:selected").val(); //
                        var vandorid = $(this).val();
                        var entitytype = $('#entityType').val();
                        bindCateSubcat(entitytype, specfi, vandorid);
                    });
                    $('#ddlType').chosen().on('change',function (event) {
                        var dID = $(this).val();
                        bindBrand(dID);
                    });
                    $('#ddlBrand').chosen().on('change',function (event) {
                        var dID = $(this).val();
                        bindModel(dID);
                    });

                    EnableDisableUpdateButton("frmAddSector", @Model.system_id > 0 ? "btnUpdateItemTemplate" : "btnSaveItemTemplate");

                    //APPLY INPUT MASK ON NETWORK ID..
                    getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');
                    $("#frmAddSector").on("submit", function () {
                        $("#network_id").val($("#txtMaskedNetworkId").dxTextBox("option", "text").toUpperCase());
                        si.upperCaseNetWorkId();
                        if (!entityReferencevalidation())
                            return false;
                    });
                    $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });


                });

                function getval(sel)
                {
                     
                    $.ajax({
                        type: "GET",
                        url: "@Url.Content("~/Sector/GetDropDownListJson")",
                        data: { layerName: "Sector", ID: sel.value},
                        success: function (data) {
                             
                            var s = '<option value="0">Select Frequency</option>';
                            for (var i = 0; i < data.length; i++) {
                                s += '<option value="' + data[i].dropdown_value + '">' + data[i].dropdown_key + '</option>';
                            }
                            $("#ddlFrequency").html(s).trigger("chosen:updated");
                        }
                    });
                }

    function IsValiddropdownValue() {
         
        if ($('#ddlFrequency').val() == "" || $('#ddlFrequency').val() == "0") {

            $('#ddlFrequency_chosen').addClass('input-validation-error');

            return false;
        }
        else{
            $('#ddlFrequency_chosen').removeClass('input-validation-error');
            return true;
        }
    }
    function fnSetAzimuthValue() {
        setTimeout(function () { fnSetAzimuthValue();},1);
        var AzimuthVal = $("#txtAzimuth").val();
        var MinAzimuthVal = @ApplicationSettings.Minazimuth;
        var MaxAzimuthVal = @ApplicationSettings.Maxazimuth;
        if (parseFloat(AzimuthVal) < parseFloat(MinAzimuthVal)) {
            $('#txtAzimuth').addClass('input-validation-error').removeClass('valid');
            return false;
        }
        if (parseFloat(AzimuthVal) > parseFloat(MaxAzimuthVal)) {
            $('#txtAzimuth').removeClass('valid');
            $('#txtAzimuth').addClass('input-validation-error');
            return false;
        }
        else {
            $('#txtAzimuth').removeClass('input-validation-error').addClass('valid');
            return true;
        }
    }
</script>

@model Models.ChangePassword

<!DOCTYPE html>
<div class="form-horizontal space-pad">
    @*@Html.ValidationSummary(true)*@
    <div class="form-group row">
        <div class="col-sm-5">@Resources.Resources.SI_OSP_CHG_NET_FRM_001</div>
        <div class="col-sm-7">
            @Html.PasswordFor(model => model.currentPassword, new { @class = "form-control", @maxlength = "20", @placeholder = @Resources.Resources.SI_OSP_CHG_NET_FRM_001 })
            @*@Html.ValidationMessageFor(model => model.currentPassword)*@
        </div>
    </div>

    <div class="form-group row">
        <div class="col-sm-5">@Resources.Resources.SI_OSP_CHG_NET_FRM_002</div>
        <div class="col-sm-7">
            @Html.PasswordFor(model => model.NewPassword, new { @class = "form-control", @maxlength = "20", @placeholder = @Resources.Resources.SI_OSP_CHG_NET_FRM_002 })
            <img src="" style="margin-top:-23px;margin-left:293px;width:21px;" class="GifImg" id="ImgPwd" />

            @*@Html.ValidationMessageFor(model => model.NewPassword)*@
            @*<input type="password" id="NewPassword" name="NewPassword" pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" title="Must contain at least one number and one uppercase and lowercase letter, and at least 8 or more characters" required>*@
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-5">@Resources.Resources.SI_OSP_CHG_NET_FRM_003</div>
        <div class="col-sm-7">
            @Html.PasswordFor(model => model.confirmNewPassword, new { @class = "form-control", @maxlength = "20", @placeholder = @Resources.Resources.SI_OSP_CHG_NET_FRM_003 })
            @*@Html.ValidationMessageFor(model => model.NewPassword)*@
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-12">
            <div class="passHint">
                <b style="color:#0044cc;">@Resources.Resources.SI_OSP_CHG_NET_FRM_004:</b>
                @Resources.Resources.SI_OSP_CHG_NET_FRM_006
            </div>
        </div>
    </div>
    <div class="form-group">
        <div class="col-md-3"></div>
        <div class="col-md-9"><label id="lblmsg"></label></div>
    </div>
</div>
<div class="ModalFooter d-flex">
    <input type="submit" id="btnClosePassWindow" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006" class="btn btn-default ml-auto" />
    <input type="submit" onclick="si.ChangePassword();" id="btnSubmit" value="@Resources.Resources.SI_OSP_CHG_NET_FRM_007" class="btn btn-success ml-10" />
</div>

<script>
    $(document).ready(function () {
        $('#ImgPwd').hide();
    });

    $('#NewPassword').keyup(function () {
        si.passwordRegex($('#NewPassword').val());
    });

    $('#btnClosePassWindow').on("click", function () {
        $('#closeModalPopup').trigger("click");
    });

</script>
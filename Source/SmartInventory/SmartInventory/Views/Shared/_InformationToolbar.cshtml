@foreach (var parentItem in Model.Where(x => x.is_buffer_needed == false).GroupBy(x => x.parent_action_id).Select(grp => grp.ToList()).ToList())
{

    var parentActionId = parentItem.Select(x => x.parent_action_id).FirstOrDefault();
    if (parentActionId != 0)
    {

        <div class="action_container act-buffer-position" style="display:none" id="entitySec_@parentActionId">
            <span class="action-pointer">
                &nbsp;
            </span>
            <div class="d-flex flex-wrap">
                @foreach (var subItem in Model.Where(x => x.parent_action_id == parentActionId).ToList())
                {
                    int index = subItem.action_name.ToUpper().IndexOf("TEMPLATE");
                    if (index >= 0)
                    {
                        <span id="Entity@(subItem.action_name)" data-bufferEnabled="@subItem.is_buffer_needed" data-action="@(subItem.action_name)"
                              class="@(subItem.action_name) @(subItem.is_template_filled ? "infoFilledTemplate" : "infoTemplate")
                    @(subItem.is_enabled ? "" : "roledisabled") @(subItem.is_buffer_needed ? "buffer-disabled" : "")" @(subItem.is_enabled ? "" : "onclick=disabledItem(event);") data-entity-title="@(subItem.action_title)" title="@subItem.action_title @(subItem.is_enabled ? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)">T</span>
                    }
                    else
                    {


                        <div id="Entity@(subItem.action_name)" data-bufferEnabled="@subItem.is_buffer_needed" data-action="@(subItem.action_name)" class="infoIcon--mrgn entitydiv @(subItem.action_name) @(subItem.is_enabled ? "" : "roledisabled") @(subItem.action_name.ToUpper() == "PENTROWREPORT" ? "icon-export_report_ROW" : "")" data-entity-title="@(subItem.action_title) " @(subItem.is_enabled ? "" : "onclick=disabledItem(event);") title="@subItem.action_title @(subItem.is_enabled ? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021) " style="display:@(subItem.is_visible ? "block;" : "none;")">
                        </div>
                    }
                }
            </div>
        </div>
    }
}

@{
    var bufferedActions = Model.Where(x => x.is_buffer_needed == true).ToList();
    if (bufferedActions.Count() > 0)
    {
        var groupAction = Model.Where(x => x.is_buffer_needed == true).FirstOrDefault();
        var parentActionId = groupAction.parent_action_id;
        <div class="buffer_container bufferClass buffer-position bufferWidth" style="display:none;" id="entitySec_@parentActionId">
            <span class="action-pointer">
                &nbsp;
            </span>
            <input type="hidden" id="EntityBufferWidth" value="0" />
            <div class="bufferClass">
                <input type="hidden" id="ShowSubMenu" value="0" />
                <input type="hidden" id="BufferSystemId" value="" />
                <input type="hidden" id="BufferEntityType" value="" />
                <input type="hidden" id="BufferGeomType" value="" />

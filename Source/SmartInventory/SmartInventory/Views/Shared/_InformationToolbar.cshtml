                </div>
            </div>
            <div class="mt-1rem">
                @foreach (var subItem in Model.Where(x => x.is_buffer_needed == true).ToList())
                {
                    int index = subItem.action_name.ToUpper().IndexOf("TEMPLATE");
                    if (index >= 0)
                    {
                        <span id="Entity@(subItem.action_name)" data-bufferEnabled="@subItem.is_buffer_needed" data-action="@(subItem.action_name)"
                              class="@(subItem.action_name) @(subItem.is_template_filled ? "infoFilledTemplate" : "infoTemplate")
                    @(subItem.is_enabled ? "" : "roledisabled") @(subItem.is_buffer_needed ? "buffer-disabled" : "")" @(subItem.is_enabled ? "" : "onclick=disabledItem(event);") data-entity-title="@(subItem.action_title)" title="@subItem.action_title">T</span>
                    }
                    else
                    {
                        <div id="Entity@(subItem.action_name)" data-bufferEnabled="@subItem.is_buffer_needed" data-action="@(subItem.action_name)" class="entitydiv @(subItem.action_name) @(subItem.is_enabled ? "" : "roledisabled") @(subItem.action_name.ToUpper() == "PENTROWREPORT" ? "icon-export_report_ROW" : "")" data-entity-title="@(subItem.action_title)" @(subItem.is_enabled ? "" : "onclick=disabledItem(event);") title="@subItem.action_title" style="display:@(subItem.is_visible ? "block;" : "none;")">
                        </div>
                    }
                }
            </div>
        </div>

    }

}





<script>
    $(document).ready(function () {
        $('#OSP_tool_bar [title!=""]').tooltip({ title: '', html: true, placement: "top", container: 'body' });
        si.bufferActionEnabling();
         
        $('#ddlBufferLinewidth').trigger("chosen:updated");

        var model = @Html.Raw(Json.Encode(Model));
        $.each(model, function (val,item) {
            let actionName = item.action_name;
            if (actionName == "UploadImage") {
                $('.hide-li').show();
            }

        });
         
        //setTimeout(function () {
        //if ($("#hdnspltype").val() == 'SECONDARY') {
        //    $("#EntityProcessSplitterData").show();

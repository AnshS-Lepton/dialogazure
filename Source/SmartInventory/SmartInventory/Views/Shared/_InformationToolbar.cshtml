        //}
        //else {
        //    $("#EntityProcessSplitterData").hide();
        //    $("#EntityProcessSplitterData2").hide();
        //    }
        //},50)
    });

    $(document).on("click", function () {
        var container = $(".action_container");
        var target = $(event.target);
        if (!target.is('#EntityAddEntity')) {
            if (!container.is(event.target) && !container.has(event.target).length) {
                container.hide();
                $('#EntityAddEntity').removeClass("active-action");
            }
        }
    });

</script>




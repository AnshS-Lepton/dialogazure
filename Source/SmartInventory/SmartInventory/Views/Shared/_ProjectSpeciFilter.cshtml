<script type="text/javascript">



    function bindPrimaryPODDropdown(preselectedValues = []) {
        var $ddl = $('#ddlPrimaryPOD');

        // Init Chosen once
        $ddl.chosen({
            width: "100%",
            placeholder_text_multiple: "Type to search POD..."
        });

        // Attach event on Chosen's internal search input
        $ddl.siblings('.chosen-container').find('.search-field input').on('keyup', function () {
            var searchText = $(this).val();

            if (searchText.length >= 3) {
                $.ajax({
                    url: "@Url.Content("~/Library/searchSite")",
                    type: 'GET',
                    data: { term: searchText },
                    success: function (resp) {

                        if (resp.results && resp.results.length > 0) {
                            const selected = $ddl.val() || [];

                            // Clear non-selected options
                            $ddl.find('option').not(':selected').remove();

                            // Add new options if not already present
                            $.each(resp.results, function (index, item) {
                                if ($ddl.find('option[value="' + item.systemId + '"]').length === 0) {
                                    $ddl.append($('<option>', {
                                        value: item.systemId,
                                        text: item.Name
                                    }));
                                }
                            });

                            // Reapply selected values
                            $ddl.val([...new Set([...selected, ...preselectedValues.map(String)])]);

                            $ddl.trigger("chosen:updated");
                        }
                    }
                });
            }
        });

        // Bind initial selected values (if needed before typing)
        if (preselectedValues.length > 0) {
            $.ajax({
                url: "@Url.Content("~/Library/searchSite")",
                type: 'GET',
                data: { term: '' }, // fetch all or with logic to return selected
                success: function (resp) {
                    if (resp.results && resp.results.length > 0) {
                        $ddl.empty();
                        $.each(resp.results, function (index, item) {
                            $ddl.append($('<option>', {
                                value: item.systemId,
                                text: item.Name
                            }));
                        });

                        $ddl.val(preselectedValues.map(String));
                        $ddl.trigger("chosen:updated");
                    }
                }
            });
        }
    }


    $(document).ready(function () {

        var selectedPODIds = @Html.Raw(Json.Encode(Model.primary_pop_system_id));

        bindPrimaryPODDropdown();
    });






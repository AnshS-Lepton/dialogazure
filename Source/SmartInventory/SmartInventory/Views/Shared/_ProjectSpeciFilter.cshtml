<script type="text/javascript">

    $(document).ready(function () {
        getval();
        $('.chosen-select').chosen({ placeholder_text_multiple: '-All-', width: '100%' });
        $("#txt3rdPartyVendor").attr('data-placeholder', "-All-").trigger("chosen:updated");
        $("#ddlSectorType").attr('data-placeholder', "-All-").trigger("chosen:updated");
        $("#ddlFrequency").attr('data-placeholder', "-All-").trigger("chosen:updated");
        $("#ddlPrimaryPOD").attr('data-placeholder', "Enter Site Id").trigger("chosen:updated");
        $("#ddlSecondaryPOD").attr('data-placeholder', "-All-").trigger("chosen:updated");
        $("#ddlFilterOwnership").attr('data-placeholder', "-All-").trigger("chosen:updated");
        if (si.thirdpartyvendor != undefined && si.thirdpartyvendor != '') {
            $("#txt3rdPartyVendor").val(si.thirdpartyvendor).trigger("chosen:updated");
        }
        if (si.ownership != undefined) {
            $("#ddlFilterOwnership").val(si.ownership).trigger("chosen:updated");
        }
        if (si.primary_pod_system_id != undefined) {
            $("#ddlPrimaryPOD").val(si.primary_pod_system_id).trigger("chosen:updated");
        }
        if (si.secondary_pod_system_id != undefined) {
            $("#ddlSecondaryPOD").val(si.secondary_pod_system_id).trigger("chosen:updated");
        }
        if (si.selectedRoutevalue != undefined) {
            $("#txtrouteInfo").val(si.selectedRoutevalue).trigger("chosen:updated");
        }
    });
    function getThirdPartyType() {
        var selectedownership = $("input[name='rdbOwnershipType']:checked").val();
        $('#txt3rdPartyVendor').val('');
        if (selectedownership == 'Third Party') {
            $('#txt3rdPartyVendor').prop('disabled', false).trigger("chosen:updated");
        }
        else {
            $('#txt3rdPartyVendor').next().removeClass('input-validation-error');
            $('#txt3rdPartyVendor').prop('disabled', true).trigger("chosen:updated");
        }
        $("#hdnOwnershipType").val(selectedownership);

    }
    function onChangeThirdParyVendor() {
        var selectedVal = $('#txt3rdPartyVendor').val();
        if (selectedVal != '' && selectedVal != null) {
            $('#txt3rdPartyVendor').next().removeClass('input-validation-error');
        }
        else {
            //   $('#txt3rdPartyVendor').next().addClass('input-validation-error');
        }
    }
    function onChangeOwnershipType() {
        if ($("#ddlFilterOwnership").val() == 'Own') {
            $('#txt3rdPartyVendor').val('');
            $('#txt3rdPartyVendor').prop('disabled', true).trigger("chosen:updated");
        }
        else {
            $('#txt3rdPartyVendor').prop('disabled', false).trigger("chosen:updated");
        }
    }
    function getval() {

         

         

        var ids = "";
        var ddlsectortype = $('#ddlSectorType').val()

        if (ddlsectortype != '' && ddlsectortype != null && ddlsectortype != undefined) {
            ids = $('#ddlSectorType').val().join(',');
        }
        $.ajax({
            type: "GET",
            url: "@Url.Content("~/Sector/GetDropDownListJson")",
            data: { layerName: "Sector", ID: ids },
            success: function (data) {
                var s = '';
                for (var i = 0; i < data.length; i++) {
                    s += '<option value="' + data[i].dropdown_value + '">' + data[i].dropdown_key + '</option>';
                }
                $("#ddlFrequency").html(s).trigger("chosen:updated");
            }
        });
    }

</script>
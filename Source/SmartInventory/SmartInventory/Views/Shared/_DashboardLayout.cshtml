                                    <i class="icon-Open_Menu pull-right addon"></i>
                                </a>
                            </li>


                            <li class="nav-item" title="Report">
                                <a class="nav-link" href="#">
                                    <i class="icon-Users"></i>
                                    <span class="nav-link-text">KPI Management</span>
                                    <i class="icon-Open_Menu pull-right addon"></i>
                                </a>
                                <ul class="sidenav-second-level" style="display:none;">
                                    <li><a href="@Url.Action("_AddKPI", "KPI", new { id = "" })">Add KPI</a><span class="right-arrow"></span></li>

                            @*@<li><a href="@Url.Action("ListTemplate", "KPI")">View Template</a><span class="right-arrow"></span></li>  hr*@
                            <!--</ul>
                            </li>
                            <li class="nav-item" title="Users">
                                <a class="nav-link" href="#">
                                    <i class="icon-report f17"></i>
                                    <span class="nav-link-text">Reports</span>

</text>),
grid.Column("task_name", Resources.Resources.SI_OSP_GBL_GBL_FRM_149, format: @<text>@item.task_name</text>),
grid.Column("task_type", Resources.Resources.SI_OSP_GBL_GBL_FRM_150, format: @<text> @item.task_type</text>),
grid.Column("task_remarks", Resources.Resources.SI_OSP_GBL_GBL_GBL_279, format: @<text>@item.task_remarks </text>),
grid.Column("task_action", Resources.Resources.SI_OSP_GBL_GBL_FRM_151, format: @<text> @item.task_action</text>),
grid.Column("assigned_by", Resources.Resources.SI_OSP_GBL_NET_RPT_011, format: @<text> @item.assigned_by</text>),
grid.Column("created_date", Resources.Resources.SI_OSP_GBL_GBL_GBL_192, format: @<text> @item.created_date</text>),
grid.Column("assigned_to", Resources.Resources.SI_OSP_GBL_NET_FRM_105, format: @<text> @item.assigned_to</text>),
grid.Column("modified_date", Resources.Resources.SI_OSP_GBL_GBL_GBL_193, format: @<text> @item.modified_date</text>),
grid.Column("task_status", Resources.Resources.SI_OSP_GBL_GBL_GBL_280, format: @<text> @item.task_status</text>)

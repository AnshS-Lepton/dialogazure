                                    </div>
                                </div>
                                <div class="row form-group">
                                    <div class="col-md-4">
                                        <label class="control-label">
                                            @Resources.Resources.SI_OSP_ROW_NET_GBL_051:
                                        </label>
                                    </div>
                                    <div class="col-md-8">

                                        @Html.TextBoxFor(m => m.toDate, new { @id = "txtDateTo", @title = "Select", @class = "input-sm form-control", @readonly = true })

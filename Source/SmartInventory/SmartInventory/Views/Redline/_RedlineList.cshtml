                            </div>
                            <div class="table-responsive">
                                @grid.GetHtml(tableStyle: "grid",

        htmlAttributes: new { id = "tblNetworkTicketManagerGrid" },
        mode: WebGridPagerModes.All,
        columns: grid.Columns(
            @*grid.Column(Resources.Resources.SI_OSP_GBL_GBL_GBL_028, format: @<text>

                </text>, canSort: false),*@
grid.Column("", Resources.Resources.SI_OSP_GBL_GBL_GBL_028, format: @<text>
                <div class="d-flex">
                    <a href="javascript:void(0);" class="i-icons-style icon-fs" onclick="showOnMap('@item.task_system_id');" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_036"><i class="fa fa-map-marker"></i></a>
                    <a href="javascript:void(0);" class="i-icons-style icon-fs" onclick="EditRecord('@item.task_system_id','@item.assigned_to_id');" title="@Resources.Resources.SI_GBL_GBL_GBL_GBL_003"><i class="fa far fa-edit"></i></a>
                    <a href="javascript:void(0);" class="i-icons-style icon-fs" onclick="RedlineHistory('@item.task_system_id', '@item.assigned_to_id');" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_339"><i class="fa far fa-history"></i></a>

            </div>
            <div id="AdvanceFilter" class="modal fade in" role="dialog" draggable="true">
                <div class="modal-dialog">
                    <!-- Modal content-->
                    <div class="modal-content1" id="dvModelid">
                        <div class="modal-header d-flex">
                            <h5 class="mtb-0">Advance Filter</h5>
                            <span class="ml-auto icon-close" id="CloseAdvanceFilter">

                            </span>
                        </div>
                        <div class="modal-body">
                            <div class="space-pad">
                                <div class="row form-group">
                                    <div class="col-md-4">
                                        <label class="control-label">
                                            @Resources.Resources.SI_OSP_GBL_GBL_FRM_149:
                                        </label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(m => m.objRedline.task_name, new { @class = "form-control" })
                                    </div>
                                </div>

                                <div class="row  form-group">
                                    <div class="col-md-4">
                                        <label class="control-label">
                                            @Resources.Resources.SI_OSP_GBL_NET_FRM_105:
                                        </label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(m => m.objRedline.assigned_to, new SelectList(Model.objRedline.AssignedBy.Select(x => new { Value = x.user_id, Text = x.user_name }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @onchange = "si.onChangeRegionsForFilter();", @id = "ddlAssignedTo" })
                                    </div>
                                </div>


                                <div class="row  form-group">
                                    <div class="col-md-4">
                                        <label class="control-label">
                                            @Resources.Resources.SI_OSP_GBL_NET_RPT_011:
                                        </label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(m => m.objRedline.assigned_by, new SelectList(Model.objRedline.AssignedBy.Select(x => new { Value = x.user_id, Text = x.user_name }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @onchange = "si.onChangeRegionsForFilter();", @id = "ddlAssignedBy" })
                                    </div>
                                </div>
                                <div class="row form-group">
                                    <div class="col-md-4">
                                        <label class="control-label">
                                            @Resources.Resources.SI_OSP_GBL_NET_GBL_160:
                                        </label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.DropDownListFor(m => m.objRedline.status_id, new List<SelectListItem>{
                                    new SelectListItem { Text = "Assigned", Value = "1"},
                                    new SelectListItem { Text = "InProgress", Value = "2"},
                                    new SelectListItem { Text = "Closed", Value = "3"},
                                     new SelectListItem { Text = "ReAssigned", Value = "4"},
                                },
                                "-Select-",
                                     new { @class = "chosen-select", @id = "ddlStatus" })
                                    </div>
                                </div>


                                <div class="row form-group">
                                    <div class="col-md-4">
                                        <label class="control-label">
                                            @Resources.Resources.SI_OSP_GBL_NET_FRM_072:
                                        </label>
                                    </div>
                                    <div class="col-md-8">

                                        @Html.DropDownListFor(m => m.customDate, new List<SelectListItem>{
                                           new SelectListItem { Text = "Custom", Value = "1"},
                                    new SelectListItem { Text = "Today", Value = "2"},
                                    new SelectListItem { Text = "Previous Day", Value = "3"},
                                    new SelectListItem { Text = "Last 7 Days", Value = "4"},
                                    new SelectListItem { Text = "Last 30 Day", Value = "5"},
                                    new SelectListItem { Text = "Last 3 Months", Value = "6"},
                                    new SelectListItem { Text = "Last 6 Months", Value = "7"},
                                  new SelectListItem { Text = "Last 1 Year", Value = "8"},
                                }, "-Select-",
                               new { @class = "chosen-select", @onchange = "onChangeCustomDate();", @id = "customedate" })
                                    </div>
                                </div>

                                <div class="row form-group">
                                    <div class="col-md-4">
                                        <label class="control-label">
                                            @Resources.Resources.SI_GBL_GBL_NET_GBL_006:
                                        </label>
                                    </div>
                                    <div class="col-md-8">
                                        @Html.TextBoxFor(m => m.fromDate, new { @id = "txtDateFrom", @title = "Select", @class = "input-sm form-control", @readonly = true })

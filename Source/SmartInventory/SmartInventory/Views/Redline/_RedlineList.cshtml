    <div id="EntityDetails" class="tab-pane"> </div>
</div>

<script>
    $(document).ready(function () {

        $("#dvModelid").draggable();
        $($('#tblNetworkTicketManagerGrid tr:first th')).addClass('gridHeaderStyle');

        $('#tblNetworkTicketManagerGrid tbody tr:first').find('td.colEnableDisable').each(function (i, td) {
            var indexOfHiddenColumn = $(td).index();
            $('#tblNetworkTicketManagerGrid thead th').eq(indexOfHiddenColumn).addClass('colEnableDisable');
        });
        $('[data-toggle="tooltip"]').tooltip();
        if ($('#AdvanceFilter').length) {
            si.Networkticket.setDateTimeCalendar_NwtworkTicket("txtDateFrom", "txtDateTo", "imgFromDate", "imgToDate", false);
        }

        $('th a, tfoot a').on("click", function () {
            $('#frmTicket').attr('action', $(this).attr('href')).submit();
            return false;
        });
        onGridHeaderClick('tblNetworkTicketManagerGrid');
        addDefaultSortingIcons("tblNetworkTicketManagerGrid");

        $('.chosen-select').chosen({ width: '100%', });
        $("#btnExportRedline").on("click", function () {
            window.location = appRoot + 'Redline/ExportRedline';
        });
        if ($("#customedate_chosen").children('a').text().trim() != "Custom") {

            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        $("#btnResetSearchFilter").on("click", function () {
            $("#frmTicket")[0].reset();
            $('#ddlTicketType').val('').trigger("chosen:updated");
            $('#txtSearchTxt').val('');
            $('#searchByText').val('').trigger("chosen:updated");
            $("#objRedline_task_name").val('');
            $('#ddlAssignedTo').val('').trigger("chosen:updated");
            $('#ddlAssignedBy').val('').trigger("chosen:updated");
            $('#ddlStatus').val('').trigger("chosen:updated");
            $('#customedate').val('').trigger("chosen:updated");
            $('#txtDateFrom').val('');
            $('#txtDateTo').val('');
            if (si.gMapObj.shapeObj)
                si.gMapObj.shapeObj.setMap(null);
        });

        $("#advanceFilterbtnReset").on("click", function () {
            $("#frmTicket")[0].reset();
            $("#objRedline_task_name").val('');
            $('#ddlAssignedTo').val('').trigger("chosen:updated");
            $('#ddlAssignedBy').val('').trigger("chosen:updated");
            $('#ddlStatus').val('').trigger("chosen:updated");
            $('#customedate').val('').trigger("chosen:updated");
            $('#txtDateFrom').val('');
            $('#txtDateTo').val('');
        });

        //GridColor();

        //
        //si.setDateTimeCalendar_ExportEntities("txtDateFrom", "txtDateTo", "imgFromDate", "imgToDate", false);
        $("#frmTicket").submit(function () {
            $("#dvEntitydetailsProgress").show();
        });
        RemoveArrows();
    });
    $('th a, tfoot a').on("click", function () {
        $('#tblNetworkTicketManagerGrid thead th').addClass('bothorder1');
    });

    function RemoveArrows() {
        $('#tblNetworkTicketManagerGrid thead th').eq(0).removeClass("bothorder");
    };


    function OnSuccess(data) {
        $("#dvEntitydetailsProgress").hide();

    }
    function GetDaysDifference(firstDate, secondDate, configuredDay) {

        var oneDay = 24 * 60 * 60 * 1000;
        var diff = 0;
        diff = Math.round(Math.abs((firstDate.getTime() - secondDate.getTime()) / (oneDay)));


        if (diff > configuredDay) {
            alert(MultilingualKey.SI_OSP_GBL_JQ_RPT_015)
            return false;

        }
    }

    function hexToRgbA(hex, opacity) {
        hex = hex.replace('#', '');
        r = parseInt(hex.substring(0, 2), 16);
        g = parseInt(hex.substring(2, 4), 16);
        b = parseInt(hex.substring(4, 6), 16);

        result = 'rgba(' + r + ',' + g + ',' + b + ',' + opacity / 100 + ')';
        return result;
    }

    function onChangeCustomDate() {

        var value = $('#customedate option:selected').val();

        SetFromAndToDate(value);
    }

    $("#btnFilter").on("click", function () {
        var value = $('#customedate option:selected').val();
        if (value == 1) // custom
        {
            if ($('#txtDateFrom').val() == "" || $('#txtDateTo').val() == "") {
                alert('Please select From Date and To Date');
                return false;
            }
        }
    });

    //Nik

    $("#btnTicketData").on("click", function () {
        if ($("#searchByText").val() == "" || $("#searchByText").val() == null || $("#searchByText").val() == 0) {
            alert('Please select Search By !!', 'warning');
            return false;
        }
    });
    //Nik

    function SetFromAndToDate(value) {

        var endDate = new Date();
        var startDate = new Date();
        var startDateDiff = 0;
        var endDateDiff = 0;

        if (value == 1) // custom
        {
            $('#txtDateFrom').val("");
            $('#txtDateTo').val("");
            $("#imgFromDate").show();
            $('#imgToDate').show();
            return;
        }
        else if (value == 2) { //Today
            startDateDiff = 0;
            endDateDiff = 0;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 3) { //previous day
            startDateDiff = -1;
            endDateDiff = -1;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 4) {//last 7 days
            startDateDiff = -6;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 5) {//last 30 days
            startDateDiff = -29;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 6) {//last 3 Months
            startDateDiff = -89;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 7) {//last 6 Months
            startDateDiff = -179;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 8) {//last 6 Months
            startDateDiff = -364;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }

        startDate.setDate(startDate.getDate() + startDateDiff);
        endDate.setDate(endDate.getDate() + endDateDiff);

        var newStartDate = startDate.toDateString();
        newStartDate = new Date(Date.parse(newStartDate));

        var newEndDate = endDate.toDateString();
        newEndDate = new Date(Date.parse(newEndDate));

        $('#txtDateFrom').val(fncCurrentDate(newStartDate));
        $('#txtDateTo').val(fncCurrentDate(newEndDate));
        if (value == 0) {
            $('#txtDateFrom').val('');
            $('#txtDateTo').val('');
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
    }
    function onChangeTicketType() {
        $("#btnTicketData").trigger("click");
    }
    function ShowAdvanceFilter() {
        $("#AdvanceFilter").modal("show");
        si.Networkticket.setDateTimeCalendar_NwtworkTicket("txtDateFrom", "txtDateTo", "imgFromDate", "imgToDate", false);
    }
    $("#CloseAdvanceFilter").on("click", function () {
        $(".modal-backdrop").remove();
        $("#AdvanceFilter").modal("hide");
    })

    function getDashboard() {
        $("#Dashboard").show();
        $("#EntityDetails").hide();
        $("#NwEntityDetails").addClass("disabled");

    }

    function clearTheTextField() {
        document.getElementById('txtSearchTxt').value = '';

    }
    function EditRecord(task_system_id, assigned_to_id) {

        popup.LoadModalDialog('CHILD', 'Redline/AddRedlineDetails', { 'objRedlineMaster.system_id': task_system_id, 'objRedlineMaster.assigned_to_id': assigned_to_id }, 'Redline Details', 'modal-xxl');
    }

    function RedlineHistory(task_system_id, assigned_to_id) {

        popup.LoadModalDialog('CHILD', 'Redline/Redline_Entity_History', { 'objRedlineFilters.task_id': task_system_id, 'objRedlineFilters.userId': assigned_to_id }, 'History', 'modal-xxl');
    }

    function showOnMap(task_system_id) {

        $('#ModalPopUp .minmizeModel>i').trigger("click");
        si.Redline.showLayerOnMap(task_system_id);
    }

    $("#closeModalPopup").on("click", function () {
        if (si.gMapObj.shapeObj)
            si.gMapObj.shapeObj.setMap(null);
    });
</script>


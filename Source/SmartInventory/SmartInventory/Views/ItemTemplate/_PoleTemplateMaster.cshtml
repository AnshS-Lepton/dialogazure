@model Models.PoleTemplateMaster
@using Models;
@using SmartInventory.Settings;
@helper ItemSpecification()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_ItemSpecification.cshtml", (itemMaster)Model); }
}
@helper SystemSpecification()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_SystemSpecification.cshtml", (itemMaster)Model); }
}
@{
    var layerDetail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.Pole.ToString().ToUpper()).FirstOrDefault() : null;

}
<input type="hidden" id="Layer_id" value="@layerDetail.layer_id" />
<fieldset class="the-fieldset">
    <legend class="the-legend">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_NET_FRM_218</legend>
    <div class="form-group">
        <label class="control-label col-sm-2" for="ddlPole_Type">@layerDetail.layer_title @Resources.Resources.SI_OSP_GBL_GBL_GBL_023:</label>
        <div class="col-sm-45">
            @Html.DropDownListFor(m => m.pole_type, new SelectList(Model.lstPoleType.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "Select Pole Type", new { @class = "chosen-select col-sm-12", @style = "padding:0;", @id = "ddlPole_Type", @is_specification_allowed = Model.is_specification_allowed })
        </div>
    </div>
</fieldset>

<fieldset class="the-fieldset">
    <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_GBL_GBL_026</legend>
    @ItemSpecification()
</fieldset>

<fieldset class="the-fieldset">
    <legend class="the-legend">Model Mapping & System Specification</legend>
    @SystemSpecification()
</fieldset>

<script type="text/javascript">
    $(document).ready(function () {

        $('.chosen-select').chosen({ width: '100%' });
        var polevalue = $("#ddlPole_Type option:selected").val();
        if (polevalue == undefined || polevalue == null || polevalue == '') {

            $('#specification').val(0).trigger("chosen:updated");
            $('#ddlVendor').val(0).trigger("chosen:updated");
            $('txtItemCode').val("");
            $('txtCategory').val("");
            $('txtSubCategory1').val("");
            $('txtSubCategory2').val("");
            $('txtSubCategory3').val("");
        }
        $('#specification').chosen().change(function (event) {

            var dID = $(this).val();
            si.bindVendor(dID);
        });
        $('#ddlVendor').chosen().change(function (event) {

            var specfi = $("#specification option:selected").val(); //
            var vandorid = $(this).val();
            var entitytype = $('#entityType').val();
            si.bindCateSubcat(entitytype, specfi, vandorid);
        });
        $('#ddlType').chosen().change(function (event) {
            debugger;
            var dID = $(this).val();
            var Layer_id = $("#Layer_id").val();
            si.bindBrand(dID, Layer_id);
        });
        $('#ddlBrand').chosen().change(function (event) {
            var dID = $(this).val();
            si.bindModel(dID);
        });

        $('#ddlPole_Type').chosen().change(function (event) {

            var Is_specification_allowed = $(this).attr("is-specification-allowed");
            var selected_pole_type = $("#ddlPole_Type option:selected").val();
            if (Is_specification_allowed == "True") {
                $("#specification option").hide();

                $("#specification option").each(function () {
                    var thisOptionValue = $(this).attr('data-type');
                    if (thisOptionValue != undefined) {
                        if (selected_pole_type == thisOptionValue) {
                            $(this).show();
                        }
                    }
                });
                $('#specification').val(0).trigger("chosen:updated");
                $("#ddlVendor option").hide();
                $('#ddlVendor').val(0).trigger("chosen:updated");
                $('txtItemCode').val("");
                $('txtCategory').val("");
                $('txtSubCategory1').val("");
                $('txtSubCategory2').val("");
                $('txtSubCategory3').val("");
            }
        });
        //---------------
    });
</script>
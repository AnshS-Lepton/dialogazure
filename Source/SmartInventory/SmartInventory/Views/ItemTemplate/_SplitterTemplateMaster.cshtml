@model Models.SplitterTemplateMaster
@using Models;
@helper ItemSpecification()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_ItemSpecification.cshtml", (itemMaster)Model); }
}
@helper SystemSpecification()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_SystemSpecification.cshtml", (itemMaster)Model); }
}
<fieldset class="the-fieldset">
    <legend class="the-legend">Splitter Details</legend>

    <div class="form-group row">
        <label class="control-label col-sm-2" for="ddlType">@Resources.Resources.SI_OSP_ONT_NET_FRM_008<i class="clsMandatory">*</i>:</label>
        <div class="col-sm-4">
            @Html.DropDownListFor(m => m.splitter_type, new SelectList(Model.lstType.Select(x => new { Value = x.value, Text = x.key }), "Value", "Text"), "Select Type", new
       {
           @class = "chosen-select col-sm-12",
           @style = "padding:0;",
           @id = "ddlSplitterType",
           @onchange = "ddlChangeRemoveCss(this.id, 'Type');"
       })
        </div>
    </div>
</fieldset>
<fieldset class="the-fieldset">
    <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_GBL_GBL_026</legend>
    @ItemSpecification()
</fieldset>

@*<fieldset class="the-fieldset">
        <legend class="the-legend">Model Mapping & System Specification</legend>
        @SystemSpecification()

    </fieldset>*@
<script type="text/javascript">
    $(document).ready(function () {
        $('.chosen-select').chosen({ width: '100%' });
        $('#specification').chosen().change(function (event) {
            var dID = $(this).val();
            bindVendor(dID);
        });
        $('#ddlVendor').chosen().change(function (event) {
            var specfi = $("#specification option:selected").val(); //
            var vandorid = $(this).val();
            var entitytype = $('#entityType').val();
            bindCateSubcat(entitytype,specfi, vandorid);
        });
        $('#ddlType').chosen().change(function (event) {
            var dID = $(this).val();
            bindBrand(dID);
        });
        $('#ddlBrand').chosen().change(function (event) {
            var dID = $(this).val();
            bindModel(dID);
        });
        $('#ddlSplitterType').chosen().change(function (event) {
            if ($('#dvMainSpecification').hasClass('dvdisabled')) {
                var specfi = $("#ddlSplitterType option:selected").val();
                var defaultSpecif = $($('#specification option[data-type="' + specfi + '"]')[0]).val();
                $('#specification').val(defaultSpecif).trigger('chosen:updated').trigger('change');
                var defaultVndor = $($('#ddlVendor option[value!=""]')[0]).val();
                $('#ddlVendor').val(defaultVndor).trigger('chosen:updated').trigger('change');
            }
        });
        $('#ddlSplitterType').val($($('#ddlSplitterType> option')[1]).text()).trigger('change').trigger('chosen:updated');

    });
</script>
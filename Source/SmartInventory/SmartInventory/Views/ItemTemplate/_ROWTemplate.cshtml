@model Models.ROWItemMaster
@using Models;

<script>
    //Set color of template icon as green in NE library
    if ('@Model.id' > 0) {
        $(".clsTemplateIcon[data-lyrname='ROW']").css('background-color', '#9999FF');
    }
</script>

@helper pageMessage()
{
    { Html.RenderPartial("_PageMessage", Model.objPM); }
}
@helper ROWTemplateMaster()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_ROWTemplateMaster.cshtml", (ROWTemplateMaster)Model); }
}
<!DOCTYPE html>
<div class="libDetail">

    @using (Ajax.BeginForm("SaveROWTemplate", "ItemTemplate", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "dvModalBody",
        LoadingElementId = "dvProgress",
        OnFailure = "si.handleError",
        OnBegin = "return validae();"

    },
            new { id = "frmItemTemplate", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {
        @Html.HiddenFor(m => m.id)
        <!-- Message Pop-up -->
        @pageMessage()
        <div class="libTabContent" style="overflow:visible !important">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="tab-pane active" id="ItemSpecfication">
                    @ROWTemplateMaster()
                </div>
            </div>
        </div>
        <div class="d-flex ModalFooter" id="dvBtnAction">
            <a href="javascript:void(0);" class="btn btn-default ml-auto mr-01" data-dismiss="modal" id="btnCancelAssignRoute">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
            @if (Model.id > 0)
            {
                <button type="submit" class="btn btn-primary" id="btnUpdateItemTemplate">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_003</button>
            }
            else
            {
                <button type="submit" class="btn btn-primary" id="btnSaveItemTemplate">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
            }

        </div>
    }
</div>
<script>
    $(document).ready(function () {

        callFormValidator("frmItemTemplate");

        $('#id').val('@Model.id');

        //Set color of template icon as green in NE library
        @*if ('@Model.id' > 0) {
            $(".clsTemplateIcon[data-lyrname='ROW']").css('background-color', '#31bd72');
        }*@

    });
    function validae() {
        if ($('#width').val() == "0" && $('#customized').val() == '') {
            $('#customized').addClass('NotValid');
            return false;
        } else if ($('#width').val() == "0" && $('#customized').val() != '')
        {
            var maxLimit = parseInt($('#hdnROWMaxWidthLimit').val());
            if (parseFloat($('#customized').val()) > maxLimit)
            {
                $('#customized').addClass('NotValid');
                alert('Maximum ' + maxLimit+'(Mtr) width are allowed only!');
                return false;
            }
        }
        return true;
    }

</script>


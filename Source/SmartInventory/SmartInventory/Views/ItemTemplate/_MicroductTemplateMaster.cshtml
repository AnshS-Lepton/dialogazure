@model Models.MicroductTemplateMaster
@using Models;
@using SmartInventory.Settings;
@helper ItemSpecification()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_ItemSpecification.cshtml", (itemMaster)Model); }
}
@helper SystemSpecification()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_SystemSpecification.cshtml", (itemMaster)Model); }
}
@{
    var layerDetail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.Microduct.ToString().ToUpper()).FirstOrDefault() : null;
}
 <input type="hidden" id="Layer_id" value="@layerDetail.layer_id" />
<fieldset class="the-fieldset">
    <legend class="the-legend">No Of Ways</legend>
    <div class="form-group">
        <label class="control-label col-sm-2" for="ddlNoOfWays">No Of Ways<i class="clsMandatory">*</i>:</label>
        <div class="col-sm-45">
            @Html.DropDownListFor(m => m.no_of_ways, new SelectList(Model.lstNoOfWays.Select(x => new { Value = x.dropdown_value.ToString(), Text = x.dropdown_value }), "Value", "Text"), "Select No Of Ways", new { @class = "chosen-select col-sm-12", @style = "padding:0;", @id = "ddlNoOfWays"})
        </div>
    </div>
</fieldset>
<fieldset class="the-fieldset">
    <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_GBL_GBL_026</legend>
    @ItemSpecification()
</fieldset>
<fieldset class="the-fieldset">
        <legend class="the-legend">Model Mapping & System Specification</legend>
        @SystemSpecification()

    </fieldset>
<script type="text/javascript">
    $(document).ready(function () {
        $('.chosen-select').chosen({ width: '100%' });
        $('#specification').chosen().change(function (event) {
            var dID = $(this).val();
            si.bindVendor(dID);
        });
        $('#ddlVendor').chosen().change(function (event) {
            var specfi = $("#specification option:selected").val(); //
            var vandorid = $(this).val();
            var entitytype = $('#entityType').val();
            si.bindCateSubcat(entitytype, specfi, vandorid);
            si.BindNoOfWays(entitytype, specfi, vandorid);
        });
        $('#ddlType').chosen().change(function (event) {
            var dID = $(this).val();
            si.bindBrand(dID);
        });
        $('#ddlBrand').chosen().change(function (event) {
            var dID = $(this).val();
            si.bindModel(dID);
        });
        //---------------        
    });
</script>

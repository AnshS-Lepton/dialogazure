@model Models.WFM.Task

<script src="~/Content/js/Main.js"></script>


@{
    ViewBag.Title = "jobViewUserTimeSheet";
}

<script>

    function fnnewFormValidation(event) {
         
        var result = true;

        if ($("#cpeserialno").val() == "") {
            alert("Please enter serial number!!");
            return false;
        }
        return result;
    }

</script>


<div id="dvUserTimeSheetContainer">
    @using (Ajax.BeginForm("upDATEjobViewUserTimeSheet", "Workforce", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "dvChildModalBody",
        OnFailure = "si.handleError",
        OnSuccess = "si.handleSuccess"
    }, new
    {
        id = "frmUserTimeSheet",
        enctype = "multipart/form-data",
        autocomplete = "off",
        @class = "form-horizontal"


    }
    ))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true)



        <div class="modalNbody">
            <div class="form-group colon" style="display:none">

                @Html.HiddenFor(h => h.hpsmid)
                <label class="control-label col-sm-2">CPE Brand:</label>
                <div class="col-sm-4">
                    @Html.TextBoxFor(model => model.cpe_brand, new { @class = "form-control", @placeholder = "cpe_brand" })
                </div>
            </div>




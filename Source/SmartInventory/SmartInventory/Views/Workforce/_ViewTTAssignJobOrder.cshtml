@{
    WebGrid grid = new WebGrid(rowsPerPage: Model.viewAssignJobOrderFilter.pageSize, canSort: true, ajaxUpdateContainerId: "divGvRouteAssignIssuesDetail", ajaxUpdateCallback: "onGridHeaderClick('tblGvRouteAssignIssuesDetail')");
    grid.Bind(Model.lstAssignJobOrderDetails, autoSortAndPage: false, rowCount: Model.viewAssignJobOrderFilter.totalRecord);
    if (Model.viewAssignJobOrderFilter.totalRecord > 0)
    {
        grid.PageIndex = Model.viewAssignJobOrderFilter.currentPage - 1;
    }

}

<script>

    var totalRowCount = @grid.TotalRowCount;
    //var maxExportReportCount = SmartTracking.Settings.ApplicationSettings.MaxExportReportCount;
    var maxExportReportCount =5000;
    var RL = new ListingPage();
    $(document).ready(function () {
        if (autoRefreshId3 > 0) {
            $("#autorefresh3").prop("checked", true);
        }
        else {
            $("#autorefresh3").prop("checked", false);
        }
        RL.initApp();
        //$('#dvViewRouteContainer select').select2({ width: '100%' });
        si.setDateTimeCalendar("txtStartDate", "txtEndDate", "imgFromDate", "imgToDate", true);
        RL.ToggleElement(@Model.viewAssignJobOrderFilter.duration == 0 ? 1 : @Model.viewAssignJobOrderFilter.duration );
    });

    function fnAssignIssue(){
         
       // alert("_ViewAssign");
        var selectedValue = [];
     var j = 0;
        var inputElements = document.getElementsByClassName('Ticket');
        for (var i = 0; inputElements[i]; ++i) {
            if (inputElements[i].checked) {
                selectedValue[j] = inputElements[i].value;
                j++;

            }
        }

       // var checkedValue = [];

        if(selectedValue.length > 0)
        {
           // var bulkAssignLength =   parseInt('//System.Configuration.ConfigurationManager.AppSettings["BulkIssueAssign"].ToString()');
            var bulkAssignLength = 10;
            if(bulkAssignLength < selectedValue.length)
            {
                alert("Maximum "+bulkAssignLength+" issues can be assigned at one time.");
            }
            else{
                si.ApproveRouteIssuett(selectedValue,'Re-Assigned');
            }
        }
        else
        {
            alert("Please select at least one Job order!");
        }
    }
    function fnAutorefresh() {
         
        if ($("#autorefresh3").prop("checked") == true) {
            if (autoRefreshId3 == 0) {
                autoRefreshId3 = setInterval(function () { $('form#frmViewRoute').submit(); }, 60000);
            }

        }
        else {
            if (autoRefreshId3 > 0) {
                clearInterval(autoRefreshId3);
                autoRefreshId3 = 0;
            }
        }
    }
</script>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                @if (item.status != "Completed" && (item.facility == "IPTV" || item.facility == "IPTV_EXTN"))
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     {

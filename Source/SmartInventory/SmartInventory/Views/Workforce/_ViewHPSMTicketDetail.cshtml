@model Models.WFM.ViewHPSMTicketDetails
@{
    WebGrid grid = new WebGrid();
    if (Model.viewTicketFilter.totalRecord > 0)
    {
        grid = new WebGrid(rowsPerPage: Model.viewTicketFilter.totalRecord, canSort: false, ajaxUpdateContainerId: "divGvHPSMTicketDetail", ajaxUpdateCallback: "ChkAddClass()");
        grid.Bind(Model.ticket_Details, autoSortAndPage: false, rowCount: Model.viewTicketFilter.totalRecord);
        grid.PageIndex = 0;// Model.viewTicketFilter.currentPage - 1;
    }
}

<div id="dvViewTicketContainer">
    @using (Ajax.BeginForm("ViewHPSMTicketTaskDetails", "Workforce", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "dvParentModalBody" }, new { autocomplete = "off", @class = "form-horizontal", @id = "frmViewHPSMTicketIssue" }))
    {
        <div id="divGvHPSMTicketDetail" >
            @if (Model.ticket_Details.Count > 0)
            {
            <div class="tablBody tpad-top">
                <div class="recordCount">
                    <div class="d-flex">
                        <h5>HOBS ticket id:<span class="ticketNumber"> @Model.viewTicketFilter.ticketId</span> </h5>
                    </div>
                    <b>Total Records: @grid.TotalRowCount</b>
                </div>
                <div class="overTable">
                    @grid.GetHtml(tableStyle: "grid",
                                htmlAttributes: new { id = "divGvHPSMTicketDetail" },
                              mode: WebGridPagerModes.All,
                columns: grid.Columns(

                @*grid.Column("HPSMSTATUS", "Status", format: @<text><span id="HPSMSTATUS">@item.HPSMSTATUS</span> </text>),*@
grid.Column("STATUS", "Status", format: @<text><span id="HPSMSTATUS">@item.STATUS</span> </text>),
grid.Column("STATUS", " Sub Status", format: @<text><span id="HPSMSubSTATUS">@item.sub_status</span> </text>),
                @*grid.Column("OPENDATE", "Open Date", format: @<text><span id="OPENDATE">@item.created_on</span> </text>),*@
                @*grid.Column("REGION", "Region", format: @<text><span id="REGION">@item.REGION</span> </text>),*@
                @*grid.Column("ISRESOLVE", "Is Resolve", format: @<text><span id="ISRESOLVE">@item.ISRESOLVE</span> </text>),*@
                @*grid.Column("DISTRICT", "District", format: @<text><span id="DISTRICT">@item.DISTRICT</span> </text>),*@
                @*grid.Column("DUEDATE", "Due date", format: @<text><span id="DUEDATE">@item.DUEDATE</span> </text>),*@
                @*grid.Column("DURATION", "Duration", format: @<text><span id="DURATION">@item.DURATION</span> </text>),*@
grid.Column("Action Date", "Action Date", format: @<text><span id="ACTIONDATE">@item.modified_on</span> </text>),
                @*grid.Column("TICKETTYPE", "Ticket Type", format: @<text><span id="TICKETTYPE">@item.TICKETTYPE</span> </text>),*@
grid.Column("COMMENT_", "Comment", format: @<text><span id="COMMENT_">@item.remarks</span> </text>),
grid.Column("user_name", "User Name", format: @<text><span id="user_name">@item.user_name</span> </text>),
grid.Column("LATITUDE", "Latitude", format: @<text><span id="LATITUDE">@item.LATITUDE</span> </text>),
grid.Column("LONGITUDE", "Longitude", format: @<text><span id="LONGITUDE">@item.LONGITUDE</span> </text>)
                @*grid.Column("TASKTYPE", "Task Type", format: @<text><span id="TASKTYPE">@item.TASKTYPE</span> </text>),
    grid.Column("TASKCATEGORY", "Task Category", format: @<text><span id="TASKCATEGORY">@item.TASKCATEGORY</span> </text>),
    grid.Column("TASKSUBCATEGORY", "Task Sub-category", format: @<text><span id="TASKSUBCATEGORY">@item.TASKSUBCATEGORY</span> </text>),*@

                @*grid.Column("customer_id", "Customer Id", format: @<text><span id="CUSTOMERID">@item.customer_id</span> </text>),

grid.Column("resolution_close_id", "RC", format: @<text><span id="RESOLUTIONCLOSEID">@item.resolution_close_id</span> </text>),
grid.Column("root_cause_id", "RCA", format: @<text><span id="ROOTCAUSEID">@item.root_cause_id</span> </text>),
*/
                @*grid.Column("root_cause_id", "RC", format: @<text><span id="ROOTCAUSEID">@item.root_cause_id</span> </text>),
    grid.Column("resolution_close_id", "RCA", format: @<text><span id="RESOLUTIONCLOSEID">@item.resolution_close_id</span> </text>)*@


                @*grid.Column("customer_serial_number1", "SRNO-1(OLD)", format: @<text><span id="DEVICESERIALNUMBER1-OLD">@item.customer_serial_number1</span> </text>),
    grid.Column("customer_serial_number2", "SRNO-2(OLD)", format: @<text><span id="DEVICESERIALNUMBER2-OLD">@item.customer_serial_number2</span> </text>),*@

                @*grid.Column("customer_brand", "BRAND(OLD)", format: @<text><span id="DEVICEBRAND-OLD">@item.customer_brand</span> </text>),
    grid.Column("customer_model", "MODEL(OLD)", format: @<text><span id="DEVICEMODEL-OLD">@item.customer_model</span> </text>),

    grid.Column("device_serial_number1", "SRNO-1(NEW)", format: @<text><span id="DEVICESERIALNUMBER1-NEW">@item.device_serial_number1</span> </text>),
    grid.Column("device_serial_number2", "SRNO-2(NEW)", format: @<text><span id="DEVICESERIALNUMBER2-NEW">@item.device_serial_number2</span> </text>),*@


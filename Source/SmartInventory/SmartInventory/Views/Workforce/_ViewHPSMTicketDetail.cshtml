    grid.Column("addressline2", "Address Line 2", format: @<text><span id="ADDRESSLINE2">@item.addressline2</span> </text>),
    grid.Column("addressline3", "Address Line 3", format: @<text><span id="ADDRESSLINE3">@item.addressline3</span> </text>),*@
                @*grid.Column("customer_preferred_time", "Preffered Time", format: @<text><span id="CUSTOMERPREFERREDTIME">@item.customer_preferred_time</span> </text>)*@

                @*grid.Column("issue_comment", "Customer Remark", format: @<text><span id="ISSUECOMMENT">@item.issue_comment</span> </text>),*@

                @*grid.Column("customer_plan_speed", "Plan Speed", format: @<text><span id="CUSTOMERPLANSPEED">@item.customer_plan_speed</span> </text>),*@
                @*grid.Column("customer_plan_name", "Plan Name", format: @<text><span id="CUSTOMERPLANNAME">@item.customer_plan_name</span> </text>),*@
                @*grid.Column("service_status", "Service Status", format: @<text><span id="SERVICESTATUS">@item.service_status</span> </text>),*@


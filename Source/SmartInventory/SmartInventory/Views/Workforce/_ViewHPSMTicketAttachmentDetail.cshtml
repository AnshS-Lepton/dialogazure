@model List<Models.WFM.vw_hpsm_ticket_attachments>

<style>

    #myImg {
        border-radius: 5px;
        cursor: pointer;
        transition: 0.3s;
    }

        #myImg:hover {
            opacity: 0.7;
        }

    /* The Modal (background) */
    .modal {
        display: none; /* Hidden by default */
        position: fixed; /* Stay in place */
        z-index: 1; /* Sit on top */
        padding-top: 0; /* Location of the box */
        left: 0;
        top: 0;
        width: 100%; /* Full width */
        height: 100%; /* Full height */
        overflow: auto; /* Enable scroll if needed */
        background-color: rgb(0,0,0); /* Fallback color */
        background-color: rgba(0,0,0,0.9); /* Black w/ opacity */
    }


    /* Modal Content (image) */
    .modal-content {
        margin: auto;
        display: block;
        width: 80%;
        max-width: 700px;
        box-shadow: none;
        border: none;
    }

    .bigImage {
        overflow-y: auto;
        height: 500px;
      /*  padding-bottom: 3rem;*/
    }


    /* Caption of Modal Image */
    #caption {
       
        text-align: center;
        color: #3535f3;
        padding: 1.5rem 0;
        font-size: 1.7rem;
        font-weight: 500;
    }

    /* Add Animation */
    .modal-content, #caption {
        -webkit-animation-name: zoom;
        -webkit-animation-duration: 0.6s;
        animation-name: zoom;
        animation-duration: 0.6s;
    }



    /* The Close Button */
    .close {
        position: absolute;
        top: 10px;
        right: 10px;
        color: #979797;
        font-size: 30px;
        font-weight: 600;
        transition: 0.3s;
    }

        .close:hover,
        .close:focus {
            color: #bbb;
            text-decoration: none;
            cursor: pointer;
        }

    .thumbImg {
    }

    .imgSize {
        height: 50px;
        width: 50px;
        margin-right: 1.5rem;
        background: #f6f6f6;
    }

    .popSpac {
        padding: 15px !important;
        max-height: 500px;
        overflow-y: auto;
        text-align: right;
        scrollbar-color: #c9d0d8 #efefef;
        scrollbar-width: thin;
    }

    .imgStyle {
        border: 1px solid #e2e2e2;
        background: #FFFFFF;
        border-radius: 5px;
        overflow:hidden;
    }

    .mb-1 {
        margin-bottom: 1rem;
    }

    .align-itm {
        align-items: center;
    }

    .titleOverflow {
        text-overflow: ellipsis;
        max-width: 195px;
        overflow: hidden;
        white-space: nowrap;
        font-size: 13px;
        font-weight: 600;
        color: #4800ff;
        cursor: pointer;
        align-items: center;
        transition: 0.3s;
    }

        .titleOverflow:hover {
            text-decoration: underline;
            color: #000000;
        }

    .dynmiBoxes {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .imgModal {
        background-color: #FFFFFF !important;
        border-radius: 5px;
        /* overflow-y:auto !important;*/
    }

    .pt-50 {
        padding-top: 50px;
    }
    .iconBtnDown{
        font-size:18px;
        cursor:pointer;
        display:inline-block;
    }
</style>

<div id="dvViewTicketContainer" class="popSpac">
    @{
        if (Model.Count > 0)
        {
            <a id="btnDownloadAll" class="iconBtnDown" href="javascript:void(0)" onclick="si.downloadAttachments('@Model[0].job_id');">
                <i class="fa fa-download"></i>
            </a>
            <div class="dynmiBoxes">
                @foreach (var item in Model)
                {
                    <div class="d-flex imgStyle align-itm" id="@item.id">
                        @if (@item.upload_type.Equals("image", StringComparison.OrdinalIgnoreCase))
                        {
                            @*<img src="~/Content/images/imgIcon.svg" class="imgSize" alt="@item.file_name" />*@
                            <img title="@item.doc_type" class="imgSize" alt="@item.doc_type" src="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id+"?doctype=imgthumb")" />
                            <span title="@item.doc_type" class="titleOverflow thumbImg" id="thumbImg_@item.id" alt="@item.doc_type" data-src-url="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id+"?doctype=img")" src="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id+"?doctype=imgthumb")">@item.doc_type</span>
                        }
                        @if (@item.upload_type.Equals("DOCUMENT", StringComparison.OrdinalIgnoreCase))
                        {
                            if (@item.file_extension.Equals(".jpg", StringComparison.OrdinalIgnoreCase) || @item.file_extension.Equals(".png", StringComparison.OrdinalIgnoreCase)|| @item.file_extension.Equals(".jpeg", StringComparison.OrdinalIgnoreCase))
                            {
                                <img title="@item.doc_type" class="imgSize" alt="@item.doc_type" src="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id+"?doctype=img")" />
                                <span title="@item.doc_type" class="titleOverflow thumbImg" id="thumbImg_@item.id" alt="@item.doc_type" data-src-url="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id+"?doctype=img")" src="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id+"?doctype=imgthumb")">@item.doc_type</span>
                            }

                            else if (@item.file_extension.Equals(".xlsx", StringComparison.OrdinalIgnoreCase))
                            {
                                <img title="@item.doc_type" src="~/Content/images/xlsxIcon.svg" class="imgSize" />
                                <a title="@item.doc_type" class="titleOverflow" href="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id + "?doctype=xlsx")">@item.doc_type</a>
                            }
                            else if (@item.file_extension.Equals(".pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <img title="@item.doc_type" src="~/Content/images/pdfIcon.svg" class="imgSize" />
                                <a title="@item.doc_type" class="titleOverflow" href="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id + "?doctype=pdf")">@item.doc_type</a>
                            }
                            else if (@item.file_extension.Equals(".docx", StringComparison.OrdinalIgnoreCase))
                            {
                                <img title="@item.doc_type" src="~/Content/images/docIcon.svg" class="imgSize" />
                                <a title="@item.doc_type" class="titleOverflow" href="@Url.Content("Workforce/GetAttachmentDetailsbyId/" + @item.id + "?doctype=docx")">@item.doc_type</a>
                            }
                        }

                    </div>
                }
            </div>
        }
    }
</div>
<!-- The Modal -->
<div id="myModal" class="modal imgModal">
    <span id="imagemodalClose" class="close">&times;</span>
    <div id="dvImageContent" class="bigImage">
    </div>
</div>
<script>

    $(document).ready(function () {
        var modal = "";
        $(".thumbImg").on("click", function () {
            modal = document.getElementById("myModal");
            // Get the modal
            modal.style.display = "block";
            // Get the image and insert it inside the modal - use its "alt" text as a caption
            var img = document.getElementsByClassName("thumbImg");
            var title = $(this).attr("alt");
            var imageurl = $(this).attr("data-src-url");
            $("#dvProgress").show();
            setTimeout(function () {

                $('#dvImageContent').append("<div id='caption'>" + title + "</div>");
                var image = new Image();
               // image.className = "modal-content";
                image.src = imageurl;
                $('#dvImageContent').append(image);
                $("#dvProgress").hide();
            }, 500);
            
        });
        $("#imagemodalClose").on("click", function () {
            $("#dvImageContent").html("");
            modal.style.display = "none";
        });

    });
</script>

@model List<Models.Admin.OrthoImageMasterModel>
@using SmartInventory.Settings;



<div class="mainlyr pr10 pl10 treeview" style="display:block;">
    @foreach (var objLayer in Model.Where(x => x.is_active == true))
    {
        <div class="lheight">
            <input id="chk_OrthP_@objLayer.system_id" type="checkbox" name="chkOrthoOverlayer" class="chknetwork-P checkbox-custom2" 
                   value="@string.Concat(objLayer.image_name,".",objLayer.image_extension)">
            <label for="chk_OrthP_@objLayer.system_id" class="checkbox-custom-label">@objLayer.display_name</label>
            <i class="fa fa-chevron-down f-right mt05" aria-hidden="true" onclick="getdropfiles(@objLayer.system_id,this)"></i>
            <div style="display:none" id="@objLayer.system_id">
                <div class="d-fx aln-item mb05 rangeStyle">
                    <span>Opacity: </span>
                    <span class="pl05">
                        <input type="range" id="sld_Ortho_@objLayer.system_id" min="0" max="100" value="100" onchange="showSliderValue(this)">
                    </span>
                    <span class="pl05" id="sld_val_@objLayer.system_id">100</span>
                </div>
            </div>
        </div>
    }
</div>
<script>
    function getdropfiles(id, e) {
         
        var scale = $('#' + id);

        if (!scale.is(':visible')) {
            e.classList.remove('fa-chevron-down');
            e.classList.add('fa-chevron-up');
        }
        else {
            e.classList.remove('fa-chevron-up');
            e.classList.add('fa-chevron-down');
        }
        scale.slideToggle('slow');
        //show('slide', { direction: 'left' }, 1400)

    }
</script>
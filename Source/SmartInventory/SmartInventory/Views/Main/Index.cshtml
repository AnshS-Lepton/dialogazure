<script type="text/javascript">
    //var applicationUrl = window.location.origin;
    var applicationUrl = '@string.Format("{0}://{1}{2}", Request.Url.Scheme, Request.Url.Authority, Url.Content("~"))';
    function isdigitOnlywithOnedot(e, event) {
        var mxlen = $(e).attr('maxlength');
        if (event.which == 46 && $(this).val().indexOf('.') != -1) {
            event.preventDefault();
        } // prevent if already decimal point
        if ($(e).val().indexOf('.') != -1) {
            var ara = $(this).val().split('.');
            if (ara[1].length > 0) {
                event.preventDefault();
            }
        }
        if ($(e).val().length > mxlen) {
            event.preventDefault();

        }
        if (event.which != 46 && (event.which < 48 || event.which > 57)) {
            event.preventDefault();
        }
    }

    function SetNEBufferValue() {

        sessionStorage.setItem("hdnNEBuffer", $("#txtNEBuffer").val());
        $("#hdnNEBuffer").val($("#txtNEBuffer").val());
        var className = $('#LigroupLibarary').attr('class');
        if (className =='btn-success active')
            si.initDistanceWidget_GroupLibrary($("#hdnNEBuffer").val(), si.LatLngGlobelLibBuffer, si.mapListners["TempLibItm"], true);
        else {
            var marker = ((si.mapListners["TempLibItm"] == undefined || si.mapListners["TempLibItm"] == null || si.mapListners["TempLibItm"] == '') ? si.gMapObj.infoEntity : si.mapListners["TempLibItm"]);
            si.initDistanceWidget_A($("#hdnNEBuffer").val(), si.LatLngForBuffer, marker);
        }

    }
</script>


@model IEnumerable<Models.BusinessLayer>

<div class="mainlyr pr10 pl10 grpNetwork" style="display:block;">
   
    @foreach (var objLayer in Model.Where(x => x.is_active == true && x.isbaselayer==false))
    {
    <div class="lheight">
        <input id="chk_wms_@objLayer.id" type="checkbox" name="chkwmsOverlayer" class="chknetwork-wms checkbox-custom"
         data-layer-type="@objLayer.layer_type" data-url="@objLayer.base_url" data-layer="@objLayer.layer_name" data-displayName="@objLayer.display_layer_name" data-key="@objLayer.authentication_key" data-style="@objLayer.style"  data-TileMatrixSet="@objLayer.tilematrixset" data-mapfilepath="@objLayer.map_file_path">
        <b><label for="chk_wms_@objLayer.id" class="checkbox-custom-label">@objLayer.display_layer_name</label></b>

        @*<i class="fa fa-chevron-down mt05 f-right" aria-hidden="true" onclick="getdropfileswms('divwms_@objLayer.id',this)"></i>
        <div style="display:none" id="divwms_@objLayer.id">
            <div class="d-fx aln-item mb05 rangeStyle">
                <span>Opacity: </span>
                <span class="pl05">
                    <input type="range" id="sld_wms_@objLayer.id" min="0" max="100" data-displayName="@objLayer.display_layer_name" value="100" onchange="showSliderValueWMS(this)" style="display: table-cell;">
                </span>
                <span class="pl05" id="sld_wms_val_@objLayer.id">100</span>
            </div>
        </div>*@
    </div>
    }
</div>

<script>
    function getdropfileswms(id, e) {
         
        var scale = $('#' + id);

        if (!scale.is(':visible')) {
            e.classList.remove('fa-chevron-down');
            e.classList.add('fa-chevron-up');
        }
        else {
            e.classList.remove('fa-chevron-up');
            e.classList.add('fa-chevron-down');
        }
        scale.slideToggle('slow');
        //show('slide', { direction: 'left' }, 1400)

    }
</script>
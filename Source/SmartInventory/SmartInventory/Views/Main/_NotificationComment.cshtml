@model List<Models.ViewEntityNotificationComments>
@if (Model.Count > 0)
{
    foreach (var item in Model)
    {
        <div class="NotifComment">
            <span class="fontID" style="font-size:13px;"> @item.created_by_text  &nbsp;&nbsp;<i><label class="control-label model-label-info" title="@(@item.created_on != null ? Utility.MiscHelper.FormatDateTime(@item.created_on.ToString()) : string.Empty)">@(@item.created_on != null ? Utility.MiscHelper.TimeAgo(@item.created_on.ToString()) : string.Empty)</label></i></span>
            <span class="fontID" style="font-weight: normal;margin-top: 5px;">@item.comment_text</span>
        </div>
    }
}

@model Models.Admin.ViewItemVendorCost
@using Utility
@using SmartInventory.Settings;
@using System.Dynamic;
@using System.Collections.Generic;
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />

<div id="libTabContent" class="libDetail">
    <div class="libTabContent">
        

        @{
            var gridData = ViewBag.transformedData as List<dynamic>;

            //var gridData = ViewBag.transformedData as List<Dictionary<string, object>>;

            var users = new List<string>();

            if (gridData != null && gridData.Any())
            {
                // Extract user-specific columns dynamically
                var firstRow = (IDictionary<string, object>)gridData.FirstOrDefault();

                users = firstRow.Keys.Where(k => k.StartsWith("User_")).ToList();


            }



        }
        @{
            WebGrid grid = new WebGrid(rowsPerPage: Model.objGridAttributes.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewLayerGroups", ajaxUpdateCallback: "onGridHeaderClick('tblItemVendorCost')");
            grid.Bind(gridData, autoSortAndPage: false, rowCount: Model.objGridAttributes.totalRecord);
            if (Model.objGridAttributes.totalRecord > 0)
            {
                grid.PageIndex = Model.objGridAttributes.currentPage - 1;
            }

            // Define column list
            var columns = new List<WebGridColumn>
    {
        grid.Column("code", "Item Code"),

        grid.Column("specification", "Specification"),
        grid.Column("uom", "UOM"),
        grid.Column("totalqty", "Quantity/Length"),
        //grid.Column("uam", "Unit Measurement")
    };

            // Add user-specific columns dynamically
            foreach (var user in users)
            {


                columns.Add(grid.Column(user, user.Replace("User_", "").Split('/')[0], format: item =>
            Html.Raw("<div style='display: flex; width: 100%;'>"


            + "<div style='width: 50%; text-align: center; padding: 5px;'>" + item[user] + "</div>"
            + "</div>")));


            }
        }


        @using (Html.BeginForm("AwardSite", "BOMBOQ", FormMethod.Post, new { autocomplete = "off", @id = "frmtblItemVendorCost" , OnSuccess = "OnSuccess" }))
        {
            <section class="libTabContent">
                <div class="tab-content">
                    <div class="form-group row">
                        <label class="control-label col-sm-4">
                            Search By :
                        </label>
                        <div class="col-sm-4">
                            @Html.DropDownListFor(m => m.objGridAttributes.searchBy, new SelectList(Model.lstBindSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control" })
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="control-label col-sm-4">
                            Search Text:
                        </label>
                        <div class="col-sm-4">
                            @Html.TextBoxFor(m => m.objGridAttributes.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })
                        </div>
                    </div>
                    <div class="ModalFooter d-flex pos-rel" id="dvBtnAction">
                        <div class="col-sm-4">
                            <button class="btn btn-success ml-auto" id="btnGetSearchResult" name="btnCommandName" value="GetSearchResult" tabindex="5"  type="submit">Search</button>                           
                             <input type="button" id="btnViewGroupExport" value="Export" class="btn btn-success ml-auto" onclick="ViewGroupsReport()" />                                                      
                        </div>
                    </div>

                </div>

                @if (gridData != null && gridData.Any())
                {
                    <div id="divLayerGroupDetail">
                        <div class="recordCount mb-01"><b>Total Records:<span data="spanTotalRowCount">@grid.TotalRowCount</span></b></div>

                        <div class="table-responsive tble_cls">
                            @grid.GetHtml(tableStyle: "grid",
            htmlAttributes: new { id = "tblItemVendorCost" },
            mode: WebGridPagerModes.All,
            columns: columns)


                            @Html.Hidden("dir", grid.SortDirection)
                            @Html.Hidden("col", grid.SortColumn)
                            @Html.HiddenFor(m => m.objGridAttributes.searchBy)
                            @Html.HiddenFor(m => m.objGridAttributes.searchText)
                        </div>

                    </div>
                }
                else
                {
                    <div style="text-align: center; margin-top: 30px;">
                        No Records Found.
                    </div>
                }

            </section>

            <div>
                <div class="form-group">
                    <label class="control-label col-sm-4">
                        Award Site TO :
                    </label>
                    <div class="col-sm-4">
                        @Html.DropDownListFor(m => m.user_id, new SelectList(Model.lstUserDetails.Select(x => new { Value = x.user_id.ToString(), Text = x.user_name }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control",id="AwardUser" })
                        <input type="button" id="btnAwarSite" value="Submit" class="btn btn-success ml-auto" onclick="ViewGroupsReport()" />
                    </div>
                </div>
            </div>
        }

       

    </div>
</div>
<script>
    function ViewGroupsReport() {
        debugger;
        let tableData = [];
        let headers = [];
        $("#tblItemVendorCost thead th").each(function () {
            headers.push($(this).text().trim());
        });
        var Awarduser = $('#AwardUser').val();
        var Awardusername = $('#AwardUser option:selected').text();
        let userNameIndex = headers.indexOf(Awardusername);
        if (userNameIndex === -1) {
            alert("User Name column not found.");
            return;
        }
        
      
       
        
        $("#tblItemVendorCost tbody tr").each(function () {
            let row = $(this).find("td");
            let user_name = headers[userNameIndex];
            if (user_name == Awardusername)
            {
                // var user_id = Model.lstUserDetails.where(u => u.user_name == Awardusername).Select(u => u.user_id).ToList();              
                let item = {
                    item_code: row.eq(0).text().trim(),
                    specification: row.eq(1).text().trim(),
                    uom: row.eq(2).text().trim(),
                    user_id: Awarduser
                };
                tableData.push(item);
            }         
        });
        $.ajax({
            url: '/BOMBOQ/AwardSitetoUser',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(tableData),
            success: function (response) {
                alert(response.message);
            },
            error: function () {
                alert("Error saving data.");
            }
        });
    }
</script>
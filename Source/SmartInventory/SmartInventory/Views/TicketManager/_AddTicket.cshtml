    function SaveTicket(objTicketMaster) {
         
        if (objTicketMaster.pageMsg.status != "OK") {
            alert(objTicketMaster.pageMsg.message);
        }
        else {
            alert(objTicketMaster.pageMsg.message);
            si.resetTicket();
            $('#frmIndexTicket').submit();
        }
    }

    function validateRFSType(objTicketMaster) {
        if (objTicketMaster.pageMsg.status != "OK") {
            alert(objTicketMaster.pageMsg.message);
        }
    }

    $('#iconCustomerMapp').on("click", function () {
        var canId = $('#txtCanId').val();
        ajaxReq('TicketManager/GetCustomerByCanId', { networkId: canId, }, true, function (resp) {
            if (resp.network_id != null) {
                $(popup.DE.MinimizeModel).trigger("click");
                zoomSearchedElement1("Point", 'Customer', resp.system_id)
            }

        }, false, false)

    });

    $('#iconBldMapp').on("click", function () {
        var buildingCode = $('#txtBuildingCode').val();
        ajaxReq('TicketManager/GetBuildingByCode', { networkId: buildingCode, }, true, function (resp) {
            if (resp.network_id != null) {
                 
                $(popup.DE.MinimizeModel).trigger("click");
                zoomSearchedElement1("Polygon", 'Building', resp.system_id)
            }
        }, false, false)

    });

    $('#iconBldDetails').on("click", function () {
        var buildingCode = $('#txtBuildingCode').val();
        ajaxReq('TicketManager/GetBuildingByCode', { networkId: buildingCode, }, true, function (resp) {
            if (resp.network_id != null) {
                 
                popup.LoadModalDialog('CHILD', 'Library/AddBuilding', { systemId: resp.system_id, entityType: "Building", geomType: resp.geomType, networkStatus: resp.network_status }, "Building", 'modal-lg');
                //popup.LoadModalDialog('CHILD', 'Library/AddPatchCord', { systemId: event.data.systemId }, titleText, modelClass);
            }
        }, false, false)

    });

    $('#iconCustomerdetails').on("click", function () {
        var canId = $('#txtCanId').val();
        ajaxReq('TicketManager/GetCustomerByCanId', { networkId: canId, }, true, function (resp) {
            if (resp.network_id != null) {
                popup.LoadModalDialog('CHILD', 'Library/AddCustomer', _data = { systemId: resp.system_id, entityType: "Customer", geomType: "Point", childModel: "dvChildModalBody" }, "Customer", 'modal-lg');
            }

        }, false, false)

    });

    function createUpdateTicket(IsNewTicket) {
         

        if ($('#ddlTicketType').val() == "") {
            $('#ddlTicketType_chosen').addClass('notvalid');
            return false;
        }
        else {
            $('#ddlTicketType_chosen').removeClass('notvalid');
        }

        if ($('#ddlRefType').val() == "") {
            $('#ddlRefType_chosen').addClass('notvalid');;
            return false;
        }
        else {
            $('#ddlRefType_chosen').removeClass('notvalid');
        }


        if ($('#txtCanId').val().trim() == "") {
            $('#txtCanId').addClass('notvalid');
            return false;
        } else {
            $('#txtCanId').removeClass('notvalid');
        }

        if ($('#customer_name').val().trim() == "") {
            $('#customer_name').addClass('notvalid');
            return false;
        } else {
            $('#customer_name').removeClass('notvalid');
        }

        if ($('#address').val().trim() == "") {
            $('#address').addClass('notvalid');
            return false;
        } else {
            $('#address').removeClass('notvalid');
        }

        if ($('#txtBuildingCode').val().trim() == "") {
            $('#txtBuildingCode').addClass('notvalid');
            return false;
        } else {
            $('#txtBuildingCode').removeClass('notvalid');
        }

        if ($('#ddlAssignedTo').val().trim() == "") {
            $('#ddlAssignedTo').next().addClass('input-validation-error');
            return false;
        }
        else {
            $('#ddlAssignedTo').next().removeClass('input-validation-error');
        } 

        if (($('#ddlTicketType option:selected').text() != "--Select--") && ($('#ddlTicketType option:selected').text() != "New Connection") && $("#iconCustomerMapp").is(":hidden")) {
            alert("Customer does not exist for " + $('#ddlTicketType option:selected').text() + " Request!");
            return false;
        }

        if (($('#ddlTicketType option:selected').text() == "New Connection") && $("#iconCustomerMapp").is(":visible")) {
            alert("CAN ID already exist for " + $('#ddlTicketType option:selected').text() + " Request!");
            return false;
        }

        //if (($('#bld_rfs_type').val() != "A-RFS") && ($('#bld_rfs_type').val() != "B-RFS") && ($('#bld_rfs_type').val() != "C-RFS")) {
        //    alert("Building RFS type should be A-RFS, B-RFS or C-RFS !");
        //    return false;
        //}

        if ($('#ddlRefType').val() == "") {
            $("#ddlRefType_chosen").addClass('notvalid');
            return false;
        }
        else {
            $('#ddlRefType_chosen').removeClass('notvalid');
        }

        if (IsNewTicket) {
            validateTicket();
        } 
    }


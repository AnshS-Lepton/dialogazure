    function getBuilding() {
         


        var buildingCode = $('#txtBuildingCode').val();
        if (buildingCode.length > 0) {

            ajaxReq('TicketManager/GetBuildingByCode', { networkId: buildingCode, }, true, function (resp) {
                if (resp.network_id != null) {
                    $('#ImgBldCross').attr('src', 'Content/images/tick_1.gif');
                    $("#iconBldMapp").show();
                    //$("#iconBldDetails").show();
                    $("#iconBldDetails").hide();
                    $('#ImgBldCross').show();
                    $('#bld_rfs_type').val(resp.rfs_status);

                }
                else {
                    $('#ImgBldCross').attr('src', 'Content/images/cross.gif');
                    $('#ImgBldCross').show();
                    $("#iconBldMapp").hide();
                    $("#iconBldDetails").hide();
                    $('#bld_rfs_type').val(resp.rfs_status);
                }
            }, false, false)
        }
        else {

            $("#iconBldMapp").hide();
            $("#iconBldDetails").hide();
            $('#ImgBldCross').hide();
        }

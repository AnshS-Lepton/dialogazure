    $("input.numbers-only").on("paste", function () {
        var thisvalue = this;
         
        setTimeout(function () {
            var OnlyNumber = new RegExp(/^[0-9]{1,10}$/);
             
            if (!OnlyNumber.test(thisvalue.value.trim())) {
                thisvalue.value = "";
            }
            else {
                thisvalue.value = thisvalue.value.trim();
            }

        }, 0);
    });


    $('.remove-white-space').on("paste", function () {
        var thisvalue = this;
         
        setTimeout(function () {
            thisvalue.value = thisvalue.value.trim();
        }, 0);
    });

    function ChangeTicketType() {
        $('#address').val('').trigger("chosen:updated");
        $('#ddlRefType').val('').trigger("chosen:updated");
        $('#txtCanId').val('').trigger("chosen:updated");
        $('#customer_name').val('').trigger("chosen:updated");
        $('#txtBuildingCode').val('').trigger("chosen:updated");
        $('#bld_rfs_type').val('').trigger("chosen:updated");
        $('#ddlAssignedTo').val('').trigger("chosen:updated");
        $("#iconCustomerMapp").hide();
        $("#iconCustomerdetails").hide();
        $("#iconBldMapp").hide();
        $("#iconBldDetails").hide();
        $('#ImgBldCross').hide();
        $('#ImgCross').hide();
        $('#txtBuildingCode').prop('readonly', false)
    }

    function validateTicket() {
        var canId = $('#txtCanId').val();

        if (canId.length > 0) {
            ajaxReq('TicketManager/GetTicketDetailByCanId', { networkId: canId, }, true, function (resp) {
                 
                if (resp.ticket_id > 0 && resp.ticket_status != 'Completed') {
                    alert(MultilingualKey.SI_OSP_GBL_JQ_FRM_031);
                    return false;
                }
                else {
                    $('#frmAddTicket').submit();
                }
            }, false, false)
        }
    }
</script>




@{
    var userModuleList = (List<string>)Session["ApplicableModuleList"];
    WebGrid grid = new WebGrid(rowsPerPage: Model.pageSize, canSort: true, ajaxUpdateContainerId: "VwTicketGrid",
    ajaxUpdateCallback: "onGridHeaderClick('tblTicketManagerGrid');CheckBox();GridColor();");
    grid.Bind(Model.lstTicketMaster, autoSortAndPage: false, rowCount: Model.totalRecord);
    if (Model.totalRecord > 0)
    {
        grid.PageIndex = Model.currentPage - 1;
    }
}
@helper CreateTicket()

<script>
    $(document).ready(function () {

        $('th a, tfoot a').on("click", function () { 
            $('#frmIndexTicket').attr('action', $(this).attr('href')).submit();
            return false;
        });
        addDefaultSortingIcons("tblTicketManagerGrid");
        onGridHeaderClick('tblTicketManagerGrid');
        $('.chosen-select').chosen({ width: '100%', });
        if ($('#Dashboard').length) {
            si.setDateTimeCalendar_ExportEntities("txtDateFrom", "txtDateTo", "imgFromDate", "imgToDate", false);
        }
        
        $("#btnExportTickets").on("click", function () {

            TicketManagerExport();
        });

        if ($("#customedate_chosen").children('a').text().trim() != "Custom") {

            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }

        $("#btnResetSearchFilter").on("click", function () {
            //showConfirm('Are you sure to reset ticket form?', function () {
            si.btnResetSearchFilter();
            // });
        });

        CheckBox();
        $("#btnTicketData").on("click", function () {

            //if (($('#customedate option:selected').text() == "Select") && ($("#txtSearchTxt").val() == "")) {
            //    alert("Please select From date or search by text!");
            //    return false;
            //}

            if (($('#customedate option:selected').text() != "Select") && ($("#txtDateFrom").val() == "")) {
                alert( MultilingualKey.SI_OSP_GBL_JQ_RPT_010);
                return false;
            }

            else if (($('#customedate option:selected').text() != "Select") && ($("#txtDateTo").val() == "")) {
                alert(MultilingualKey.SI_OSP_GBL_JQ_RPT_011);
                return false;
            }

            else if ($("#txtDateFrom").val() != "" && $("#txtDateTo").val() != "") {
                var startDate = new Date($('#txtDateFrom').val());
                var endDate = new Date($('#txtDateTo').val());
                var configuredDay = 1825;
                return GetDaysDifference(startDate, endDate, configuredDay);
            }
            else {
                return true;
            }
        });
        GridColor();


    });

    function GetDaysDifference(firstDate, secondDate, configuredDay) {

        var oneDay = 24 * 60 * 60 * 1000;
        var diff = 0;
        diff = Math.round(Math.abs((firstDate.getTime() - secondDate.getTime()) / (oneDay)));


        if (diff > configuredDay) {
            alert(MultilingualKey.SI_OSP_GBL_JQ_RPT_015)
            return false;

        }
    }
    function GridColor(){

        $("#tblTicketManagerGrid tbody tr").each(function (e) {
             
            var ticket_stauts=  $($(this).children('td')[7]).text();
            if (ticket_stauts=="Assigned") {
                $(this).css('background-color','rgba(128, 142, 251, 0.5)');
            }
            else if (ticket_stauts=="InProgress") {
                $(this).css('background-color','rgba(255, 206, 75, 0.6)');
            }
            else if (ticket_stauts=="Completed") {
                $(this).css('background-color','rgba(77, 167, 115, 0.6)');
            }
            @*var model = @Html.Raw(Json.Encode(Model.lstTicketMaster));
            var model1=@Html.Raw(Json.Encode(Model.objticketstatus));

            for (let i = 0; i < model.length; ++i) {
                if (model[i].ticket_status=="Assigned") {

                    // $("#tblTicketManagerGrid tbody tr").addClass('Assign');
                   // $(this).parent().context.css('background-color','#808efb');
                    $("#tblTicketManagerGrid tbody tr").css('background-color','#808efb');
                }
                else if (model[i].ticket_status=="InProgress") {

                    // $("#tblTicketManagerGrid tbody tr").addClass('Assign');
                    //$(this).parent().context.css('background-color','#ffce4b');
                    $("#tblTicketManagerGrid tbody tr").css('background-color','#ffce4b');
                }
                else if (model[i].ticket_status=="Completed") {

                    // $("#tblTicketManagerGrid tbody tr").addClass('Assign');
                   // $(this).parent().context.css('background-color','#4da773');
                   $("#tblTicketManagerGrid tbody tr").css('background-color','#4da773');
                }
            }*@


        });
    }

    function CheckBox(){
         
        $("#tblTicketManagerGrid th").each(function () {
            if ($.trim($(this).text().toString().toLowerCase()) === "{checkall}") {
                $(this).text('');
                $(this).append("<label class='CustomTicketManager @(Model.objTicketMaster.user_role_id!=1?"":"dvdisabled")' style='cursor:pointer;@(Model.objTicketMaster.user_role_id!=1?"": "pointer-events: none;opacity: 0.4;")'> <input type='CheckBox' id='cbSelectAll' name='chkSelect' class='chkSurvey'><span class='CustomTicketManagercheck' style='top:0px;'></span> "+MultilingualKey.SI_OSP_GBL_GBL_GBL_037+"</label>");
            }
        });

        //2nd click event for header checkbox for select /deselect all
        $("#cbSelectAll").on("click", function () {
             
            var ischecked = this.checked;
            $('#tblTicketManagerGrid').find("input:checkbox").not(".dvdisabled").each(function () {
                this.checked = ischecked;
            });

        });
        $("input[name='chkSelect']").on("click", function () {
             
            var totalRows = $("#tblTicketManagerGrid td :checkbox[data-ticketstatus='Assigned']").not(".dvdisabled").length;
            var checked =$("#tblTicketManagerGrid td :checkbox[data-ticketstatus='Assigned']:checked").not(".dvdisabled").length;
            console.log("totalRows"+totalRows+" checked"+checked);
            if (checked >0 || totalRows>0) {
                if ( checked == totalRows) {
                    $("#tblTicketManagerGrid").find("input:checkbox").not(".dvdisabled").each(function () {
                        this.checked = true;
                    });
                }
                else {
                    $("#cbSelectAll").removeAttr("checked");
                }
            }

        });
    }
    function deleteTicket() {
         
        //var totalSelected = $('#VwTicketGrid input:checkbox[name=chkSelect]:checked').length;
        var totalSelected =$("#tblTicketManagerGrid td :checkbox[data-ticketstatus='Assigned']:checked").length;
        if (totalSelected == 0) {
            alert(MultilingualKey.SI_OSP_GBL_JQ_FRM_023);
        }
        else {
            //var selectedIds = $('#VwTicketGrid input[name=chkSelect]:checked').map(function () {
            var selectedIds = $("#tblTicketManagerGrid td :checkbox[data-ticketstatus='Assigned']:checked").map(function () {
                return $(this).val();
            }).get().join(',');
            var selectedId = $('input:checkbox[name=chkSelect]:checked').val();
             
            showConfirm( MultilingualKey.SI_OSP_GBL_JQ_FRM_105, function () {
                ajaxReq('TicketManager/DeleteTicket', { ticket_ids: selectedIds, }, true, function (resp) {
                     
                    if (resp.status == "OK") {

                        alert(resp.message);
                        $('#frmIndexTicket').submit();
                    }
                    else {
                        alert(resp.message);
                    }
                }, false, false)
            });
        }
    }
    function onChangeCustomDate() {

        var value = $('#customedate option:selected').val();

        SetFromAndToDate(value);
    }
    function SetFromAndToDate(value) {

        var endDate = new Date();
        var startDate = new Date();
        var startDateDiff = 0;
        var endDateDiff = 0;

        if (value == 1) // custom
        {
            $('#txtDateFrom').val("");
            $('#txtDateTo').val("");
            $("#imgFromDate").show();
            $('#imgToDate').show();
            return;
        }
        else if (value == 2) { //Today
            startDateDiff = 0;
            endDateDiff = 0;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 3) { //previous day
            startDateDiff = -1;
            endDateDiff = -1;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 4) {//last 7 days
            startDateDiff = -6;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 5) {//last 30 days
            startDateDiff = -29;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 6) {//last 3 Months
            startDateDiff = -89;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 7) {//last 6 Months
            startDateDiff = -179;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 8) {//last 6 Months
            startDateDiff = -364;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }

        startDate.setDate(startDate.getDate() + startDateDiff);
        endDate.setDate(endDate.getDate() + endDateDiff);

        var newStartDate = startDate.toDateString();
        newStartDate = new Date(Date.parse(newStartDate));

        var newEndDate = endDate.toDateString();
        newEndDate = new Date(Date.parse(newEndDate));

        $('#txtDateFrom').val(fncCurrentDate(newStartDate));
        $('#txtDateTo').val(fncCurrentDate(newEndDate));
        if (value == 0) {
            $('#txtDateFrom').val('');
            $('#txtDateTo').val('');
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
    }


    function applyFilter()
    {var Model = @Html.Raw(Json.Encode(Model));
        popup.LoadModalDialog('CHILD', 'TicketManager/TicketFilter', _data = { objTicketManagerFilter:Model,  childModel: "dvChildModalBody" }, "Filter", 'modal-sm');
    }
</script>

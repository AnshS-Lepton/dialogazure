    $('#btnSave').on("click", function () {
        var boundaryType = $('input[name=boundary_type]').val();
        var lstUpdateRegionProvince = [];
         
        $('#tblRegionProvinceLstInfo').find('input[type="checkbox"]:checked:not("#chkAll")').each(function () {
            lstUpdateRegionProvince.push($(this).attr("data-shapeId"));
        });
        if (lstUpdateRegionProvince.length > 0) {
             
            $("#dvFileInfoProgress").show();
            lstUpdateRegionProvince = JSON.stringify({ 'lstUpdateRegionProvince': lstUpdateRegionProvince });
            $.ajax({
                contentType: 'application/json; charset=utf-8',
                dataType: 'json',
                type: 'POST',
                url: "@Url.Action("SaveRegionProvinceShapFile", "RegionProvince")",
                data: lstUpdateRegionProvince,
                success: function (Data) {
                    $("#dvRegionProvinceFileInfo").hide();
                    $("#dvFileInfoProgress").hide();
                    $("#dvImportRegProSetting").hide();
                    $("#divRegionProvinceLogs").show();
                    $("#lblTotalLogs").html(Data.result.Total);
                    $("#lblValidLogs").html(Data.result.Valid);
                    $("#lblInvalidLogs").html(Data.result.Invalid);
                    si.refreshRegionProvince(); 
                },
                failure: function (response) {
                    $("#dvFileInfoProgress").hide();
                }
            });
        }
        else { alert('No ' + boundaryType + ' selected!') }
    });
    function checkentity(checkvalue) {
        var totalBoundaries = $("#tblRegionProvinceLstInfo tbody tr td input[type=checkbox]").length;
        var totalSelected = $("#tblRegionProvinceLstInfo tbody tr td input[type=checkbox]:checked").length;
        $('#chkAll').prop("checked", totalBoundaries == totalSelected ? true : false);
        var checkstatus = $(checkvalue).is(":checked");
        $(checkvalue)[0].value = checkstatus;
        $("#lblSelectedRecords").html($("#tblRegionProvinceLstInfo input[type=checkbox]:checked:not('#chkAll')").length);
    }
    function checkallentity(checkvalue) {
        $("#tblRegionProvinceLstInfo tbody tr td input[type=checkbox]").prop("checked", $(checkvalue).prop("checked"));
        $("#tblRegionProvinceLstInfo input[type=checkbox]:not('#chkAll')").each(function () {
            var checkstatus = $(this).is(":checked")
            $(this)[0].value = checkstatus;
        });
        $("#lblSelectedRecords").html($("#tblRegionProvinceLstInfo input[type=checkbox]:checked:not('#chkAll')").length);
    }
    function AssignTemplateValue() {
        var TemplateActionValue = $("input[name='TemplateAction']:checked").val();
        var url = appRoot + "RegionProvince/DownloadRegionProvinceUploadTemplate?BoundaryType=";
        $("#lnkDownloadTemplate").attr("href", (url + TemplateActionValue));
        $("#hdnBoundaryType").val(TemplateActionValue);
    }
    function ResetImport() {
        $('#div_regioninformation').empty();
        $("#dvRegionProvinceFileInfo").hide();
        $("#FileRegProvImport").val('');
        $("#chkRegion").prop("checked", true);
        $("#chkProvince").prop("checked", false);
        AssignTemplateValue(); 
        rpdataUploader.ResetUploadData(); 
    }
    function ShowOnMap(markervalue) {
        var boundaryType = $("#hdnBoundaryType").val().toUpperCase();
        var geomText = markervalue.previousElementSibling.value;
        si.showRegionProvinceOnMap(boundaryType, geomText);
    }
    function DrawBoundaryOnMap(DrawOnMapValue) {
        var boundaryType = $("#hdnBoundaryType").val().toUpperCase();
        si.RegionProvinceDrawOnMap.initiateDrawingsRegionProvince(DrawOnMapValue, 'Polygon', boundaryType);
    }
    function ResetDone() {
        confirm(MultilingualKey.SI_OSP_GBL_JQ_GBL_108, function () {//Logs will not be available after click on Done. Do you want to continue?
            $('#closeModalPopup').trigger("click");
        });
    }
</script>

@model Models.ModelExternalDataDetails
<link href="~/Content/css/inputpicker/jquery.inputpicker.css" rel="stylesheet" />
<style>
    #inputpicker-wrapped-list {
        max-height: 230px;
        left: 0px !important;
        top: 0px !important;
    }
    .filenm {
        height: 28px;
        border-radius: 3px;
        width: 100%;
    }
</style>

<!DOCTYPE html>
<div class="libDetail">
    <div class="libTabContent">
        <div class="form-group row">
            <div class="col-md-4 RowCol3">
                <span class="DivRowSpn"> @Resources.Resources.SI_OSP_GBL_GBL_GBL_049<i class="clsMandatory">*</i>:</span>
            </div>
            <div class="col-md-8">
                    <select id="ddlfiletype" onchange="OnFileTypeChange();" class="chosen-select">
                        <option value="Tab">Tab</option>
                        <option value="Shape">Shape</option>
                        <option value="kml_kmz">KML/KMZ</option>
                        <option value="DXF">DXF</option>
                    </select>
            </div>
        </div>
        <div class="form-group row" id="divDxfSource">
            <div class="col-md-4 RowCol3">
                <span class="DivRowSpn">Source Projection <br/> System<i class="clsMandatory">*</i>:</span>
            </div>
            <div class="col-md-8">
                <input class="form-control" id="ddldxfSource" value="--Select--">
                <div id="demo-input-picker" style="position:relative;">
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-md-4 ColM3">
                <span class="DivRowSpn"> @Resources.Resources.SI_OSP_GBL_NET_FRM_107<i class="clsMandatory">*</i>:</span>
            </div>
            <div class="col-md-8">
                <input type="text" id="txtfilename" class="form-control filenm" name="txtfilename" maxlength="25" placeholder="@Resources.Resources.SI_OSP_GBL_NET_FRM_107" />
            </div>
        </div>
        <div class="form-group row">
            <div class="col-md-4 ColM3">
                <span class="DivRowSpn"> @Resources.Resources.SI_OSP_GBL_NET_FRM_075<i class="clsMandatory">*</i>:</span>
            </div>
            <div class="col-md-8">
                <span class="btn btn-file" style="width: 100%;overflow: hidden;background: white;color: #636262;border: 1px solid #aaa; font-weight:normal;">
                    <span><input type="file" id="fupload" accept=".kml,.kmz" style="width:100%" /></span>
                </span>

            </div>

        </div>
        <div class="form-group row">
            <div class="col-md-4 RowCol3">
                <span class="DivRowSpn"> @Resources.Resources.SI_OSP_GBL_NET_FRM_108<i class="clsMandatory">*</i>:</span>
            </div>
            <div class="col-md-8">
                <div>
                    <label class="Custom_Radio_Buttons">
                        <input type="radio" id="rdbpublic" name="rdbAccess" value="Public" checked> 
                        <span class="checkmark"> 
                            <spam class="fu--radioBtn">@Resources.Resources.SI_OSP_GBL_GBL_GBL_037</spam>
                        </span>
                    </label>
                    <label class="Custom_Radio_Buttons">
                        <input type="radio" id="rdbprivate" name="rdbAccess" value="Private"> 
                        <span class="checkmark"> 
                            <spam class="fu--radioBtn">@Resources.Resources.SI_OSP_GBL_NET_FRM_109</spam>
                        </span>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="ModalFooter d-flex" id="dvBtnAction">
        <a href="javascript:void(0);" class="btn btn-default ml-auto" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
        <button class="btn btn-success ml-10" type="button" onclick="extnldata.uploadExternalData();"> @Resources.Resources.GBL_GBL_GBL_GBL_GBL_008 </button>
    </div>
    <div class="clearfix"></div>
</div>
<script>
    $(document).ready(function () {
        $('#ddlfiletype').val('kml_kmz').trigger('chosen:updated');
        $('.chosen-select').chosen({ width: '100%' });
        $('#divDxfSource').hide();
        $('#fupload').on("click", function () {
            
            switch ($("#ddlfiletype").val().toLowerCase()) {
                case "shape":
                    $(this).attr("accept", ".shp,.dbf,.prj,.shx").attr("multiple", "true");
                    break;
                case "tab":
                    $(this).attr("accept", ".tab,.id,.map,.dat").attr("multiple", "true");
                    break;
                case "kml":
                case "kmz":
                case "kml_kmz":
                    $(this).attr("accept", ".kml,.kmz").removeAttr("multiple");
                    break;
                case "dxf":
                    $(this).attr("accept", ".dxf").removeAttr("multiple");

            }
        })
    });
    function OnFileTypeChange() {
        $("#fupload").val('');
        var _templateType = $('#ddlfiletype :selected').val();
        if (_templateType == "DXF") {
            $('#divDxfSource').show();
            ajaxReq('datauploader/getDxfSourceList', null, true, function (response) {
                 

                var result = $.parseJSON(response);

                $('#ddldxfSource').inputpicker({
                    data: result,
                    //fields: ['epsg', 'aoi', 'dsname'],
                    fields: [
                        { name: 'epsg', text: 'Epsg' },
                        { name: 'dsname', text: 'Name' },
                      
                        { name: 'aoi', text: 'Area' }
                    ],
                    fieldText: 'aoi',
                    fieldValue: 'epsg',
                    filterOpen: true,
                    autoOpen: true,
                    width: '100%',
                    height: '200px'
                });
                // $('#inputpicker-1').val("--Select--");
                $('#inputpicker-1').val("");


            }, false, true);
        }
        else {
            $('#divDxfSource').hide();
        }
    }

</script>


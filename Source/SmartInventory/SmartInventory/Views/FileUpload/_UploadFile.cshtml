@model Models.ModelExternalDataDetails
@using SmartInventory.Settings;
<!DOCTYPE html>
<div class="libDetail">
    <div class="libTabs">
        <ul class="nav nav-tabs tabs-left">
            @*<li class="active"><a href="#UploadImage" data-toggle="tab">@Resources.Resources.SI_OSP_UPP_NET_FRM_001</a></li>
                <li><a href="#UploadAttachment" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_192</a></li>
                <li><a href="#UploadRefLink" data-toggle="tab">Ref. Link</a></li>*@
            <li class="@(Model.lstUserModule.Contains("ENT-UID-I")?"active":"roledisabled")" title="@Resources.Resources.SI_OSP_UPP_NET_FRM_001 @(Model.lstUserModule.Contains("ENT-UID-I")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-UID-I") ? "" : "block;")"><a href="@(Model.lstUserModule.Contains("ENT-UID-I")?"#UploadImage":"")" data-toggle="tab">@Resources.Resources.SI_OSP_UPP_NET_FRM_001</a></li>
            <li class="@(Model.lstUserModule.Contains("ENT-UID-D")?"":"roledisabled")" title="@Resources.Resources.SI_OSP_GBL_NET_FRM_192 @(Model.lstUserModule.Contains("ENT-UID-D")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-UID-D") ? "" : "block;")"><a href="@(Model.lstUserModule.Contains("ENT-UID-D")?"#UploadAttachment":"")" data-toggle="tab">@Resources.Resources.SI_OSP_GBL_NET_FRM_192</a></li>
            <li class="@(Model.lstUserModule.Contains("ENT-UID-RL")?"":"roledisabled")" title="Ref. Link @(Model.lstUserModule.Contains("ENT-UID-RL")? "" : Resources.Resources.GBL_GBL_GBL_GBL_GBL_021)" style="display:@(Model.lstUserModule.Contains("ENT-UID-RL") ? "" : "block;")"><a href="@(Model.lstUserModule.Contains("ENT-UID-RL")?"#UploadRefLink" :"")" data-toggle="tab">Ref. Link</a></li>
        </ul>
    </div>
    <input type="hidden" id="hdnMaxFileUploadSizeLimit" value="@ApplicationSettings.MaxFileUploadSizeLimit" />
    <input type="hidden" id="fdnMaxFileCountLimit" value="@ApplicationSettings.MaxFileCountLimit" />
    <input type="hidden" id="allowedDocumentAttachmentType" value="@ApplicationSettings.validDocumentTypes" />
    <input type="hidden" id="allowedImageAttachmentType" value="@ApplicationSettings.validImageTypes" />
    <div class="libTabContent pad-0">
        <!-- Tab panes -->
        <div class="tab-content">
            <div class="tab-pane active" id="UploadImage">
                <div class="space-pad">
                    <fieldset class="@(Model.lstUserModule.Contains("ENT-UID-I")?"the-fieldset":"the-fieldset dvdisabled")">
                        <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_NET_FRM_193</legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtCableCode">@Resources.Resources.SI_OSP_UPP_NET_FRM_001:</label>
                            <div class="col-md-10">
                                <input type="file" name="fuImgUpload" id="fuImgUpload" accept=".bmp,.gif,.png,.jpg,.jpeg,.zip" multiple>
                            </div>
                        </div>
                        <div class="form-group d-flex">
                            <label class="control-label ml-auto flex-cont" for="txtCableCode"><i class="clsMandatory">*</i>Supported file formats:bmp,gif,png,jpg,jpeg</label>
                        </div>
                        <div class="form-group d-flex">
                            <label class="ml-auto flex-cont" for="txtLatitude"><i class="clsMandatory">*</i>Maximum image file size: @(ApplicationSettings.MaxFileUploadSizeLimit/1000) MB</label>
                        </div>
                    </fieldset>
                </div>
                <div class="d-flex ModalFooter" id="dvBtnAction">
                    <a href="javascript:void(0);" class="btn btn-default ml-auto" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                    @*<button type="submit" class="btn btn-primary ml-10" onclick="si.uploadMultipleImageFile();" id="btnSaveFile">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>*@
                    <button type="submit" class="btn btn-primary ml-10" onclick="si.uploadMultipleImageFile();" id="btnSaveFile">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
                </div>
            </div>
            <div class="tab-pane" id="UploadAttachment">
                <div class="space-pad">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">@Resources.Resources.SI_OSP_GBL_NET_FRM_194</legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="txtCableCode">
                                @Resources.Resources.SI_OSP_GBL_NET_FRM_192:
                            </label>
                            <div class="col-md-10">
                                <input type="file" name="fuAttachmentUpload" id="fuAttachmentUpload" multiple>
                            </div>
                        </div>
                        <div class="form-group d-flex">
                            <label class="control-label ml-auto flex-cont" for="txtCableCode"><i class="clsMandatory">*</i>Supported file formats:dwg,pdf,jpeg,jpg,doc,docx,xls,xlsx,csv,vsd,ppt,pptx,png,htm,html,rar,zip,msg</label>
                        </div>
                        <div class="form-group d-flex">
                            <label class="ml-auto flex-cont" for="txtLatitude"><i class="clsMandatory">*</i>Maximum document file size: @(ApplicationSettings.MaxFileUploadSizeLimit/1000) MB</label>
                        </div>
                    </fieldset>
                </div>
                <div class="d-flex ModalFooter" id="dvBtnAction">
                    <a href="javascript:void(0);" class="btn btn-default ml-auto" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                    <button type="submit" class="btn btn-primary ml-10" onclick="si.uploadMultipleDocumentFile();" id="btnSaveDocumentFile">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
                </div>
            </div>

            <div class="tab-pane" id="UploadRefLink">
                <div class="space-pad">
                    <fieldset class="the-fieldset">
                        <legend class="the-legend">Upload Reference Link</legend>
                        <div class="form-group row">
                            <label class="control-label col-sm-4" for="DocrefLinkText">
                                Display Name:<i class="clsMandatory">*</i>
                            </label>
                            <div class="col-sm-8">
                                <input type="text" id="DocrefLinkText" class="form-control" maxlength="190">
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-4" for="DocrefLink">
                                Reference Link:<i class="clsMandatory">*</i>
                            </label>
                            <div class="col-sm-8">
                                <input type="text" id="DocrefLink" class="form-control" placeholder="http or https://www.xyz.com" maxlength="498">
                            </div>
                        </div>
                    </fieldset>
                </div>
                <div class="d-flex ModalFooter" id="dvBtnActionRefLink">
                    <a href="javascript:void(0);" class="btn btn-default ml-auto" data-dismiss="modal" id="btnCancel">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_006</a>
                    <button type="submit" class="btn btn-primary ml-10" onclick="si.uploadRefLink();" id="btnSaveRefLink">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
                </div>
            </div>
        </div>
    </div>
</div>

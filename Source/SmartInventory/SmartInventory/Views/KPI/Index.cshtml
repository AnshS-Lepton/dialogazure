using Models.KPIMaster;
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
@{
    var kpi_data = Model.KPI_Master_Json;
    var kpi_temp_details = Model.kpi_Template != "" ? Model.kpi_Template : "";

}
<div id="dvPageMessage">

</div>
<div id="dvInfoVendor" class="update_panel">

    <div id="" class="title">
        <h4>KPI</h4>
    </div>
    <div class="pad_left">
        <div class="form-group">
            <div class="row align-items-center">
                <label class="col-md-1 mr-01">
                    KPI Category
                </label>
                <div class="col-md-3">
                    <select class="form-control" id="ddlKPICategory" onchange="BindKPI(this.value);"></select>
                </div>
                <label class="col-md-1">
                    KPI Name
                </label>
                <div class="col-md-3">
                    <select class="form-control" id="ddlKPIName" onchange="BindXYValues()"><option>Select</option></select>
                </div>
                <div class="col-md-1 pl-0">
                    <button class="btn btn-danger allBtn" onclick="location.reload(true);">
                        Reset
                    </button>
                </div>
            </div>

        </div>
        <div class="operations">
            <div class="operations__tab-container">
                <button class="tabBtn operations__tab operations__tab--1 operations__tab--active" data-tab="1" id="tableview" onclick="showExcelButton()">
                    Tabular View
                </button>
                <button class="tabBtn operations__tab operations__tab--2" data-tab="2" id="chartview" onclick="showExcelButton()">
                    Graphical View
                </button>
                <a href="javascript:void();" class="poseBtn" id="btnExcelData" onclick="fnDownloadKPIData();" style="display:none;">
                    <img src="~/images/excel.svg" />
                </a>
            </div>
            <div class="operations__content operations__content--1 operations__content--active">
                @*<div id="grdKPI">  @Html.AjaxGrid(Url.Action("KPIList"))</div>*@
            </div>

            <div class="operations__content operations__content--2">
                <div class="form-group">
                    <div class="row align-items-center" id="chartFilter" style="display:none;">
                        <label class="col-md-1">
                            X-Axis
                        </label>
                        <div class="col-md-2">
                            <select class="form-control" id="XAxisFieldName" onchange="resetYAxisdata(this.value)">
                                <option>Select</option>
                            </select>
                        </div>
                        <label class="col-md-1">
                            Y-Axis
                        </label>
                        <div class="col-md-6">
                            <select class="form-control chosen-select" id="YAxisFieldName" multiple>
                                <option>Select</option>
                            </select>
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-primary btn-small" id="btnDrawChart" onclick="showchart()">Draw Chart</button>
                            @*<a href="javascript:void(0)" id="btnSaveTemplate" class="addCate fw-60">+</a>*@
                        </div>
                    </div>
                </div>
                <div id="chartContainer"></div>
            </div>
        </div>
    </div>
</div>
<div class="widgets__col" id="tblContainer" style="display:none;"></div>
<div class="modalPopup" id="popupBox">
    <div class="hpad d-flex">
        <div class="widgets__col--head" id="popupHeading"></div>
        <a href="#" class="closeBox">X</a>
    </div>
    <div id="popbody" class="popPadd pb-0">
    </div>

    <div class="d-flex widgets__col--fotter" id="chartContainer1"></div>
</div>

<div class="modalPopup" id="btnSaveTemplatepp" style="width:33%">
    <div class="title d-flex">
        <h4>Add Template</h4>
        <a href="#" class="closeBox">X</a>
    </div>
    <div id="SaveTemplateID">
        @{
            Html.RenderPartial("_AddTemplate");
        }
    </div>

</div>


@section Scripts{

    <script type="text/javascript">

        BindKPICategory();
        const tabContainer = document.querySelector('.operations__tab-container');
        const tabs = document.querySelectorAll('.operations__tab');
        const tabContent = document.querySelectorAll('.operations__content');

        tabContainer.addEventListener('click', function (el) {
            const punch = el.target.closest('.operations__tab');
            if (!punch) return;

            tabs.forEach(t => t.classList.remove('operations__tab--active'));
            tabContent.forEach(c => c.classList.remove('operations__content--active'));

            punch.classList.add('operations__tab--active');

            document
                .querySelector(`.operations__content--${punch.dataset.tab}`)
                .classList.add('operations__content--active');
        });
    </script>
    <script type="text/javascript">
        var chartresponse = null;
        var jsonObj = null;
        $(document).ready(function () {
            //btnSaveTemplate
            //$(document).on('click', '.closeBox', function () {
            //    $('#popupBox').toggleClass('showHide');
            //})

            google.charts.load('current', { 'packages': ["corechart", "bar", "table"] });

        });

        $('.closeBox').click(function () {
            $('.modalPopup').removeClass('showHide')
        });

    </script>
}
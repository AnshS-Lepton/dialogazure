                <div class="row form-group">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_067  :</div>
                    <div class="col-md-9">
                        @*@Html.DropDownListFor(m => m.objReportFilters.SelectedNetworkStatus, new List<SelectListItem>

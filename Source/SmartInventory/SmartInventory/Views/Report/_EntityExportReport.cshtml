@model Models.ExportEntitiesReportNew
@using System.Globalization;
@{
    string[] arrSelectedNetworkStatus = Model.objReportFilters.SelectedNetworkStatus == null ? new string[3] { "Planned", "As Built", "Dormant" } : Model.objReportFilters.SelectedNetworkStatus.ToArray();
    var planned_count = 0;
    var asbuilt_count = 0;
    var dormant_count = 0;
    var total_count = 0;
}
@using SmartInventory.Settings;
<input type="hidden" id="reportTypes" name="reportTypes" />

<style>
    .table-scroll {
        position: relative;
        width: 100%;
        z-index: 1;
        margin: auto;
        overflow: auto;
        height: 415px;
    }

    .table-wrap {
        position: relative;
    }

    .table-scroll thead th {
        /*  background: #00ba8a;*/
        color: #fff;
        position: -webkit-sticky;
        position: sticky;
        top: -1px;
    }
    /* safari and ios need the tfoot itself to be position:sticky also */
    .table-scroll tfoot,
    .table-scroll tfoot th,
    .table-scroll tfoot td {
        position: -webkit-sticky;
        position: sticky;
        bottom: 0;
        z-index: 4;
    }

    /*.table-scroll a{
        background: #00ba8a;
    }*/

    th:first-child {
        position: -webkit-sticky;
        position: sticky;
        left: 0;
        z-index: 2;
    }

    thead th:first-child, thead th:last-child,
    tfoot th:first-child {
        z-index: 5;
    }

    #tblSummaryAll > tfoot > tr > th {
        padding: 3px;
    }

    .calendar {
        top: 225px !important;
        left: 500px !important;
    }

    .checkbox-custom-label {
        position: inherit !important;
    }

    .tablePad-bn .form-control {
        height: 28px;
    }

    .tablePad-bn .dropbox {
        top: 40px;
    }

    .tablePad-bn .chosen-container {
        min-width: 100px;
    }

    .modal-md-new {
        width: 600px;
    }
</style>

<!DOCTYPE html>
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />
<div class="exportReportHeader">
    <ul id="ulRptTabs" class="tab">
        <li id="liFilter" class="tablinks activerpt" onclick="SwitchReportTabs(this.id, 'divFilter')"><i>1</i>@Resources.Resources.SI_OSP_GBL_NET_FRM_063</li>
        <li id="liSummary" class="tablinks" onclick="SwitchReportTabs(this.id, 'divSummary')"><i>2</i>@Resources.Resources.SI_OSP_GBL_NET_FRM_064</li>
    </ul>
</div>

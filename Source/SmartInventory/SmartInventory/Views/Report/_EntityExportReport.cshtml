    function ManageHeaderCheckBox() {
        if ($("#tblSummaryAll input[type=checkbox]:not('#checkallentity')").length ==
            $("#tblSummaryAll input[type=checkbox]:not('#checkallentity'):checked").length) {
            $("#thtotalName")[0].innerHTML = MultilingualKey.SI_OSP_GBL_GBL_GBL_041;
            $("#checkallentity").prop("checked", true);
        }
        else if ($("#tblSummaryAll input[type=checkbox]:not('#checkallentity'):checked").length == 0) {
            $("#thtotalName")[0].innerHTML = MultilingualKey.SI_OSP_GBL_GBL_GBL_041;
        }
        else {
            $("#thtotalName")[0].innerHTML = MultilingualKey.SI_GBL_GBL_JQ_FRM_028;// "Selected Total";
            $("#checkallentity").prop("checked", false);
        }

        //for sum of footer
        var plannedTotal = parseInt(0);
        var asBuildTotal = parseInt(0);
        var dormantTotal = parseInt(0);
        $("#tblSummaryAll input[type=checkbox]:not('#checkallentity')").each(function () {
            var row = $(this).closest('tr');
            var checkstatus = $(this).is(":checked")
            if (row.find(".tdplannedcount")[0] != undefined) {
                var plannedText = (row.find(".tdplannedcount")[0].innerText).replaceAll(',', '');
                if (!isNaN(plannedText) && row.find(".tdplannedcount")[0].innerText.length != 0 && checkstatus == true) {
                    plannedTotal += parseInt(plannedText);
                }
            }
            if (row.find(".tdasbuiltcount")[0] != undefined) {
                var asbuildText = (row.find(".tdasbuiltcount")[0].innerText).replaceAll(',', '');
                if (!isNaN(asbuildText) && row.find(".tdasbuiltcount")[0].innerText.length != 0 && checkstatus == true) {
                    asBuildTotal += parseInt(asbuildText);
                }
            }
            if (row.find(".tddormantcount")[0] != undefined) {
                var asdormantText = (row.find(".tddormantcount")[0].innerText).replaceAll(',', '');
                if (!isNaN(asdormantText) && row.find(".tddormantcount")[0].innerText.length != 0 && checkstatus == true) {
                    dormantTotal += parseInt(asdormantText);
                }
            }
        })
        if ($("#thplannedtotal")[0] != undefined) {
            $("#thplannedtotal")[0].innerHTML = plannedTotal;
        }
        if ($("#thasbuilttotal")[0] != undefined) {
            $("#thasbuilttotal")[0].innerHTML = asBuildTotal;
        }
        if ($("#thdormanttotal")[0] != undefined) {
            $("#thdormanttotal")[0].innerHTML = dormantTotal;
        }
        $("#thalltotal")[0].innerHTML = (plannedTotal + asBuildTotal + dormantTotal);
        UpdateFormattedNumbers();
    }

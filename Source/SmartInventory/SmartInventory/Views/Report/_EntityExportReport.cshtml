                            }
                        </select>
                    </div>
                </div>
                @*<div class="row form-group">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_020:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedLayerId, new SelectList(Model.lstLayers.Select(x => new { Value = x.layer_id.ToString(), Text = x.layer_title.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlLayers" })
                        </div>
                    </div>*@
                @*<div class="row form-group">
                        <div class="col-md-3">@Resources.Resources.SI_GBL_GBL_GBL_GBL_009:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedOwnerShipId, new SelectList(Model.listOwnership.Select(x => new { Value = x.dropdown_key.ToString(), Text = x.dropdown_value.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlFilterOwnershipType" })
                        </div>
                    </div>*@

                <div class="row form-group">
                    <div class="col-md-3">@Resources.Resources.SI_GBL_GBL_GBL_GBL_147</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.SelectedOwnerShipType, new List<SelectListItem>
                                {
                                        new SelectListItem { Text = "Own", Value = "Own"},
                                        new SelectListItem { Text = "Third Party", Value = "Third Party"},
                                }, new { @class = "chosen-select", @id = "ddlFilterOwnershipType", @onchange = "onChangeOwnershipType()" })
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-md-3">@Resources.Resources.SI_GBL_GBL_GBL_GBL_148</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.SelectedThirdPartyVendorId, new SelectList(Model.list3rdPartyVendorId.Select(x => new { Value = x.key, Text = x.value }), "Value", "Text"), new { @multiple = "multiple", @disabled = "disabled", @class = "chosen-select form-control ", id = "ddl3rdPartyVendor" })
                    </div>
                </div>
                @if (Model.lstUserModule.Contains("PROJ"))
                {
                    <div class="row form-group">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_070:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedProjectId, new SelectList(Model.lstBindProjectCode.Select(x => new { Value = x.system_id.ToString(), Text = x.project_code.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlProjectCode" })
                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_008:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedPlanningId, new SelectList(Model.lstBindPlanningCode.Select(x => new { Value = x.system_id.ToString(), Text = x.planning_code.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlPlanningCode" })
                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_009:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedWorkOrderId, new SelectList(Model.lstBindWorkorderCode.Select(x => new { Value = x.system_id.ToString(), Text = x.workorder_code.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlWorkorderCode" })
                        </div>
                    </div>
                    <div class="row form-group">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_011:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedPurposeId, new SelectList(Model.lstBindPurposeCode.Select(x => new { Value = x.system_id.ToString(), Text = x.purpose_code.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlPurposeCode" })
                        </div>
                    </div>
                }
                <div class="row form-group">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_071<i class="clsMandatory">*</i>:</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.durationbasedon, new SelectList(Model.lstDurationBasedOn.Select(x => new { Value = x.dropdown_key.ToString(), Text = x.dropdown_value.ToString() }), "Value", "Text"), new { @class = "chosen-select col-sm-12", @id = "ddlDurationBasedOn" })
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_072<i class="clsMandatory">*</i>:</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.customDate, new List<SelectListItem>{
                                new SelectListItem { Text = "All", Value = "9"},
                                new SelectListItem { Text = "Custom", Value = "1"},
                                new SelectListItem { Text = "Today", Value = "2"},
                                new SelectListItem { Text = "Previous Day", Value = "3"},
                                new SelectListItem { Text = "Last 7 Days", Value = "4"},
                                new SelectListItem { Text = "Last 30 Day", Selected=true, Value = "5"},
                                new SelectListItem { Text = "Last 3 Months", Value = "6"},
                                new SelectListItem { Text = "Last 6 Months", Value = "7"},
                              new SelectListItem { Text = "Last 1 Year", Value = "8"},

                            }, new { @class = "chosen-select", @onchange = "onChangeCustomDate();", @id = "customedate" })
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-md-3"></div>
                    <div class="col-md-9" style="display:flex">
                        <div class="col-md-6" style="padding:0px;padding-right: 6px;">
                            @Html.TextBoxFor(m => m.objReportFilters.fromDate, new { @id = "txtDateFrom", @title = Resources.Resources.SI_OSP_GBL_NET_FRM_096, @tabindex = "4", @class = "input-sm form-control", @readonly = true, @placeholder = Resources.Resources.SI_OSP_GBL_NET_FRM_096 })
                            <img id="imgFromDate" class="export-report-cal" src="@Url.Content("~/Content/images/calendar.png")" style="right: 12px;">
                        </div>
                        <div class="col-md-6" style="padding:0px;">
                            @Html.TextBoxFor(m => m.objReportFilters.toDate, new { @id = "txtDateTo", @title = Resources.Resources.SI_OSP_GBL_NET_FRM_097, @tabindex = "4", @class = "input-sm form-control", @readonly = true, @placeholder = Resources.Resources.SI_OSP_GBL_NET_FRM_097 })
                            <img id="imgToDate" class="export-report-cal" src="@Url.Content("~/Content/images/calendar.png")">
                        </div>
                    </div>
                </div>
            </div>
            <div class="ModalFooter d-flex">
                <button type="button" class="btn btn-default ml-auto" id="btnEntityExportClear">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_005</button>
                <button type="submit" class="btn btn-success ml-10" id="btnShowReportData">@Resources.Resources.SI_OSP_GBL_GBL_GBL_040</button>
            </div>
        </div>
        <div class="EEReport Summary" id="divSummary">
            <div id="dvReportProgress" class="ExportReportProgress"></div>

            @if (Model.lstReportData.Count > 0)
            {
                <div class="tablePad-bn d-flex mb-15">
                    <div class="fw-bold">@Resources.Resources.SI_OSP_GBL_GBL_GBL_035:<span data="spanTotalRowCount"> @Model.lstReportData.Count</span></div>
                    <div class="ml-auto d-flex --gap05">
                        <div class="d-flex --gap05">
                            <label class="white-space">Report Attributes</label>
                            @Html.DropDownListFor(m => m.objReportFilters.reportType, new List<SelectListItem>{
        @*new SelectListItem { Text = "All", Value = "ALL"},*@
new SelectListItem { Text = "Gis Attribute", Value = "GIS"},
new SelectListItem { Text = "CDB Attribute", Value = "CDB"},
new SelectListItem { Text = "Additional Attribute", Value = "ADDITIONAL"},

}, new { @multiple = "multiple", @class = "chosen-select form-control", @id = "reportType" })
                        </div>

                        <div>
                            <button type="button" class="btn btn-default dropfiles">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_010 <i class="fa fa-chevron-down" aria-hidden="true"></i></button>


                            <div class="dropbox">

                                @foreach (var item in Model.lstfiletypes)
                                {
                                    <span onclick="ExportSummaryDetail('@item.file_type')">@item.file_display_name</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div id="dvReportProgress1" class="progress utili-prog-bar" style="display:none;">
                        <div class="progress-bar progress-bar-striped" style="width:70%;background-color: darkgreen;">@Resources.Resources.SI_OSP_GBL_NET_FRM_073</div>
                    </div>
                </div>
            }
            <div class="expPad_LefRig">
                <div class="overAuto exptReptHei table-scroll">
                    @if (Model.lstReportData.Count > 0)
                    {
                        <table class="grid" id="tblSummaryAll">
                            <thead>
                                <tr>
                                    <th scope="col">
                                        <input type="checkbox" checked="checked" class="checkbox-custom" id="checkallentity" onclick="selectallentity(this)"><b><label for="checkallentity" class="checkbox-custom-label"></label></b>
                                    </th>
                                    <th scope="col">@Resources.Resources.SI_OSP_GBL_NET_GBL_008</th>

                                    @foreach (var item in Model.lstNetworkStatus)
                                    {
                                        var Nwitem = (item.dropdown_value.ToString() == "DORMANT" ? "Dormant" : item.dropdown_value.ToString());
                                        <th align="center" scope="col">@CultureInfo.InvariantCulture.TextInfo.ToTitleCase(Nwitem.ToLower().Contains("built") ? Nwitem.ToLower().Replace(" ", "-") : Nwitem.ToLower())</th>
                                    }
                                    <th style="width: 54px;" scope="col">@Resources.Resources.SI_OSP_GBL_GBL_GBL_028</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.lstReportData)
                                {
                                    var chkid = item.entity_id;
                                    var recordCounts = 0;
                                    <tr>

                                        <td><input type="checkbox" checked="checked" class="checkbox-custom chksingle" id="@chkid" onclick="ManageHeaderCheckBox()"><b><label for="@chkid" class="checkbox-custom-label"></label></b></td>
                                        <td>@item.entity_title</td>
                                        @foreach (var eitem in Model.lstNetworkStatus)
                                        {
                                            if (eitem.dropdown_value.ToString().ToUpper() == "PLANNED")
                                            {
                                                planned_count += item.planned_count;
                                                recordCounts += item.planned_count;
                                                <td align="center" class="tdplannedcount">@item.planned_count</td>
                                            }
                                            if (eitem.dropdown_value.ToString().ToUpper() == "AS-BUILT")
                                            {
                                                asbuilt_count += item.as_built_count;
                                                recordCounts += item.as_built_count;
                                                <td align="center" class="tdasbuiltcount">@item.as_built_count</td>
                                            }
                                            if (@SmartInventory.Settings.ApplicationSettings.IsDormantEnabled)
                                            {
                                                if (eitem.dropdown_value.ToString().ToUpper() == "DORMANT")
                                                {
                                                    dormant_count += item.dormant_count;
                                                    recordCounts += item.dormant_count;
                                                    <td align="center" class="tddormantcount">@item.dormant_count</td>

                                                }
                                            }
                                        }
                                        <td>
                                            <a href="#" onclick="si.ExportEntitySummaryView('@item.entity_name');" class="dropdown-toggle @(recordCounts == 0 ? "btnNotAllowed" : "")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_042">
                                                @*@item.entity_name.Replace(" ", "")*@
                                                <i class="glyphicon glyphicon-eye-open"></i>
                                            </a>

                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th align="center" colspan="2" id="thtotalName">@Resources.Resources.SI_OSP_GBL_GBL_GBL_041</th>

                                    @foreach (var item in Model.lstNetworkStatus)
                                    {
                                        //var count = 0;
                                        //count = item.ToLower() == "planned" ? planned_count : item.ToLower() == "as built" ? asbuilt_count : item.ToLower() == "dormant" ? dormant_count : 0;
                                        if (item.dropdown_value.ToLower() == "planned")
                                        {
                                            <th align="center" id="thplannedtotal">@planned_count</th>
                                        }
                                        if (item.dropdown_value.ToLower() == "as-built")
                                        {
                                            <th align="center" id="thasbuilttotal">@asbuilt_count</th>
                                        }
                                        if (@SmartInventory.Settings.ApplicationSettings.IsDormantEnabled)
                                        {
                                            if (item.dropdown_value.ToLower() == "dormant")
                                            {
                                                <th align="center" id="thdormanttotal">@dormant_count</th>
                                            }
                                            total_count = planned_count + asbuilt_count + dormant_count;
                                        }
                                        else { total_count = planned_count + asbuilt_count; }

                                    }
                                    <th align="center" id="thalltotal">@total_count</th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="nr-found">
                            <span>@Resources.Resources.SI_OSP_GBL_GBL_RPT_001</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<script src="~/Content/js/Utility.js"></script>

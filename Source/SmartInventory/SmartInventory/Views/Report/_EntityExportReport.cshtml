                <div class="row form-group">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_068:</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.SelectedParentUser, new SelectList(Model.lstParentUsers.Select(x => new { Value = x.user_id.ToString(), Text = x.user_name.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlParentUsers", @onchange = "si.onChangeParentUser();" })
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_069:</div>
                    <div class="col-md-9">
                        @*@Html.DropDownListFor(m => m.objReportFilters.SelectedUserId, new SelectList(Model.lstUserReport.Select(x => new { Value = x.user_id.ToString(), Text = x.user_name.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlUsers" })*@

                        @*<select id="ddlUsers" class="chosen-select col-sm-12" multiple name="objReportFilters.SelectedUserId">
                            @{
                                var groupName = "";
                                var count = 0;
                            }

                            @foreach (var attribute in Model.lstUserReport)
                            {
                                count = count + 1;
                                if (groupName != attribute.groupUser && attribute.groupUser == "Others")
                                {

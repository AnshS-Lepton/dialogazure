@using SmartInventory.Settings;
@model Models.PODMaster
<style>

    .btn {
        font-weight: bold !important;
        line-height: 1.42857143 !important;
    }

    .icon-kmldownload {
        font-size: 20px;
    }

    .sitePlan_fieldset {
        padding: 0.5rem 1rem 1rem;
        border: 1px solid #CCCCCC;
        margin-bottom: 1rem;
        border-radius: 4px;
    }

        .sitePlan_fieldset legend {
            width: auto;
            border-bottom: none;
            padding-block: 0.5rem;
            margin-bottom: 0;
        }

    .pose-plus {
        position: absolute;
        right: 9px;
        top: 1px;
        z-index: 9;
    }

    .txtdesc {
        width: 469px;
    }

    #dvregionId .chosen-container, #dvringId .chosen-container {
        width: 84% !important;
        margin-left: 20px;
    }

    #dvregionId .btn, #dvringId .btn {
        padding: 4px 6px;
    }
</style>

<!DOCTYPE html>
<div class="libDetail" id="topologyid">



                            "<td>" + RingName + "</td>" +
                            "<td>" + extractedValue + "</td>" +
                            "</tr>";

                        $tbody.append(row);
                    }

                    // Show or hide the table based on data availability
                    if ($tbody.children().length > 0) {
                        $dvsiteTable.show();
                        $table.show(); // Show table if data exists
                        $table.addClass("grid"); // Show table if data exists
                    } else {
                        $dvsiteTable.hide();
                        $table.hide(); // Hide table if no data
                    }
                }




            });

            var childrenlength = $tbody.children().length;
            // Show or hide the table based on data availability
            if ($tbody.children().length > 0) {
                $table.removeClass("hidden");
                $dvsiteTable.removeClass("hidden");
                $table.addClass("grid"); // Show table if data exists
            } else {
                $table.addClass("hidden");
                $dvsiteTable.addClass("hidden");
            }
        }

        function getSiteListItemRingwise(isfresh = false) {
    var $dvsiteTable = $("#dvsiteTable");
    var $table = $("#siteTable");
    var $tbody = $table.find("tbody");

    // Clear previous data
            $tbody.empty();

    $table.addClass("hidden");
    $dvsiteTable.addClass("hidden");

            var selectedRingId = $("#ddlringtype").val(); // Get selected value
            var selectedRing = $("#ddlringtype option:selected").text(); // Get selected value
            if (selectedRing !="--Select Ring Type--")
            $("#lbdringsiteId").text(selectedRing).css("display", "block");
    var visibleCount = 0;
    var secondaryVisibleCount = 0;
    var thirdCount = 0;

    var $dropdownA = $("#ddlRingASite");
            var $dropdownB = $("#ddlRingBSite");
            var $ddlOtherRingSite = $("#ddlOtherRingSite");
            var ddltopologytype = $("#ddltopologytype").val();

            function filterDropdownOptions($dropdown, condition, hideOthers = true, isfresh  = true) {

                if (isfresh) {
                    $dropdown.find("option").each(function () {
                        var ringId = $(this).attr("data-ringid");
                        debugger;
                        if ((ddltopologytype == "Dual Home" || ddltopologytype == "Linear") && condition != "0" && (ringId === condition || ringId === "" || ringId === undefined))
                        {
                            $(this).show();
                            if (hideOthers) visibleCount++;
                        }
                        else if (ddltopologytype != "Dual Home" && (ringId === "0" || ringId === "" || ringId === undefined)) {
                            $(this).show();
                            if (hideOthers) visibleCount++;
                        } else {
                            $(this).hide();
                        }
                    });
                }
                else {
                    $dropdown.find("option").each(function () {
                        var ringId = $(this).attr("data-ringid");
                        debugger;
                        if (ddltopologytype == "Dual Home" && condition !="0" && (ringId === condition || ringId === "" || ringId === undefined)) {
                            $(this).show();
                            if (hideOthers) visibleCount++;
                        }
                        else if (ddltopologytype != "Dual Home" && (ringId === condition || ringId === "0" || ringId === "" || ringId === undefined)) {
                            $(this).show();
                            if (hideOthers) visibleCount++;
                        } else {
                            $(this).hide();
                        }
                    });
                }
        
    }

            debugger;
    //--- Start Case First ---
            if (!isfresh) {
                filterDropdownOptions($dropdownA, selectedRingId, true, isfresh);
                filterDropdownOptions($dropdownB, selectedRingId, false, isfresh);
            }
            else {
                filterDropdownOptions($dropdownA, selectedRingId, true, isfresh);
                filterDropdownOptions($dropdownB, selectedRingId, false, isfresh);
            }
    //--- End Case First ---

            debugger;
    //--- Start Case Second ---
    if (visibleCount === 1 && !isfresh) {
        filterDropdownOptions($dropdownA, "0", true, isfresh);
        filterDropdownOptions($dropdownB, "0", false, isfresh);
        if (visibleCount==2)
        secondaryVisibleCount++;
    }
    //--- End Case Second ---
            debugger;
    //--- Start Case Third ---
            if ((ddltopologytype == "Dual Home" && visibleCount == 1) || (secondaryVisibleCount === 1 || isfresh)) {
        $ddlOtherRingSite.find("option").each(function () {
            var ringId = $(this).attr("data-ringid");
            if (ringId !== selectedRingId && ringId !== "0" && ringId !== "" || ringId === undefined) {
                $(this).show();
                thirdCount++;
            } else {
                $(this).hide();
            }
        });
       
    }

            if (thirdCount > 1 && selectedRingId !== null || isfresh) {

        updateGrid();
    }
    //--- End Case Third ---

    // Refresh dropdowns
    $dropdownA.trigger("chosen:updated");
            $dropdownB.trigger("chosen:updated");
            $ddlOtherRingSite.trigger("chosen:updated");
}


        function getAllSitelistItem() {
    // Get selected values
            var topologytype = $("#ddltopologytype").val();
            var maxdistancepeer = $("#txtmaxdistancepeer").val();
    var ringid = $("#ddlringtype").val() || 0; // Fallback to 0 if null/undefined
    var systemId = $("#hdnSystemId").val() || 0;

            if (!systemId) {
                alert("System ID is missing. Defaulting to 0.");
            }

     // AJAX Call
     $.ajax({
         url: '@Url.Action("Gettopologygetsites", "Report")',
         type: "GET",
         dataType: "json",
         data: { systemId: systemId, ringId: ringid, distance: maxdistancepeer },
         success: function (response) {
            if (response && response.lsttopologygetsites && response.lsttopologygetsites.length > 0) {
                populateDropdowns(response.lsttopologygetsites);
            } else {
                resetDropdowns();
            }
          },
         error: function (xhr, status, error) {
            console.error("Error fetching topology sites:", status, error);
            alert("Error fetching topology sites. Please try again.");
              }
      });
}

            // Function to populate dropdowns
        function populateDropdowns(sites, isfresh = false) {
            debugger;
                var dropdownA = $("#ddlRingASite");
            var dropdownB = $("#ddlRingBSite");
            var dropdownOther = $("#ddlOtherRingSite");

                // Clear existing options
                dropdownA.empty();
            dropdownB.empty();
            dropdownOther.empty();

                // Append default option
                dropdownA.append('<option value="">--Select--</option>');
                dropdownB.append('<option value="">--Select--</option>');

                debugger;
                // Append new options
                $.each(sites, function (index, item) {
                    var optionHtml = '<option value="' + item.ringid + '" data-distance="' + item.sitedistance + '" data-ringid="' + item.ringid + '"  data-siteid="' + item.siteid + '">' + item.sitename + ' (' + (item.sitedistance / 1000).toFixed(3) + ')</option>';
                    dropdownA.append(optionHtml);
                    dropdownB.append(optionHtml);
                    dropdownOther.append(optionHtml);
                });

            getSiteListItemRingwise(isfresh);
                // Refresh dropdowns
                dropdownA.trigger("chosen:updated");
            dropdownB.trigger("chosen:updated");
            dropdownOther.trigger("chosen:updated");
            }

            // Function to reset dropdowns
            function resetDropdowns() {
                var dropdownA = $("#ddlRingASite");
                var dropdownB = $("#ddlRingBSite");
                var ddlOtherRingSite = $("#ddlOtherRingSite");

                // Clear existing options
                dropdownA.empty();
                dropdownB.empty();
                ddlOtherRingSite.empty();

                // Append default option
                dropdownA.append('<option value="">--Select--</option>');
                dropdownB.append('<option value="">--Select--</option>');

                // Refresh dropdowns
                dropdownA.trigger("chosen:updated");
                dropdownB.trigger("chosen:updated");
                ddlOtherRingSite.trigger("chosen:updated");
        }


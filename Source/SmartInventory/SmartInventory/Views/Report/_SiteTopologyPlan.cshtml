<script type="text/javascript">
    $(document).ready(function () {
        // Get selected values
        var topologytype = $("#ddltopologytype").val();
        // Get ring and system IDs
        var ringid = $("#ddlringtype").val();
        var systemId = $("#hdnSystemId").val();

        // Determine endpoint based on topology type
        var endpoint = (topologytype === "Dual Home") ? "Gettopologygetsitesringwise" : "Gettopologygetsites"; // Can add more conditions if needed

        // Ensure systemId and ringId are valid
        if (!systemId || !ringid) {
           /* alert("System ID or Ring ID is missing.systemId : " + systemId);*/
            ringid=0;
        }
        // AJAX Call
        $.ajax({
 url: '@Url.Action("Endpoint", "Report")'.replace("Endpoint", endpoint),
 type: "GET",
 dataType: "json",
 data: { systemId: systemId, ringId: ringid },
     success: function (response) {
         debugger;
 if (response.lsttopologygetsites.length > 0) {

     populateDropdowns(response.lsttopologygetsites);
 }
 else {
     resetDropdowns();
 }
 },
 error: function () {
 alert("Error fetching topology sites. Please try again.");
 }
 });

        // Function to populate dropdowns
        function populateDropdowns(sites) {
            var dropdownA = $("#ddlRingASite");
            var dropdownB = $("#ddlRingBSite");

            // Clear existing options
            dropdownA.empty();
            dropdownB.empty();

            // Append default option
            dropdownA.append('<option value="">--Select--</option>');
            dropdownB.append('<option value="">--Select--</option>');

            // Append new options
            $.each(sites, function (index, item) {
                var optionHtml = '<option value="' + item.siteid + '" data-distance="' + item.sitedistance + '">' + item.sitename + ' (' + item.sitedistance + ')</option>';
                dropdownA.append(optionHtml);
                dropdownB.append(optionHtml);
            });

            // Refresh dropdowns
            dropdownA.trigger("chosen:updated");
            dropdownB.trigger("chosen:updated");
        }

        // Function to reset dropdowns
        function resetDropdowns() {
            var dropdownA = $("#ddlRingASite");
            var dropdownB = $("#ddlRingBSite");

            // Clear existing options
            dropdownA.empty();
            dropdownB.empty();

            // Append default option
            dropdownA.append('<option value="">--Select--</option>');
            dropdownB.append('<option value="">--Select--</option>');

            // Refresh dropdowns
            dropdownA.trigger("chosen:updated");
            dropdownB.trigger("chosen:updated");
        }
    });
</script>



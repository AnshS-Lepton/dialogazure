<style>
    /* Custom button styles */
    .action-btn-success {
        background-color: #28a745; /* Green color */
        color: white;
        border: none;
        padding: 5px 10px;
        cursor: pointer;
        border-radius: 5px;
    }

        .action-btn-success:hover {
            background-color: #218838; /* Darker green on hover */
        }
</style>

<script type="text/javascript">
    $(document).ready(function () {
        $("#GISInfo .input-validation-error").removeClass("input-validation-error");
        $("#segmentModal .input-validation-error").removeClass("input-validation-error");
        $("#ringModal .input-validation-error").removeClass("input-validation-error");

        $(".AsiterowShowOnMap").hide(); // Ensure it's hidden on page load
        $(".BsiterowShowOnMap").hide(); // Ensure it's hidden on page load
        var siteId = '@Model.site_id';
          var sitename = '@Model.site_name';
        $("#txtSiteId").val(siteId);
        $("#txtSiteName").val(sitename);
        $('.chosen-select').chosen({ width: '100%' });
        $("#txtnoOfsite").on("input", function () {
            this.value = this.value.replace(/[^0-9]/g, ''); // Remove non-numeric characters
        });
        $("#txtmaxdistancepeer").on("input", function () {
            this.value = this.value.replace(/[^0-9.]/g, ''); // Remove invalid characters
            if ((this.value.match(/\./g) || []).length > 1) {
                this.value = this.value.slice(0, -1); // Prevent multiple dots
            }
        });
               $("#txtSiteId").autocomplete({
    source: function (request, response) {
        $.ajax({
            url: '@Url.Action("GetSiteIds", "Report")',
            type: "GET",
            dataType: "json",
            data: { term: request.term },
            success: function (data) {
            if (data.length === 0) {
            response([{ label: "No results found", value: "", siteName: "", systemId: "" }]);
            } else {
            response($.map(data, function (item) {
            return {
            label: item.label,   // Display site_id in dropdown
            value: item.value,   // Set site_id in input
            siteName: item.siteName, // Set site_name
            systemId: item.systemId  // Store system_id
            };
            }));
            }
            }
            });
            },
            minLength: 3,
            select: function (event, ui) {
            if (ui.item.value !== "") {
            $("#txtSiteId").val(ui.item.value);   // Set selected site_id
            $("#txtSiteName").val(ui.item.siteName); // Set corresponding site_name
            $("#hdnSystemId").val(ui.item.systemId); // Set system_id in hidden field
            }
            return false;
            }
            });


            $("#ddltopologytype").change(function () {
            debugger;
                var selectedValue = $(this).val(); // Get selected value
                var ddlRingASite = $("#ddlRingASite").val();
                var ddlRingBSite = $("#ddlRingBSite").val();
                if (selectedValue == "Ring") {
                    var ddlnofsites = $('#ddlnofsites');
                    ddlnofsites.prop('selectedIndex', 0).trigger("chosen:updated");
                    $("#ddlnofsites").prop("disabled", false).trigger("chosen:updated");

                    var ddlringcapacity = $('#ddlringcapacity');
                    ddlringcapacity.prop('selectedIndex', 0).trigger("chosen:updated");
                    $("#ddlringcapacity").prop("disabled", false).trigger("chosen:updated");

                    $("#txtagg2").css("display", "block").prop("disabled", false);
                    $("#ddlRingBSite").prop("disabled", false).trigger("chosen:updated");
                    $("#ddlsegment").prop("disabled", false).trigger("chosen:updated");
                    $("#btncreatesegmentdiv").css("display", "block");
                    $("#ddlringtype").prop("disabled", false).trigger("chosen:updated");
                    $("#btncreateringdiv").css("display", "block");

                }
                else if (selectedValue == "Linear")
                {
                   // $("#txtagg2").val("");
                    $("#txtagg2").css("display", "block").prop("disabled", false);
                    $("#ddlRingBSite").prop("disabled", true).trigger("chosen:updated");
                    //  $("#ddlsegment").prop("disabled", true).trigger("chosen:updated");
                    var ddlnofsites = $('#ddlnofsites');
                    ddlnofsites.prop('selectedIndex', 0).trigger("chosen:updated");
                    $("#ddlnofsites").prop("disabled", false).trigger("chosen:updated");

                    var ddlringcapacity = $('#ddlringcapacity');
                    ddlringcapacity.prop('selectedIndex', 0).trigger("chosen:updated");
                    $("#ddlringcapacity").prop("disabled", false).trigger("chosen:updated");
                    $("#btncreatesegmentdiv").css("display", "none");
                   // $("#ddlringtype").prop("disabled", true).trigger("chosen:updated");
                    $("#btncreateringdiv").css("display", "none");
                    $("#ddlringtype").val('');
                    $("#ddlRingBSite_chosen").val('');
                }
                else
                {
                    var ddlnofsites = $('#ddlnofsites');
                    ddlnofsites.prop('selectedIndex', 0).trigger("chosen:updated");
                    $("#ddlnofsites").prop("disabled", false).trigger("chosen:updated");

                    var ddlringcapacity = $('#ddlringcapacity');
                    ddlringcapacity.prop('selectedIndex', 0).trigger("chosen:updated");
                    $("#ddlringcapacity").prop("disabled", false).trigger("chosen:updated");

                    $("#txtagg2").css("display", "block").prop("disabled", true); // Show and enable
                     $("#ddlRingBSite").prop("disabled", false).trigger("chosen:updated");// Show and enable for Dual home
                    $("#ddlsegment").prop("disabled", false).trigger("chosen:updated");
                    $("#ddlRingBSite_chosen").val('');
                    $("#btncreatesegmentdiv").css("display", "block");
                    $("#ddlringtype").prop("disabled", false).trigger("chosen:updated");
                    $("#btncreateringdiv").css("display", "none");

                }

<script type="text/javascript">
    $(document).ready(function () {
        $("#GISInfo .input-validation-error").removeClass("input-validation-error");
        $("#segmentModal .input-validation-error").removeClass("input-validation-error");
        $("#ringModal .input-validation-error").removeClass("input-validation-error");

        var siteId = '@Model.site_id';
          var sitename = '@Model.site_name';
        $("#txtSiteId").val(siteId);
        $("#txtSiteName").val(sitename);
        $('.chosen-select').chosen({ width: '100%' });
        $("#txtnoOfsite").on("input", function () {
            this.value = this.value.replace(/[^0-9]/g, ''); // Remove non-numeric characters
        });
        $("#txtmaxdistancepeer").on("input", function () {
            this.value = this.value.replace(/[^0-9.]/g, ''); // Remove invalid characters
            if ((this.value.match(/\./g) || []).length > 1) {
                this.value = this.value.slice(0, -1); // Prevent multiple dots
            }
        });
               $("#txtSiteId").autocomplete({
    source: function (request, response) {
        $.ajax({
            url: '@Url.Action("GetSiteIds", "Report")',
            type: "GET",
            dataType: "json",
            data: { term: request.term },
            success: function (data) {
            if (data.length === 0) {
            response([{ label: "No results found", value: "", siteName: "", systemId: "" }]);
            } else {
            response($.map(data, function (item) {
            return {
            label: item.label,   // Display site_id in dropdown
            value: item.value,   // Set site_id in input
            siteName: item.siteName, // Set site_name
            systemId: item.systemId  // Store system_id
            };
            }));
            }
            }
            });
            },
            minLength: 3,
            select: function (event, ui) {
            if (ui.item.value !== "") {
            $("#txtSiteId").val(ui.item.value);   // Set selected site_id
            $("#txtSiteName").val(ui.item.siteName); // Set corresponding site_name
            $("#hdnSystemId").val(ui.item.systemId); // Set system_id in hidden field
            }
            return false;
            }
            });


            $("#ddltopologytype").change(function () {
            debugger;
            var selectedValue = $(this).val(); // Get selected value

            if (selectedValue === "Ring") {
            $("#txtagg2").css("display", "block").prop("disabled", false);
            }
            else
            {
            $("#txtagg2").css("display", "block").prop("disabled", true); // Show and enable
            }
            });
            $("#txtagg1").autocomplete({
            source: function (request, response) {
            $.ajax({
            url: '@Url.Action("GetAGG1", "Report")',
            type: "GET",
            dataType: "json",
            data: { term: request.term },
            success: function (data) {
            if (data.length === 0) {
            response([{ label: "No results found", value: "", systemId: "" }]);
            } else {
            response($.map(data, function (item) {
            return {
            label: item.label,   // Display agg_01 in dropdown
            value: item.value,   // Set agg_01 in input
            systemId: item.systemId  // Store system_id
            };
            }));
            }
            }
            });
            },
            minLength: 3,
            select: function (event, ui) {
            if (ui.item.value !== "") {
            $("#txtagg1").val(ui.item.value);   // Set selected agg_01
            $("#hdnAgg1SystemId").val(ui.item.systemId); // Set system_id in hidden field
            }
            return false;
            }
            });

            $("#txtagg2").autocomplete({
            source: function (request, response) {
            $.ajax({
            url: '@Url.Action("GetAGG2", "Report")',
            type: "GET",
            dataType: "json",
            data: { term: request.term },
            success: function (data) {
            if (data.length === 0) {
            response([{ label: "No results found", value: "", systemId: "" }]);
            } else {
            response($.map(data, function (item) {
            return {
            label: item.label,   // Display agg_02 in dropdown
            value: item.value,   // Set agg_02 in input
            systemId: item.systemId  // Store system_id
            };
            }));
            }
            }
            });
            },
            minLength: 3,
            select: function (event, ui) {
            if (ui.item.value !== "") {
            $("#txtagg2").val(ui.item.value);   // Set selected agg_02
            $("#hdnAgg2SystemId").val(ui.item.systemId); // Store system_id in hidden field
            }
            return false;
            }
            });

            $('#ddlregionid').change(function () {
            debugger;
            var regionId = $(this).val(); // Get the selected RegionId

            if (regionId) {
            $.ajax({
            url: '@Url.Action("GetSegmentsByRegion", "Report")', // Action to fetch ring types
            type: 'GET',
            data: { id: regionId }, // Pass selected regionId to the server
            success: function (data) {
            // Populate the Ring Type Dropdown
            var segmenttype = $('#ddlsegment');
            segmenttype.empty(); // Clear existing options
            segmenttype.append('<option value="">--Select Ring Type--</option>');

            // Append options from the data
            $.each(data, function (index, item) {
            segmenttype.append('<option value="' + item.Value + '">' + item.Text + '</option>');
            });
            segmenttype.trigger("chosen:updated");
            },
            error: function () {
            alert("Error fetching ring types. Please try again.");
            }
            });
            } else {
            // Clear the ringtype dropdown if no region is selected
            // $('#ddlringtype').empty().append('<option value="">--Select Ring Type--</option>');
            }
            $('#ddlsegment').change(function () {
            debugger;
            var segmentId = $(this).val(); // Get the selected SegmentId

            if (segmentId) {
            $.ajax({
            url: '@Url.Action("GetRingTypesByRegion", "Report")', // Fetch ring types
            type: 'GET',
            data: { segmentId: segmentId }, // Pass the selected segment ID
            success: function (data) {
            var ringTypeDropdown = $('#ddlringtype'); // Ensure correct variable name
            ringTypeDropdown.empty(); // Clear existing options
            ringTypeDropdown.append('<option value="">--Select Ring Type--</option>');

            // Append new options from response
            $.each(data, function (index, item) {
                ringTypeDropdown.append('<option value="' + item.ring_id + '">' + item.ring_info + '</option>');
            });

            // **Update Chosen Dropdown**
            ringTypeDropdown.trigger("chosen:updated"); // Fix variable name


            },
            error: function () {
            alert("Error fetching ring types. Please try again.");
            }
            });

            } else {
            // Clear the ringtype dropdown if no segment is selected
            $('#ddlringtype').empty().append('<option value="">--Select Ring Type--</option>');
            }

            });

                $("#ddlringtype").on("change", function () {
                    debugger;
                var topologytype = $("#ddltopologytype option:selected").text();
                var region = $("#ddlregionid option:selected").text();
            var segment = $("#ddlsegment option:selected").text();
                var ringtype = $("#ddlringtype option:selected").text();
                var noofsites = $("#ddlnofsites").val();
                var networkIdValue = (ringtype ?? "N/A");
            $("#lbdringsiteId").text(networkIdValue).css("display", "block");
            $("#ring_site_id").val(networkIdValue);
            //$("#networkIdField").val(networkIdValue);
            var ringid = $("#ddlringtype").val();
                    var systemId = $("#hdnSystemId").val();

        </div>
        <div class="ModalFooter d-flex" id="dvBtnAction">
            <div class="ml-auto">
                <button type="submit" class="btn btn-success ml-auto" id="btnShowReportData">@Resources.Resources.SI_OSP_GBL_NET_FRM_112</button>
                @*@if (Model.objReportFilters.totalRecord > 0)
    {

         <button type="button" class="btn btn-primary" id="btnExportLMCIntoExcel">
            @Resources.Resources.GBL_GBL_GBL_GBL_GBL_010
            <i class="fa fa-chevron-down" aria-hidden="true" style="display:none"></i>
        </button>



    }
    else
    {
        <button type="button" class="btn btn-primary" id="btnExportLMCIntoExcel" disabled="disabled">
            @Resources.Resources.GBL_GBL_GBL_GBL_GBL_010

            <i class="fa fa-chevron-down" aria-hidden="true"  style="display:none"></i>
        </button>


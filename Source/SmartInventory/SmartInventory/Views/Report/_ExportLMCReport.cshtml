                    <span id="btnExportLMCIntoToKML" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_010" class="btn" @string.Format(Model.objReportFilters.totalRecord > 0 ? "" : "dvdisabled")>@Resources.Resources.SI_GBL_GBL_NET_FRM_043</span>

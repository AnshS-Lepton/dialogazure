@model Models.ExportLMCEntitiesReport
@using Utility;
@using SmartInventory.Settings;
@{


    WebGrid grid = new WebGrid(rowsPerPage: Model.objReportFilters.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewLMCExportData",
        ajaxUpdateCallback: "onGridHeaderClick('tblExportReport');");
    grid.Bind(Model.lstReportData, autoSortAndPage: false, rowCount: Model.objReportFilters.totalRecord);
    if (Model.objReportFilters.totalRecord > 0)
    {
        grid.PageIndex = Model.objReportFilters.currentPage - 1;
    }

}
<style>
    #frmLMCExportEntities .chosen-container-multi .chosen-choices {
        font-size: 11px;
    }

    #frmLMCExportEntities .chosen-disabled .chosen-choices {
        background: #ccc;
    }

  
    .FlowDiv {
        right: -170px;
        width: 280px;
        height: auto;
        background-color: #fcfcfc;
        border: 1px solid #00ba8a;
        position: absolute;
        border-radius: 4px;
        margin: 3px 55px 0px 0px;
        text-align: left;
        display: none;
    }

        .FlowDiv span {
            font-size: 14px;
            width: 100%;
            float: left;
            border-bottom: 1px solid #bdb9b9;
            padding: 5px;
            color: #bdb9b9;
        }

        .FlowDiv .pdf {
            color: #e60000;
        }

            .FlowDiv .pdf a {
                color: #666;
            }

                .FlowDiv .pdf a:hover {
                    color: #e60000;
                    font-weight: 600;
                }


        .FlowDiv .excel {
            color: #207245;
        }

            .FlowDiv .excel a {
                color: #666;
            }

            .FlowDiv .excel :hover {
                color: #207245;
                font-weight: 600;
            }

        .FlowDiv .arrow-up {
            width: 0;
            height: 0;
            border-left: 8px solid transparent;
            border-right: 8px solid transparent;
            border-bottom: 8px solid #00ba8a;
            position: absolute;
            top: -8px;
            z-index: 9;
        }

    .legendparent {
        width: 85px;
        float: left;
        margin-left: 5px;
    }

    .Applied, .Approved, .Rejected, .Associated, .Created {
        width: 15px;
        height: 15px;
        border-radius: 4px;
        float: left;
        border: 1px solid grey;
    }

    .Applied {
        background-color: #FCE27C;
    }

    .Approved {
        background-color: #3AE786;
    }

    .Rejected {
        background-color: #FD8B8B;
    }

    .Associated {
        background-color: #50C1FA;
    }

    .Created {
        background-color: yellow;
    }

    #frmLMCExportEntities .icon-ARROW_DOWN:before {
        content: "\e908";
        float: right;
        margin-left: 5px;
    }

    .btn {
        font-weight: bold !important;
        line-height: 1.42857143 !important;
    }

    .icon-kmldownload {
        font-size: 20px;
    }
</style>

<!DOCTYPE html>

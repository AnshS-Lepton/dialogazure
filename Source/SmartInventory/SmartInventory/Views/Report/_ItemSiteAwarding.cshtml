@model Models.Admin.ViewItemVendorCost
@using Utility
@using SmartInventory.Settings;
@using System.Dynamic;
@using System.Collections.Generic;
<input type="hidden" id="hdnNumberFormatType" value="@ApplicationSettings.numberFormatType" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
    .form-control{
        padding-block:2px;
    }
</style>
<div id="libTabContent" class="libDetail">
    <div class="libTabContent">


        @{
            var gridData = ViewBag.transformedData as List<dynamic>;

            //var gridData = ViewBag.transformedData as List<Dictionary<string, object>>;

            var users = new List<string>();

            if (gridData != null && gridData.Any())
            {
                // Extract user-specific columns dynamically
                var firstRow = (IDictionary<string, object>)gridData.FirstOrDefault();

                users = firstRow.Keys.Where(k => k.StartsWith("User_")).ToList();


            }



        }
        @{
            WebGrid grid = new WebGrid(rowsPerPage: Model.objGridAttributes.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewLayerGroups", ajaxUpdateCallback: "onGridHeaderClick('tblItemVendorCost1')");
            grid.Bind(gridData, autoSortAndPage: false, rowCount: Model.objGridAttributes.totalRecord);
            if (Model.objGridAttributes.totalRecord > 0)
            {
                grid.PageIndex = Model.objGridAttributes.currentPage - 1;
            }

            // Define column list
            var columns = new List<WebGridColumn>
    {
        grid.Column("code", "Item Code"),

        grid.Column("specification", "Specification"),
        grid.Column("uom", "UOM"),
        grid.Column("totalqty", "Quantity/Length"),
        //grid.Column("uam", "Unit Measurement")
    };

            // Add user-specific columns dynamically
            foreach (var user in users)
            {


                columns.Add(grid.Column(user, user.Replace("User_", "").Split('/')[0], format: item =>
            Html.Raw("<div style='display: flex; width: 100%;'>"


            + "<div style='width: 50%; text-align: center; padding: 5px;'>" + item[user] + "</div>"
            + "</div>")));


            }
        }


        @using (Ajax.BeginForm("SiteBomBoqSummary", "Report", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "dvModalBody", LoadingElementId = "dvProgress", OnSuccess = "OnSuccess", },
            new { autocomplete = "off", enctype = "multipart/form-data", @class = "form-horizontal", @id = "frmtblItemVendorCost" }))
        {
            <div>
                <div class="tab-content">
                    <div class="d-flex --gap10 mb-01">
                        @Html.DropDownListFor(m => m.objGridAttributes.searchBy, new SelectList(Model.lstBindSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", @id = "searchBy", })

                        @Html.TextBoxFor(m => m.objGridAttributes.searchText, new { @id = "searchText", @title = "Search text", @tabindex = "4", @class = "input-sm form-control", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })

                        <button class="btn btn-default" id="btnGetSearchResult1" name="btnCommandName1" value="GetSearchResult" tabindex="5" onclick="search()">Search</button>
                        <input type="button" id="btnViewGroupExport" value="Export" class="btn btn-success ml-auto" onclick="DownloadReport()" />

                    </div>
                </div>

                @if (gridData != null && gridData.Any())
                {
                    <div id="divLayerGroupDetail">
                        <div class="mb-01 d-flex">
                            <b class="white-space">Total Records:<span data="spanTotalRowCount">@grid.TotalRowCount</span></b>

                            <div class="d-flex --gap10 ml-auto">
                                <b class="ml-auto white-space">
                                    Award Site TO :
                                </b>

                                @Html.DropDownListFor(m => m.user_id, new SelectList(Model.lstUserDetails.Select(x => new { Value = x.user_id.ToString(), Text = x.user_name }), "Value", "Text"), "-Select-", new { @class = "chosen-select form-control", id = "AwardUser" })
                                <input type="button" id="btnAwarSite" value="Submit" class="btn btn-success" onclick="ViewGroupsReport()" />
                            </div>
                        </div>

                        <div class="table-responsive tble_cls">
                            @grid.GetHtml(tableStyle: "grid",
            htmlAttributes: new { id = "tblItemVendorCost1", border = "1" },
            mode: WebGridPagerModes.All,
            columns: columns)


                            @Html.Hidden("dir", grid.SortDirection)
                            @Html.Hidden("col", grid.SortColumn)
                            @Html.HiddenFor(m => m.objGridAttributes.searchBy)
                            @Html.HiddenFor(m => m.objGridAttributes.searchText)
                        </div>

                    </div>
                }
                else
                {
                    <div class="nr-found">
                        <span>No Records Found.</span>
                    </div>
                }

            </div>

        }



    </div>
</div>
<script>
    function OnSuccess(data) {
        debugger;
       // $("#closeModalPopup").trigger("click");
        //si.SiteReport.ItemSiteAwarding(null, systemId, null, this);
    }
    function search() {
        event.preventDefault();
        debugger;
        var searchBy = $('#searchBy').val();
        var searchText = $('#searchText').val();
        var systemId = '';
        si.SiteReport.ItemSiteAwarding(null, systemId, null, this, searchBy, searchText);
    }
    function ViewGroupsReport() {
        debugger;
        let tableData = [];
        let headers = [];
        $("#tblItemVendorCost1 thead th").each(function () {
            headers.push($(this).text().trim());
        });
        var Awarduser = $('#AwardUser').val();
        var Awardusername = $('#AwardUser option:selected').text();
        let userNameIndex = headers.indexOf(Awardusername);
        if (userNameIndex === -1) {
            alert("User Name column not found.");
            return;
        }

        $("#tblItemVendorCost1 tbody tr").each(function () {
            let row = $(this).find("td");
            let user_name = headers[userNameIndex];
            if (user_name == Awardusername) {
                // var user_id = Model.lstUserDetails.where(u => u.user_name == Awardusername).Select(u => u.user_id).ToList();
                let item = {
                    item_code: row.eq(0).text().trim(),
                    specification: row.eq(1).text().trim(),
                    uom: row.eq(2).text().trim(),
                    user_id: Awarduser
                };
                tableData.push(item);
            }
        });
        $.ajax({
            url: '/Report/AwardSitetoUser',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(tableData),
            success: function (response) {
                alert(response.message);
            },
            error: function () {
                alert("Error saving data.");
            }
        });

    }

    function exportTableToExcel(tableID, filename = 'ExportedData.xlsx') {
        debugger;
        // Select the table
        let table = document.getElementById("tblItemVendorCost1");
        let wb = XLSX.utils.book_new();
        let ws = XLSX.utils.table_to_sheet(table);

        // Apply borders to each cell
        let range = XLSX.utils.decode_range(ws['!ref']);
        for (let R = range.s.r; R <= range.e.r; ++R) {
            for (let C = range.s.c; C <= range.e.c; ++C) {
                let cellAddress = XLSX.utils.encode_cell({ r: R, c: C });
                if (!ws[cellAddress]) continue; // Skip empty cells

                ws[cellAddress].s = {
                    border: {
                        top: { style: "thin", color: { auto: 1 } },
                        bottom: { style: "thin", color: { auto: 1 } },
                        left: { style: "thin", color: { auto: 1 } },
                        right: { style: "thin", color: { auto: 1 } }
                    },
                    alignment: {
                        horizontal: "center",
                        vertical: "center"
                    }
                };
            }
        }

        XLSX.utils.book_append_sheet(wb, ws, "Sheet1");

        // Save the file
        XLSX.writeFile(wb, filename);
    }

    function DownloadReport() {
        debugger;
        window.location = appRoot + 'Report/DownloadReport';
    }
    //function ViewUserReport() {
    //    window.location = appRoot + 'Report/DownloadVendorDetails';
    //}
</script>
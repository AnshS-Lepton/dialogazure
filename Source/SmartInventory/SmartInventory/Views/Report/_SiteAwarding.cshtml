@using SmartInventory.Settings;
@model Models.ViewUserModel
@using Utility
@{
    WebGrid grid = new WebGrid(rowsPerPage: Model.objGridAttributes.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewUsers", ajaxUpdateCallback: "onGridHeaderClick('tblUserDetail')");
    grid.Bind(Model.lstUsers, autoSortAndPage: false, rowCount: Model.objGridAttributes.totalRecord);
    if (Model.objGridAttributes.totalRecord > 0)
    {
        if ((Model.objGridAttributes.searchBy != "name" && Model.objGridAttributes.searchBy != "user_email"))
        {
            grid.PageIndex = Model.objGridAttributes.currentPage - 1;
        }

    }
}
<style>

    .btn {
        font-weight: bold !important;
        line-height: 1.42857143 !important;
    }

    .icon-kmldownload {
        font-size: 20px;
    }
</style>

<!DOCTYPE html>
<div class="libDetail">
  

    @using (Ajax.BeginForm("SiteAwarding", "Report", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "dvModalBody", LoadingElementId = "dvProgress" },
                                                    new { id = "frmROWExportEntities", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {

        @*@Html.HiddenFor(m => m.objReportFilters.geom)
            @Html.HiddenFor(m => m.objReportFilters.geomType)
            @Html.HiddenFor(m => m.objReportFilters.radius)
            @Html.HiddenFor(m => m.objReportFilters.layerName, new { id = "hdnLayerName" })*@
        <input type="hidden" id="hdnApproveCount" value="0">
        <div class="libTabContent">
            <!-- Tab panes -->
            <div class="tab-content">
                <div class="tab-pane active" id="GISInfo">

                    <div class="form-group row">
                        <label class="control-label col-sm-2" for="searchby">@Resources.Resources.SI_OSP_GBL_NET_FRM_100 :</label>
                        <div class="col-sm-4">
                            @Html.DropDownListFor(m => m.objGridAttributes.searchBy, new SelectList(Model.lstSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), new { @class = "input-sm col-sm-12" })
                        </div>
                        <label class="control-label col-sm-2" for="txtSearchtext">@Resources.Resources.SI_OSP_GBL_NET_FRM_101 :</label>
                        <div class="col-sm-4">
                            @Html.TextBoxFor(m => m.objGridAttributes.searchText, new { @id = "txtSearchText", @title = "Search text", @tabindex = "4", @class = "input-sm col-sm-12", @placeholder = "Search text", @maxlength = 100, @onkeypress = "fnOnKeyPress(event)" })
                        </div>
                    </div>
                    <div class="d-flex --gap03" id="dvBtnAction" style="position: relative; left: 84%;">
                        <button class="btn btn-primary" id="btnGetSearchResult" tabindex="5" type="submit">@Resources.Resources.SI_OSP_GBL_GBL_GBL_046</button>

                        @if (Model.lstUsers.Count > 0)
                        {
                            <input type="button" id="btnViewUserExport" value="Export" class="btn btn-primary" onclick="ViewUserReport()" />
                        }
                        else
                        {

                            <input type="button" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_010" class="btn btn-default ml-10" @string.Format((grid.TotalRowCount == 0) ? "disabled" : "") />

                        }


                    </div>
                </div>
            </div>

        </div>

        if (Model.lstUsers.Count > 0)
        {
            <div id="dvViewROWExportData" class="space-pad">

                <div class="table-responsive">
                    @grid.GetHtml(tableStyle: "grid",
                                 htmlAttributes: new { id = "tblUserDetail" },
                                 mode: WebGridPagerModes.All,
                                 columns: grid.Columns(
                                     grid.Column(header: "S.No.", format: @<text>@item.S_No</text>, canSort: false),
grid.Column("", "Action", format:@<text>

                    <span>
                        <a title="@Resources.Resources.SI_OSP_GBL_GBL_RPT_002" style="font-size: 16px;" data-value=@item.user_id ,@item.vendorCost class="dropdown-toggle AwardSiteToSelectedVendor" href="#" target="_parent">
                            <i class="fa fa-download"></i>
                        </a>
                    </span>
                    @*<input type="checkbox" id="@item.user_id" data-view-id="@item.user_id" onclick="ManageHeaderCheckBox()"><b><label for="@item.user_id" class="checkbox-custom-label"></label></b>*@

                </text>, canSort: false
),
grid.Column("Name", "Name", format: @<text>@item.name</text>, canSort: true),
grid.Column("mobile_number", "Mobile No.", format: @<text>@item.mobile_number</text>, canSort: true),
grid.Column("user_email", "Email", format: @<text>@item.user_email</text>, canSort: true),
grid.Column("vendorCost", "Vendor Cost", format: @<text> @item.vendorCost</text>, canSort: true)


))

                    @Html.Hidden("dir", grid.SortDirection)
                    @Html.Hidden("col", grid.SortColumn)
                    @Html.HiddenFor(m => m.objGridAttributes.searchBy)
                    @Html.HiddenFor(m => m.objGridAttributes.searchText)
                </div>
            </div>
        }
        else
        {
            <div id="divNoRecordFound" class="nr-found filtersBg">
                <span>@Resources.Resources.SI_OSP_GBL_NET_RPT_071</span>
            </div>
        }
    }

</div>

<script>
    $(document).ready(function () {
        updateNumberstoFormatedNumber();
        addDefaultSortingIcons("tblUserDetail");
        onGridHeaderClick('tblUserDetail');
        $($('#tblUserDetail tr:first th')).addClass('gridHeaderStyle');

        $('[data-toggle="tooltip"]').tooltip();
        $('#tblUserDetail thead tr th:eq(0)').removeClass('bothorder');
    });
    $('.AwardSiteToSelectedVendor').on("click", function () {
        var systemId = $(this).attr('data-value');
        var resultArray = systemId.split(',');
        si.SiteReport.AwardSiteToSelectedVendor(resultArray[0], resultArray[1]);

    });
    $("#btnExport").on("click", function () {

        window.location = appRoot + 'Home/Export_Dashboard_Data';
    })
    function EditUserStatus(id, event, e) {

        e.preventDefault();
        var item_id = '#Edit_' + id;
        var msg = event.checked == true ? "Are you sure you want to Activate this user?" : "Are you sure you want to de-activate this user?";

        var csts = $(item_id).is(":checked");
        showConfirm(msg, function () {

            ajaxReq('User/EditUserStatus', { user_id: id, status: csts }, true, function (resp) {

                if (resp.status == "OK") {

                    alert(resp.message, 'Success', 'success');
                    setTimeout(function () {

                        $("#frmViewUsers").submit();
                    }, 1000);
                    return $(item_id).is(":checked") == true ? $(item_id).prop('checked', false) : $(item_id).prop('checked', true);
                }
                else
                    alert(resp.message);
            }, true, true);
        }, function () {
            if (event.checked) {
                $(item_id).prop('checked', true);
            }
            else {
                $(item_id).prop('checked', false);
            }

        });

    }

    function ViewUserReport() {
        window.location = appRoot + 'Report/DownloadVendorDetails';
    }

    function UploadUser() {
        alert("pankaj");
    }
    $('th a, tfoot a').on("click", function () {
        $('#frmViewUsers').attr('action', $(this).attr('href')).submit();
        return false;
    });
    function updateNumberstoFormatedNumber() {
        $('span[data]').each(function (index) {
            // Get the value of the data-target attribute for each element
            var targetValue = $(this).data('data');

            // Do whatever you want with the element or its data
            $(this).text(getFormattedNumber($(this).text().trim()));
        });
    }
</script>

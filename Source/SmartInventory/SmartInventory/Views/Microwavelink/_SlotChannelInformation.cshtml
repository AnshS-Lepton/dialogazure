
@model Models.MicrowaveLinkViewModel
<div class="form-group">
    <label class="control-label col-sm-2"></label>
    <label class="control-label col-sm-5">Radio A</label>
    <label class="control-label col-sm-5">Radio B</label>
</div>
<fieldset class="the-fieldset">
    <legend class="the-legend">Slot & Channel Information</legend>
    <div class="form-group col-md-12">
        <div class="col-md-4">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">User Power(dBm)</label> &nbsp;&nbsp;&nbsp;
            
        </div>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.user_power, new { @class = "form-control" })
        </div>
        <div class="col-md-4">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">User Power(dBm)</label> &nbsp;&nbsp;&nbsp;
           
        </div>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.user_power, new { @class = "form-control" })
        </div>
        
    </div>


    <div class="form-group col-md-12">
        <div class="col-md-6">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">Use per configuration Power(dBm)</label> &nbsp;&nbsp;&nbsp;
        </div>  
        <div class="col-md-6">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">Use per configuration Power(dBm)</label> &nbsp;&nbsp;&nbsp;
        </div>
    </div>
    <div class="form-group">
        <label class="control-label col-sm-1" for="txtParentType">Type:</label>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.type, new { @class = "form-control"})
        </div>
        <label class="control-label col-sm-1" for="txtParentType">Offset (dB):</label>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.config_power_offset, new { @class = "form-control"})
        </div>
        <label class="control-label col-sm-1" for="txtParentType">Type:</label>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.type, new { @class = "form-control"})
        </div>
        <label class="control-label col-sm-1" for="txtParentType">Offset (dB):</label>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.config_power_offset, new { @class = "form-control"})
        </div>
    </div>

    <div class="form-group col-md-12">
        <div class="col-md-6">
            <input type="checkbox" id="male" name="gender" value="male">
            <label for="male">Use ATPC</label> &nbsp;&nbsp;&nbsp;
        </div>
        <div class="col-md-6">
            <input type="checkbox" id="male" name="gender" value="male">
            <label for="male">Use ATPC</label> &nbsp;&nbsp;&nbsp
        </div>
        
    </div>
    <div class="form-group col-md-12">
        <div class="col-md-4">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">User Power(dBm)</label> &nbsp;&nbsp;&nbsp;

        </div>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.user_power, new { @class = "form-control", @readonly = true })
        </div>
        <div class="col-md-4">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">User Power(dBm)</label> &nbsp;&nbsp;&nbsp;

        </div>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.user_power, new { @class = "form-control", @readonly = true })
        </div>

    </div>

    <div class="form-group col-md-12">
        <div class="col-md-4">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">Use per configuration Power(dBm</label> &nbsp;&nbsp;&nbsp;

        </div>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.config_power, new { @class = "form-control", @readonly = true })
        </div>
        <div class="col-md-4">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">Use per configuration Power(dBm</label> &nbsp;&nbsp;&nbsp;

        </div>
        <div class="col-sm-2">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.config_power, new { @class = "form-control", @readonly = true })
        </div>

    </div>
</fieldset>


<fieldset class="the-fieldset">
    <div class="form-group">
        <label class="control-label col-sm-2" for="txtParentType">Frequency Plan:</label>
        <div class="col-sm-4">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.frequency_plan, new { @class = "form-control" })
        </div>
       
    </div>

    <div class="form-group">
        <label class="control-label col-sm-2" for="txtParentType">Channels:</label>
        <div class="col-sm-4">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.channel_name, new { @class = "form-control" })
        </div>

    </div>
    <div class="form-group">
        <label class="control-label col-sm-2" for="txtParentType">Polarization:</label>
        <div class="col-sm-4">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.polarization, new { @class = "form-control" })
        </div>

    </div>
    <div class="form-group">
       
        <label class="control-label col-sm-2" for="txtParentType">TDM Type:<i class="clsMandatory">*</i>:</label>
        <div class="col-sm-4">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.tdm_type, new { @class = "form-control" })
        </div>
        <label class="control-label col-sm-2" for="txtParentType">TDM Capacity:<i class="clsMandatory">*</i>:</label>
        <div class="col-sm-4">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.tdm_capacity, new { @class = "form-control" })
        </div>
    </div>
    <div class="form-group">
        <label class="control-label col-sm-2" for="txtParentType">IP Throughput: <i class="clsMandatory">*</i>:</label>
        <div class="col-sm-4">
            @Html.TextBoxFor(m => m.microwaveLinkMaster.ip_throughput, new { @class = "form-control" })
        </div>
        <label class="control-label col-sm-2" for="txtParentType">Link Capacity:</label>
        <div class="col-sm-4">
            @Html.TextBoxFor(m => m.microwavelinkPowerA.system_id, new { @class = "form-control", @readonly = true })
        </div>
    </div>
    <div class="form-group col-md-12">
        <div class="col-md-2">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">High</label> &nbsp;&nbsp;&nbsp;

        </div>
        
        <div class="col-md-2">
            <input type="radio" id="male" name="gender" value="male">
            <label for="male">Low</label> &nbsp;&nbsp;&nbsp;

        </div>
        

    </div>
</fieldset>
        border-bottom: 1px solid #efefef;
        position: relative;
    }

    div.scrollerhide {
        overflow: hidden;
    }

        div.scrollerhide .nav-tabs {
            display: flex;
        }

            div.scrollerhide .nav-tabs > li > a {
                padding: 7px 8px;
                font-weight: normal;
            }



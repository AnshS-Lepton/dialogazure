@model Models.MicrowaveLinkMaster
@using Models;
@using SmartInventory.Settings;

@helper TowerInformation()
{
    { Html.RenderPartial("~/Views/Microwavelink/_TowerInformation.cshtml", Model); }
}

@helper AntennaInformation()
{
    { Html.RenderPartial("~/Views/Microwavelink/_AntennaInformation.cshtml", Model); }
}


@helper ItemSpecification()
{
    { Html.RenderPartial("~/Views/ItemTemplate/_ItemSpecification.cshtml", (itemMaster)Model); }
}
@helper ProjectSpecifications()
{
    { Html.RenderPartial("~/Views/Library/_ProjectSpecification.cshtml", (IProjectSpecification)Model); }
}
@helper OwnershipInfo()
{
    { Html.RenderPartial("~/Views/Library/_OwnershipInfo.cshtml", (IOwnershipInfo)Model); }
}
@helper InstallationInfo()
{
    { Html.RenderPartial("~/Views/Library/_InstallationInformation.cshtml", (IInstallationInfo)Model); }
}
@helper IduOduScreen()
{
    { Html.RenderPartial("~/Views/Microwavelink/_IduOduScreen.cshtml", Model); }

}

@helper Idu()
{
    { Html.RenderPartial("~/Views/Microwavelink/_IduScreen.cshtml", Model); }

}
@helper pageMessage()
{
    {
        Html.RenderPartial("_PageMessage", Model.objPM);
    }
}
@helper Reference()
{
    { Html.RenderPartial("~/Views/Library/_Reference.cshtml", (IReference)Model); }
}
@helper GeographicDetails()
{
    { Html.RenderPartial("~/Views/Library/_GeographicDetails.cshtml", (IGeographicDetails)Model); }
}
@helper AdditionalFields()
{
    { Html.RenderPartial("~/Views/Library/_AdditionalFields.cshtml", (IAdditionalFields)Model); }
}
@{
    var layerDetail = ApplicationSettings.listLayerDetails.Count > 0 ? ApplicationSettings.listLayerDetails.Where(x => x.layer_name.ToUpper() == EntityType.MicrowaveLink.ToString().ToUpper()).FirstOrDefault() : null;
    var editPermission = Utility.MiscHelper.GetLayerEditPermission(Model.system_id, (List<NetworkLayer>)Session["NerworkLayerDetails"], Model.network_status, EntityType.MicrowaveLink.ToString());

}


<style type="text/css">
    .maindiv {
        width: 650px;
        height: 500px;
        margin: auto;
        background-color: #ffffff;
        border-radius: 5px;
        border: 1px solid #b9b7b7;
    }


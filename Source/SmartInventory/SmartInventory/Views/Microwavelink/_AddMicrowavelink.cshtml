                }
                else
                {
                    <button type="button" onclick="formPost()" class="btn btn-primary @(editPermission==true?"":"dvdisabled")" onclick="return Validation()" id="btnSaveItemTemplate" disabled="disabled">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_004</button>
                }

            </div>
        </div>
        <div class="clearfix"></div>
    }
</div>
<script type="text/javascript">
    var inputs = [];
    $(document).ready(function () {
        $("#dropdown").on("click", function () {
            $(".dropMenu").slideToggle();
            $(".arrowDropUp").toggle();
        });

        $('.dropMenu ul li').on("click", function () {
            $('.dropMenu ul li').removeClass("activeSideMenu ");
            $(this).addClass("activeSideMenu");
        });
        $('.go-right').on("click", function (event) {
            var pos = $('div.overflow-hidden').scrollLeft() + 160;
            $('div.overflow-hidden').css("scroll-behavior", "smooth");
            $('div.overflow-hidden').scrollLeft(pos);

        });
        $('.go-left').on("click", function (event) {
            var pos = $('div.overflow-hidden').scrollLeft() - 160;
            $('div.overflow-hidden').css("scroll-behavior", "smooth");
            $('div.overflow-hidden').scrollLeft(pos);
        });


        callFormValidator("frmAddMicrowaveLink");

        $('.chosen-select').chosen({ width: '100%' });
        $('#specification').chosen().change(function (event) {
            var dID = $(this).val();
            bindVendor(dID);
        });
        $('#ddlVendor').chosen().change(function (event) {
            var specfi = $("#specification option:selected").val(); //
            var vandorid = $(this).val();
            var entitytype = $('#entityType').val();
            bindCateSubcat(entitytype, specfi, vandorid);
        });
        $('#ddlType').chosen().change(function (event) {
            var dID = $(this).val();
            bindBrand(dID);
        });
        $('#ddlBrand').chosen().change(function (event) {
            var dID = $(this).val();
            bindModel(dID);
        });

        EnableDisableUpdateButton("frmAddMicrowaveLink", @Model.system_id > 0 ? "btnUpdateItemTemplate" : "btnSaveItemTemplate");

        //$("#microwaveLinkMaster_network_id").val()
        //APPLY INPUT MASK ON NETWORK ID..
        getMaskedNetworkId('@Model.network_id', '@Model.system_id', '@Model.networkIdType');
        $("#frmAddMicrowaveLink").on("submit", function () {
            $("#microwaveLinkMaster_network_id").val($("#txtMaskedNetworkId").dxTextBox("option", "text").toUpperCase());
            si.upperCaseNetWorkId();
            if (!entityReferencevalidation())
                return false;
            return true;
        });
        $('.ModalFooter [title!=""]').tooltip({ title: '', html: true, placement: "top" });
    });
    function Validation() {
         
      /*  emID.addClass('input-validation-error');*/
        if ($('#ddlLinkType_chosen :selected').val() == "") {
           // $('#ddlLinkType').css('border-color', 'red');
            $('#ddlLinkType_chosen').addClass('input-validation-error');
            return false;
        } else {

            /*  $('#ddlLinkType').css('border-color', '');*/
            $('#ddlLinkType_chosen').removeClass('input-validation-error');
        }
        if (($('#ddlLinkType').val() == "Redundant Link") && ($('#ddlMainlinktype').val() == "")) {
            $('#ddlMainlinktype_chosen a').css('border-color', 'red');
            return false;
        } else {

            $('#ddlMainlinktype_chosen a').css('border-color', '');

        }
        if (($('#ddlLinkType').val() == "Redundant Link") && ($('#txtmainlinkid').val() == "")) {
            $('#txtmainlinkid').css('border-color', 'red');

            return false;
        } else {

            $('#txtmainlinkid').css('border-color', '');
        }


        if (($('#ddlLinkType').val() == "Main Link") && ($('#ddlredundantlinktype').val() == "")) {
            $('#ddlredundantlinktype_chosen a').css('border-color', 'red');
            return false;
        } else {

            $('#ddlredundantlinktype_chosen a').css('border-color', '');
        }
        if (($('#ddlLinkType').val() == "Main Link") && ($('#txtredundantlinkid').val() == "")) {

            $('#txtredundantlinkid').css('border-color', 'red');

            return false;
        } else {
            $('#txtredundantlinkid').css('border-color', '');
        }
    }
    function OnChangeddlLinkType()
    {
        if ($('#ddlLinkType_chosen :selected').val() == "")
        {
            $('#ddlLinkType_chosen').removeClass('input-validation-error');
        }
    }
    function formPost() {
         
        if ($('#txtbomsubcategory').val() == '') {
            $('#txtbomsubcategory').next().addClass('input-validation-error');
            return false;
        }
        else {
            $("#frmAddMicrowaveLink").submit();
        }
    }
</script>

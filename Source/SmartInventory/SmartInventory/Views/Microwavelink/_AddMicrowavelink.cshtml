                        @class = "chosen-select form-control",
                        @style = "padding:0;",
                    }, new { @id = "ddlredundantlinktype", @tabindex = "2", @title = "Status", @required = true }))*@

                                @Html.TextBoxFor(m => m.main_link_id, new { @class = "form-control", @maxlength = "50", @id = "txtmainlinkid" })
                            </div>
                        </div>

                        <div class="form-group row">

                            <label class="control-label col-sm-2">@Resources.Resources.SI_OSP_GBL_NET_GBL_190:</label>
                            <div class="col-md-4">
                                @*@Html.DropDownListFor(m => m.main_link_id, new List<SelectListItem>
                    {

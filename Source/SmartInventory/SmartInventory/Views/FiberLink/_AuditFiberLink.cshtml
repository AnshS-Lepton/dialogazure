@model Models.ViewAuditFiberLinkInfo
@{
    WebGrid grid = new WebGrid(rowsPerPage: Model.objFilterAttributes.pageSize, canSort: false, ajaxUpdateContainerId: "dvViewFiberLinkAudit", ajaxUpdateCallback: "onGridHeaderClick('tblFiberLinkHistory')");
    grid.Bind(Model.lstData, autoSortAndPage: false, rowCount: Model.objFilterAttributes.totalRecord);
    if (Model.objFilterAttributes.totalRecord > 0)
    {
        grid.PageIndex = Model.objFilterAttributes.currentPage - 1;
    }
}

<!DOCTYPE html>
<div class="libDetail">
    @using (Ajax.BeginForm("GetFiberLinkHistory", "Audit", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "dvChildModalBody", LoadingElementId = "dvProgress" },
                                 new { id = "frmFiberLinkHistory", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {
        @Html.HiddenFor(m => m.LinkSystemId); 

        if (Model.lstData.Count > 0)
        {
            <div class="d-flex space-pad" id="dvBtnAction">
                <div class="div_totalRecord"><b>@Resources.Resources.SI_OSP_GBL_GBL_GBL_035:&nbsp;<span>@grid.TotalRowCount</span></b></div>
                <div class="ml-auto">
                    @if (@grid.TotalRowCount > 0)
                    {
                        @*<input type="button" id="btnExport" value="Export" class="btn btn-primary" />*@ <span id="btnExport" class="btn exp--btn" value="Export"><i class="icon-Export mr-03"></i> @Resources.Resources.GBL_GBL_GBL_GBL_GBL_010</span>
                    }
                    else
                    {
                        <input type="button" id="btnExport" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_010" disabled="disabled" class="btn exp--btn" />
                    }
                </div>
            </div>
            <div id="objViewAuditHistory">

                @if (Model.lstData.Count > 0)
                {
                    <div id="dvViewFiberLinkAudit">
                        <div class="tablePad--tn">
                            <div class="table-responsive">
                                @grid.GetHtml(tableStyle: "grid",
                             htmlAttributes: new { id = "tblFiberLinkHistory" },
                                mode: WebGridPagerModes.All)
                            </div>
                        </div>
                    </div>
                }
            </div>

        }
        else
        {
            <div class="nr-found">
                <span> @Resources.Resources.SI_OSP_GBL_GBL_RPT_001</span>
            </div>
        }

    }
</div>

<script>
    $(document).ready(function () {

        //$('tfoot a').on("click", function () {
        //    $('form').attr('action', $(this).attr('href')).submit();
        //    return false;
        //});
        $('th a, tfoot a').on("click", function () {
             
            $('#frmFiberLinkHistory').attr('action', $(this).attr('href')).submit();
            return false;
        });
        changeColor('tblFiberLinkHistory');

        $("#btnExport").on("click", function () {
             
            fiberLink.FiberLinkAuditReport("DownloadFiberLinkHistory");
        });

    });
</script>



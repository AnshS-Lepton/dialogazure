                        <div class="col-md-6 col-sm-6 d-flex" id="divDocumentUpload">
                            <input type="file" class="file" name="FiberLinkDocUpload" id="FiberLinkDocUpload">
                            <a href="#" class="fiberLInk" onclick="fiberLink.attachment.upload(@Model.system_id,'','');" value="Upload" id="btnUploadDocument">@Resources.Resources.SI_OSP_STR_NET_FRM_037</a>
                            <a href="#" class="fiberLInk" onclick="fiberLink.attachment.clear();" value="Clear" id="btnClearDocument">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_009</a>
                        </div>
                        <div class="col-md-6 col-sm-6" id="divDocumentUpload"></div>
                    </div>

                    <div id="divFiberLinkAttachment" class="tab-pane y-scroll">

                        @Html.Partial("~/Views/Library/_ViewFiberLinkAttachment.cshtml", Model.lstFiberLinkAttachments)
                    </div>
                </fieldset>
            }

        </div>
        <div class="ModalFooter d-flex">
            <button type="button" id="btnclear" class="btn btn-default ml-auto" onclick="fiberLink.resetCreateLink();"> @Resources.Resources.GBL_GBL_GBL_GBL_GBL_005</button>
            <button type="button" id="btnCreateLink" class="btn btn-success ml-10" onclick="fiberLink.createUpdateLink(true);">@(Model.system_id == 0 ? Resources.Resources.SI_OSP_GBL_GBL_GBL_038 : Resources.Resources.GBL_GBL_GBL_GBL_GBL_003)</button>
        </div>
    </div>
}
<script type="text/javascript">
    if (typeof fiberLink === 'undefined' || fiberLink === null) {
        var fiberLink = new FiberLink();
    }
    $(document).ready(function () {
       // fiberLink.InitApp();
        callFormValidator("frmAddFiberLink");
    });
</script>

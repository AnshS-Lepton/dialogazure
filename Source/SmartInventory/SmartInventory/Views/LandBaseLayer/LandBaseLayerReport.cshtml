@model Models.ExportLandBaseLayerReport
@using System.Globalization;

<style>
    .table-scroll {
        position: relative;
        z-index: 1;
        overflow: auto;
        height: 380px;
    }


        .table-scroll thead th {
            position: -webkit-sticky;
            position: sticky;
            top: 0;
        }
        /* safari and ios need the tfoot itself to be position:sticky also */
        .table-scroll tfoot,
        .table-scroll tfoot th,
        .table-scroll tfoot td {
            position: -webkit-sticky;
            position: sticky;
            bottom: 0;
            z-index: 4;
        }

    /*.table-scroll a{
        background: #00ba8a;
    }*/

    th:first-child {
        position: -webkit-sticky;
        position: sticky;
        left: 0;
        z-index: 2;
        background-color: #00ba8a;
    }

    thead th:first-child,
    tfoot th:first-child {
        z-index: 5;
    }

    #tblSummaryAll > tfoot > tr > th {
        padding: 3px;
    }

    .t-pl-pr {
        padding-left: 15px;
        padding-right: 15px;
    }
</style>
<!DOCTYPE html>
<div class="exportReportHeader">
    <ul id="ulRptTabs" class="tab">
        <li id="liFilter" class="tablinks activerpt" onclick="SwitchReportTabs(this.id, 'divFilter')"><i>1</i>@Resources.Resources.SI_OSP_GBL_NET_FRM_063</li>
        <li id="liSummary" class="tablinks" onclick="SwitchReportTabs(this.id, 'divSummary')"><i>2</i>@Resources.Resources.SI_OSP_GBL_NET_FRM_064</li>
    </ul>
</div>
@{
    var total_count = 0;
}
<div class="ExportReportbody">
    @using (Ajax.BeginForm("LandBaseLayerExportReport", "Report", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "dvModalBody", LoadingElementId = "dvReportProgress", OnSuccess = "switchToResultTab()" }, new { id = "frmExportLandBaseLayerSummaryData", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {
        @Html.HiddenFor(m => m.objReportFilters.geom)
        @Html.HiddenFor(m => m.objReportFilters.geomType)
        @Html.HiddenFor(m => m.objReportFilters.SelectedParentUser, new { id = "hdnSelectedParentUsers" })
        <div class="EEReport" id="divFilter">
            <div class="scrollDiv space-pad">
                @if (Model.objReportFilters.geom != null && Model.objReportFilters.geom != "")
                {
                    <div class="row form-group row">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_065:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedRegionId, new SelectList(Model.lstRegion.Select(x => new { Value = x.regionId.ToString(), Text = x.regionName.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @onchange = "si.onChangeRegion();", @id = "ddlRegions", @disabled = "disabled" })
                        </div>
                    </div>
                    <div class="row form-group row">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_066:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedProvinceId, new SelectList(Model.lstProvince.Select(x => new { Value = x.provinceId.ToString(), Text = x.provinceName.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlProvinces", @disabled = "disabled" })
                        </div>
                    </div>
                }
                else
                {
                    <div class="row form-group row">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_065:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedRegionId, new SelectList(Model.lstRegion.Select(x => new { Value = x.regionId.ToString(), Text = x.regionName.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @onchange = "si.onChangeRegion();", @id = "ddlRegions" })
                        </div>
                    </div>
                    <div class="row form-group row">
                        <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_066:</div>
                        <div class="col-md-9">
                            @Html.DropDownListFor(m => m.objReportFilters.SelectedProvinceId, new SelectList(Model.lstProvince.Select(x => new { Value = x.provinceId.ToString(), Text = x.provinceName.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlProvinces" })
                        </div>
                    </div>
                }
                <div class="row form-group row">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_068:</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.SelectedParentUser, new SelectList(Model.lstParentUsers.Select(x => new { Value = x.user_id.ToString(), Text = x.user_name.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlParentUsers", @onchange = "si.onChangeParentUser();" })
                    </div>
                </div>
                <div class="row form-group row">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_069:</div>
                    <div class="col-md-9">
                        <select id="ddlUsers" name="objReportFilters.SelectedUserId" multiple class="chosen-select col-sm-12">

                            @foreach (var attribute in Model.lstUsers.GroupBy(x => x.groupUser))
                            {
                                <optgroup value="@attribute.Key" label="@attribute.Key">
                                    @foreach (var user in attribute)
                                    {
                                        <option value="@user.user_id">@user.user_name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                </div>
                <div class="row form-group row">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_020:</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.SelectedLayerId, new SelectList(Model.lstLayers.Select(x => new { Value = x.id.ToString(), Text = x.layer_name.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddlLayers" })
                    </div>
                </div>
                <div class="row form-group row">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_071<i class="clsMandatory">*</i>:</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.durationbasedon, new SelectList(Model.lstDurationBasedOn.Select(x => new { Value = x.dropdown_key.ToString(), Text = x.dropdown_value.ToString() }), "Value", "Text"), new { @class = "chosen-select col-sm-12", @id = "ddlDurationBasedOn" })
                    </div>
                </div>
                <div class="row form-group row">
                    <div class="col-md-3">@Resources.Resources.SI_OSP_GBL_NET_FRM_072<i class="clsMandatory">*</i>:</div>
                    <div class="col-md-9">
                        @Html.DropDownListFor(m => m.objReportFilters.customDate, new List<SelectListItem>{
                                new SelectListItem { Text = "Custom", Value = "1"},
                                new SelectListItem { Text = "Today", Value = "2"},
                                new SelectListItem { Text = "Previous Day", Value = "3"},
                                new SelectListItem { Text = "Last 7 Days", Value = "4"},
                                new SelectListItem { Text = "Last 30 Day", Selected=true, Value = "5"},
                                new SelectListItem { Text = "Last 3 Months", Value = "6"},
                                new SelectListItem { Text = "Last 6 Months", Value = "7"},
                              new SelectListItem { Text = "Last 1 Year", Value = "8"},
                            }, new { @class = "chosen-select", @onchange = "onChangeCustomDate();", @id = "customedate" })
                    </div>
                </div>
                <div class="row form-group row">
                    <div class="col-md-3"></div>
                    <div class="col-md-9 pl-0 pr-0">
                        <div class="col-md-6">
                            @Html.TextBoxFor(m => m.objReportFilters.fromDate, new { @id = "txtDateFrom", @title = Resources.Resources.SI_OSP_GBL_NET_FRM_096, @tabindex = "4", @class = "input-sm form-control", @readonly = true, @placeholder = Resources.Resources.SI_OSP_GBL_NET_FRM_096 })
                            <img id="imgFromDate" class="calend" src="@Url.Content("~/Content/images/calendar.png")">
                        </div>
                        <div class="col-md-6">
                            @Html.TextBoxFor(m => m.objReportFilters.toDate, new { @id = "txtDateTo", @title = Resources.Resources.SI_OSP_GBL_NET_FRM_097, @tabindex = "4", @class = "input-sm form-control", @placeholder = Resources.Resources.SI_OSP_GBL_NET_FRM_097 })
                            <img id="imgToDate" class="calend" src="@Url.Content("~/Content/images/calendar.png")">
                        </div>
                    </div>
                </div>
            </div>
            <div class="ModalFooter d-flex">
                <button type="button" class="btn btn-default ml-auto" id="btnEntityExportClear">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_005</button>
                <button type="submit" class="btn btn-success ml-10" id="btnShowReportData">@Resources.Resources.SI_OSP_GBL_GBL_GBL_040</button>
            </div>
        </div>
        <div class="EEReport Summary" id="divSummary">
            <div id="dvReportProgress" class="ExportReportProgress"></div>

            @if (Model.lstReportData.Count > 0)
            {
                <div class="space-pad d-flex">
                    <div class="fw-bold">@Resources.Resources.SI_OSP_GBL_GBL_GBL_035: @Model.lstReportData.Count</div>
                    <div id="dvReportProgress1" class="progress utili-prog-bar" style="display:none;">
                        <div class="progress-bar progress-bar-striped" style="width:70%;background-color: darkgreen;">@Resources.Resources.SI_OSP_GBL_NET_FRM_073</div>
                    </div>

                    <div class="ml-auto">
                        <button type="button" class="btn btn-default dropfiles">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_010 <i class="fa fa-chevron-down" aria-hidden="true"></i></button>
                        <div class="dropbox">
                            <span onclick="ExportLandBaseLayerSummaryDetail('PDF',false)">@Resources.Resources.SI_OSP_GBL_NET_GBL_004</span>
                            <span onclick="ExportLandBaseLayerSummaryDetail('EXCEL',false)">@Resources.Resources.SI_OSP_GBL_NET_GBL_005</span>
                            <span onclick="ExportLandBaseLayerSummaryDetail('ALLEXCEL',false)">@Resources.Resources.SI_OSP_GBL_NET_GBL_006</span>
                            <span onclick="ExportLandBaseLayerSummaryDetail('ALLCSV',false)">All Data (CSV)</span>
                            <span onclick="ExportLandBaseLayerSummaryDetail('KML',false)">@Resources.Resources.SI_OSP_GBL_NET_GBL_007</span>
                            @*<span onclick="ExportLandBaseLayerSummaryDetail('ALLSHAPE',false)">@Resources.Resources.SI_OSP_GBL_NET_FRM_074</span>*@
                            <span onclick="ExportLandBaseLayerSummaryDetail('ALLSHAPE',false)">All Data (Shape M)</span>
                            @*<span onclick="ExportLandBaseLayerSummaryDetail('ALLSHAPE',true)">@Resources.Resources.SI_OSP_GBL_NET_FRM_074</span>*@
                            <span onclick="ExportLandBaseLayerSummaryDetail('ALLSHAPE',true)">All Data (Shape S)</span>
                            <span onclick="ExportLandBaseLayerSummaryDetail('DXF',false)">Record(DXF)</span>
                        </div>
                    </div>
                </div>
            }
            <div class="scrollDiv table-scroll t-pl-pr mt-1rem">
                <div class="form-group">
                    @if (Model.lstReportData.Count > 0)
                    {
                        <table class="grid" id="tblSummaryAll">
                            <thead>
                                <tr>
                                    <th scope="col">
                                        <input type="checkbox" checked="checked" class="checkbox-custom" id="checkallentity" onclick="selectallentity(this)"><b><label for="checkallentity" class="checkbox-custom-label"></label></b>
                                    </th>
                                    <th scope="col">@Resources.Resources.SI_OSP_GBL_NET_FRM_438</th>

                                    <th align="center" scope="col">@Resources.Resources.SI_OSP_GBL_NET_FRM_403</th>

                                    <th scope="col">@Resources.Resources.SI_OSP_GBL_GBL_GBL_028</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.lstReportData)
                                {
                                    var chkid = item.entity_id;
                                    <tr>
                                        <td><input type="checkbox" checked="checked" class="checkbox-custom chksingle" id="@chkid" onclick="ManageHeaderCheckBox()"><b><label for="@chkid" class="checkbox-custom-label"></label></b></td>
                                        <td>@item.entity_title</td>
                                        <td align="center" class="tdcount">@item.entity_count</td>
                                        <td>
                                            <a href="#" onclick="LandBase.ExportLayerSummaryView('@item.entity_name');" class="dropdown-toggle @(item.entity_count == 0 ? "btnNotAllowed" : "")" title="@Resources.Resources.SI_OSP_GBL_GBL_GBL_042">

                                                <i class="glyphicon glyphicon-eye-open"></i>
                                            </a>

                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    @foreach (var item in Model.lstReportData)
                                    {
                                        total_count += item.entity_count;
                                    }
                                    <th align="center" colspan="2" id="thtotalName">@Resources.Resources.SI_OSP_GBL_GBL_GBL_041</th>
                                    <th align="center" id="thalltotal">@total_count</th>
                                    <th align="center" id="thalltotal"></th>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="nr-found">
                            <span>@Resources.Resources.SI_OSP_GBL_GBL_RPT_001</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">

    function onChangeOwnershipType() {
         
        if ($("#ddlFilterOwnershipType").val() == 'Own' || $("#ddlFilterOwnershipType").val() == null || $("#ddlFilterOwnershipType").val() == undefined) {
            $('#ddl3rdPartyVendor').val('');
            $('#ddl3rdPartyVendor').prop('disabled', true).trigger("chosen:updated");
        }
        else {
            $('#ddl3rdPartyVendor').prop('disabled', false).trigger("chosen:updated");
            @*var selectedthirdpartyvalues = '@Model.objReportFilters.SelectedThirdPartyVendors.Replace("'","")';
            $("#ddl3rdPartyVendor").val(selectedthirdpartyvalues.split(',')).trigger("chosen:updated");*@
        }
    }
    function SwitchReportTabs(tabLinkId, tabDivId) {
        if (tabDivId == "divSummary") {
            if (isValidReportFilter()) {
                $("#frmExportLandBaseLayerSummaryData").submit();
            }
            else {
                return;
            }
        }
        else { $('.dropbox').css("display", "none"); }
        $('.EEReport').not('#' + tabDivId).hide();
        $('#' + tabDivId).show();
        $('#ulRptTabs > li').removeClass("activerpt");
        $('#' + tabLinkId).addClass("activerpt");
    }

    $('.chosen-select').chosen({ placeholder_text_multiple: '--All--', width: '100%' });

    $(document).ready(function () {
         
        if ($("#txtDateFrom").val() == "") {
            $("#customedate").val(5).trigger("chosen:updated");
            onChangeCustomDate();
        }
        if ($("#customedate_chosen").children('a').text().trim() != "Custom") {

            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        var SelectedRegionIds = '@Model.objReportFilters.SelectedRegionIds';
        $("#ddlRegions").val(SelectedRegionIds.split(',')).trigger("chosen:updated");

        var selectedProvinces = '@Model.objReportFilters.SelectedProvinceIds';
        $("#ddlProvinces").val(selectedProvinces.split(',')).trigger("chosen:updated");


        //$("#ddlParentUsers").val(SelectedParentUsers.split(',')).trigger("chosen:updated");

        //alert(SelectedUserIds);
        var selectedLayerIds = '@Model.objReportFilters.SelectedLayerIds';
        $("#ddlLayers").val(selectedLayerIds.split(',')).trigger("chosen:updated");


        si.setDateTimeCalendar_ExportEntities("txtDateFrom", "txtDateTo", "imgFromDate", "imgToDate", false);
        if ($('#ddlParentUsers > option').length > 1) {
            si.onChangeParentUser();
            var SelectedUserIds = '@Model.objReportFilters.SelectedUserIds';
            $("#ddlUsers").val(SelectedUserIds.split(',')).trigger("chosen:updated");
        }
         
        if ($('#ddlParentUsers > option').length == 1) {
            $('#ddlParentUsers option:first-child').attr("selected", "selected").trigger("chosen:updated");

            si.onChangeParentUser();
            $('#hdnSelectedParentUsers').val($('#ddlParentUsers option:first-child').val());
            $('#ddlParentUsers').attr("disabled", true).trigger("chosen:updated");

            var SelectedUserIds = '@Model.objReportFilters.SelectedUserIds';
            $("#ddlUsers").val(SelectedUserIds.split(',')).trigger("chosen:updated");
        }
        //$('.chosen-select').trigger("chosen:updated");
    });

    $('#btnEntityExportClear').on("click", function () {
        ResetExportEntitesFilterValues();
    });

    function switchToResultTab() {
        //SHOW SUMMARY TAB
        $("#divFilter").hide();
        $("#divSummary").show();
        $("#liFilter").removeClass("activerpt");
        $("#liSummary").addClass("activerpt");
    }

    function isValidReportFilter() {
        if ($("#txtDateFrom").val() == "") {
            alert(MultilingualKey.SI_OSP_GBL_JQ_RPT_010);
            return false;
        }
        else if ($("#txtDateTo").val() == "") {
            alert(MultilingualKey.SI_OSP_GBL_JQ_RPT_011);
            return false;
        }
        else {
            return true;
            //var startDate = new Date($('#txtDateFrom').val());
            //var endDate = new Date($('#txtDateTo').val());
            //var configuredDay = 365 * 5;
            //var diffInDays = Math.round(Math.abs((startDate.getTime() - endDate.getTime()) / (24 * 60 * 60 * 1000)));
            //if (diffInDays > configuredDay) {
            //    alert('Difference between From date and To date should not be more than ' + parseInt(configuredDay / 365) + ' years !')
            //    return false;
            //}
            //else {
            //    return true;
            //}
        }
    }

    $("#btnShowReportData").on("click", function () {
        if (isValidReportFilter()) {
            //SHOW SUMMARY TAB
            $("#divFilter").hide();
            $("#divSummary").show();
            $("#liFilter").removeClass("activerpt");
            $("#liSummary").addClass("activerpt");
            return true;
        }
        else {
            return false;
        }
    });

    function ResetExportEntitesFilterValues() {
        $('#ddlLayers').val(0).trigger("chosen:updated");
        $('#SelectedNetworkStatus').val(0).trigger("chosen:updated");
        $('#ddlRegions').val(0).trigger("chosen:updated");
        $('#ddlProvinces').empty().trigger("chosen:updated");
        $('#ddlProvinces').val(0).trigger("chosen:updated");
        //$('#ddlParentUsers').val(0).trigger("chosen:updated");
        $('#ddlUsers').val(0).trigger("chosen:updated");
        $('#ddlProjectCode').val('').trigger("chosen:updated");
        $('#ddlPlanningCode').empty().trigger("chosen:updated");;
        $('#ddlWorkorderCode').empty().trigger("chosen:updated");;
        $('#ddlPurposeCode').empty().trigger("chosen:updated");;
        $('#ddlDurationBasedOn').val("Created_On").trigger("chosen:updated");
        $('#txtDateFrom').val('');
        $('#txtDateTo').val('');
        $('#customedate').val(5).trigger("chosen:updated");
        $('#ddlFilterOwnershipType').val(0).trigger("chosen:updated");
        $('#ddl3rdPartyVendor').val(0).trigger("chosen:updated");
        onChangeOwnershipType();
        onChangeCustomDate();

        if ($('#ddlParentUsers > option').length == 1) {
            $('#ddlParentUsers option:first-child').attr("selected", "selected").trigger("chosen:updated");

            si.onChangeParentUser();
            $('#hdnSelectedParentUsers').val($('#ddlParentUsers option:first-child').val());
            $('#ddlParentUsers').attr("disabled", true).trigger("chosen:updated");

            var SelectedUserIds = '@Model.objReportFilters.SelectedUserIds';
            $("#ddlUsers").val(SelectedUserIds.split(',')).trigger("chosen:updated");
        }
        else {
            $('#ddlParentUsers').val(0).trigger("chosen:updated");
        }
    }

    function selectallentity(chkAll) {
        if (!$(chkAll).is(":checked")) {
            $("#tblSummaryAll input[type=checkbox]:not('#checkallentity')").removeAttr("checked");
        }
        else {
            $("#tblSummaryAll input[type=checkbox]:not('#checkallentity')").prop("checked", true);
        }
        ManageHeaderCheckBox();
    }

    function ManageHeaderCheckBox() {
        if ($("#tblSummaryAll input[type=checkbox]:not('#checkallentity')").length ==
            $("#tblSummaryAll input[type=checkbox]:not('#checkallentity'):checked").length) {
            $("#thtotalName")[0].innerHTML = MultilingualKey.SI_OSP_GBL_GBL_GBL_041;
            $("#checkallentity").prop("checked", true);
        }
        else {
            $("#thtotalName")[0].innerHTML = MultilingualKey.SI_GBL_GBL_JQ_FRM_028;// "Selected Total";
            $("#checkallentity").prop("checked", false);
        }

        //for sum of footer
        //var plannedTotal = parseInt(0);
        //var asBuildTotal = parseInt(0);
        //var dormantTotal = parseInt(0);

        var countTotal = parseInt(0);

        $("#tblSummaryAll input[type=checkbox]:not('#checkallentity')").each(function () {
            var row = $(this).closest('tr');
            var checkstatus = $(this).is(":checked")
            if (row.find(".tdcount")[0] != undefined) {
                if (!isNaN(row.find(".tdcount")[0].innerText) && checkstatus == true) {
                    countTotal += parseInt(row.find(".tdcount")[0].innerText);
                }
            }
        })
        $("#thalltotal")[0].innerHTML = countTotal;
    }

    function ExportLandBaseLayerSummaryDetail(purpose,singleFileDownlaod) {
         
        var entityids = "";
        var chkAll = document.getElementById("checkallentity");
        if (chkAll.checked == true) {
            entityids = '@Model.objReportFilters.SelectedLayerIds';
        }
        else {
            //Fetch all rows of the Table.
            var rows = $("#tblSummaryAll input[type=checkbox]:not('#checkallentity'):checked"); //document.getElementById("tblSummaryAll").rows;
            //Execute loop on all rows excluding the Header row.
            for (var i = 0; i < rows.length; i++) {
                //if (rows[i].getElementsByTagName("INPUT")[0].checked) {
                entityids += entityids != "" ? ("," + rows[i].id) : rows[i].id;
                //}
            }
        }
        if (chkAll.checked == false && entityids == "") {
            alert(MultilingualKey.SI_OSP_GBL_JQ_GBL_109);//"Please select at least 1 record!"
        }
        else {
            if (purpose == "ALLEXCEL" || purpose == "KML" ||purpose == "ALLCSV") {
                var SummaryTotal = parseInt(0);
                //Loop through all checked CheckBoxes in GridView.
                //$("#tblSummaryAll input[type=checkbox]:checked").each(function (index) {
                //    var row = $(this).closest("tr")[0];
                //    if (row.cells[1].innerHTML != "Entity Name") {
                //        SummaryTotal += parseInt(row.cells[2].innerHTML);
                //        SummaryTotal += parseInt(row.cells[3].innerHTML);
                //        SummaryTotal += parseInt(row.cells[4].innerHTML);
                //    }
                //});
                $("#tblSummaryAll input[type=checkbox]:not('#checkallentity')").each(function () {
                    var row = $(this).closest('tr');
                    var checkstatus = $(this).is(":checked")
                    if (row.find(".tdplannedcount")[0] != undefined) {
                        if (!isNaN(row.find(".tdplannedcount")[0].innerText) && row.find(".tdplannedcount")[0].innerText.length != 0 && checkstatus == true) {
                            SummaryTotal += parseInt(row.find(".tdplannedcount")[0].innerText);
                        }
                    }
                    if (row.find(".tdasbuiltcount")[0] != undefined) {
                        if (!isNaN(row.find(".tdasbuiltcount")[0].innerText) && row.find(".tdasbuiltcount")[0].innerText.length != 0 && checkstatus == true) {
                            SummaryTotal += parseInt(row.find(".tdasbuiltcount")[0].innerText);
                        }
                    }
                    if (row.find(".tddormantcount")[0] != undefined) {
                        if (!isNaN(row.find(".tddormantcount")[0].innerText) && row.find(".tddormantcount")[0].innerText.length != 0 && checkstatus == true) {
                            SummaryTotal += parseInt(row.find(".tddormantcount")[0].innerText);
                        }
                    }
                })
                 
                //SummaryTotal = 110000;
                var MaxRecord = $("#hdnExportReportMaxRecord").val();
                if (SummaryTotal > MaxRecord) {
                    alert($.validator.format(MultilingualKey.SI_OSP_GBL_JQ_FRM_067, MaxRecord));
                    //alert(MultilingualKey.SI_OSP_STR_JQ_FRM_002+" " + MaxRecord + " " + MultilingualKey.SI_OSP_GBL_JQ_FRM_067);
                    $("#divSummary .dropfiles").trigger("click");
                    return false;
                }
            }
            $("#dvReportProgress1").show();
            $('#dvReportProgress1').css('display', 'block');
            setCookie('downloadStarted', 0, 3600); //Expiration could be anything... As long as we reset the value
            setTimeout(checkDownloadCookie, 1000); //Initiate the loop to check the cookie.
            LandBase.ExportLandBaseLayerReportSummary(purpose, entityids, singleFileDownlaod);
            //$("#dvReportProgress").hide();
            $("#divSummary .dropfiles").trigger("click");
        }
    }
    var downloadTimeout;
    var checkDownloadCookie = function () {
        //console.log(getCookie("downloadStarted"));
        if (getCookie("downloadStarted") == 1) {
            //console.log(getCookie("downloadStarted") + "RT");
            setCookie("downloadStarted", false, 100); //Expiration could be anything... As long as we reset the value
            $('#dvReportProgress1').hide();
        } else {
            downloadTimeout = setTimeout(checkDownloadCookie, 1000); //Re-run this function in 1 second.
        }
    }
    var setCookie = function (name, value, expiracy) {
        var exdate = new Date();
        exdate.setTime(exdate.getTime() + expiracy * 1000);
        var c_value = escape(value) + ((expiracy == null) ? "" : "; expires=" + exdate.toUTCString());
        document.cookie = name + "=" + c_value + '; path=/';
    };

    var getCookie = function (name) {
        var i, x, y, ARRcookies = document.cookie.split(";");
        for (i = 0; i < ARRcookies.length; i++) {
            x = ARRcookies[i].substr(0, ARRcookies[i].indexOf("="));
            y = ARRcookies[i].substr(ARRcookies[i].indexOf("=") + 1);
            x = x.replace(/^\s+|\s+$/g, "");
            if (x == name) {
                return y ? decodeURI(unescape(y.replace(/\+/g, ' '))) : y; //;//unescape(decodeURI(y));
            }
        }
    };
    //export-report-cal
    function onChangeCustomDate() {
        var value = $('#customedate option:selected').val();
        SetFromAndToDate(value);
    }

    function SetFromAndToDate(value) {
        var endDate = new Date();
        var startDate = new Date();
        var startDateDiff = 0;
        var endDateDiff = 0;
        if (value == 1) // custom
        {
            $('#txtDateFrom').val("");
            $('#txtDateTo').val("");
            $("#imgFromDate").show();
            $('#imgToDate').show();
            return;
        }
        else if (value == 2) { //Today
            startDateDiff = 0;
            endDateDiff = 0;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 3) { //previous day
            startDateDiff = -1;
            endDateDiff = -1;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 4) {//last 7 days
            startDateDiff = -6;
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 5) {//last 30 days
            startDateDiff = getDaysDiffByMonth(1);
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 6) {//last 3 Months
            startDateDiff = getDaysDiffByMonth(3);
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 7) {//last 6 Months
            startDateDiff = getDaysDiffByMonth(6);
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
        else if (value == 8) {//last 1 year
            startDateDiff = getDaysDiffByMonth(12);
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }

        startDate.setDate(startDate.getDate() + startDateDiff);
        endDate.setDate(endDate.getDate() + endDateDiff);

        var newStartDate = startDate.toDateString();
        newStartDate = new Date(Date.parse(newStartDate));

        var newEndDate = endDate.toDateString();
        newEndDate = new Date(Date.parse(newEndDate));

        $('#txtDateFrom').val(fncCurrentDate(newStartDate));
        $('#txtDateTo').val(fncCurrentDate(newEndDate));
        if (value == 0) {
            $('#txtDateFrom').val('');
            $('#txtDateTo').val('');
            $('#imgFromDate').hide();
            $('#imgToDate').hide();
        }
    }

    function getDaysDiffByMonth(_monthCount) {
        var previousDate = new Date();
        previousDate.setMonth(previousDate.getMonth() - _monthCount);
        return parseInt((previousDate.getTime() - new Date().getTime()) / (1000 * 3600 * 24)) + 1;
    }

</script>

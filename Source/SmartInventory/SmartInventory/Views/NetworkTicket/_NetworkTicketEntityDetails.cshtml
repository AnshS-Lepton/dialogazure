    function verifyEntities() {
        var p_remarks = $("#txtRemarks").val();
        if( $("#hdnStatus").val()=='R')
        {
            var _comment = getRejectComment();
            if (_comment.trim() != '')
            {
                validateEntitiest();
            }
        }
        else  if (p_remarks != "") {
            $("#txtRemarks").css('border-color', '');
            validateEntitiest();
        }
        else {
            $("#txtRemarks").css('border-color', 'red');
            //alert("Remarks cannot be blank!");
        }
    };
    function validateEntitiest() {
        var p_remarks = $("#txtRemarks").val();
        if(p_remarks=""){
            p_remarks=   getRejectComment();
        }
        $("#dvEntitydetailsProgress").show();
        $("#verify").addClass("dvdisabled")
        var p_entity_ids_types = $("#hdnentityidstypes").val();
        var p_ticket_id = $("#hdnticketid").val();
        var _status = $("#hdnStatus").val();
            var type= $("#headers").text()
            showConfirm($.validator.format(MultilingualKey.SI_OSP_BUL_JQ_RPT_001, type), function () {
                ajaxReq('NetworkTicket/VerifyEntities', { ticket_id: p_ticket_id, entity_ids_types: p_entity_ids_types, remarks: p_remarks,status:_status }, true, function (resp) {
                    if (resp.status == "OK") {
                        alert(resp.message);
                        $("#verify").modal("hide");
                        $('#headers').removeAttr();
                        $("#txtRemarks").val("");
                        getNWEntitydetais(@Model.objNetworkTicket.ticket_id,'@Model.objNetworkTicket.Network_Ticket_ID','@Model.objNetworkTicket.ticket_status','','','@Model.objNetworkTicket.ticket_type')
                        $("#networkEntityDetails").toggleClass("active");
                        $("#networkEntityDashboard").toggleClass("active");
                        $("#dvEntitydetailsProgress").hide();

                    }

                    else {
                        alert(resp.message);
                        $("#dvEntitydetailsProgress").hide();
                    }
                }, false, false);
            });



    }

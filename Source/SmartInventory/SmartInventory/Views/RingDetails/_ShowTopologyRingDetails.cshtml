        $('.chosen-select').chosen({ width: '100%' });
        $('th a, tfoot a').on("click", function () {
            // onGridHeaderClick('tblFiberLinkGrid');
            $('#frmViewRingDetails').attr('action', $(this).attr('href')).submit();
            return false;
        });


    });

        HttpMethod = "POST",
        UpdateTargetId = "dvModalBody",
        //LoadingElementId = "dvViewLinkProgress",
        InsertionMode = InsertionMode.Replace
    }, new { id = "frmViewRingDetails", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
    {
        
            @Html.HiddenFor(m => m.objRingDetails.region_name, new { id = "hdnregionname" })
            @Html.HiddenFor(m => m.objRingDetails.segment_code, new { id = "hdnsegmentname" })
            @Html.HiddenFor(m => m.objRingDetails.ring_capacity, new { id = "hdnringname" })
            <!-- Filters Section -->
            <div class="libTabContent">
                <!-- Tab panes -->
                <div class="tab-content">
                    <div class="tab-pane active" id="GISInfo">

                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="searchby">Region:</label>
                            <div class="col-sm-4">

                                @Html.DropDownListFor(m => m.objRingDetails.SearchbyRegionName,
                                    new SelectList(Model.lstRegionName.Select(x => new { Value = x.value.ToString().ToString(), Text = x.value.ToString() }), "Value", "Text"),
                                    "--Select--",
                                    new { @class = "chosen-select", @id = "ddllstRegionName" })


                            </div>
                            <label class="control-label col-sm-2" for="searchby">Segment:</label>
                            <div class="col-sm-4">

                                @Html.DropDownListFor(m => m.objRingDetails.SearchbySegmentName,
                                    new SelectList(Model.lstSegmentName.Select(x => new { Value = x.value.ToString(), Text = x.value.ToString() }), "Value", "Text"),
                                    "--Select--",
                                    new { @class = "chosen-select col-sm-12", @id = "ddllstSegmentName" })

                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="control-label col-sm-2" for="searchby">Ring Code:</label>

                            <div class="col-sm-4">


                                @Html.DropDownListFor(m => m.objRingDetails.SearchbyRingTypes, new SelectList(Model.lstRingType.Select(x => new { Value = x.value.ToString(), Text = x.value.ToString() }), "Value", "Text"), new { @multiple = "multiple", @class = "chosen-select col-sm-12", @id = "ddllstRingName" })


                <input type="submit" id="btnRingReset" class="btn btn-default ml-10" value="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_005" />
            </div>



            if (Model.lstRingDetails.Count > 0)
            {
<div class="table-responsive">
    <div class="d-flex mb-15">
        <div class="div_totalRecord">

                                                    <i class="fa fa-globe action_icon fa-fw m-r-xs"></i>
                                                    @*<i class="cptr fa fa-bullseye m-r-xs" title="Schematic View" onclick="GetSLDDaigramFiberLink(@item.id, '@item.ring_code')" style="color: #FFA500; font-size: 14px; padding-left: 7px"></i>*@
                                                </a>
                                                <a href="javascript:void(0);"
                                                   title="Schematic View"
                                                   onclick="getslddaigramfiberlink(@item.id, '@item.ring_code')">
                                                    <i class="cptr fa fa-bullseye m-r-xs" style="color: #FFA500; font-size: 14px; padding-left: 7px"></i>

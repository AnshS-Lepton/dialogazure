            icon: imageUrl,
            draggable: false,
            id: system_id,
            eType: en_type,
            portNo: port_no,
            networkId: network_id,
            isVirtualPortAllowed: is_virtual_port_allowed
        });

        return gmarkernew;
    }
    this.ShowEntityOnMap = function (ringId) {

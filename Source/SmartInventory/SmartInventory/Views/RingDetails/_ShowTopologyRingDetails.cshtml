grid.Column("region_name", "Region", format: @<text>@item.region_name</text> , canSort: true),
grid.Column("agg1_site_id", "Aggregate Site 1", format: @<text>@item.agg1_site_id</text>, canSort: true),
grid.Column("agg2_site_id", "Aggregate Site 2", format: @<text>@item.agg2_site_id</text>, canSort: true),
grid.Column("ring_capacity", "Capacity", format: @<text>@item.ring_capacity</text>, canSort: true),
grid.Column("description", "Description", format: @<text>@item.description</text>, canSort: true),

grid.Column("bh_status", "Site Status of the Access Ring", format: @<text>@item.bh_status</text>, canSort: true),
grid.Column("Peer1", "Peer Site 1", format: @<text>@item.Peer1</text>, canSort: true),
grid.Column("Peer2", "Peer Site 2", format: @<text>@item.Peer2</text>, canSort: true),
grid.Column("ring_a_site_distance", "Distances From Peer Site 1 (KM)", format: @<text>@item.ring_a_site_distance</text>, canSort: true),
grid.Column("ring_b_site_distance", "Distances From Peer Site 2 (KM)", format: @<text>@item.ring_b_site_distance</text>, canSort: true)

))

    @Html.Hidden("dir", grid.SortDirection)
    @Html.Hidden("col", grid.SortColumn)
    @Html.HiddenFor(m => m.objGridAttributes.searchBy)
    @Html.HiddenFor(m => m.objGridAttributes.searchText)
</div>

            }
            else
            {
            <div class="nr-found">
                <strong>No Records Found.</strong>
            </div>
            }

            }
        
</div>

<script>


    function isDivEnabledByClass(className) {
        const divs = document.getElementsByClassName(className);
        for (let div of divs) {
            const style = window.getComputedStyle(div);
            const isVisible = div.offsetParent !== null;
            const isInteractive = style.pointerEvents !== "none" &&
                style.display !== "none" &&
                style.visibility !== "hidden";
            const isNotCustomDisabled = !div.hasAttribute("disabled") &&
                !div.classList.contains("disabled");

            if (isVisible && isInteractive && isNotCustomDisabled) {
                return true; // at least one enabled div found
            }
        }
        return false; // no enabled divs
    }


    $("#btnRingReset").on("click", function () {
        $("#ddllstRingName")[0].selectedIndex = -1; // removes all selections
        $("#ddllstRingName").trigger("chosen:updated");
        document.getElementById("ddllstSegmentName").selectedIndex = 0;
        $("#ddllstSegmentName").trigger("chosen:updated");
        document.getElementById("ddllstRegionName").selectedIndex = 0;
        $("#ddllstRegionName").trigger("chosen:updated");
        $('#btnExport').attr('disabled', 'disabled');
        $('#txtSearchText').val('');
    });

    $("#btnExportLinks").on("click", function () {
        const enabled = isDivEnabledByClass("div_totalRecord");
        debugger;
        if (!enabled) {
            $('#btnExport').attr('disabled', 'disabled');
            return false;
        }
        console.log("div_totalRecord is enabled:", enabled);

        window.location = appRoot + 'RingDetails/ExportRingDetails';
    });
    function validateSearch(event) {
        debugger;
        /* var ringCode = $("#ddllstRingName").val()?.trim();*/
        var ringCodes = $("#ddllstRingName").val(); // array
        var segName = $("#ddllstSegmentName").val()?.trim();
        var regName = $("#ddllstRegionName").val()?.trim();

        if (!ringCodes && !segName && !regName) {
            alert("Please select at least one valid search criteria.");
            event.preventDefault(); // Prevents submission
            event.returnValue = false; // Ensures older browser compatibility
            return false;
        }
        return true;
    }


</script>


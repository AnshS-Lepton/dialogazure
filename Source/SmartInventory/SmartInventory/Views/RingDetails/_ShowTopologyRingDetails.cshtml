@model Models.RingDetailsFiltter
@using Models;
@using Utility;

<!DOCTYPE html>

@if (Model.objRingDetails != null && Model.objRingDetails.SearchbyRingTypes != null && Model.objRingDetails.SearchbyRingTypes.Any())
{
    var ringIdsCsv = string.Join(",", Model.objRingDetails.SearchbyRingTypes);
    <script type="text/javascript">
        $(document).ready(function () {
            var SelectedRingIds = '@ringIdsCsv';
            $("#ddllstRingName").val(SelectedRingIds.split(',')).trigger("chosen:updated");

            $('.chosen-select').chosen({ width: '100%' });
            $('th a, tfoot a').on("click", function () {
                // onGridHeaderClick('tblFiberLinkGrid');
                $('#frmViewRingDetails').attr('action', $(this).attr('href')).submit();
                return false;
            });
        });
    </script>
}
else
{
    <script type="text/javascript">
        $(document).ready(function () {


            $('.chosen-select').chosen({ width: '100%' });
            //$('th a, tfoot a').on("click", function () {
            //    // onGridHeaderClick('tblFiberLinkGrid');
            //    $('#frmViewRingDetails').attr('action', $(this).attr('href')).submit();
            //    return false;
            //});

            $('th a, tfoot a').on("click", function (e) {

                debugger;
                var lstRingName = $("#ddllstRingName").val();
                if (lstRingName != "") {
                    return false;
                }

                // Proceed with setting form action and submitting
                $('#frmViewRingDetails').attr('action', $(this).attr('href')).submit();
                return false;
            });



        });

        this.clearUserTempOverlay = function (lyrObj) {
            debugger;
            if (lyrObj) {
                for (var i = 0; i < lyrObj.length; i++)
                    lyrObj[i].setMap(null);
            }
            lyrObj = [];
        }
        this.createMarkerForPathFinder = function (mrkrLatlng, imageUrl, system_id, en_type, network_id, is_virtual_port_allowed) {
            var gmarkernew = new google.maps.Marker({
                position: mrkrLatlng,
                icon: imageUrl,
                draggable: false,
                id: system_id,
                eType: en_type,
                portNo: port_no,
                networkId: network_id,
                isVirtualPortAllowed: is_virtual_port_allowed
            });

            return gmarkernew;
        }


        this.getslddaigramfiberlink = function (ringId, ring_code) {
            debugger;
            var ringId = ringId.toString();
            ajaxReq('main/Encrypt', { systemId: ringId + '/' + ring_code }, false, function (resp) {

                window.open(appRoot + 'RingDetails/GetSchematicView?key=' + resp + '&ring_id=' + ringId + '&ring_code=' + ring_code, '_blank');
            }, false, false);
        }
    </script>


}




<style>
    /* Main Container */
    .container {
        padding: 20px;
    }

    /* Filter Section */
    .filter-container {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px;
    }

        .filter-container label {
            font-weight: bold;
        }

        .filter-container select {
            width: 180px;
            padding: 5px;
        }

        .filter-container strong {
            font-size: 18px;
        }

    .search-btn {
        padding: 6px 15px;
        background-color: #007bff;
        color: white;
        border: none;
        cursor: pointer;
        border-radius: 5px;
    }

        .search-btn:hover {
            background-color: #0056b3;
        }

    /* Table Styling */
    .table-responsive {
        overflow-x: auto; /* Enables horizontal scroll */
    }


    .action-icon {
        color: #007bff;
        cursor: pointer;
    }

        .action-icon:hover {
            color: #0056b3;
        }
</style>


@{


    WebGrid grid = new WebGrid(rowsPerPage: Model.objGridAttributes.pageSize, canSort: true, ajaxUpdateContainerId: "dvViewRingDeatils",
ajaxUpdateCallback: "onGridHeaderClick('tblRingDetail');");
    grid.Bind(Model.lstRingDetails, autoSortAndPage: false, rowCount: Model.objGridAttributes.totalRecord);
    if (Model.objGridAttributes.totalRecord > 0)
    {
        grid.PageIndex = Model.objGridAttributes.currentPage - 1;
    }


}

<div class="libDetail">

    @using (Ajax.BeginForm("ShowTopologyRingDetails", "RingDetails", new AjaxOptions

<script>
    $(document).ready(function () {
       sf.setDateTimeCalendar_ExportEntities("fromDate", "toDate", "imgFromDate", "imgToDate", false);
    });
    @*$("#tblPastFeas tfoot tr td").each(function (i, col) {
        $(col).children().each(function (i, a) {
            var href = $(a).attr("href");
            var pageUrl = href + "&searchBy=" + '@Model.objGridAttributes.searchBy' + "&searchText=" + '@Model.objGridAttributes.searchText' + '&FromDate=' + $("#fromDate").val() + '&ToDate=' + $("#toDate").val();
            // alert(pageUrl);

            $(a).attr("href", pageUrl);
        })


    });*@

    $('#tblPastFeas tfoot a').on("click", function () {
        $('#frmHistoryList').attr('action', $(this).attr('href')).submit();
        return false;
    });

    function ResetFormValues()
    {
        $("#txtSearchtext").val('');
        $("#fromDate").val('');
        $("#toDate").val('');
        $("#ddlSearchby").val('');
        $("#frmHistoryList").submit();
    }
    function clearSearchText()
    {
        $("#txtSearchtext").val('');
    }
    function Validform()
    {
        if ($("#fromDate").val() == "" && $("#toDate").val() != "")
        {
            alert("Please fill From Date");
            return false;
        }
        if ($("#fromDate").val() != "" && $("#toDate").val() == "") {
            alert("Please fill To Date");
            return false;
        }
        if ($("#ddlSearchby").val() == "" && $("#txtSearchtext").val() != "")
        {
            alert("Please select Search By");
            return false;
        }
        if ($("#ddlSearchby").val() != "" && $("#txtSearchtext").val() == "") {
            alert("Please select Search text");
            return false;
        }
        return true;
    }
    if (sf) {
        sf.pastFeasibilities = JSON.parse('@Html.Raw(Json.Encode(Model.lstPastFeasibility))'.replace("	 ",""));

        var feasibilityHistory = new FeasibilityHistory();
        feasibilityHistory.init();
        $($("#tabs ul li")[1]).attr("style", "display:none;");
        // $($("#tabs ul li")[1]).attr('disabled', true).addClass('ui-state-disabled');
        // feasibilityHistory.bindRadioEvent();
    }
</script>
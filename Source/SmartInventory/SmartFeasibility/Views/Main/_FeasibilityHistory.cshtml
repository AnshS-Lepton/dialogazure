<script>
    $(document).ready(function () {

        $('tfoot a').on("click", function () {
            $('#frmHistory').attr('action', $(this).attr('href')).submit();
            return false;
        });

        //Post form on page header click..
        $('th a').on("click", function () {
            $('#frmHistory').attr('action', $(this).attr('href')).submit();

            return false;
        });
    });

    function searchByChange()
    {
        var searchvalue = $('#objFilterAttributes_searchBy').val();
        $('#objFilterAttributes_searchText').val('');
        if (searchvalue == "cores") {
            $('#objFilterAttributes_searchText').attr('onkeypress', 'return sf.allowOnlyNumber(event);');
        }
        else {
            $('#objFilterAttributes_searchText').removeAttr('onkeypress');
        }
    }

</script>

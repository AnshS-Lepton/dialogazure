            if (Model.lstData.Count > 0)
            {
            <div class="mb10" id="dvBtnAction">
                <div class="dflex">
                    <span class="div_totalRecord"><b>@Resources.Resources.SF_GBL_GBL_NET_FRM_026:&nbsp;<span>@grid.TotalRowCount</span></b></span>
                    <input type="button" id="btnBomHistoryExport" value="@Resources.Resources.SF_GBL_GBL_NET_RPT_001" class="btn btn-primary ml-auto" onclick="sf.ExportBomHistory(@Model.systemId)" />

                </div>

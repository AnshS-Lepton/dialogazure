@model Models.Feasibility.ViewHistoryMaster

@{
    WebGrid grid = new WebGrid(rowsPerPage: Model.objFilterAttributes.pageSize, canSort: false, ajaxUpdateContainerId: "objViewHistory", ajaxUpdateCallback: "onGridHeaderClick('tblHistory')");
    grid.Bind(Model.lstData, autoSortAndPage: false, rowCount: Model.objFilterAttributes.totalRecord);
    if (Model.objFilterAttributes.totalRecord > 0)
    {
        grid.PageIndex = Model.objFilterAttributes.currentPage - 1;
    }
   //  var SystemId = Model.lstData[0].systemId;
}
<!DOCTYPE html>
<div id="divCableTypeHistory">
    <div class="libDetail pa20">
        @using (Ajax.BeginForm("GetHistory", "Main", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "divCableTypeHistory", LoadingElementId = "dvProgress" },
                     new { id = "frmHistory", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
        {
        @Html.HiddenFor(m => m.systemId);
         @Html.HiddenFor(m => m.eType);


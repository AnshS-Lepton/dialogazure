@model Models.Feasibility.FeasibilityCableTypeViewModel
@using Utility

@{
    WebGrid grid = new WebGrid(rowsPerPage: Model.objGridAttributes.pageSize, canSort: false, ajaxUpdateContainerId: "dvCableTypeLst", ajaxUpdateCallback: "onGridHeaderClick('WebGrid')");
    grid.Bind(Model.lstCableTypes, autoSortAndPage: false, rowCount: Model.objGridAttributes.totalRecord);
    if (Model.objGridAttributes.totalRecord > 0)
    {
        grid.PageIndex = Model.objGridAttributes.currentPage - 1;
    }
}

<!DOCTYPE html>
<div id="MainDiv">
    <div class="libDetail">
        @using (Ajax.BeginForm("GetCableTypeLst", "Main", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "MainDiv", LoadingElementId = "dvProgress" },
                                 new { id = "frmCableTypeLst", enctype = "multipart/form-data", autocomplete = "off", @class = "form-horizontal" }))
        {
        <div class="form-inline">

            @*<div class="form-group">
                <label class="control-label col-sm-1">@Resources.Resources.SF_GBL_GBL_NET_FRM_034 : </label>
                <div class="col-sm-2">
                    @Html.DropDownListFor(m => m.objGridAttributes.searchBy, new SelectList(Model.lstSearchBy.Select(x => new { Value = x.value.ToString(), Text = x.key }), "Value", "Text"), "--Select--", new { @class = "chosen-select form-control", @onchange = "searchByChange();" })
                </div>

                <label class="control-label col-sm-2" style="margin-left: 13px;">
                    @Resources.Resources.SF_GBL_GBL_NET_FRM_035:
                </label>
                <div class="col-sm-2">
                    @if (Model.objGridAttributes.searchBy == "cores")
                    {
                    @Html.TextBoxFor(m => m.objGridAttributes.searchText, new { @title = Resources.Resources.SF_GBL_GBL_NET_FRM_035, @tabindex = "4", @class = "input-sm form-control", @placeholder = Resources.Resources.SF_GBL_GBL_NET_FRM_035, @maxlength = 100, @onkeypress = "return sf.allowOnlyNumber(event);" })
                    }
                    else
                    {
                    @Html.TextBoxFor(m => m.objGridAttributes.searchText, new {  @title = Resources.Resources.SF_GBL_GBL_NET_FRM_035, @tabindex = "4", @class = "input-sm form-control", @placeholder = Resources.Resources.SF_GBL_GBL_NET_FRM_035, @maxlength = 100 })
                    }
                </div>
                <div class="col-sm-4 text-right">
                    <button class="btn btn-primary" id="btnGetSearchResult" name="btnCommandName" value="GetSearchResult" tabindex="5" type="submit">@Resources.Resources.SF_GBL_GBL_GBL_GBL_006</button>
                    <a onclick="sf.showBomRecord(0, 'feasibility_cable_type');" class="btn btn-default" title="@Resources.Resources.GBL_GBL_GBL_GBL_GBL_005">@Resources.Resources.GBL_GBL_GBL_GBL_GBL_005</a>
                </div>
            </div>*@

        </div>

            if (Model.lstCableTypes.Count > 0)
            {
    <div class="mb10" id="dvBtnAction">
        <div class="dflex">
            <span class="div_totalRecord"><b>@Resources.Resources.SF_GBL_GBL_NET_FRM_026:&nbsp;<span>@grid.TotalRowCount</span></b></span>

            @if (@grid.TotalRowCount > 0)
            {
                <input type="button" id="btnExport" value="@Resources.Resources.SF_GBL_GBL_NET_RPT_001" class="btn btn-primary ml-auto" onclick="sf.ExportBomRecord(0);" />
            }
            else
            {
                <input type="button" id="btnExport" value="@Resources.Resources.SF_GBL_GBL_NET_RPT_001" disabled="disabled" class="btn btn-primary" />
            }
        </div>
    </div>
            <div class="clearfix"></div>

            <div id="dvCableTypeLst">

                @if (Model.lstCableTypes.Count > 0)
                {
                <div>

                    @grid.GetHtml(tableStyle: "tableOp2",
                 headerStyle: "webGridHeader",
                 alternatingRowStyle: "alt",
                   htmlAttributes: new { @id = "WebGrid", @class = "table table-responsive" },
            columns: grid.Columns(
                grid.Column("", Resources.Resources.SF_GBL_GBL_JQ_FRM_008, format:
                @<text>
                    <span class="floorRowDelete" onclick="sf.deleteCableType('@item.cable_type_id', '@item.is_used.ToString()');" title="@Resources.Resources.SF_GBL_GBL_NET_RPT_008" style="">x</span>&nbsp;&nbsp;
                    <span class="icon-history" id="iconBomHistory" title='@Resources.Resources.SF_GBL_GBL_NET_RPT_003' onclick="sf.showHistory('@item.cable_type_id', 'feasibility_cable_type');" style="cursor:pointer;"></span>

                    @*<span class="floorshowlog" title="@Resources.Resources.SF_GBL_GBL_NET_RPT_003" style=""><a href="#"  onclick="sf.showHistory('@item.cable_type_id', 'feasibility_cable_type');">@Resources.Resources.SF_GBL_GBL_NET_RPT_002</a></span>*@

                </text>, style:"ActionCol"),
                grid.Column("cores", Resources.Resources.SF_GBL_GBL_JQ_FRM_002, format: @<text>@item.cores</text>),
                grid.Column("display_name", Resources.Resources.SF_GBL_GBL_NET_FRM_027, format: @<text>@item.display_name</text>),
                 grid.Column("material_price_per_unit", Resources.Resources.SF_GBL_GBL_JQ_FRM_003 + " ("+ @SmartFeasibility.Settings.ApplicationSettings.CustomerCurrency +")", format: @<text>@item.material_price_per_unit</text>),
                 grid.Column("Service_price_per_unit", Resources.Resources.SF_GBL_GBL_JQ_FRM_004 + " (" + @SmartFeasibility.Settings.ApplicationSettings.CustomerCurrency + ")", format: @<text>@item.service_price_per_unit</text>),
                 grid.Column("created_user", Resources.Resources.SF_GBL_GBL_JQ_FRM_005, format: @<text>@item.created_user</text>),
                 grid.Column("created_on", Resources.Resources.SF_GBL_GBL_JQ_FRM_009, format: @<text> @(item.created_on == null ? item.created_on : MiscHelper.FormatDateTime(item.created_on.ToString())) </text>),
                 grid.Column("modified_user", Resources.Resources.SF_GBL_GBL_JQ_FRM_006, format: @<text>@item.modified_user</text>),
                 grid.Column("modified_on", Resources.Resources.SF_GBL_GBL_JQ_FRM_007, format: @<text> @(item.modified_on == null ? item.modified_on : MiscHelper.FormatDateTime(item.modified_on.ToString())) </text>)

                    )
               )
</div>
                }
            </div>

            }
            else
            {
            <div class="nr-found">
                <span> @Resources.Resources.SF_GBL_GBL_NET_FRM_037	</span>
            </div>
            }

        }
    </div>
</div>
<script>
    $(document).ready(function () {

        $('tfoot a').on("click", function () {
            $('#frmCableTypeLst').attr('action', $(this).attr('href')).submit();
            return false;
        });

        //Post form on page header click..
        $('th a').on("click", function () {
            $('#frmCableTypeLst').attr('action', $(this).attr('href')).submit();

            return false;
        });

    });


    function searchByChange() {
        var searchvalue = $('#objGridAttributes_searchBy').val();
        $('#objGridAttributes_searchText').val('');
        if (searchvalue == "cores") {
            $('#objGridAttributes_searchText').attr('onkeypress', 'return sf.allowOnlyNumber(event);');
        }
        else {
            $('#objGridAttributes_searchText').removeAttr('onkeypress');
        }
    }
</script>

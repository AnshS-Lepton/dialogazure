@{
    Layout = null;
}

@model Models.User
@using SmartFeasibility.Settings;
@{
    ViewBag.Title = "Index";
    var isClientNameRequired = (!string.IsNullOrEmpty(ApplicationSettings.ClientName)) ? true : false;
}
}

<style>

    body {
        /* background: #009e76 url(../images/main_bg.png) top center no-repeat; */
        background: #fff !important;
        overflow: hidden !important;
        padding: 0 !important;
        margin: 0 !important;
        background-size: 100% 100% !important;
        background-attachment: fixed !important;
        font: 12px arial !important;
        color: #fff !important;
    }

    .scnd_img {
        width: 50%;
        height: 100%;
        float: left;
        text-align: center;
        background: #ceedff;
        padding: 3% 0 0 0;
        background: -moz-linear-gradient(top, #ceedff 0%, #009ec3 100%);
        background: -webkit-linear-gradient(top, #ceedff 0%,#009ec3 100%);
        background: linear-gradient(to bottom, #ceedff 0%,#009ec3 100%);
        filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#ceedff', endColorstr='#009ec3',GradientType=0 );
    }

    .logo {
        text-align: center !important;
        font-size: 36px !important;
        /*width: 100%;*/
        padding-top: 55px !important;
        text-transform: uppercase !important;
        color: #009ec3 !important;
        right: 13% !important;
    }

    .applicationName {
        margin-top: 10px !important;
        margin-bottom: 10px !important;
        font-size: 28px !important;
        text-align: center !important;
        font-weight: bold !important;
        text-transform: none !important;
    }

    .login_area {
        width: 406px !important;
        height: auto !important;
        margin: 0 auto !important;
        background-color: #fff !important;
        top: 45% !important;
        right: 10% !important;
    }

    .codrops-bottom {
        color: #353535;
        font-size: 13px !important;
        font-weight: normal !important;
        padding-top: 60px !important;
        width: 100% !important;
        height: auto !important;
        text-align: center !important;
        bottom: -480px !important;
        left: 25% !important;
    }
    .d-flex{
        display:flex;
        align-items:center;
    }
    .logosNew {
        justify-content: center;
        gap:20px;
    }
    .logosNew img{
        width:84px;

@model Models.Legend
@using SmartInventory.Settings;
<style>
    #maindiv {
        background-color: white !important;
    }

    #subLayer {
        width: 100%;
        float: left;
        height: 26px;
        display: inline-block;
        font-size: 12px;
    }

        #subLayer img {
            width: 17px;
            float: left;
        }

        #subLayer span {
            float: left;
            margin-left: 5px;
        }

    #dvLegend {
        width: 70px;
        float: left;
        height: auto;
        background-color: #1b9461 !important;
        display: none;
    }

    #LayerTitle {
        font-weight: bolder;
        font-size: medium;
        margin-bottom: 10px;
    }
</style>

<!DOCTYPE html>
<meta name="viewport" content="width=device-width, initial-scale=1">
<div class="libTabContentLegend" style="height: 500px;">
    <div id="LegendDetails">
        <div id="staticLegned">
            <div style="width: 100%; float: right; height: auto; font-size: 10px;">
                <div id="maindiv" style="width: 100%; height: auto; float: left;">
                    <div id="dvLegendContent" style="width: 100%; height: auto; float: left;padding-left: 11px;">
                        <div style="width:100%; height:10px; ">&nbsp;</div>
                        @if (Model.legendList != null && Model.legendList.Count > 0)
                        {
                            var ctrD = 0;
                            var ctrT = 0;
                            var groupItem = (from c in Model.legendList
                                             select c.group_name)
                                                        .Distinct();
                            //.OrderBy(x => x);
                            <div style="display: block; padding-left: 0px; height: 35px; ">
                                <div style="display: flex;  align-items: flex-end; gap: 10px; }">
                                    <div id="subLayer" style="width: auto; display: flex; ALIGN-ITEMS: FLEX-END; "><img src="~/Content/images/icons/lib/Legend/Planned.png" alt="printLayerImg"><span>Planned</span></div>
                                    @if (ApplicationSettings.IsDormantEnabled)
                                    {
                                        <div id="subLayer" style="width: auto; display: flex; ALIGN-ITEMS: FLEX-END; "><img src="~/Content/images/icons/lib/Legend/Dorment.png" alt="printLayerImg"><span>Dormant</span></div>
                                    }
                                    <div id="subLayer" style="width: auto; display: flex; ALIGN-ITEMS: FLEX-END; "><img src="~/Content/images/icons/lib/Legend/AsBuilt.png" alt="printLayerImg"><span>As Built</span></div>
                                </div>
                               

                                @foreach (var grpLayer in groupItem)
                                {
                                    <div id="LayerTitle" style="MARGIN-TOP: 10PX;"><span><u>@grpLayer</u></span></div>
                                    <div style="display:block;">
                                        @if (ApplicationSettings.IsWMSLayerLoadingEnabled)
                                        {

                                            foreach (var item in Model.legendList.Where(x => x.group_name == grpLayer).ToList())
                                            {

                                                if (item.group_name == "Duct" && ctrD == 0)
                                                {
                                                    ctrD = ctrD + 1;
                                                   <div id="subLayer" style="width: 100%; float: left; height: 26px; align-items: center; display: flex; font-size: 12px;">

                                                       <img src="@(String.Format("{0}{1}{2}", Model.baseUrl, "Content/images/icons/lib/Legend/", @item.icon_path))" alt="printLayerImg" style="width:@(item.layer_id == 19 ? "35px" : "16px;")">
                                                   </div>
                                                }

                                                if (item.group_name == "Trench" && ctrT == 0)
                                                {
                                                    ctrT = ctrT + 1;
                                                    <div id="subLayer" style="width: 100%; float: left; height: 26px; align-items: center; display: flex; font-size: 12px;">
                                                        <img src="@(String.Format("{0}{1}{2}", Model.baseUrl, "Content/images/icons/lib/Legend/", @item.icon_path))" alt="printLayerImg" style="width:@(item.layer_id == 19 ? "35px" : "16px;")">
                                                    </div>
                                                }
                                                if (item.group_name != "Trench" && item.group_name != "Duct")
                                                {
                                                    <div id="subLayer" style="width: 100%; float: left; height: 26px; align-items: center; display: flex; font-size: 12px;">
                                                        <img src="@(String.Format("{0}{1}{2}", Model.baseUrl, "Content/images/icons/lib/Legend/", @item.icon_path))" alt="printLayerImg" style="width:@(item.layer_id == 19 ? "35px" : "16px;")">

                                                        @if (item.group_name == "Feeder Cable" || item.group_name == "Distribution Cable" || item.group_name == "Access Cable")
                                                        {
                                                            <span>@item.sub_Layer.Substring(0, 8)</span>
                                                        }
                                                        else
                                                        {
                                                            <span>@item.sub_Layer</span>
                                                        }
                                                    </div>
                                                }
                                            }
                                        }
                                        else
                                        {
                                            foreach (var item in Model.legendList.Where(x => x.group_name == grpLayer).ToList())
                                            {

                                                <div id="subLayer" style="width: 100%; float: left; height: 26px; align-items: center; display: flex; font-size: 12px;">
                                                    @if (@item.group_name == "Boundary")
                                                    {
                                                        <div id="@item.layer_id" style="width: 15px; height: 10px; background-color:@item.color_code_hex;border:@item.outline_color_hex;outline-style: solid;outline-width: thin;"></div>
                                                    }
                                                    else if (item.group_name == "Feeder Cable" || item.group_name == "Distribution Cable" || item.group_name == "Access Cable" || item.group_name.ToUpper() == "DUCT" || item.group_name.ToUpper() == "TRENCH")
                                                    {
                                                        if (item.sub_Layer.Contains("As-Built"))
                                                        {
                                                            <span style=" width: 64px; border-bottom:3px solid; color: @item.color_code_hex; margin-left:0"></span>
                                                        }
                                                        else if (item.sub_Layer.Contains("Dormant"))
                                                        {
                                                            <span style="width: 64px; height: 3px; background: repeating-linear-gradient(90deg,@item.color_code_hex 0 20px,#0000 0 23px); margin-left: 0"></span>
                                                            @*<div class="dash-dot"></div>*@
                                                        }
                                                        else
                                                        {
                                                            <span style=" width: 64px; border-bottom: 3px dashed; color: @item.color_code_hex; margin-left: 0"></span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <img src="@(String.Format("{0}{1}{2}", Model.baseUrl, "Content/images/icons/lib/Legend/", @item.icon_path))" alt="printLayerImg" style="width:@(item.layer_id== 19 ? "35px" : "16px;")">
                                                    }
                                                    @*<img src="@(String.Format("{0}{1}{2}", Model.baseUrl, "Content/images/icons/lib/Legend/", @item.icon_path))" alt="printLayerImg" style="padding-top:3px;width:@(item.layer_id == 19 ? "35px" : "16px;")">*@
                                                    @if (item.group_name == "Feeder Cable" || item.group_name == "Distribution Cable" || item.group_name == "Access Cable")
                                                    {
                                                        <span>@item.sub_Layer.Substring(0, 8)</span>
                                                    }
                                                    else
                                                    {<span>&nbsp;&nbsp;@item.sub_Layer</span>}

                                                </div>

                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>
